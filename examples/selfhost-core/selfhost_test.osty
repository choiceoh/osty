use std.testing

use go "strings" as strings {
    fn Contains(s: String, substr: String) -> Bool
}

fn testSemverRequirementMatching() {
    let req = caretReq(stableVersion(1, 2, 3))
    testing.assert(semReqMatches(req, stableVersion(1, 2, 3)))
    testing.assert(semReqMatches(req, stableVersion(1, 9, 9)))
    testing.assert(!(semReqMatches(req, stableVersion(2, 0, 0))))
    testing.assert(!(semReqMatches(req, stableVersion(1, 2, 2))))

    let zeroReq = caretReq(stableVersion(0, 1, 2))
    testing.assert(semReqMatches(zeroReq, stableVersion(0, 1, 9)))
    testing.assert(!(semReqMatches(zeroReq, stableVersion(0, 2, 0))))

    let tilde = tildeReq(stableVersion(1, 2, 3))
    testing.assert(semReqMatches(tilde, stableVersion(1, 2, 9)))
    testing.assert(!(semReqMatches(tilde, stableVersion(1, 3, 0))))
}

fn testSemverMaxAndWildcardSelection() {
    let versions = [
        stableVersion(0, 9, 0),
        stableVersion(1, 0, 0),
        stableVersion(1, 2, 5),
        stableVersion(1, 9, 9),
        stableVersion(2, 0, 0),
    ]
    let best = maxMatchingVersion(wildcardMajorReq(1), versions)
    testing.assert(best.found)
    testing.assertEq(compareSemVersion(best.version, stableVersion(1, 9, 9)), 0)

    let minor = maxMatchingVersion(wildcardMinorReq(1, 2), versions)
    testing.assert(minor.found)
    testing.assertEq(compareSemVersion(minor.version, stableVersion(1, 2, 5)), 0)
}

fn testRegistrySkipsYankedVersions() {
    let versions = [
        registryVersion(stableVersion(1, 0, 0), false),
        registryVersion(stableVersion(1, 5, 0), true),
        registryVersion(stableVersion(1, 4, 0), false),
        registryVersion(stableVersion(2, 0, 0), false),
    ]
    testing.assertEq(visibleRegistryCount(versions), 3)

    let best = bestRegistryVersion(wildcardMajorReq(1), versions)
    testing.assert(best.found)
    testing.assertEq(compareSemVersion(best.version, stableVersion(1, 4, 0)), 0)
}

fn testDiagnosticCodeClassification() {
    testing.assertEq(diagnosticSeverityName(diagnosticSeverity("E0500")), "error")
    testing.assertEq(diagnosticSeverityName(diagnosticSeverity("W0750")), "warning")
    testing.assertEq(diagnosticSeverityName(diagnosticSeverity("L0041")), "lint")
    testing.assertEq(diagnosticSeverityName(diagnosticSeverity("Z0000")), "unknown")

    testing.assertEq(diagnosticFamilyName(diagnosticFamily("E0001")), "lexical")
    testing.assertEq(diagnosticFamilyName(diagnosticFamily("E0505")), "resolution")
    testing.assertEq(diagnosticFamilyName(diagnosticFamily("E0731")), "type-checking")
    testing.assertEq(diagnosticFamilyName(diagnosticFamily("E2017")), "manifest")
    testing.assertEq(diagnosticFamilyName(diagnosticFamily("L0030")), "lint")
    testing.assert(diagnosticIsCompilerError("E0700"))
    testing.assert(!(diagnosticIsCompilerError("L0001")))
}

fn testManifestFeatureValidation() {
    let features = [
        featureSpec("default", ["serde"]),
        featureSpec("serde", ["serde"]),
        featureSpec("cli", ["serde"]),
    ]

    let ok = validateFeatureGraph(["default", "cli"], features)
    testing.assertEq(ok.undefinedDefault, 0)
    testing.assertEq(ok.selfReferences, 1)

    let bad = validateFeatureGraph(["missing"], features)
    testing.assertEq(bad.undefinedDefault, 1)
    testing.assertEq(bad.selfReferences, 1)
}

fn parsedSelfhostVersion(text: String) -> SemVersion {
    let mut out = stableVersion(0, 0, 0)
    match parseSemVersionText(text) {
        Ok(version) -> {
            out = version
        },
        Err(e) -> testing.fail(e),
    }
    out
}

fn testSelfhostExampleDependencyResolutionScenario() {
    let versions = [
        registryVersion(parsedSelfhostVersion("1.4.0"), false),
        registryVersion(parsedSelfhostVersion("1.4.1"), false),
        registryVersion(parsedSelfhostVersion("1.5.0"), true),
        registryVersion(parsedSelfhostVersion("1.5.1-alpha"), false),
        registryVersion(parsedSelfhostVersion("2.0.0"), false),
    ]
    let best = bestRegistryVersion(caretReq(parsedSelfhostVersion("1.4.0")), versions)

    testing.assert(best.found)
    testing.assertEq(compareSemVersion(best.version, parsedSelfhostVersion("1.4.1")), 0)
}

fn testSelfhostExamplePackageArchiveScenario() {
    let paths = [
        "osty.toml",
        "osty.lock",
        "src/lib.osty",
        "src/parser_test.osty",
        "README.md",
        ".osty",
        ".git",
    ]
    let mut sources = 0
    let mut hashed = 0
    let mut ignored = 0
    for path in paths {
        if isOstySourceEntry(path) {
            sources = sources + 1
        }
        if shouldHashPackageEntry(path) {
            hashed = hashed + 1
        } else {
            ignored = ignored + 1
        }
    }

    testing.assertEq(sources, 2)
    testing.assertEq(hashed, 5)
    testing.assertEq(ignored, 2)
}

fn testSelfhostExampleFrontEndPipelineScenario() {
    let source = r"""
        /// Adds two integers.
        pub fn add(a: Int, b: Int) -> Int {
            let sum = a + b
            return sum
        }
        """
    let lexed = frontendLexStream(source)
    let tree = frontendParseTree(source)

    testing.assert(frontLexTokenCount(lexed) > 0)
    testing.assertEq(frontLexDiagnosticCount(lexed), 0)
    testing.assertEq(frontLeadingDocAttachmentCount(lexed), 1)
    testing.assertEq(frontParseTreeDiagnosticCount(tree), 0)
    testing.assertEq(frontParseTreeNodeNameCount(tree, "fn"), 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "param") >= 2)
    testing.assert(frontParseTreeNodeNameCount(tree, "return") >= 1)
}

fn testSelfhostExamplePipelineWiresIrWithAnalyzerCores() {
    let source = r"""
        pub struct User { pub name: String }
        enum Color { Red, Green }

        fn add(left: Int, right: Int) -> Int {
            let total = left + right
            total
        }
        """
    let report = selfhostPipelineSource("main", source)

    testing.assert(report.tokens > 0)
    testing.assert(report.parseNodes > 0)
    testing.assert(report.irNodes >= report.irDecls)
    testing.assertEq(report.irDecls, 3)
    testing.assertEq(report.irFuncs, 1)
    testing.assert(report.irStmts >= 1)
    testing.assert(report.irExprs >= 1)
    testing.assert(report.irScopes >= 2)
    testing.assert(report.irSymbols >= 5)
    testing.assert(report.irTypedNodes >= 3)
    testing.assert(report.irTerminalNodes == 0)
    testing.assertEq(report.irInvalidScopes, 0)
    testing.assert(report.resolveSymbols >= 5)
    testing.assert(report.checkedExpressions >= 1)
    testing.assertEq(report.lintDiagnostics, 0)
    testing.assertEq(selfhostPipelineBlockingErrorCount(report), 0)
}

fn testSelfhostExamplePipelineCarriesRecoveryIntoIr() {
    let report = selfhostPipelineSource("main", r"fn broken( {")

    testing.assert(report.parseDiagnostics > 0)
    testing.assert(report.irDiagnostics > 0)
    testing.assert(report.lintParseErrors > 0)
}

fn testSelfhostExamplePipelineRendersAnalyzerDiagnostics() {
    let source = "fn main() \{\n    let unusedValue = 1\n    missing()\n\}\n"
    let report = selfhostPipelineSource("main", source)

    testing.assert(report.resolveDiagnostics > 0)
    testing.assert(report.lintDiagnostics > 0)
    testing.assert(report.diagnostics != "")
    testing.assert(selfhostPipelineBlockingErrorCount(report) >= report.resolveDiagnostics)
    testing.assert(strings.Contains(report.diagnostics, "error[E0500]"))
    testing.assert(strings.Contains(report.diagnostics, "resolution"))
    testing.assert(strings.Contains(report.diagnostics, "undefined name `missing`"))
    testing.assert(strings.Contains(report.diagnostics, "lint[L0001]"))
}

fn testSelfhostExamplePipelinePreparesLintFixes() {
    let source = "fn main(unused: Bool) -> Int \{\n    let unusedValue = 1\n    let mut neverChanged = 2\n    println(neverChanged)\n    return neverChanged\n\}\n"
    let report = selfhostPipelineSourceWithFixes("main", source, true)

    testing.assert(report.lintDiagnostics >= 4)
    testing.assert(report.lintFixes >= 4)
    testing.assertEq(report.lintFixSkipped, 0)
    testing.assert(report.lintFixApplied >= 4)
    testing.assert(strings.Contains(report.fixedSource, "_unused"))
    testing.assert(strings.Contains(report.fixedSource, "_unusedValue"))
    testing.assert(strings.Contains(report.fixedSource, "let neverChanged = 2"))
    testing.assert(!(strings.Contains(report.fixedSource, "return neverChanged")))
}
