fn llvmCallArgs(args: List<LlvmValue>) -> String {
    let mut parts: List<String> = []
    for arg in args {
        parts.push("{arg.typ} {arg.name}")
    }
    llvmStrings.Join(parts, ", ")
}

fn llvmParams(params: List<LlvmParam>) -> String {
    let mut parts: List<String> = []
    for param in params {
        parts.push("{param.typ} %{param.name}")
    }
    llvmStrings.Join(parts, ", ")
}

fn llvmNextTemp(emitter: LlvmEmitter) -> String {
    let name = "%t{emitter.temp}"
    emitter.temp = emitter.temp + 1
    name
}

fn llvmNextLabel(emitter: LlvmEmitter, prefix: String) -> String {
    let name = "{prefix}{emitter.label}"
    emitter.label = emitter.label + 1
    name
}
