pub fn llvmSmokeMinimalPrintIR(sourcePath: String) -> String {
    let emitter = llvmEmitter()
    let value = llvmBinaryI64(emitter, "add", llvmIntLiteral(40), llvmIntLiteral(2))
    llvmPrintlnI64(emitter, value)
    llvmReturnI32Zero(emitter)
    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i32", "main", [], emitter.body),
        ],
    )
}

pub fn llvmSmokeScalarArithmeticIR(sourcePath: String) -> String {
    let add = llvmEmitter()
    llvmBind(add, "a", llvmI64("%a"))
    llvmBind(add, "b", llvmI64("%b"))
    let sum = llvmBinaryI64(add, "add", llvmIdent(add, "a"), llvmIdent(add, "b"))
    llvmReturn(add, sum)

    let main = llvmEmitter()
    let value = llvmCall(main, "i64", "add", [llvmIntLiteral(40), llvmIntLiteral(2)])
    llvmImmutableLet(main, "value", value)
    let cond = llvmCompare(main, "eq", llvmIdent(main, "value"), llvmIntLiteral(42))
    let labels = llvmIfStart(main, cond)
    llvmPrintlnI64(main, llvmIdent(main, "value"))
    llvmIfElse(main, labels)
    llvmPrintlnI64(main, llvmIntLiteral(0))
    llvmIfEnd(main, labels)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction(
                "i64",
                "add",
                [
                    llvmParam("a", "i64"),
                    llvmParam("b", "i64"),
                ],
                add.body,
            ),
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

pub fn llvmSmokeControlFlowIR(sourcePath: String) -> String {
    let sumTo = llvmEmitter()
    llvmBind(sumTo, "n", llvmI64("%n"))
    llvmMutableLet(sumTo, "total", llvmIntLiteral(0))
    let loop = llvmInclusiveRangeStart(sumTo, "i", llvmIntLiteral(1), llvmIdent(sumTo, "n"))
    let nextTotal = llvmBinaryI64(sumTo, "add", llvmIdent(sumTo, "total"), llvmIdent(sumTo, "i"))
    let _ = llvmAssign(sumTo, "total", nextTotal)
    llvmRangeEnd(sumTo, loop)
    llvmReturn(sumTo, llvmIdent(sumTo, "total"))

    let main = llvmEmitter()
    let value = llvmCall(main, "i64", "sumTo", [llvmIntLiteral(5)])
    llvmPrintlnI64(main, value)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i64", "sumTo", [llvmParam("n", "i64")], sumTo.body),
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

pub fn llvmSmokeBooleansIR(sourcePath: String) -> String {
    let choose = llvmEmitter()
    llvmBind(choose, "a", llvmI64("%a"))
    llvmBind(choose, "b", llvmI64("%b"))
    let lt = llvmCompare(choose, "slt", llvmIdent(choose, "a"), llvmIdent(choose, "b"))
    let eqZero = llvmCompare(choose, "eq", llvmIdent(choose, "a"), llvmIntLiteral(0))
    let nonZero = llvmNotI1(choose, eqZero)
    let cond = llvmLogicalI1(choose, "and", lt, nonZero)
    let labels = llvmIfExprStart(choose, cond)
    let thenValue = llvmBinaryI64(choose, "sub", llvmIdent(choose, "b"), llvmIdent(choose, "a"))
    llvmIfExprElse(choose, labels)
    let elseValue = llvmBinaryI64(choose, "add", llvmIdent(choose, "a"), llvmIdent(choose, "b"))
    let result = llvmIfExprEnd(choose, "i64", thenValue, elseValue, labels)
    llvmReturn(choose, result)

    let main = llvmEmitter()
    let value = llvmCall(main, "i64", "choose", [llvmIntLiteral(3), llvmIntLiteral(10)])
    llvmPrintlnI64(main, value)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction(
                "i64",
                "choose",
                [
                    llvmParam("a", "i64"),
                    llvmParam("b", "i64"),
                ],
                choose.body,
            ),
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

