use std.testing

use go "strings" as llvmTestStrings {
    fn Contains(s: String, substr: String) -> Bool
    fn Join(elems: List<String>, sep: String) -> String
}

fn assertLlvmContains(ir: String, text: String) {
    testing.assert(llvmTestStrings.Contains(ir, text))
}

fn testLlvmSmokeMinimalPrintIsOstyOwned() {
    let ir = llvmSmokeMinimalPrintIR("/tmp/minimal_print.osty")

    assertLlvmContains(ir, "; Code generated by osty LLVM backend. DO NOT EDIT.")
    assertLlvmContains(ir, "source_filename = \"/tmp/minimal_print.osty\"")
    assertLlvmContains(ir, "define i32 @main() \{")
    assertLlvmContains(ir, "%t0 = add i64 40, 2")
    assertLlvmContains(ir, "call i32 (ptr, ...) @printf(ptr @.fmt_i64, i64 %t0)")
    assertLlvmContains(ir, "ret i32 0")
}

fn testLlvmSkeletonIsOstyOwned() {
    let ir = llvmRenderSkeleton(
        "main",
        "/tmp/unsupported.osty",
        "llvm-ir",
        "x86_64-unknown-linux-gnu",
        "llvmgen: unsupported source shape",
    )

    assertLlvmContains(ir, "; Osty LLVM backend skeleton")
    assertLlvmContains(ir, "; package: main")
    assertLlvmContains(ir, "; source: /tmp/unsupported.osty")
    assertLlvmContains(ir, "; emit: llvm-ir")
    assertLlvmContains(ir, "; target: x86_64-unknown-linux-gnu")
    assertLlvmContains(ir, "; unsupported: llvmgen: unsupported source shape")
    assertLlvmContains(ir, "; code generation is not implemented yet")
    assertLlvmContains(ir, "source_filename = \"/tmp/unsupported.osty\"")
    assertLlvmContains(ir, "target triple = \"x86_64-unknown-linux-gnu\"")
}

fn testLlvmSkeletonDefaultsPackageAndSource() {
    let ir = llvmRenderSkeleton("", "", "binary", "", "")

    assertLlvmContains(ir, "; package: main")
    assertLlvmContains(ir, "; source: <unknown>")
    assertLlvmContains(ir, "; emit: binary")
    assertLlvmContains(ir, "source_filename = \"<unknown>\"")
}

fn testLlvmToolchainPlanIsOstyOwned() {
    testing.assert(llvmNeedsObjectArtifact("object"))
    testing.assert(llvmNeedsObjectArtifact("binary"))
    testing.assert(!(llvmNeedsObjectArtifact("llvm-ir")))
    testing.assert(llvmNeedsBinaryArtifact("binary"))
    testing.assert(!(llvmNeedsBinaryArtifact("object")))

    let compile = llvmTestStrings.Join(
        llvmClangCompileObjectArgs("x86_64-unknown-linux-gnu", "/tmp/main.ll", "/tmp/main.o"),
        " ",
    )
    assertLlvmContains(compile, "-target x86_64-unknown-linux-gnu")
    assertLlvmContains(compile, "-c /tmp/main.ll")
    assertLlvmContains(compile, "-o /tmp/main.o")

    let link = llvmTestStrings.Join(
        llvmClangLinkBinaryArgs("", "/tmp/main.o", "/tmp/app"),
        " ",
    )
    assertLlvmContains(link, "/tmp/main.o")
    assertLlvmContains(link, "-o /tmp/app")
    testing.assert(!(llvmTestStrings.Contains(link, "-target")))
    assertLlvmContains(llvmMissingClangMessage(), "clang not found")
    assertLlvmContains(
        llvmClangFailureMessage("link binary", "clang main.o -o app", "boom"),
        "link binary",
    )
}

fn testLlvmExecutableCorpusPlanIsOstyOwned() {
    let cases = llvmSmokeExecutableCorpus()

    testing.assert(cases.len() == 7)
    testing.assert(cases[0].name == "minimal")
    testing.assert(cases[0].fixture == "minimal_print.osty")
    testing.assert(cases[0].stdout == "42\n")
    testing.assert(cases[1].name == "scalar")
    testing.assert(cases[1].fixture == "scalar_arithmetic.osty")
    testing.assert(cases[1].stdout == "42\n")
    testing.assert(cases[2].name == "control")
    testing.assert(cases[2].fixture == "control_flow.osty")
    testing.assert(cases[2].stdout == "15\n")
    testing.assert(cases[3].name == "booleans")
    testing.assert(cases[3].fixture == "booleans.osty")
    testing.assert(cases[3].stdout == "7\n")
    testing.assert(cases[4].name == "string")
    testing.assert(cases[4].fixture == "string_print.osty")
    testing.assert(cases[4].stdout == "hello, osty\n")
    testing.assert(cases[5].name == "string-escape")
    testing.assert(cases[5].fixture == "string_escape_print.osty")
    testing.assert(cases[5].stdout == "line one\nquote \" slash \\\n")
    testing.assert(cases[6].name == "string-let")
    testing.assert(cases[6].fixture == "string_let_print.osty")
    testing.assert(cases[6].stdout == "stored string\n")
}

fn testLlvmUnsupportedDiagnosticPolicyIsOstyOwned() {
    let goFfi = llvmUnsupportedDiagnostic("go-ffi", "strings")
    testing.assert(goFfi.code == "LLVM001")
    testing.assert(goFfi.kind == "go-only")
    assertLlvmContains(goFfi.message, "use go \"strings\"")
    assertLlvmContains(goFfi.message, "Go backend")
    assertLlvmContains(goFfi.hint, "--backend=go")
    let summary = llvmUnsupportedSummary(goFfi)
    assertLlvmContains(summary, "LLVM001 go-only")
    assertLlvmContains(summary, "hint:")

    let fallback = llvmUnsupportedDiagnostic("unknown", "custom reason")
    testing.assert(fallback.code == "LLVM000")
    testing.assert(fallback.kind == "unsupported-source")
    assertLlvmContains(fallback.message, "custom reason")
    assertLlvmContains(fallback.hint, "LLVM smoke subset")
    assertLlvmContains(llvmUnsupportedBackendErrorMessage(), "not implemented yet")
}

fn testLlvmUnsupportedTaxonomyIsOstyOwned() {
    let layout = llvmUnsupportedDiagnostic("source-layout", "missing main")
    testing.assert(layout.code == "LLVM010")
    testing.assert(layout.kind == "source-layout")
    assertLlvmContains(layout.hint, "simple main")

    let typ = llvmUnsupportedDiagnostic("type-system", "String")
    testing.assert(typ.code == "LLVM011")
    assertLlvmContains(typ.hint, "Int or Bool")

    let stmt = llvmUnsupportedDiagnostic("statement", "match")
    testing.assert(stmt.code == "LLVM012")
    assertLlvmContains(stmt.hint, "range-for")

    let expr = llvmUnsupportedDiagnostic("expression", "String literal")
    testing.assert(expr.code == "LLVM013")
    assertLlvmContains(expr.hint, "value-if")

    let flow = llvmUnsupportedDiagnostic("control-flow", "if-let")
    testing.assert(flow.code == "LLVM014")
    assertLlvmContains(flow.hint, "plain if/else")

    let call = llvmUnsupportedDiagnostic("call", "named argument")
    testing.assert(call.code == "LLVM015")
    assertLlvmContains(call.hint, "positional")

    let name = llvmUnsupportedDiagnostic("name", "bad-name")
    testing.assert(name.code == "LLVM016")
    assertLlvmContains(name.hint, "ASCII identifiers")

    let sig = llvmUnsupportedDiagnostic("function-signature", "generic")
    testing.assert(sig.code == "LLVM017")
    assertLlvmContains(sig.hint, "non-generic")
}

fn testLlvmSmokeScalarArithmeticIsOstyOwned() {
    let ir = llvmSmokeScalarArithmeticIR("/tmp/scalar_arithmetic.osty")

    assertLlvmContains(ir, "define i64 @add(i64 %a, i64 %b) \{")
    assertLlvmContains(ir, "%t0 = add i64 %a, %b")
    assertLlvmContains(ir, "ret i64 %t0")
    assertLlvmContains(ir, "define i32 @main() \{")
    assertLlvmContains(ir, "%t0 = call i64 @add(i64 40, i64 2)")
    assertLlvmContains(ir, "%t1 = icmp eq i64 %t0, 42")
    assertLlvmContains(ir, "br i1 %t1, label %if.then0, label %if.else1")
    assertLlvmContains(ir, "if.then0:")
    assertLlvmContains(ir, "if.else1:")
    assertLlvmContains(ir, "if.end2:")
}

fn testLlvmSmokeControlFlowIsOstyOwned() {
    let ir = llvmSmokeControlFlowIR("/tmp/control_flow.osty")

    assertLlvmContains(ir, "define i64 @sumTo(i64 %n) \{")
    assertLlvmContains(ir, "alloca i64")
    assertLlvmContains(ir, "store i64 0")
    assertLlvmContains(ir, "store i64 1")
    assertLlvmContains(ir, "br label %for.cond0")
    assertLlvmContains(ir, "for.cond0:")
    assertLlvmContains(ir, "icmp sle i64")
    assertLlvmContains(ir, "br i1")
    assertLlvmContains(ir, "store i64")
    assertLlvmContains(ir, "for.end2:")
    assertLlvmContains(ir, "ret i64")
    assertLlvmContains(ir, "%t0 = call i64 @sumTo(i64 5)")
    assertLlvmContains(ir, "call i32 (ptr, ...) @printf(ptr @.fmt_i64, i64 %t0)")
}

fn testLlvmSmokeBooleansIsOstyOwned() {
    let ir = llvmSmokeBooleansIR("/tmp/booleans.osty")

    assertLlvmContains(ir, "define i64 @choose(i64 %a, i64 %b) \{")
    assertLlvmContains(ir, "icmp slt i64 %a, %b")
    assertLlvmContains(ir, "icmp eq i64 %a, 0")
    assertLlvmContains(ir, "xor i1")
    assertLlvmContains(ir, "and i1")
    assertLlvmContains(ir, "br i1")
    assertLlvmContains(ir, "if.expr.then0:")
    assertLlvmContains(ir, "if.expr.else1:")
    assertLlvmContains(ir, "phi i64")
    assertLlvmContains(ir, "%t0 = call i64 @choose(i64 3, i64 10)")
}

fn testLlvmSmokeStringPrintIsOstyOwned() {
    let ir = llvmSmokeStringPrintIR("/tmp/string_print.osty")

    assertLlvmContains(ir, "@.str0 = private unnamed_addr constant [13 x i8] c\"hello, osty\\0A\\00\"")
    assertLlvmContains(ir, "define i32 @main() \{")
    assertLlvmContains(ir, "call i32 (ptr, ...) @printf(ptr @.str0)")
    assertLlvmContains(ir, "ret i32 0")
}

fn testLlvmSmokeStringEscapeIsOstyOwned() {
    let ir = llvmSmokeStringEscapeIR("/tmp/string_escape_print.osty")

    assertLlvmContains(ir, "@.str0 = private unnamed_addr constant [26 x i8] c\"line one\\0Aquote \\22 slash \\5C\\0A\\00\"")
    assertLlvmContains(ir, "define i32 @main() \{")
    assertLlvmContains(ir, "call i32 (ptr, ...) @printf(ptr @.str0)")
    assertLlvmContains(ir, "ret i32 0")
}

fn testLlvmSmokeStringLetIsOstyOwned() {
    let ir = llvmSmokeStringLetIR("/tmp/string_let_print.osty")

    assertLlvmContains(ir, "@.str0 = private unnamed_addr constant [15 x i8] c\"stored string\\0A\\00\"")
    assertLlvmContains(ir, "define i32 @main() \{")
    assertLlvmContains(ir, "call i32 (ptr, ...) @printf(ptr @.str0)")
    assertLlvmContains(ir, "ret i32 0")
}
