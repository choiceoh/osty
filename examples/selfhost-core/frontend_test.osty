use std.testing

fn testFrontendLexerSummarizesCompilerTokens() {
    let summary = frontendLexSummary(r"pub fn add ( value : Int ) -> Int { let answer = 42 }")

    testing.assertEq(summary.tokens, 17)
    testing.assertEq(summary.keywords, 3)
    testing.assertEq(summary.identifiers, 5)
    testing.assertEq(summary.literals, 1)
    testing.assertEq(summary.punctuation, 7)
    testing.assertEq(summary.errors, 0)
    testing.assertEq(summary.first, "pub")
    testing.assertEq(summary.second, "fn")
    testing.assertEq(summary.third, "IDENT")
}

fn testFrontendLexerScansPackedSource() {
    let summary = frontendLexSummary(r"pub fn add(value:Int)->Int{let answer=42}")

    testing.assertEq(summary.tokens, 17)
    testing.assertEq(summary.keywords, 3)
    testing.assertEq(summary.identifiers, 5)
    testing.assertEq(summary.literals, 1)
    testing.assertEq(summary.punctuation, 7)
    testing.assertEq(summary.errors, 0)
}

fn testFrontendLexerHandlesCommentsAndLiterals() {
    let source = "/// docs\nfn main() // line\nlet s = \"hi\"\nlet raw = r\"json\"\nlet c = 'x'\nlet b = b'z'\n"
    let summary = frontendLexSummary(source)

    testing.assertEq(summary.docs, 1)
    testing.assertEq(summary.newlines, 5)
    testing.assertEq(summary.tokens, 26)
    testing.assertEq(summary.keywords, 5)
    testing.assertEq(summary.identifiers, 5)
    testing.assertEq(summary.literals, 4)
    testing.assertEq(summary.punctuation, 6)
    testing.assertEq(summary.errors, 0)
}

fn testFrontendLexerHandlesOperatorsAndBlockComments() {
    let summary = frontendLexSummary("a==b && c!=d\nx <<= 1\n/* block */_")

    testing.assertEq(summary.tokens, 14)
    testing.assertEq(summary.identifiers, 5)
    testing.assertEq(summary.literals, 1)
    testing.assertEq(summary.punctuation, 5)
    testing.assertEq(summary.newlines, 2)
    testing.assertEq(summary.errors, 0)
}

fn testFrontendLexerHandlesBomShebangAndCrLf() {
    let summary = frontendLexSummary("\u{FEFF}#!/usr/bin/env osty\r\nfn main()\r\n\{\r\n\}\r")

    testing.assertEq(summary.bomStripped, 1)
    testing.assertEq(summary.shebangs, 1)
    testing.assertEq(summary.keywords, 1)
    testing.assertEq(summary.identifiers, 1)
    testing.assertEq(summary.punctuation, 4)
    testing.assertEq(summary.newlines, 2)
    testing.assertEq(summary.errors, 0)
}

fn testFrontendLexerHandlesBasePrefixesAndExponentFloats() {
    let summary = frontendLexSummary("0xFF 0B101 0o77 3.0e+2 1..10")

    testing.assertEq(summary.literals, 6)
    testing.assertEq(summary.baseLiterals, 3)
    testing.assertEq(summary.uppercaseBasePrefixes, 1)
    testing.assertEq(summary.punctuation, 1)
    testing.assertEq(summary.errors, 1)
}

fn testFrontendLexerHandlesTripleStringsAndInterpolation() {
    let source = "\"\"\"\n\{x\}\n\"\"\" r\"\"\"\nraw\n\"\"\" \"hi \{name\}\""
    let summary = frontendLexSummary(source)

    testing.assertEq(summary.literals, 3)
    testing.assertEq(summary.tripleStrings, 2)
    testing.assertEq(summary.interpolations, 2)
    testing.assertEq(summary.errors, 0)
}

fn testFrontendLexerReportsUnterminatedLiteralsAndComments() {
    let summary = frontendLexSummary("\"oops\n/* nope")

    testing.assertEq(summary.errors, 2)
}

fn testFrontendLexerEmitsRichTokenStream() {
    let stream = frontendLexStream("/// docs\nfn main() \{\nlet x = 1\n\}\n")

    testing.assertEq(frontLexTokenCount(stream), 12)
    testing.assertEq(frontCommentCount(stream), 1)
    testing.assertEq(frontLexDiagnosticCount(stream), 0)
    testing.assertEq(stream.sourceUnits, 33)

    let first = frontLexTokenAt(stream, 0)
    testing.assertEq(frontTokenKindName(first.kind), "fn")
    testing.assertEq(first.leadingDocLines, 1)
    testing.assertEq(first.start.line, 2)
    testing.assertEq(first.start.column, 1)

    let intTok = frontLexTokenAt(stream, 8)
    testing.assertEq(frontTokenKindName(intTok.kind), "INT")
    testing.assertEq(intTok.start.line, 3)
    testing.assertEq(intTok.start.column, 9)
    testing.assertEq(intTok.end.column, 10)

    let doc = frontCommentAt(stream, 0)
    testing.assertEq(frontCommentKindName(doc.kind), "doc")
    testing.assertEq(doc.start.line, 1)
}

fn testFrontendLexerEmitsStructuredDiagnostics() {
    let stream = frontendLexStream("0B101\n\"oops\n/* nope")

    testing.assertEq(frontLexDiagnosticCount(stream), 3)
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 0).code),
        "E_LEX_UPPERCASE_BASE_PREFIX",
    )
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 1).code),
        "E_LEX_NEWLINE_IN_STRING",
    )
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 2).code),
        "E_LEX_UNTERMINATED_BLOCK_COMMENT",
    )

    let firstDiag = frontLexDiagnosticAt(stream, 0)
    testing.assertEq(firstDiag.start.line, 1)
    testing.assertEq(firstDiag.end.column, 3)
}

fn testFrontendLexerTokenizesInterpolationExpressions() {
    let stream = frontendLexStream("\"hi \{name + 1\}\"")

    testing.assertEq(frontStringPartCount(stream), 2)
    testing.assertEq(frontInterpolationTokenCount(stream), 3)

    let text = frontStringPartAt(stream, 0)
    testing.assertEq(frontStringPartKindName(text.kind), "text")
    testing.assertEq(text.length, 3)
    testing.assertEq(text.start.column, 2)

    let expr = frontStringPartAt(stream, 1)
    testing.assertEq(frontStringPartKindName(expr.kind), "interpolation")
    testing.assertEq(expr.ownerToken, 0)
    testing.assertEq(expr.exprTokenStart, 0)
    testing.assertEq(expr.exprTokenCount, 3)

    testing.assertEq(frontTokenKindName(frontInterpolationTokenAt(stream, 0).token.kind), "IDENT")
    testing.assertEq(frontInterpolationTokenAt(stream, 0).token.start.column, 6)
    testing.assertEq(frontTokenKindName(frontInterpolationTokenAt(stream, 1).token.kind), "+")
    testing.assertEq(frontTokenKindName(frontInterpolationTokenAt(stream, 2).token.kind), "INT")
}

fn testFrontendLexerNormalizesTripleStrings() {
    let stream = frontendLexStream("\"\"\"\n    alpha\n    beta\n    \"\"\"")

    testing.assertEq(frontLexDiagnosticCount(stream), 0)
    testing.assertEq(stream.normalizedTripleUnits, 10)
    testing.assertEq(stream.tripleIndentErrors, 0)

    let token = frontLexTokenAt(stream, 0)
    testing.assert(token.triple)
    testing.assertEq(token.interpolations, 0)

    let part = frontStringPartAt(stream, 0)
    testing.assertEq(frontStringPartKindName(part.kind), "text")
    testing.assertEq(part.normalizedLength, 10)
}

fn testFrontendLexerReportsDeepStringDiagnostics() {
    let stream = frontendLexStream("\"bad \\q\" \"hi \{name\" \"\"\"\n  ok\nbad\n  \"\"\" '' b''")

    testing.assertEq(stream.escapeErrors, 1)
    testing.assertEq(stream.tripleIndentErrors, 1)
    testing.assertEq(frontLexDiagnosticCount(stream), 5)
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 0).code),
        "E_LEX_UNKNOWN_ESCAPE",
    )
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 1).code),
        "E_LEX_UNTERMINATED_INTERPOLATION",
    )
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 2).code),
        "E_LEX_BAD_TRIPLE_INDENT",
    )
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 3).code),
        "E_LEX_EMPTY_CHAR",
    )
    testing.assertEq(
        frontLexDiagnosticCodeName(frontLexDiagnosticAt(stream, 4).code),
        "E_LEX_EMPTY_BYTE",
    )
}

fn testFrontendLexerBridgesDirectlyIntoParser() {
    let parsed = frontendParseLexedSummary("pub fn add() \{\}\nstruct User \{\}\n")

    testing.assertEq(parsed.decls, 2)
    testing.assertEq(parsed.funcs, 1)
    testing.assertEq(parsed.structs, 1)
    testing.assertEq(parsed.publicDecls, 1)
    testing.assertEq(parsed.errors, 0)
}

fn testFrontendParserCountsTopLevelDeclarations() {
    testing.assertEq(frontTokenKindName(frontToken("pub", "pub").kind), "pub")
    testing.assertEq(frontTokenKindName(frontToken("fn", "add").kind), "fn")

    let parsed = frontendParseSummary(
        [
            frontToken("pub", "pub"),
            frontToken("fn", "add"),
            frontToken("IDENT", "add"),
            frontToken(r"{", r"{"),
            frontToken(r"}", r"}"),
            frontToken("struct", "struct"),
            frontToken("IDENT", "User"),
            frontToken("enum", "enum"),
            frontToken("IDENT", "Result"),
            frontToken("use", "use"),
            frontEOF(),
        ],
    )

    testing.assertEq(parsed.decls, 4)
    testing.assertEq(parsed.funcs, 1)
    testing.assertEq(parsed.structs, 1)
    testing.assertEq(parsed.enums, 1)
    testing.assertEq(parsed.uses, 1)
    testing.assertEq(parsed.publicDecls, 1)
    testing.assertEq(parsed.maxBlockDepth, 1)
    testing.assertEq(parsed.errors, 0)
}

fn testFrontendParserReportsBraceRecoveryErrors() {
    let parsed = frontendParseSummary(
        [
            frontToken("fn", "broken"),
            frontToken(r"{", r"{"),
            frontEOF(),
        ],
    )

    testing.assertEq(parsed.decls, 1)
    testing.assertEq(parsed.errors, 1)
}

fn testFrontendParserPortsFunctionShape() {
    let parsed = frontendParseRichSummary(
        r"pub fn map<T>(xs: List<Int>, f: fn(Int) -> Int) -> List<Int> { let y = f(1 + 2) return y }",
    )

    testing.assertEq(parsed.decls, 1)
    testing.assertEq(parsed.funcs, 1)
    testing.assertEq(parsed.publicDecls, 1)
    testing.assertEq(parsed.genericParams, 1)
    testing.assertEq(parsed.params, 2)
    testing.assertEq(parsed.typeRefs, 8)
    testing.assertEq(parsed.blocks, 1)
    testing.assertEq(parsed.statements, 2)
    testing.assertEq(parsed.lets, 1)
    testing.assertEq(parsed.returns, 1)
    testing.assertEq(parsed.calls, 1)
    testing.assertEq(parsed.literals, 2)
    testing.assertEq(parsed.binaryOps, 1)
    testing.assertEq(parsed.errors, 0)
}

fn testFrontendParserPortsAggregateDeclarations() {
    let source = "use std.testing\npub struct Box<T> \{ value: T fn get(value: T) -> T \{ return value \} \}\nenum Maybe<T> \{ Some(T), None, fn has(flag: Bool) -> Bool \{ return flag \} \}\ninterface Reader \{ Closeable\n fn read(buf: Bytes) -> Int \}\ntype Names = List<String>\n"
    let parsed = frontendParseRichSummary(source)

    testing.assertEq(parsed.decls, 5)
    testing.assertEq(parsed.uses, 1)
    testing.assertEq(parsed.structs, 1)
    testing.assertEq(parsed.enums, 1)
    testing.assertEq(parsed.interfaces, 1)
    testing.assertEq(parsed.aliases, 1)
    testing.assertEq(parsed.publicDecls, 1)
    testing.assertEq(parsed.genericParams, 2)
    testing.assertEq(parsed.fields, 1)
    testing.assertEq(parsed.methods, 3)
    testing.assertEq(parsed.variants, 2)
    testing.assertEq(parsed.variantFields, 1)
    testing.assertEq(parsed.params, 3)
    testing.assert(parsed.typeRefs >= 10)
    testing.assertEq(parsed.blocks, 2)
    testing.assertEq(parsed.returns, 2)
    testing.assertEq(parsed.maxBlockDepth, 2)
    testing.assertEq(parsed.errors, 0)
}

fn testFrontendParserRecoversRichShapeFromBrokenBlock() {
    let parsed = frontendParseRichSummary(r"fn broken(x: Int) -> Int { if x { return 1")

    testing.assertEq(parsed.decls, 1)
    testing.assertEq(parsed.funcs, 1)
    testing.assertEq(parsed.params, 1)
    testing.assertEq(parsed.blocks, 1)
    testing.assertEq(parsed.ifs, 1)
    testing.assertEq(parsed.returns, 1)
    testing.assertEq(parsed.literals, 1)
    testing.assert(parsed.errors > 0)
}

fn testFrontendParserPortsDeclarationSurface() {
    let parsed = frontendParseRichSummary(
        r"""
            use go "net/http" as http {
                fn Get(url: String) -> Result<Response, Error>
            }

            /// A user.
            #[deprecated(message = "use Account")]
            pub struct User {
                #[json(key = "user_name")]
                pub name: String,
                age: Int = 0,
                pub fn greet(self) -> String { "hi" }
            }

            pub interface ReadWriter {
                Reader
                Writer
                fn source(self) -> Error? { None }
            }

            pub type Handler = fn(Request) -> Result<(Response, Error), Error?>
            pub fn connect(timeout: Int = 30) -> Handler { makeHandler(timeout) }
            """,
    )

    testing.assertEq(parsed.goUses, 1)
    testing.assertEq(parsed.useAliases, 1)
    testing.assertEq(parsed.useGoItems, 1)
    testing.assert(parsed.annotations >= 2)
    testing.assert(parsed.docComments >= 1)
    testing.assertEq(parsed.fields, 2)
    testing.assertEq(parsed.defaultValues, 2)
    testing.assert(parsed.fnTypes >= 1)
    testing.assert(parsed.optionalTypes >= 2)
    testing.assert(parsed.tupleTypes >= 1)
    testing.assert(parsed.typeRefs >= 14)
    testing.assertEq(parsed.errors, 0)
}

fn testFrontendParserPortsExpressionSurface() {
    let parsed = frontendParseRichSummary(
        r"""
            fn f(ch: Chan<Int>, items: List<Int>, maybe: Result<Int, Error>?) -> Int {
                let mut point = Point { x: 0, y: 1, ..origin }
                let xs = [1, 2, 3]
                let pair = (1, 2)
                let cfg = json.parse::<Config>(text, timeout: 60)
                let v = xs[0] ?? 1
                ch <- v
                defer point.close()
                for let Some(x) = maybe {
                    if let Some(y) = next() {
                        match y {
                            0..=9 -> process(|n| n + x),
                            _ if y > 10 -> process(|| y),
                        }
                    } else { break }
                }
                return v?
            }
            """,
    )

    testing.assertEq(parsed.mutableBindings, 1)
    testing.assert(parsed.variantPatterns >= 2)
    testing.assertEq(parsed.ifLets, 1)
    testing.assertEq(parsed.elseBranches, 1)
    testing.assertEq(parsed.matchArms, 2)
    testing.assertEq(parsed.matchGuards, 1)
    testing.assertEq(parsed.closures, 2)
    testing.assertEq(parsed.closureParams, 1)
    testing.assertEq(parsed.turbofish, 1)
    testing.assertEq(parsed.keywordArgs, 1)
    testing.assertEq(parsed.listLits, 1)
    testing.assertEq(parsed.tupleLits, 1)
    testing.assertEq(parsed.structLits, 1)
    testing.assertEq(parsed.structLitFields, 2)
    testing.assertEq(parsed.spreads, 1)
    testing.assertEq(parsed.indexes, 1)
    testing.assertEq(parsed.ranges, 1)
    testing.assertEq(parsed.channelSends, 1)
    testing.assertEq(parsed.questionOps, 1)
    testing.assertEq(parsed.errors, 0)
}

fn testFrontendParserBuildsLosslessParseTree() {
    let source = r"""
        use std.testing
        #[deprecated(message = "old")]
        pub fn f(xs: List<Int>) -> Result<Int, Error> {
            let value = xs[0] ?? 1
            return process::<Int>(value)
        }
        """
    let tree = frontendParseTree(source)
    let lexed = frontendLexStream(source)

    testing.assertEq(tree.tokens, frontLexTokenCount(lexed))
    testing.assertEq(tree.coveredTokens, tree.tokens)
    testing.assertEq(frontParseTreeInvalidSpanCount(tree), 0)
    testing.assertEq(frontParseTreeDiagnosticCount(tree), 0)
    testing.assertEq(frontParseTreeNodeNameCount(tree, "file"), 1)
    testing.assertEq(frontParseTreeNodeNameCount(tree, "use"), 1)
    testing.assertEq(frontParseTreeNodeNameCount(tree, "fn"), 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "param") >= 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "block") >= 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "letStmt") >= 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "return") >= 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "index") >= 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "turbofish") >= 1)
}

fn testFrontendParserTreeRecoversAndContinues() {
    let tree = frontendParseTree(
        r"""
            fn good() { 1 }
            @ bad
            fn good2() { 2 }
            """,
    )

    testing.assertEq(frontParseTreeNodeNameCount(tree, "fn"), 2)
    testing.assert(frontParseTreeNodeNameCount(tree, "recovery") >= 1)
    testing.assert(frontParseTreeDiagnosticNameCount(tree, "unexpected") >= 1)
    testing.assert(tree.recovered >= 1)
    testing.assertEq(frontParseTreeInvalidSpanCount(tree), 0)
}

fn testFrontendParserTreeReportsPrecedenceDiagnostics() {
    let tree = frontendParseTree(
        r"""
            fn f() {
                a < b < c
                let r = a..b..c
            }
            """,
    )

    testing.assert(frontParseTreeDiagnosticNameCount(tree, "nonAssoc") >= 2)
    testing.assert(tree.precedenceDiagnostics >= 2)
    testing.assert(frontParseTreeNodeNameCount(tree, "binary") >= 1)
    testing.assert(frontParseTreeNodeNameCount(tree, "range") >= 1)
    testing.assertEq(frontParseTreeInvalidSpanCount(tree), 0)
}

fn testFrontendTypeCheckerModelsAssignableLiterals() {
    testing.assert(frontAssignableName("Int", "UntypedInt"))
    testing.assert(frontAssignableName("Float", "UntypedInt"))
    testing.assert(frontAssignableName("Float", "UntypedFloat"))
    testing.assert(frontAssignableName("String", "Never"))

    testing.assert(!(frontAssignableName("Int", "Float")))
    testing.assert(!(frontAssignableName("Int", "UntypedFloat")))
}

fn testFrontendTypeCheckerInfersAndCombinesPrimitiveTypes() {
    testing.assertEq(frontInferLiteralName("123"), "UntypedInt")
    testing.assertEq(frontInferLiteralName("1.25"), "UntypedFloat")
    testing.assertEq(frontInferLiteralName("\"hi\""), "String")

    testing.assertEq(frontBinaryResultName("+", "UntypedInt", "Int"), "Int")
    testing.assertEq(frontBinaryResultName("+", "UntypedInt", "Float"), "Float")
    testing.assertEq(frontBinaryResultName("&&", "Bool", "Bool"), "Bool")
    testing.assertEq(frontBinaryResultName("+", "String", "String"), "Invalid")
}

fn testFrontendTypeCheckerAssignmentBatch() {
    let checked = frontendCheckAssignments(
        [
            frontAssignment("Int", "UntypedInt"),
            frontAssignment("Float", "UntypedFloat"),
            frontAssignment("Bool", "String"),
        ],
    )

    testing.assertEq(checked.assignments, 3)
    testing.assertEq(checked.accepted, 2)
    testing.assertEq(checked.errors, 1)
}

fn testFrontendLexerRejectsBadNumericSeparator() {
    // Each violation (trailing, after-prefix, consecutive) fires one
    // FrontDiagBadNumericSeparator. Valid forms on the same line stay silent.
    let summary = frontendLexSummary("1_ 0x_FF 1__2 1_000 0xDEAD_BEEF")

    testing.assertEq(summary.errors, 3)
    testing.assertEq(summary.literals, 5)
}

fn testFrontendLexerRejectsEmptyCharAndByte() {
    let summary = frontendLexSummary("let a = '' \n let b = b''")

    // Two empty-literal violations — both map to E0009 downstream.
    testing.assertEq(summary.errors, 2)
}

fn testFrontendLexerAcceptsValidNumericSeparators() {
    let summary = frontendLexSummary("1_000 0xFF_FF 0b1010_1010 0o7_7_7 1_000.5 1.5e1_0")

    testing.assertEq(summary.errors, 0)
    testing.assertEq(summary.literals, 6)
}
