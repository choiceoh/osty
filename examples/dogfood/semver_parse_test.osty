use std.testing

fn assertParsedVersion(text: String, want: SemVersion) {
    match parseSemVersionText(text) {
        Ok(got) -> testing.assertEq(compareSemVersion(got, want), 0),
        Err(e) -> testing.fail(e),
    }
}

fn assertParseVersionFails(text: String) {
    match parseSemVersionText(text) {
        Ok(_) -> testing.fail("expected parse failure"),
        Err(_) -> testing.assert(true),
    }
}

fn testParseSemverCoreAndBuild() {
    assertParsedVersion("1.2.3", stableVersion(1, 2, 3))
    assertParsedVersion("v1.2.3", stableVersion(1, 2, 3))
    assertParsedVersion("0.0.0", stableVersion(0, 0, 0))
    assertParsedVersion("1.0.0+build.2", versionWithBuild(1, 0, 0, "build.2"))
}

fn testParseSemverPrerelease() {
    assertParsedVersion("1.2.3-alpha", prerelease1(1, 2, 3, preText("alpha")))
    assertParsedVersion("1.2.3-alpha.1", prerelease2(1, 2, 3, preText("alpha"), preNumber(1)))

    match parseSemVersionText("1.2.3-rc.1+meta") {
        Ok(got) -> {
            let want = semVersion(1, 2, 3, preText("rc"), preNumber(1), preNone(), "meta")
            testing.assertEq(compareSemVersion(got, want), 0)
        },
        Err(e) -> testing.fail(e),
    }
}

fn testParseSemverRejectsInvalidForms() {
    assertParseVersionFails("")
    assertParseVersionFails("1")
    assertParseVersionFails("1.2")
    assertParseVersionFails("1.2.3.4")
    assertParseVersionFails("01.0.0")
    assertParseVersionFails("1.02.0")
    assertParseVersionFails("1.2.3-")
    assertParseVersionFails("1.2.3-01")
    assertParseVersionFails("1.2.3-alpha+")
    assertParseVersionFails("1.2.3-al_pha")
}
