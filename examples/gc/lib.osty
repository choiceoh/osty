pub struct GcHeap {
    pub config: GcConfig,
    nextId: Int,
    nextAddress: Int,
    liveBytes: Int,
    cycle: Int,
    minorCollections: Int,
    majorCollections: Int,
    phase: TracePhase,
    objects: Map<Int, GcObject>,
    roots: Set<Int>,
    globalRoots: Map<String, GcGlobalRoot>,
    closureEnvironments: Map<Int, GcClosureEnvironment>,
    asyncFrames: Map<Int, GcAsyncFrameRoot>,
    tlabs: Map<Int, GcTlab>,
    tenured: GcTenuredAllocator,
    humongous: GcHumongousAllocator,
    barriers: GcBarrierCounters,
    cardTable: GcCardTable,
    loweredPointerSlots: Map<String, GcLoweredPointerSlot>,
    remembered: Set<Int>,
    grey: List<Int>,
    allocatedSinceLastGC: Int,
    lastStats: GcStats?,
    lastMinorTrace: GcMinorCollectionTrace,

    pub fn tryAllocate(mut self, kind: ObjectKind, size: Int) -> Result<Int, String> {
        let normalized = normalizeSize(size)
        let large = self.isLargeSize(normalized)

        if !(large) && self.phase == GcIdle && self.config.nurseryLimit > 0 && self.nurseryBytes() + normalized > self.config.nurseryLimit {
            let _ = self.minorCollectFor("nursery-pressure")
        }

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            let _ = self.majorCollectFor("heap-pressure")
        }

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            Err("gc heap exhausted: requested {normalized} bytes with {self.liveBytes} live bytes")
        } else {
            Ok(self.allocateRaw(kind, normalized))
        }
    }

    pub fn tryAllocateTenured(mut self, kind: ObjectKind, size: Int) -> Result<Int, String> {
        let normalized = normalizeSize(size)

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            let _ = self.majorCollectFor("tenured-heap-pressure")
        }

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            Err("gc heap exhausted: requested {normalized} bytes with {self.liveBytes} live bytes")
        } else {
            Ok(self.allocateTenuredRaw(kind, normalized))
        }
    }

    pub fn tryAllocateThread(mut self, ownerId: Int, kind: ObjectKind, size: Int) -> Result<Int, String> {
        let normalized = normalizeSize(size)
        if ownerId <= 0 {
            return Err("tlab owner id must be positive")
        }
        if self.config.tlabSize <= 0 || self.isLargeSize(normalized) || normalized > self.config.tlabSize {
            return self.tryAllocate(kind, normalized)
        }
        if self.tlabCanAllocate(ownerId, normalized) && self.heapLimitAllows(normalized) {
            return Ok(self.allocateRawInTlab(ownerId, kind, normalized))
        }
        match self.refillTlab(ownerId, normalized) {
            Ok(_) -> {},
            Err(e) -> {
                return Err(e)
            },
        }
        if self.tlabCanAllocate(ownerId, normalized) && self.heapLimitAllows(normalized) {
            Ok(self.allocateRawInTlab(ownerId, kind, normalized))
        } else {
            Err("gc heap exhausted: requested {normalized} bytes with {self.liveBytes} live bytes")
        }
    }

    pub fn allocate(mut self, kind: ObjectKind, size: Int) -> Int {
        self.tryAllocate(kind, size).unwrap()
    }

    pub fn allocateTenured(mut self, kind: ObjectKind, size: Int) -> Int {
        self.tryAllocateTenured(kind, size).unwrap()
    }

    pub fn allocateThread(mut self, ownerId: Int, kind: ObjectKind, size: Int) -> Int {
        self.tryAllocateThread(ownerId, kind, size).unwrap()
    }

    pub fn barrierAbi(self) -> GcBarrierAbi {
        let _ = self
        gcBarrierAbiV1()
    }

    pub fn gcPreWriteBarrier(mut self, slotKind: GcBarrierSlotKind, ownerId: Int, oldValue: Int) -> Bool {
        let _ = slotKind
        if !(self.objects.containsKey(ownerId)) {
            return false
        }
        if oldValue >= 0 && !(self.objects.containsKey(oldValue)) {
            return false
        }
        self.recordPreWriteBarrier()
        true
    }

    pub fn gcPostWriteBarrier(mut self, slotKind: GcBarrierSlotKind, ownerId: Int, newValue: Int) -> Bool {
        let _ = slotKind
        if !(self.objects.containsKey(ownerId)) {
            return false
        }
        if newValue >= 0 && !(self.objects.containsKey(newValue)) {
            return false
        }
        self.recordPostWriteBarrier()
        if newValue < 0 {
            return true
        }

        let owner = self.objects[ownerId]
        let child = self.objects[newValue]
        if owner.generation > child.generation {
            let mut next = owner
            next.remembered = true
            self.objects.insert(ownerId, next)
            self.remembered.insert(ownerId)
            self.dirtyCardForObject(ownerId, true)
            self.recordRememberedSetBarrier()
        }

        let current = self.objects[ownerId]
        if self.phase == GcMarking && current.color == GcBlack && child.color == GcWhite {
            self.shade(newValue)
            self.recordIncrementalBarrierShade()
        }
        true
    }

    pub fn gcLoadBarrier(mut self, value: Int) -> Int? {
        self.recordLoadBarrier()
        if value >= 0 && self.objects.containsKey(value) {
            Some(value)
        } else {
            None
        }
    }

    pub fn lowerStructFieldStore(
        mut self,
        ownerId: Int,
        slot: Int,
        name: String,
        newValue: Int,
    ) -> GcLoweredStoreEvent? {
        self.lowerPointerSlotStore(
            GcStructFieldStore,
            GcBarrierObjectField,
            ownerId,
            slot,
            name,
            newValue,
        )
    }

    pub fn lowerTuplePayloadStore(
        mut self,
        ownerId: Int,
        slot: Int,
        name: String,
