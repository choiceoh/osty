    pub fn loweredObjectFieldValue(self, ownerId: Int, slot: Int) -> Int? {
        match self.loweredPointerSlotValue(GcStructFieldStore, ownerId, slot) {
            Some(value) -> {
                return Some(value)
            },
            None -> {},
        }
        match self.loweredPointerSlotValue(GcTuplePayloadStore, ownerId, slot) {
            Some(value) -> {
                return Some(value)
            },
            None -> {},
        }
        match self.loweredPointerSlotValue(GcEnumPayloadStore, ownerId, slot) {
            Some(value) -> {
                return Some(value)
            },
            None -> {},
        }
        match self.loweredPointerSlotValue(GcReceiverFieldStore, ownerId, slot) {
            Some(value) -> {
                return Some(value)
            },
            None -> {},
        }
        None
    }

    pub fn loweredPointerSlotCount(self) -> Int {
        self.loweredPointerSlots.len()
    }

    pub fn loweredPointerSlotValue(self, kind: GcLoweredStoreKind, ownerId: Int, slot: Int) -> Int? {
        let key = loweredPointerSlotKey(kind, ownerId, slot)
        if self.loweredPointerSlots.containsKey(key) {
            Some(self.loweredPointerSlots[key].objectId)
        } else {
            None
        }
    }

    pub fn pinnedObjectCount(self) -> Int {
        let mut total = 0
        for (id, obj) in self.objects {
            let _ = id
            if obj.pinned {
                total = total + 1
            }
        }
        total
    }

    pub fn validateHeap(self) -> Result<(), String> {
        let mut byteSum = 0
        let mut maxEnd = 0

        if self.config.nurseryLimit < 0 {
            return Err("nurseryLimit is negative: {self.config.nurseryLimit}")
        }
        if self.config.survivorLimit < 0 {
            return Err("survivorLimit is negative: {self.config.survivorLimit}")
        }
        if self.config.promotionAge < 0 {
            return Err("promotionAge is negative: {self.config.promotionAge}")
        }
        if self.config.incrementalBudget < 0 {
            return Err("incrementalBudget is negative: {self.config.incrementalBudget}")
        }
        if self.config.largeObjectThreshold < 0 {
            return Err("largeObjectThreshold is negative: {self.config.largeObjectThreshold}")
        }
        if self.config.tlabSize < 0 {
            return Err("tlabSize is negative: {self.config.tlabSize}")
        }
        if self.config.cardSize <= 0 {
            return Err("cardSize must be positive: {self.config.cardSize}")
        }

        for (id, obj) in self.objects {
            if obj.id != id {
                return Err("heap object key/id mismatch: key={id}, object={obj.id}")
            }
            if id <= 0 {
                return Err("heap object id must be positive: {id}")
            }
            if id >= self.nextId {
                return Err("heap object id {id} is outside nextId {self.nextId}")
            }
            if obj.size <= 0 {
                return Err("object {id} has non-positive size {obj.size}")
            }
            if obj.address < 0 {
                return Err("object {id} has negative address {obj.address}")
            }
            if obj.generation != 0 && obj.generation != 1 {
                return Err("object {id} has invalid generation {obj.generation}")
            }
            if obj.age < 0 {
                return Err("object {id} has negative age {obj.age}")
            }
            if obj.large && obj.generation != 1 {
                return Err("large object {id} is not tenured")
            }
            if !(obj.pinned) && !(obj.large) && obj.generation == 0 && obj.age == 0 && obj.region != GcEdenRegion {
                return Err("young object {id} with age 0 is not in eden")
            }
            if !(obj.pinned) && !(obj.large) && obj.generation == 0 && obj.age > 0 && obj.region != GcSurvivorRegion {
                return Err("aged young object {id} is not in survivor space")
            }
            if obj.region != regionForObject(obj) {
                return Err("object {id} has stale region metadata")
            }
            if obj.color == GcWhite && obj.marked {
                return Err("object {id} is white but marked")
            }
            if obj.color != GcWhite && !(obj.marked) {
                return Err("object {id} is non-white but unmarked")
            }

            for childId in obj.refs {
                if !(self.objects.containsKey(childId)) {
                    return Err("object {id} references missing object {childId}")
                }
            }

            let expectedRemembered = obj.generation > 0 && self.hasYoungRef(obj)
            if obj.remembered != expectedRemembered {
                return Err("object {id} remembered flag is stale")
            }
            if expectedRemembered && !(self.remembered.contains(id)) {
                return Err("old object {id} has a young edge but is not remembered")
            }
            if !(expectedRemembered) && self.remembered.contains(id) {
                return Err("object {id} is remembered without an old-to-young edge")
            }

            byteSum = byteSum + obj.size
            let end = obj.address + obj.size
            if end > maxEnd {
                maxEnd = end
            }
        }

        if byteSum != self.liveBytes {
            return Err("liveBytes mismatch: field={self.liveBytes}, actual={byteSum}")
        }
        if maxEnd > self.nextAddress {
            return Err("nextAddress {self.nextAddress} is before heap span {maxEnd}")
        }
        if self.allocatedSinceLastGC < 0 {
            return Err("allocatedSinceLastGC is negative: {self.allocatedSinceLastGC}")
        }
        if self.tenured.cursor < 0 {
            return Err("tenured allocator cursor is negative: {self.tenured.cursor}")
        }
        if self.tenured.cursor > self.nextAddress {
            return Err(
                "tenured allocator cursor {self.tenured.cursor} is beyond nextAddress {self.nextAddress}",
            )
        }
        if self.tenured.bumpAllocations < 0 || self.tenured.reuseAllocations < 0 || self.tenured.directAllocations < 0 || self.tenured.promotedAllocations < 0 || self.tenured.reusedBytes < 0 {
            return Err("tenured allocator has negative accounting")
        }
        if self.humongous.cursor < 0 {
            return Err("humongous allocator cursor is negative: {self.humongous.cursor}")
        }
        if self.humongous.cursor > self.nextAddress {
            return Err(
                "humongous allocator cursor {self.humongous.cursor} is beyond nextAddress {self.nextAddress}",
            )
        }
        if self.humongous.bumpAllocations < 0 || self.humongous.reuseAllocations < 0 || self.humongous.allocatedObjects < 0 || self.humongous.reclaimedObjects < 0 || self.humongous.allocatedBytes < 0 || self.humongous.reclaimedBytes < 0 || self.humongous.reusedBytes < 0 {
            return Err("humongous allocator has negative accounting")
        }
        if self.barriers.preWriteCalls < 0 || self.barriers.postWriteCalls < 0 || self.barriers.loadCalls < 0 || self.barriers.rememberedSetWrites < 0 || self.barriers.incrementalShades < 0 || self.barriers.loadForwards < 0 {
            return Err("barrier counters have negative accounting")
        }
        if self.cardTable.cardSize != self.config.cardSize {
            return Err("card table size does not match config")
        }
        if self.cardTable.dirtyWrites < 0 || self.cardTable.scannedCards < 0 || self.cardTable.clearedCards < 0 {
            return Err("card table has negative accounting")
        }
        for card in self.cardTable.dirtyCards.toList() {
            if card < 0 {
                return Err("card table contains negative card index {card}")
            }
            if !(self.dirtyCardHasRememberedObject(card)) {
                return Err("dirty card {card} has no remembered old-to-young object")
            }
        }
        if self.lastMinorTrace.rootObjectsScanned < 0 || self.lastMinorTrace.globalRootsScanned < 0 || self.lastMinorTrace.asyncFrameRootsScanned < 0 || self.lastMinorTrace.rememberedObjectsScanned < 0 || self.lastMinorTrace.dirtyCardsScanned < 0 || self.lastMinorTrace.youngMarked < 0 || self.lastMinorTrace.survivorCopiedObjects < 0 || self.lastMinorTrace.promotedObjects < 0 {
            return Err("minor collection trace has negative accounting")
        }
        for (key, slot) in self.loweredPointerSlots {
            if key != loweredPointerSlotKey(slot.kind, slot.ownerId, slot.slot) {
                return Err("lowered pointer slot key/slot mismatch: {key}")
            }
            if slot.ownerId <= 0 || !(self.objects.containsKey(slot.ownerId)) {
                return Err("lowered pointer slot {key} references missing owner")
            }
            if slot.slot < 0 {
                return Err("lowered pointer slot {key} has negative slot")
            }
            if slot.name == "" {
                return Err("lowered pointer slot {key} has empty name")
            }
            if slot.objectId < -1 {
                return Err("lowered pointer slot {key} has invalid object id {slot.objectId}")
            }
            if slot.kind == GcRuntimeFrameSlotStore && self.objects[slot.ownerId].kind != GcRuntimeFrame {
                return Err("runtime frame slot {key} is not attached to a runtime frame")
            }
            if slot.kind == GcAsyncFrameRootStore {
                if self.objects[slot.ownerId].kind != GcRuntimeFrame {
                    return Err("async frame root slot {key} is not attached to a runtime frame")
                }
                if slot.objectId >= 0 && !(self.asyncFrameSnapshotContains(
                    slot.ownerId,
                    slot.objectId,
                )) {
                    return Err("async frame root slot {key} is missing from snapshot roots")
                }
            }
            if slot.objectId >= 0 {
                if !(self.objects.containsKey(slot.objectId)) {
                    return Err("lowered pointer slot {key} references missing object")
                }
                let owner = self.objects[slot.ownerId]
                if !(owner.refs.contains(slot.objectId)) {
                    return Err("lowered pointer slot {key} is missing from owner refs")
                }
            }
        }
        let survivorBytes = self.survivorBytes()
        if survivorBytes > self.config.survivorLimit {
            return Err(
                "survivor space overflow: bytes={survivorBytes}, limit={self.config.survivorLimit}",
            )
        }

        for idx in 0..self.tenured.freeList.len() {
            let block = self.tenured.freeList[idx]
            if block.address < 0 {
                return Err("tenured free block {idx} has negative address {block.address}")
            }
            if block.size <= 0 {
                return Err("tenured free block {idx} has non-positive size {block.size}")
            }
            if block.address + block.size > self.nextAddress {
                return Err("tenured free block {idx} is outside heap span")
            }
            for (id, obj) in self.objects {
                if rangesOverlap(block.address, block.size, obj.address, obj.size) {
                    return Err("tenured free block {idx} overlaps live object {id}")
                }
            }
            for otherIdx in 0..self.tenured.freeList.len() {
                if idx != otherIdx {
                    let other = self.tenured.freeList[otherIdx]
                    if rangesOverlap(block.address, block.size, other.address, other.size) {
                        return Err("tenured free blocks {idx} and {otherIdx} overlap")
                    }
                }
            }
        }

        for idx in 0..self.humongous.freeList.len() {
            let block = self.humongous.freeList[idx]
            if block.address < 0 {
                return Err("humongous free block {idx} has negative address {block.address}")
            }
            if block.size <= 0 {
                return Err("humongous free block {idx} has non-positive size {block.size}")
            }
            if block.address + block.size > self.nextAddress {
                return Err("humongous free block {idx} is outside heap span")
            }
            for (id, obj) in self.objects {
                if rangesOverlap(block.address, block.size, obj.address, obj.size) {
                    return Err("humongous free block {idx} overlaps live object {id}")
                }
            }
            for tenuredIdx in 0..self.tenured.freeList.len() {
                let tenuredBlock = self.tenured.freeList[tenuredIdx]
                if rangesOverlap(block.address, block.size, tenuredBlock.address, tenuredBlock.size) {
                    return Err(
                        "humongous free block {idx} overlaps tenured free block {tenuredIdx}",
                    )
                }
            }
            for otherIdx in 0..self.humongous.freeList.len() {
                if idx != otherIdx {
                    let other = self.humongous.freeList[otherIdx]
                    if rangesOverlap(block.address, block.size, other.address, other.size) {
                        return Err("humongous free blocks {idx} and {otherIdx} overlap")
                    }
                }
            }
        }

        for rootId in self.roots.toList() {
            if !(self.objects.containsKey(rootId)) {
                return Err("root references missing object {rootId}")
            }
        }

        for (key, root) in self.globalRoots {
            if key != globalRootKey(root.moduleName, root.name) {
                return Err("global root key/name mismatch: {key}")
            }
            if root.moduleName == "" || root.name == "" {
                return Err("global root has empty module or name")
            }
            if root.objectId < -1 {
                return Err("global root {key} has invalid object id {root.objectId}")
            }
            if root.state == GcGlobalDeclared && root.objectId >= 0 {
                return Err("declared global root {key} already has an object")
            }
            if root.state == GcGlobalReady && root.objectId < 0 {
                return Err("ready global root {key} has no object")
            }
            if root.state == GcGlobalPoisoned && root.objectId >= 0 {
                return Err("poisoned global root {key} still has an object")
            }
            if root.objectId >= 0 && !(self.objects.containsKey(root.objectId)) {
                return Err("global root {key} references missing object {root.objectId}")
            }
        }

        for (closureId, env) in self.closureEnvironments {
            if closureId != env.closureId {
                return Err("closure environment key/id mismatch: {closureId}")
            }
            if !(self.objects.containsKey(env.closureId)) {
                return Err("closure environment {closureId} references missing closure")
            }
            let closure = self.objects[env.closureId]
            if closure.kind != GcClosure {
                return Err("closure environment {closureId} is not attached to a closure object")
            }
            if env.functionName == "" {
                return Err("closure environment {closureId} has empty function name")
            }
            match self.validateClosureCaptures(env.captures) {
                Ok(_) -> {},
                Err(e) -> {
                    return Err(e)
                },
            }
            let expectedRefs = closureCaptureObjectIds(env.captures)
            if closure.refs.len() != expectedRefs.len() {
                return Err("closure environment {closureId} refs do not match capture descriptor")
            }
            for refId in expectedRefs {
                if !(closure.refs.contains(refId)) {
                    return Err("closure environment {closureId} is missing capture ref {refId}")
                }
            }
        }

        for (taskId, frame) in self.asyncFrames {
            if taskId != frame.taskId {
                return Err("async frame key/id mismatch: {taskId}")
            }
            if frame.taskId <= 0 {
                return Err("async frame id must be positive")
            }
            if frame.functionName == "" {
                return Err("async frame {taskId} has empty function name")
            }
            if frame.state == GcAsyncFrameSuspended {
                if frame.safepointId <= 0 {
                    return Err("suspended async frame {taskId} has invalid safepoint")
                }
                if frame.frameObjectId < 0 || !(self.objects.containsKey(frame.frameObjectId)) {
                    return Err("suspended async frame {taskId} references missing frame object")
                }
                if self.objects[frame.frameObjectId].kind != GcRuntimeFrame {
                    return Err("suspended async frame {taskId} root object is not a runtime frame")
                }
                match self.validateAsyncFrameRoots(frame.roots) {
                    Ok(_) -> {},
                    Err(e) -> {
                        return Err(e)
                    },
                }
            } else if frame.frameObjectId >= 0 || intListLen(frame.roots) > 0 {
                return Err("inactive async frame {taskId} still retains roots")
            }
        }

        for (ownerId, tlab) in self.tlabs {
            if ownerId != tlab.ownerId {
                return Err("tlab key/owner mismatch: {ownerId}")
            }
            if tlab.ownerId <= 0 {
                return Err("tlab owner id must be positive")
            }
            if tlab.start < 0 || tlab.cursor < 0 || tlab.limit < 0 {
                return Err("tlab {ownerId} has negative range metadata")
            }
            if tlab.cursor < tlab.start || tlab.cursor > tlab.limit {
                return Err("tlab {ownerId} cursor is outside its range")
            }
            if tlab.limit > self.nextAddress {
                return Err("tlab {ownerId} limit is beyond heap cursor")
            }
            if tlab.refills < 0 || tlab.fastAllocations < 0 || tlab.slowAllocations < 0 || tlab.wasteBytes < 0 {
                return Err("tlab {ownerId} has negative accounting")
            }
            if tlab.slowAllocations > tlab.refills {
                return Err("tlab {ownerId} has more slow allocations than refills")
            }
        }

        for id in self.remembered.toList() {
            if !(self.objects.containsKey(id)) {
                return Err("remembered set references missing object {id}")
            }
            let obj = self.objects[id]
            if obj.generation == 0 {
                return Err("young object {id} is present in remembered set")
            }
            if !(obj.remembered) {
                return Err("remembered object {id} has remembered=false")
            }
            if !(self.hasYoungRef(obj)) {
                return Err("remembered object {id} has no young reference")
            }
            let card = self.objectCardIndex(obj)
            if !(self.cardTable.dirtyCards.contains(card)) {
                return Err("remembered object {id} has no dirty card")
            }
        }

        if self.phase != GcMarking && self.grey.len() > 0 {
            return Err("grey queue is non-empty outside marking phase")
        }
        for id in self.grey {
            if !(self.objects.containsKey(id)) {
                return Err("grey queue references missing object {id}")
            }
            let obj = self.objects[id]
            if obj.color != GcGrey {
                return Err("grey queue object {id} is not grey")
            }
            if !(obj.marked) {
                return Err("grey queue object {id} is unmarked")
            }
        }

        Ok(())
    }

    fn allocateRaw(mut self, kind: ObjectKind, size: Int) -> Int {
        if self.isLargeSize(size) {
            return self.allocateHumongousRaw(kind, size)
        }

        let id = self.nextId
        let address = self.nextAddress
        self.nextId = self.nextId + 1
        self.nextAddress = self.nextAddress + size
        self.liveBytes = self.liveBytes + size
        self.allocatedSinceLastGC = self.allocatedSinceLastGC + size
        self.objects.insert(id, newGcObject(id, kind, size, address, self.cycle, false))
        id
    }

    fn allocateTenuredRaw(mut self, kind: ObjectKind, size: Int) -> Int {
        if self.isLargeSize(size) {
            return self.allocateHumongousRaw(kind, size)
        }

        let id = self.nextId
        let address = self.reserveTenuredAddress(size)
        let mut object = newGcObject(id, kind, size, address, self.cycle, false)
        object.generation = 1
        if object.age < self.config.promotionAge {
            object.age = self.config.promotionAge
        }
        object.region = regionForObject(object)
        self.nextId = self.nextId + 1
        self.liveBytes = self.liveBytes + size
        self.allocatedSinceLastGC = self.allocatedSinceLastGC + size
        let mut tenured = self.tenured
        tenured.directAllocations = tenured.directAllocations + 1
        self.tenured = tenured
        self.objects.insert(id, object)
        id
    }

    fn allocateHumongousRaw(mut self, kind: ObjectKind, size: Int) -> Int {
        let id = self.nextId
        let address = self.reserveHumongousAddress(size)
        self.nextId = self.nextId + 1
        self.liveBytes = self.liveBytes + size
        self.allocatedSinceLastGC = self.allocatedSinceLastGC + size
        let mut humongous = self.humongous
        humongous.allocatedObjects = humongous.allocatedObjects + 1
        humongous.allocatedBytes = humongous.allocatedBytes + size
        self.humongous = humongous
        self.objects.insert(id, newGcObject(id, kind, size, address, self.cycle, true))
        id
    }

    fn allocateRawInTlab(mut self, ownerId: Int, kind: ObjectKind, size: Int) -> Int {
        let mut tlab = self.tlabs[ownerId]
        let id = self.nextId
        let address = tlab.cursor
        tlab.cursor = tlab.cursor + size
        tlab.fastAllocations = tlab.fastAllocations + 1
        self.tlabs.insert(ownerId, tlab)
        self.nextId = self.nextId + 1
        self.liveBytes = self.liveBytes + size
        self.allocatedSinceLastGC = self.allocatedSinceLastGC + size
        self.objects.insert(id, newGcObject(id, kind, size, address, self.cycle, false))
        id
    }

    fn refillTlab(mut self, ownerId: Int, requested: Int) -> Result<(), String> {
        if self.phase == GcIdle && self.config.nurseryLimit > 0 && self.nurseryBytes() + requested > self.config.nurseryLimit {
            let _ = self.minorCollectFor("tlab-refill")
        }
        if self.config.heapLimit > 0 && self.liveBytes + requested > self.config.heapLimit {
            let _ = self.majorCollectFor("tlab-heap-pressure")
        }
        if self.config.heapLimit > 0 && self.liveBytes + requested > self.config.heapLimit {
            return Err(
                "gc heap exhausted: requested {requested} bytes with {self.liveBytes} live bytes",
            )
        }

        let mut tlab = if self.tlabs.containsKey(ownerId) {
            self.tlabs[ownerId]
        } else {
            emptyTlab(ownerId)
        }
        let waste = tlabRemainingBytes(tlab)
        if waste > 0 {
            tlab.wasteBytes = tlab.wasteBytes + waste
        }
        let refillSize = tlabRefillSize(self.config.tlabSize, requested)
        tlab.start = self.nextAddress
        tlab.cursor = self.nextAddress
        tlab.limit = self.nextAddress + refillSize
        tlab.refills = tlab.refills + 1
        tlab.slowAllocations = tlab.slowAllocations + 1
        self.nextAddress = self.nextAddress + refillSize
        self.tlabs.insert(ownerId, tlab)
        Ok(())
    }

    fn isLargeSize(self, size: Int) -> Bool {
        self.config.largeObjectThreshold > 0 && size >= self.config.largeObjectThreshold
    }

    fn heapLimitAllows(self, size: Int) -> Bool {
        self.config.heapLimit <= 0 || self.liveBytes + size <= self.config.heapLimit
    }

    fn tlabCanAllocate(self, ownerId: Int, size: Int) -> Bool {
        if self.tlabs.containsKey(ownerId) {
            tlabRemainingBytes(self.tlabs[ownerId]) >= size
        } else {
            false
        }
    }

    fn retireAllTlabs(mut self) {
        let ownerIds = self.tlabs.keys()
        for ownerId in ownerIds {
            if self.tlabs.containsKey(ownerId) {
                let mut tlab = self.tlabs[ownerId]
                let waste = tlabRemainingBytes(tlab)
                if waste > 0 {
                    tlab.wasteBytes = tlab.wasteBytes + waste
                }
                tlab.start = 0
                tlab.cursor = 0
                tlab.limit = 0
                self.tlabs.insert(ownerId, tlab)
            }
        }
    }

    fn clearAllMarks(mut self) {
        self.grey.clear()
        let ids = self.objects.keys()
        for id in ids {
            if self.objects.containsKey(id) {
                let mut next = self.objects[id]
                next.marked = false
                next.color = GcWhite
                self.objects.insert(id, next)
            }
        }
    }

    fn clearYoungMarks(mut self) {
        self.grey.clear()
        let ids = self.objects.keys()
        for id in ids {
            if self.objects.containsKey(id) {
                let obj = self.objects[id]
                if obj.generation == 0 {
                    let mut next = obj
                    next.marked = false
                    next.color = GcWhite
                    self.objects.insert(id, next)
                }
            }
        }
    }

    fn shade(mut self, id: Int) {
        if self.objects.containsKey(id) {
            let obj = self.objects[id]
            if obj.color == GcWhite {
                let mut next = obj
                next.color = GcGrey
                next.marked = true
                self.objects.insert(id, next)
                self.grey.push(id)
            }
        }
    }

    fn shadeGlobalRoots(mut self) {
        for (key, root) in self.globalRoots {
            let _ = key
            if root.objectId >= 0 {
                self.shade(root.objectId)
            }
        }
    }

    fn shadeAsyncFrameRoots(mut self) {
        for (taskId, frame) in self.asyncFrames {
            let _ = taskId
            if frame.state == GcAsyncFrameSuspended {
                if frame.frameObjectId >= 0 {
                    self.shade(frame.frameObjectId)
                }
                self.shadeObjectList(frame.roots)
            }
        }
    }

    fn shadeObjectList(mut self, ids: List<Int>) {
        for id in ids {
            self.shade(id)
        }
    }

    fn shadeYoung(mut self, id: Int) {
        if self.objects.containsKey(id) {
            let obj = self.objects[id]
            if obj.generation == 0 && obj.color == GcWhite {
                let mut next = obj
                next.color = GcGrey
                next.marked = true
                self.objects.insert(id, next)
                self.grey.push(id)
            }
        }
    }

    fn markYoungRoots(mut self) {
        for id in self.roots.toList() {
            if self.objects.containsKey(id) {
                let obj = self.objects[id]
                if obj.generation == 0 {
                    self.shadeYoung(id)
                } else {
                    self.shadeYoungChildren(obj)
                }
            }
        }

        for (key, root) in self.globalRoots {
            let _ = key
            if root.objectId >= 0 && self.objects.containsKey(root.objectId) {
                self.markYoungRootObject(root.objectId)
            }
        }

        for (taskId, frame) in self.asyncFrames {
            let _ = taskId
            if frame.state == GcAsyncFrameSuspended {
                if frame.frameObjectId >= 0 && self.objects.containsKey(frame.frameObjectId) {
                    self.markYoungRootObject(frame.frameObjectId)
                }
                for id in frame.roots {
                    if self.objects.containsKey(id) {
                        self.markYoungRootObject(id)
                    }
                }
            }
        }

        self.markYoungRememberedCards()
    }

    fn markYoungRootObject(mut self, id: Int) {
        let obj = self.objects[id]
        if obj.generation == 0 {
            self.shadeYoung(id)
        } else {
            self.shadeYoungChildren(obj)
        }
    }

    fn markYoungRememberedCards(mut self) {
        for card in self.cardTable.dirtyCards.toList() {
            for id in self.remembered.toList() {
                if self.objects.containsKey(id) {
                    let obj = self.objects[id]
                    if obj.remembered && self.objectCardIndex(obj) == card {
                        self.shadeYoungChildren(obj)
                    }
                }
            }
        }
    }

    fn shadeYoungChildren(mut self, obj: GcObject) {
        for childId in obj.refs {
            self.shadeYoung(childId)
        }
    }

    fn drainGrey(mut self, budget: Int, youngOnly: Bool) -> Int {
        let unlimited = budget <= 0
        let mut steps = 0
        for self.grey.len() > 0 && (unlimited || steps < budget) {
            let id = self.grey.pop() ?? -1
            if id >= 0 {
                if youngOnly {
                    self.blackenYoung(id)
                } else {
                    self.blacken(id)
                }
                steps = steps + 1
            }
        }
        steps
    }

    fn blacken(mut self, id: Int) {
        if self.objects.containsKey(id) {
            let obj = self.objects[id]
            if obj.color == GcGrey {
                let refs = obj.refs
                let mut next = obj
                next.color = GcBlack
                next.marked = true
                self.objects.insert(id, next)
                for childId in refs {
                    self.shade(childId)
                }
            }
        }
    }

    fn blackenYoung(mut self, id: Int) {
        if self.objects.containsKey(id) {
            let obj = self.objects[id]
            if obj.generation == 0 && obj.color == GcGrey {
                let refs = obj.refs
                let mut next = obj
                next.color = GcBlack
                next.marked = true
                self.objects.insert(id, next)
                for childId in refs {
                    self.shadeYoung(childId)
                }
            }
        }
    }

    fn sweepYoung(mut self) -> (Int, Int, Int, Int) {
        let mut reclaimedObjects = 0
        let mut reclaimedBytes = 0
        let mut promotedObjects = 0
        let mut survivorCopiedObjects = 0
        let mut survivorBytes = 0
        let ids = self.objects.keys()

        for id in ids {
            if self.objects.containsKey(id) {
                let obj = self.objects[id]
                if obj.generation == 0 {
                    if obj.marked {
                        let mut next = obj
                        next.age = next.age + 1
                        if self.shouldPromoteYoungSurvivor(next, survivorBytes) {
                            next = self.promoteYoungObject(next)
                            promotedObjects = promotedObjects + 1
                        } else {
                            survivorBytes = survivorBytes + next.size
                            survivorCopiedObjects = survivorCopiedObjects + 1
                        }
                        next.region = regionForObject(next)
                        next.marked = false
                        next.color = GcWhite
                        self.objects.insert(id, next)
                    } else {
                        self.dropObjectSideTables(id)
                        let _ = self.objects.remove(id)
                        self.liveBytes = self.liveBytes - obj.size
                        reclaimedObjects = reclaimedObjects + 1
                        reclaimedBytes = reclaimedBytes + obj.size
                    }
                }
            }
        }

        (reclaimedObjects, reclaimedBytes, promotedObjects, survivorCopiedObjects)
    }

    fn shouldPromoteYoungSurvivor(self, obj: GcObject, survivorBytes: Int) -> Bool {
        if obj.pinned {
            return true
        }
        if obj.age >= self.config.promotionAge {
            return true
        }
        if self.config.survivorLimit <= 0 {
            return true
        }
        survivorBytes + obj.size > self.config.survivorLimit
    }

    fn promoteYoungObject(mut self, obj: GcObject) -> GcObject {
        let mut next = obj
        next.generation = 1
        if !(next.pinned) && !(next.large) {
            let sourceAddress = next.address
            next.address = self.reserveTenuredAddress(next.size)
            self.releaseTenuredBlock(sourceAddress, next.size)
        }
        let mut tenured = self.tenured
        tenured.promotedAllocations = tenured.promotedAllocations + 1
        self.tenured = tenured
        next
    }

    fn sweepAll(mut self) -> (Int, Int) {
        let mut reclaimedObjects = 0
        let mut reclaimedBytes = 0
        let ids = self.objects.keys()

        for id in ids {
            if self.objects.containsKey(id) {
                let obj = self.objects[id]
                if obj.marked {
                    let mut next = obj
                    next.generation = 1
                    if next.age < self.config.promotionAge {
                        next.age = self.config.promotionAge
                    }
                    next.region = regionForObject(next)
                    next.marked = false
                    next.color = GcWhite
                    self.objects.insert(id, next)
                } else {
                    self.dropObjectSideTables(id)
                    if obj.large {
                        self.releaseHumongousObject(obj)
                    } else if obj.generation == 1 && !(obj.pinned) {
                        self.releaseTenuredBlock(obj.address, obj.size)
                    }
                    let _ = self.objects.remove(id)
                    self.liveBytes = self.liveBytes - obj.size
                    reclaimedObjects = reclaimedObjects + 1
                    reclaimedBytes = reclaimedBytes + obj.size
                }
            }
        }

        (reclaimedObjects, reclaimedBytes)
    }

    fn compactLive(mut self) -> Int {
        let ids = self.objects.keys().sorted()
        let mut freeList: List<GcFreeBlock> = []
        let mut cursor = 0
        let mut moved = 0

        for id in ids {
            if self.objects.containsKey(id) {
                let mut next = self.objects[id]
                if next.pinned || next.large {
                    if next.address > cursor {
                        let gapSize = next.address - cursor
                        if !(self.rangeOverlapsHumongousFree(cursor, gapSize)) {
                            freeList.push(
                                GcFreeBlock {
                                    address: cursor,
                                    size: gapSize,
                                },
                            )
                        }
                    }
                    let end = next.address + next.size
                    if end > cursor {
                        cursor = end
                    }
                } else {
                    cursor = self.avoidHumongousFreeBlocks(cursor, next.size)
                    if next.address != cursor {
                        moved = moved + 1
                    }
                    next.address = cursor
                    cursor = cursor + next.size
                }
                self.objects.insert(id, next)
            }
        }

        let humongousEnd = self.humongousReservedEnd()
        if humongousEnd > cursor {
            cursor = humongousEnd
        }
        self.nextAddress = cursor
        let mut tenured = self.tenured
        tenured.cursor = cursor
        tenured.freeList = freeList
        self.tenured = tenured
        let mut humongous = self.humongous
        humongous.cursor = cursor
        self.humongous = humongous
        moved
    }

    fn reserveTenuredAddress(mut self, size: Int) -> Int {
        let mut address = -1
        let mut consumed = false
        let mut nextFreeList: List<GcFreeBlock> = []

        for block in self.tenured.freeList {
            if !(consumed) && block.size >= size {
                address = block.address
                consumed = true
                if block.size > size {
                    nextFreeList.push(
                        GcFreeBlock {
                            address: block.address + size,
                            size: block.size - size,
                        },
                    )
                }
            } else {
                nextFreeList.push(block)
            }
        }

        let mut tenured = self.tenured
        if consumed {
            tenured.freeList = nextFreeList
            tenured.reuseAllocations = tenured.reuseAllocations + 1
            tenured.reusedBytes = tenured.reusedBytes + size
            self.tenured = tenured
            return address
        }

        if tenured.cursor > self.nextAddress {
            address = tenured.cursor
        } else {
            address = self.nextAddress
        }
        tenured.cursor = address + size
        tenured.bumpAllocations = tenured.bumpAllocations + 1
        self.nextAddress = tenured.cursor
        self.tenured = tenured
        address
    }

    fn reserveHumongousAddress(mut self, size: Int) -> Int {
        let mut address = -1
        let mut consumed = false
        let mut nextFreeList: List<GcFreeBlock> = []

        for block in self.humongous.freeList {
            if !(consumed) && block.size >= size {
                address = block.address
                consumed = true
                if block.size > size {
                    nextFreeList.push(
                        GcFreeBlock {
                            address: block.address + size,
                            size: block.size - size,
                        },
                    )
                }
            } else {
                nextFreeList.push(block)
            }
        }

        let mut humongous = self.humongous
        if consumed {
            humongous.freeList = nextFreeList
            humongous.reuseAllocations = humongous.reuseAllocations + 1
            humongous.reusedBytes = humongous.reusedBytes + size
            self.humongous = humongous
            return address
        }

        if humongous.cursor > self.nextAddress {
            address = humongous.cursor
        } else {
            address = self.nextAddress
        }
        humongous.cursor = address + size
        humongous.bumpAllocations = humongous.bumpAllocations + 1
        self.nextAddress = humongous.cursor
        self.humongous = humongous
        address
    }

    fn releaseTenuredBlock(mut self, address: Int, size: Int) {
        if size <= 0 {
            return
        }
        let mut tenured = self.tenured
        tenured.freeList.push(GcFreeBlock { address, size })
        self.tenured = tenured
    }

    fn releaseHumongousObject(mut self, obj: GcObject) {
        let mut humongous = self.humongous
        humongous.freeList.push(
            GcFreeBlock {
                address: obj.address,
                size: obj.size,
            },
        )
        humongous.reclaimedObjects = humongous.reclaimedObjects + 1
        humongous.reclaimedBytes = humongous.reclaimedBytes + obj.size
        self.humongous = humongous
    }

    fn avoidHumongousFreeBlocks(self, address: Int, size: Int) -> Int {
        let mut candidate = address
        let mut changed = true
        for changed {
            changed = false
            for block in self.humongous.freeList {
                if rangesOverlap(candidate, size, block.address, block.size) {
                    candidate = block.address + block.size
                    changed = true
                }
            }
        }
        candidate
    }

    fn rangeOverlapsHumongousFree(self, address: Int, size: Int) -> Bool {
        for block in self.humongous.freeList {
            if rangesOverlap(address, size, block.address, block.size) {
                return true
            }
        }
        false
    }

    fn humongousReservedEnd(self) -> Int {
        let mut end = 0
        for block in self.humongous.freeList {
            let blockEnd = block.address + block.size
            if blockEnd > end {
                end = blockEnd
            }
        }
        for (id, obj) in self.objects {
            let _ = id
            if obj.large {
                let objectEnd = obj.address + obj.size
                if objectEnd > end {
                    end = objectEnd
                }
            }
        }
        end
    }

    fn recordPreWriteBarrier(mut self) {
        let mut barriers = self.barriers
        barriers.preWriteCalls = barriers.preWriteCalls + 1
        self.barriers = barriers
    }

    fn recordPostWriteBarrier(mut self) {
        let mut barriers = self.barriers
        barriers.postWriteCalls = barriers.postWriteCalls + 1
        self.barriers = barriers
    }

    fn recordLoadBarrier(mut self) {
        let mut barriers = self.barriers
        barriers.loadCalls = barriers.loadCalls + 1
        self.barriers = barriers
    }

    fn recordRememberedSetBarrier(mut self) {
        let mut barriers = self.barriers
        barriers.rememberedSetWrites = barriers.rememberedSetWrites + 1
        self.barriers = barriers
    }

    fn recordIncrementalBarrierShade(mut self) {
        let mut barriers = self.barriers
        barriers.incrementalShades = barriers.incrementalShades + 1
        self.barriers = barriers
    }

    fn recordCardScan(mut self, count: Int) {
        if count <= 0 {
            return
        }
        let mut cardTable = self.cardTable
        cardTable.scannedCards = cardTable.scannedCards + count
        self.cardTable = cardTable
    }

    fn clearScannedDirtyCards(mut self, count: Int) {
        let mut cardTable = self.cardTable
        cardTable.dirtyCards.clear()
        if count > 0 {
            cardTable.clearedCards = cardTable.clearedCards + count
        }
        self.cardTable = cardTable
    }

    fn resetDirtyCardsForRebuild(mut self) {
        let mut cardTable = self.cardTable
        cardTable.dirtyCards.clear()
        self.cardTable = cardTable
    }

    fn dirtyCardForObject(mut self, id: Int, countWrite: Bool) {
        if !(self.objects.containsKey(id)) {
            return
        }
        let card = self.cardIndexForAddress(self.objects[id].address)
        if card < 0 {
            return
        }

        let mut cardTable = self.cardTable
        if !(cardTable.dirtyCards.contains(card)) {
            cardTable.dirtyCards.insert(card)
            if countWrite {
                cardTable.dirtyWrites = cardTable.dirtyWrites + 1
            }
        }
        self.cardTable = cardTable
    }

    fn cardIndexForAddress(self, address: Int) -> Int {
        if self.cardTable.cardSize <= 0 {
            return -1
        }
        address / self.cardTable.cardSize
    }

    fn objectCardIndex(self, obj: GcObject) -> Int {
        self.cardIndexForAddress(obj.address)
    }

    fn rememberedObjectsOnDirtyCards(self) -> Int {
        let mut total = 0
        for id in self.remembered.toList() {
            if self.objects.containsKey(id) {
                let obj = self.objects[id]
                let card = self.objectCardIndex(obj)
                if self.cardTable.dirtyCards.contains(card) {
                    total = total + 1
                }
            }
        }
        total
    }

    fn dirtyCardHasRememberedObject(self, card: Int) -> Bool {
        for id in self.remembered.toList() {
            if self.objects.containsKey(id) {
                let obj = self.objects[id]
                if obj.remembered && self.objectCardIndex(obj) == card {
                    return true
                }
            }
        }
        false
    }

    fn lowerPointerSlotStore(
        mut self,
        kind: GcLoweredStoreKind,
        barrierSlotKind: GcBarrierSlotKind,
        ownerId: Int,
        slot: Int,
        name: String,
        newValue: Int,
    ) -> GcLoweredStoreEvent? {
        if slot < 0 || name == "" {
            return None
        }
        if !(self.objects.containsKey(ownerId)) {
            return None
        }
        if newValue < -1 {
            return None
        }
        if newValue >= 0 && !(self.objects.containsKey(newValue)) {
            return None
        }

        let key = loweredPointerSlotKey(kind, ownerId, slot)
        let oldValue = self.loweredPointerSlotStoredValue(key)
        let mut preWriteCalled = false
        if oldValue >= 0 {
            preWriteCalled = self.gcPreWriteBarrier(barrierSlotKind, ownerId, oldValue)
        }

        self.loweredPointerSlots.insert(
            key,
            GcLoweredPointerSlot {
                ownerId,
                slot,
                name,
                kind,
                objectId: newValue,
            },
        )
        self.syncLoweredPointerSlotRefs(ownerId, oldValue, newValue)
        let postWriteCalled = self.gcPostWriteBarrier(barrierSlotKind, ownerId, newValue)
        self.rebuildRemembered()

        Some(
            GcLoweredStoreEvent {
                kind,
                ownerId,
                slot,
                name,
                oldValue,
                newValue,
                barrierSlotKind,
                preWriteCalled,
                postWriteCalled,
            },
        )
    }

    fn syncLoweredPointerSlotRefs(mut self, ownerId: Int, oldValue: Int, newValue: Int) {
        if !(self.objects.containsKey(ownerId)) {
            return
        }

        let mut obj = self.objects[ownerId]
        if oldValue >= 0 && oldValue != newValue && !(self.loweredPointerSlotStillReferences(
            ownerId,
            oldValue,
        )) {
            obj.refs = intListWithout(obj.refs, oldValue)
        }
        if newValue >= 0 && !(obj.refs.contains(newValue)) {
            obj.refs.push(newValue)
        }
        self.objects.insert(ownerId, obj)
    }

    fn syncAsyncFrameRootSnapshot(mut self, taskId: Int, oldValue: Int, newValue: Int) {
        if !(self.asyncFrames.containsKey(taskId)) {
            return
        }

        let mut frame = self.asyncFrames[taskId]
        if oldValue >= 0 && oldValue != newValue && !(self.asyncFrameLoweredRootStillReferences(
            frame.frameObjectId,
            oldValue,
        )) {
            frame.roots = intListWithout(frame.roots, oldValue)
        }
        if newValue >= 0 && !(intListContains(frame.roots, newValue)) {
            frame.roots.push(newValue)
        }
        self.asyncFrames.insert(taskId, frame)
    }

    fn loweredPointerSlotStillReferences(self, ownerId: Int, objectId: Int) -> Bool {
        for (key, slot) in self.loweredPointerSlots {
            let _ = key
            if slot.ownerId == ownerId && slot.objectId == objectId {
                return true
            }
        }
        false
    }

    fn asyncFrameLoweredRootStillReferences(self, frameObjectId: Int, objectId: Int) -> Bool {
        for (key, slot) in self.loweredPointerSlots {
            let _ = key
            if slot.kind == GcAsyncFrameRootStore && slot.ownerId == frameObjectId && slot.objectId == objectId {
                return true
            }
        }
        false
    }

    fn asyncFrameSnapshotContains(self, frameObjectId: Int, objectId: Int) -> Bool {
        for (taskId, frame) in self.asyncFrames {
            let _ = taskId
            if frame.state == GcAsyncFrameSuspended && frame.frameObjectId == frameObjectId && intListContains(
                frame.roots,
                objectId,
            ) {
                return true
            }
        }
        false
    }

    fn loweredPointerSlotStoredValue(self, key: String) -> Int {
        if self.loweredPointerSlots.containsKey(key) {
            return self.loweredPointerSlots[key].objectId
        }
        return -1
    }

    fn rebuildRemembered(mut self) {
        self.remembered.clear()
        self.resetDirtyCardsForRebuild()
        let ids = self.objects.keys()
        for id in ids {
            if self.objects.containsKey(id) {
                let mut next = self.objects[id]
                next.remembered = next.generation > 0 && self.hasYoungRef(next)
                if next.remembered {
                    self.remembered.insert(id)
                    self.dirtyCardForObject(id, false)
                }
                self.objects.insert(id, next)
            }
        }
    }

    fn dropObjectSideTables(mut self, id: Int) {
        if self.closureEnvironments.containsKey(id) {
            let _ = self.closureEnvironments.remove(id)
        }
        let keys = self.loweredPointerSlots.keys()
        for key in keys {
            if self.loweredPointerSlots.containsKey(key) {
                let slot = self.loweredPointerSlots[key]
                if slot.ownerId == id || slot.objectId == id {
                    let _ = self.loweredPointerSlots.remove(key)
                }
            }
        }
    }

    fn validateClosureCaptures(self, captures: List<GcClosureCapture>) -> Result<(), String> {
        let mut seenSlots: Map<Int, Bool> = {:}
        for capture in captures {
            if capture.slot < 0 {
                return Err("closure capture slot must be non-negative")
            }
            if capture.name == "" {
                return Err("closure capture slot {capture.slot} is unnamed")
            }
            if seenSlots.containsKey(capture.slot) {
                return Err("duplicate closure capture slot {capture.slot}")
            }
            seenSlots.insert(capture.slot, true)
            if capture.kind == GcCaptureScalar {
                if capture.objectId >= 0 {
                    return Err("scalar closure capture {capture.name} cannot carry an object")
                }
            } else {
                if capture.objectId < 0 {
                    return Err("pointer closure capture {capture.name} has no object")
                }
                if !(self.objects.containsKey(capture.objectId)) {
                    return Err(
                        "closure capture {capture.name} references missing object {capture.objectId}",
                    )
                }
            }
        }
        Ok(())
    }

    fn validateAsyncFrameRoots(self, roots: List<Int>) -> Result<(), String> {
        let mut seen: Map<Int, Bool> = {:}
        for id in roots {
            if id <= 0 {
                return Err("async frame root id must be positive")
            }
            if seen.containsKey(id) {
                return Err("async frame has duplicate root {id}")
            }
            seen.insert(id, true)
            if !(self.objects.containsKey(id)) {
                return Err("async frame references missing root {id}")
            }
        }
        Ok(())
    }

    fn rewriteClosureCaptureRefs(mut self, closureId: Int, captures: List<GcClosureCapture>) {
        if self.objects.containsKey(closureId) {
            let mut obj = self.objects[closureId]
            let oldRefs = obj.refs
            let newRefs = closureCaptureObjectIds(captures)
            for oldId in oldRefs {
                if !(newRefs.contains(oldId)) {
                    let _ = self.gcPreWriteBarrier(GcBarrierClosureCapture, closureId, oldId)
                }
            }
            obj.refs = newRefs
            obj.remembered = false
            let _ = self.remembered.remove(closureId)
            self.objects.insert(closureId, obj)
            for childId in newRefs {
                let _ = self.gcPostWriteBarrier(GcBarrierClosureCapture, closureId, childId)
            }
        }
    }

    fn hasYoungRef(self, obj: GcObject) -> Bool {
        for childId in obj.refs {
            if self.objects.containsKey(childId) {
                let child = self.objects[childId]
                if child.generation == 0 {
                    return true
                }
            }
        }
        false
    }

    fn heapSpan(self) -> Int {
        let mut span = 0
        for (id, obj) in self.objects {
            let _ = id
            let end = obj.address + obj.size
            if end > span {
                span = end
            }
        }
        span
    }
}

pub fn productionGcConfig() -> GcConfig {
    GcConfig {
        nurseryLimit: 64 * 1024,
        survivorLimit: 16 * 1024,
        heapLimit: 16 * 1024 * 1024,
        promotionAge: 2,
        incrementalBudget: 64,
        largeObjectThreshold: 128 * 1024,
        tlabSize: 32 * 1024,
        cardSize: 512,
    }
}

pub fn testGcConfig() -> GcConfig {
    GcConfig {
        nurseryLimit: 256,
        survivorLimit: 64,
        heapLimit: 4096,
        promotionAge: 1,
        incrementalBudget: 1,
        largeObjectThreshold: 512,
        tlabSize: 64,
        cardSize: 64,
    }
}

pub fn newGcHeap(config: GcConfig) -> GcHeap {
    let objects: Map<Int, GcObject> = {:}
    let globalRoots: Map<String, GcGlobalRoot> = {:}
    let closureEnvironments: Map<Int, GcClosureEnvironment> = {:}
    let asyncFrames: Map<Int, GcAsyncFrameRoot> = {:}
    let tlabs: Map<Int, GcTlab> = {:}
    let tenured = emptyTenuredAllocator()
    let humongous = emptyHumongousAllocator()
    let barriers = emptyBarrierCounters()
    let loweredPointerSlots: Map<String, GcLoweredPointerSlot> = {:}
    let emptyRoots: List<Int> = []
    let emptyRemembered: List<Int> = []
    let emptyDirtyCards: List<Int> = []
    let grey: List<Int> = []
    let cardTable = GcCardTable {
        cardSize: config.cardSize,
        dirtyCards: emptyDirtyCards.toSet(),
        dirtyWrites: 0,
        scannedCards: 0,
        clearedCards: 0,
    }

    GcHeap {
        config,
        nextId: 1,
        nextAddress: 0,
        liveBytes: 0,
        cycle: 0,
        minorCollections: 0,
        majorCollections: 0,
        phase: GcIdle,
        objects,
        roots: emptyRoots.toSet(),
        globalRoots,
        closureEnvironments,
        asyncFrames,
        tlabs,
        tenured,
        humongous,
        barriers,
        cardTable,
        loweredPointerSlots,
        remembered: emptyRemembered.toSet(),
        grey,
        allocatedSinceLastGC: 0,
        lastStats: None,
        lastMinorTrace: emptyMinorCollectionTrace(),
    }
}

fn globalRootKey(moduleName: String, name: String) -> String {
    "{moduleName}::{name}"
}

fn loweredPointerSlotKey(kind: GcLoweredStoreKind, ownerId: Int, slot: Int) -> String {
    "{loweredStoreKindName(kind)}:{ownerId}:{slot}"
}

fn loweredStoreKindName(kind: GcLoweredStoreKind) -> String {
    match kind {
        GcStructFieldStore -> "struct.field",
        GcTuplePayloadStore -> "tuple.payload",
        GcEnumPayloadStore -> "enum.payload",
        GcReceiverFieldStore -> "receiver.field",
        GcArrayElementStore -> "array.element",
        GcListElementStore -> "list.element",
        GcMapKeyStore -> "map.key",
        GcMapValueStore -> "map.value",
        GcSetKeyStore -> "set.key",
        GcRuntimeFrameSlotStore -> "runtime.frame",
        GcAsyncFrameRootStore -> "async.frame.root",
    }
}

fn loweredCollectionSlotName(prefix: String, slot: Int) -> String {
    "{prefix}[{slot}]"
}

fn intListLen(values: List<Int>) -> Int {
    let mut total = 0
    for value in values {
        let _ = value
        total = total + 1
    }
    total
}

fn intListWithout(values: List<Int>, removed: Int) -> List<Int> {
    let mut out: List<Int> = []
    for value in values {
        if value != removed {
            out.push(value)
        }
    }
    out
}

fn intListContains(values: List<Int>, target: Int) -> Bool {
    for value in values {
        if value == target {
            return true
        }
    }
    false
}

fn closureCaptureObjectIds(captures: List<GcClosureCapture>) -> List<Int> {
    let mut out: List<Int> = []
    for capture in captures {
        if capture.objectId >= 0 && !(out.contains(capture.objectId)) {
            out.push(capture.objectId)
        }
    }
    out
}

fn emptyTlab(ownerId: Int) -> GcTlab {
    GcTlab {
        ownerId,
        start: 0,
        cursor: 0,
        limit: 0,
        refills: 0,
        fastAllocations: 0,
        slowAllocations: 0,
        wasteBytes: 0,
    }
}

fn emptyTenuredAllocator() -> GcTenuredAllocator {
    let freeList: List<GcFreeBlock> = []
    GcTenuredAllocator {
        cursor: 0,
        freeList,
        bumpAllocations: 0,
        reuseAllocations: 0,
        directAllocations: 0,
        promotedAllocations: 0,
        reusedBytes: 0,
    }
}

fn emptyHumongousAllocator() -> GcHumongousAllocator {
    let freeList: List<GcFreeBlock> = []
    GcHumongousAllocator {
        cursor: 0,
        freeList,
        bumpAllocations: 0,
        reuseAllocations: 0,
        allocatedObjects: 0,
        reclaimedObjects: 0,
        allocatedBytes: 0,
        reclaimedBytes: 0,
        reusedBytes: 0,
    }
}

fn emptyBarrierCounters() -> GcBarrierCounters {
    GcBarrierCounters {
        preWriteCalls: 0,
        postWriteCalls: 0,
        loadCalls: 0,
        rememberedSetWrites: 0,
        incrementalShades: 0,
        loadForwards: 0,
    }
}

fn emptyMinorCollectionTrace() -> GcMinorCollectionTrace {
    GcMinorCollectionTrace {
        rootObjectsScanned: 0,
        globalRootsScanned: 0,
        asyncFrameRootsScanned: 0,
        rememberedObjectsScanned: 0,
        dirtyCardsScanned: 0,
        youngMarked: 0,
        survivorCopiedObjects: 0,
        promotedObjects: 0,
        edenReset: false,
        survivorSwap: false,
    }
}

pub fn gcBarrierAbiV1() -> GcBarrierAbi {
    GcBarrierAbi {
        version: 1,
        preWriteSymbol: "osty.gc.pre_write_v1",
        postWriteSymbol: "osty.gc.post_write_v1",
        loadSymbol: "osty.gc.load_v1",
        preWriteRequired: false,
        postWriteRequired: true,
        loadRequired: false,
    }
}

fn tlabRemainingBytes(tlab: GcTlab) -> Int {
    if tlab.limit > tlab.cursor {
        tlab.limit - tlab.cursor
    } else {
        0
    }
}

fn tlabRefillSize(configured: Int, requested: Int) -> Int {
    if configured > requested {
        configured
    } else {
        requested
    }
}

pub fn gcScalarCapture(slot: Int, name: String) -> GcClosureCapture {
    GcClosureCapture {
        slot,
        name,
        kind: GcCaptureScalar,
        objectId: -1,
    }
}

pub fn gcValueCapture(slot: Int, name: String, objectId: Int) -> GcClosureCapture {
    GcClosureCapture {
        slot,
        name,
        kind: GcCaptureValue,
        objectId,
    }
}

pub fn gcBoxedCapture(slot: Int, name: String, objectId: Int) -> GcClosureCapture {
    GcClosureCapture {
        slot,
        name,
        kind: GcCaptureBoxedValue,
        objectId,
    }
}

pub fn gcMutableBoxCapture(slot: Int, name: String, objectId: Int) -> GcClosureCapture {
    GcClosureCapture {
        slot,
        name,
        kind: GcCaptureMutableBox,
        objectId,
    }
}

pub fn gcRootSlot(slot: Int, kind: GcRootSlotKind, name: String) -> GcLiveRootSlot {
    GcLiveRootSlot {
        slot,
        kind,
        name,
        derivedFrom: -1,
        nullable: true,
    }
}

pub fn gcDerivedRootSlot(slot: Int, name: String, derivedFrom: Int) -> GcLiveRootSlot {
    GcLiveRootSlot {
        slot,
        kind: GcDerivedRootSlot,
        name,
        derivedFrom,
        nullable: false,
    }
}

pub fn gcSafepoint(
    id: Int,
    kind: GcSafepointKind,
    irNode: Int,
    instructionOffset: Int,
    liveRoots: List<GcLiveRootSlot>,
) -> GcSafepoint {
    GcSafepoint {
        id,
        kind,
        irNode,
        instructionOffset,
        mayCollect: true,
        mayAllocate: safepointMayAllocate(kind),
        maySuspend: kind == GcAsyncYieldSafepoint,
        requiresStackMap: true,
        runsDefer: false,
        questionExit: false,
        earlyReturn: false,
        liveRoots,
    }
}

pub fn gcSafepointPlan(functionName: String, frameSlots: Int, safepoints: List<GcSafepoint>) -> GcSafepointPlan {
    GcSafepointPlan {
        functionName,
        frameSlots,
        safepoints,
    }
}

pub fn validateSafepointPlan(plan: GcSafepointPlan) -> Result<(), String> {
    if plan.functionName == "" {
        return Err("safepoint plan requires a function name")
    }
    if plan.frameSlots < 0 {
        return Err("safepoint plan has negative frame slot count")
    }

    let mut seenIds: Map<Int, Bool> = {:}
    for point in plan.safepoints {
        if point.id <= 0 {
            return Err("safepoint id must be positive")
        }
        if seenIds.containsKey(point.id) {
            return Err("duplicate safepoint id {point.id}")
        }
        seenIds.insert(point.id, true)

        match validateSafepoint(plan, point) {
            Ok(_) -> {},
            Err(e) -> {
                return Err(e)
            },
        }
    }

    Ok(())
}

pub fn gcFrameSlot(
    slot: Int,
    kind: GcFrameSlotKind,
    name: String,
    byteOffset: Int,
    pointer: Bool,
) -> GcFrameSlot {
    GcFrameSlot {
        slot,
        kind,
        name,
        byteOffset,
        pointer,
        derivedFrom: -1,
        preserveForDefer: false,
        preserveForQuestion: false,
        preserveForReturn: false,
    }
}

pub fn gcPreservedFrameSlot(
    slot: Int,
    kind: GcFrameSlotKind,
    name: String,
    byteOffset: Int,
    pointer: Bool,
    preserveForDefer: Bool,
    preserveForQuestion: Bool,
    preserveForReturn: Bool,
) -> GcFrameSlot {
    GcFrameSlot {
        slot,
        kind,
        name,
        byteOffset,
        pointer,
        derivedFrom: -1,
        preserveForDefer,
        preserveForQuestion,
        preserveForReturn,
    }
}

pub fn gcDerivedFrameSlot(
    slot: Int,
    kind: GcFrameSlotKind,
    name: String,
    byteOffset: Int,
    derivedFrom: Int,
) -> GcFrameSlot {
    GcFrameSlot {
        slot,
        kind,
        name,
        byteOffset,
        pointer: true,
        derivedFrom,
        preserveForDefer: false,
        preserveForQuestion: false,
        preserveForReturn: false,
    }
}

pub fn buildGcStackMap(
    plan: GcSafepointPlan,
    frameLayout: List<GcFrameSlot>,
    inlineSlots: Int,
) -> Result<GcStackMap, String> {
    match validateSafepointPlan(plan) {
        Ok(_) -> {},
        Err(e) -> {
            return Err(e)
        },
    }

    match validateFrameLayout(plan, frameLayout) {
        Ok(_) -> {},
        Err(e) -> {
            return Err(e)
        },
    }

    let inline = normalizeInlineSlots(inlineSlots, plan.frameSlots)
    let mut entries: List<GcStackMapEntry> = []
    for point in plan.safepoints {
        match validateSafepointAgainstFrameLayout(point, frameLayout) {
            Ok(_) -> {},
            Err(e) -> {
                return Err(e)
            },
        }
        entries.push(buildStackMapEntry(point, inline))
    }

    Ok(
        GcStackMap {
            functionName: plan.functionName,
            frameSlots: plan.frameSlots,
            pointerSize: 8,
            inlineSlots: inline,
            frameLayout,
            entries,
        },
    )
}

pub fn stackMapEntryIndex(map: GcStackMap, safepointId: Int) -> Int? {
    let mut index = 0
    for entry in map.entries {
        if entry.safepointId == safepointId {
            return Some(index)
        }
        index = index + 1
    }
    None
}

pub fn stackMapHasPointer(entry: GcStackMapEntry, slot: Int) -> Bool {
    if slot < 0 {
        return false
    }
    if slot < entry.inlineSlots {
        let word = slot / 32
        if word < 0 || word >= entry.bitmapWords.len() {
            return false
        }
        let mask = 1 << (slot % 32)
        return (entry.bitmapWords[word] & mask) != 0
    }

    entry.overflowSlots.contains(slot)
}

fn newGcObject(id: Int, kind: ObjectKind, size: Int, address: Int, cycle: Int, large: Bool) -> GcObject {
    let refs: List<Int> = []
    let generation = if large {
        1
    } else {
        0
    }
    let region = if large {
        GcHumongousRegion
    } else {
        GcEdenRegion
    }
    GcObject {
        id,
        kind,
        size,
        address,
        generation,
        age: 0,
        color: GcWhite,
        marked: false,
        pinned: false,
        large,
        region,
        refs,
        remembered: false,
        allocatedCycle: cycle,
    }
}

fn validateSafepoint(plan: GcSafepointPlan, point: GcSafepoint) -> Result<(), String> {
    if point.irNode < 0 {
        return Err("safepoint {point.id} has negative IR node")
    }
    if point.instructionOffset < 0 {
        return Err("safepoint {point.id} has negative instruction offset")
    }
    if !(point.mayCollect) {
        return Err("safepoint {point.id} cannot run collector work")
    }
    if !(point.requiresStackMap) {
        return Err("safepoint {point.id} is missing required stack map")
    }
    if point.kind == GcAllocationSafepoint && !(point.mayAllocate) {
        return Err("allocation safepoint {point.id} must be marked mayAllocate")
    }
    if point.kind == GcAsyncYieldSafepoint && !(point.maySuspend) {
        return Err("async yield safepoint {point.id} must be marked maySuspend")
    }

    let mut seenSlots: Map<Int, Bool> = {:}
    for root in point.liveRoots {
        if root.slot < 0 || root.slot >= plan.frameSlots {
            return Err("safepoint {point.id} root slot {root.slot} is outside frame")
        }
        if root.name == "" {
            return Err("safepoint {point.id} root slot {root.slot} is unnamed")
        }
        if seenSlots.containsKey(root.slot) {
            return Err("safepoint {point.id} has duplicate root slot {root.slot}")
        }
        seenSlots.insert(root.slot, true)

        if root.kind == GcDerivedRootSlot {
            if root.derivedFrom < 0 {
                return Err("derived root slot {root.slot} has no base slot")
            }
            if root.derivedFrom == root.slot {
                return Err("derived root slot {root.slot} cannot derive from itself")
            }
            if !(safepointHasRootSlot(point.liveRoots, root.derivedFrom)) {
                return Err(
                    "derived root slot {root.slot} references missing base slot {root.derivedFrom}",
                )
            }
        } else if root.derivedFrom >= 0 {
            return Err("non-derived root slot {root.slot} has derivedFrom metadata")
        }
    }

    Ok(())
}

fn safepointHasRootSlot(roots: List<GcLiveRootSlot>, slot: Int) -> Bool {
    for root in roots {
        if root.slot == slot {
            return true
        }
    }
    false
}

fn safepointMayAllocate(kind: GcSafepointKind) -> Bool {
    kind == GcCallSafepoint || kind == GcAllocationSafepoint
}

fn validateFrameLayout(plan: GcSafepointPlan, frameLayout: List<GcFrameSlot>) -> Result<(), String> {
    let mut seenSlots: Map<Int, Bool> = {:}

    for slot in frameLayout {
        if slot.slot < 0 || slot.slot >= plan.frameSlots {
            return Err("frame slot {slot.slot} is outside frame")
        }
        if seenSlots.containsKey(slot.slot) {
            return Err("duplicate frame slot {slot.slot}")
        }
        seenSlots.insert(slot.slot, true)
        if slot.name == "" {
            return Err("frame slot {slot.slot} is unnamed")
        }
        if slot.byteOffset < 0 {
            return Err("frame slot {slot.slot} has negative byte offset")
        }
        if slot.derivedFrom >= 0 {
            if !(slot.pointer) {
                return Err("derived frame slot {slot.slot} must be a pointer")
            }
            if slot.derivedFrom == slot.slot {
                return Err("derived frame slot {slot.slot} cannot derive from itself")
            }
            if !(frameLayoutHasPointerSlot(frameLayout, slot.derivedFrom)) {
                return Err(
                    "derived frame slot {slot.slot} references missing pointer base {slot.derivedFrom}",
                )
            }
        }
    }

    Ok(())
}

fn validateSafepointAgainstFrameLayout(point: GcSafepoint, frameLayout: List<GcFrameSlot>) -> Result<(), String> {
    for root in point.liveRoots {
        let frame = frameLayoutSlotIndex(frameLayout, root.slot)
        match frame {
            Some(index) -> {
                let slot = frameLayout[index]
                if !(slot.pointer) {
                    return Err("safepoint {point.id} marks non-pointer frame slot {root.slot} live")
                }
                if !(rootKindMatchesFrameSlot(root.kind, slot.kind)) {
                    return Err(
                        "safepoint {point.id} root slot {root.slot} has incompatible frame slot kind",
                    )
                }
                if root.kind == GcDerivedRootSlot && slot.derivedFrom >= 0 && slot.derivedFrom != root.derivedFrom {
                    return Err("derived root slot {root.slot} disagrees with frame layout base")
                }
            },
            None -> {
                return Err("safepoint {point.id} references missing frame slot {root.slot}")
            },
        }
    }

    for slot in frameLayout {
        if point.runsDefer && slot.pointer && slot.preserveForDefer && !(safepointHasRootSlot(
            point.liveRoots,
            slot.slot,
        )) {
            return Err("safepoint {point.id} drops defer-preserved root slot {slot.slot}")
        }
        if point.questionExit && slot.pointer && slot.preserveForQuestion && !(safepointHasRootSlot(
            point.liveRoots,
            slot.slot,
        )) {
            return Err("safepoint {point.id} drops question-preserved root slot {slot.slot}")
        }
        if point.earlyReturn && slot.pointer && slot.preserveForReturn && !(safepointHasRootSlot(
            point.liveRoots,
            slot.slot,
        )) {
            return Err("safepoint {point.id} drops return-preserved root slot {slot.slot}")
        }
    }

    Ok(())
}

fn buildStackMapEntry(point: GcSafepoint, inlineSlots: Int) -> GcStackMapEntry {
    let mut bitmapWords = zeroBitmapWords(inlineSlots)
    let mut overflowSlots: List<Int> = []
    let mut derivedRoots: List<GcDerivedRootMap> = []

    for root in point.liveRoots {
        if root.slot < inlineSlots {
            let word = root.slot / 32
            let mask = 1 << (root.slot % 32)
            bitmapWords[word] = bitmapWords[word] | mask
        } else {
            overflowSlots.push(root.slot)
        }
        if root.kind == GcDerivedRootSlot {
            derivedRoots.push(
                GcDerivedRootMap {
                    derivedSlot: root.slot,
                    baseSlot: root.derivedFrom,
                },
            )
        }
    }

    GcStackMapEntry {
        safepointId: point.id,
        instructionOffset: point.instructionOffset,
        liveCount: point.liveRoots.len(),
        inlineSlots,
        bitmapWords,
        overflowSlots,
        derivedRoots,
    }
}

fn zeroBitmapWords(inlineSlots: Int) -> List<Int> {
    let mut words: List<Int> = []
    for idx in 0..bitmapWordCount(inlineSlots) {
        let _ = idx
        words.push(0)
    }
    words
}

fn bitmapWordCount(inlineSlots: Int) -> Int {
    if inlineSlots <= 0 {
        0
    } else {
        (inlineSlots + 31) / 32
    }
}

fn normalizeInlineSlots(inlineSlots: Int, frameSlots: Int) -> Int {
    if inlineSlots <= 0 {
        frameSlots
    } else if inlineSlots > frameSlots {
        frameSlots
    } else {
        inlineSlots
    }
}

fn frameLayoutSlotIndex(frameLayout: List<GcFrameSlot>, slotId: Int) -> Int? {
    let mut index = 0
    for slot in frameLayout {
        if slot.slot == slotId {
            return Some(index)
        }
        index = index + 1
    }
    None
}

fn frameLayoutHasPointerSlot(frameLayout: List<GcFrameSlot>, slotId: Int) -> Bool {
    match frameLayoutSlotIndex(frameLayout, slotId) {
        Some(index) -> frameLayout[index].pointer,
        None -> false,
    }
}

fn rootKindMatchesFrameSlot(rootKind: GcRootSlotKind, frameKind: GcFrameSlotKind) -> Bool {
    match rootKind {
        GcRegisterRootSlot -> frameKind == GcFrameRegisterSpillSlot,
        GcSpillRootSlot -> frameKind == GcFrameRegisterSpillSlot,
        GcTemporaryRootSlot -> frameKind == GcFrameTemporarySlot,
        GcClosureRootSlot -> frameKind == GcFrameClosureCaptureSlot,
        GcDerivedRootSlot -> true,
        GcLocalRootSlot -> frameKind == GcFrameLocalSlot || frameKind == GcFrameTupleFieldSlot || frameKind == GcFrameDeferSlot || frameKind == GcFrameQuestionSlot || frameKind == GcFrameReturnSlot,
    }
}

fn normalizeSize(size: Int) -> Int {
    if size <= 0 {
        1
    } else {
        size
    }
}

fn rangesOverlap(leftAddress: Int, leftSize: Int, rightAddress: Int, rightSize: Int) -> Bool {
    let leftEnd = leftAddress + leftSize
    let rightEnd = rightAddress + rightSize
    leftAddress < rightEnd && rightAddress < leftEnd
}

fn regionForObject(obj: GcObject) -> GcRegionKind {
    if obj.pinned {
        GcPinnedRegion
    } else if obj.large {
        GcHumongousRegion
    } else if obj.generation == 0 {
        if obj.age > 0 {
            GcSurvivorRegion
        } else {
            GcEdenRegion
        }
    } else {
        GcOldRegion
    }
}

fn percent(part: Int, whole: Int) -> Int {
    if whole <= 0 {
        0
    } else {
        part * 100 / whole
    }
}

fn telemetryPauseUnits(
    markSteps: Int,
    reclaimedObjects: Int,
    promotedObjects: Int,
    compactedObjects: Int,
    rememberedScanned: Int,
) -> Int {
    markSteps + reclaimedObjects + promotedObjects + compactedObjects + rememberedScanned
}

fn emptyStats(kind: String, heap: GcHeap) -> GcStats {
    let fragmented = heap.fragmentedBytes()
    GcStats {
        kind,
        trigger: "idle",
        cycle: heap.cycle,
        beforeObjects: heap.objectCount(),
        afterObjects: heap.objectCount(),
        reclaimedObjects: 0,
        beforeBytes: heap.totalLiveBytes(),
        afterBytes: heap.totalLiveBytes(),
        reclaimedBytes: 0,
        promotedObjects: 0,
        compactedObjects: 0,
        rememberedScanned: 0,
        markSteps: 0,
        pauseUnits: 0,
        allocationBytesSinceLastGC: heap.allocatedSinceLastGC,
        beforeFragmentedBytes: fragmented,
        afterFragmentedBytes: fragmented,
        fragmentedBytes: heap.fragmentedBytes(),
        survivalPercent: percent(heap.objectCount(), heap.objectCount()),
        promotionPercent: 0,
    }
}
