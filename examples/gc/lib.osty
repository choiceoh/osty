pub struct GcHeap {
    pub config: GcConfig,
    nextId: Int,
    nextAddress: Int,
    liveBytes: Int,
    cycle: Int,
    minorCollections: Int,
    majorCollections: Int,
    phase: TracePhase,
    objects: Map<Int, GcObject>,
    roots: Set<Int>,
    globalRoots: Map<String, GcGlobalRoot>,
    closureEnvironments: Map<Int, GcClosureEnvironment>,
    asyncFrames: Map<Int, GcAsyncFrameRoot>,
    tlabs: Map<Int, GcTlab>,
    tenured: GcTenuredAllocator,
    humongous: GcHumongousAllocator,
    barriers: GcBarrierCounters,
    cardTable: GcCardTable,
    loweredPointerSlots: Map<String, GcLoweredPointerSlot>,
    remembered: Set<Int>,
    grey: List<Int>,
    forwarding: Map<Int, GcForwardingEntry>,
    allocatedSinceLastGC: Int,
    lastStats: GcStats?,
    lastMinorTrace: GcMinorCollectionTrace,
    lastFullMarkTrace: GcFullMarkTrace,
    lastEvacuationTrace: GcEvacuationTrace,
    lastRemapTrace: GcRemapTrace,
    schedulerTrace: GcIncrementalSchedulerTrace,
    concurrentTrace: GcConcurrentMarkTrace,
    nextLlvmHandle: Int,
    nextLlvmRootRef: Int,
    llvmHandles: Map<Int, GcLlvmHandleEntry>,
    llvmRootRefs: Map<Int, GcLlvmRootRefEntry>,
    llvmRuntimeRoots: Set<Int>,
    llvmBridgeTrace: GcLlvmBridgeTrace,
    lastLoweredAllocation: GcLoweredAllocationTrace?,
    lastLoweredStore: GcLoweredStoreTrace?,

    pub fn tryAllocate(mut self, kind: ObjectKind, size: Int) -> Result<Int, String> {
        let normalized = normalizeSize(size)
        let large = self.isLargeSize(normalized)

        if !(large) && self.phase == GcIdle && self.config.nurseryLimit > 0 && self.nurseryBytes() + normalized > self.config.nurseryLimit {
            let _ = self.minorCollectFor("nursery-pressure")
        }

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            let _ = self.majorCollectFor("heap-pressure")
        }

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            Err("gc heap exhausted: requested {normalized} bytes with {self.liveBytes} live bytes")
        } else {
            Ok(self.allocateRaw(kind, normalized))
        }
    }

    pub fn tryAllocateTenured(mut self, kind: ObjectKind, size: Int) -> Result<Int, String> {
        let normalized = normalizeSize(size)

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            let _ = self.majorCollectFor("tenured-heap-pressure")
        }

        if self.config.heapLimit > 0 && self.liveBytes + normalized > self.config.heapLimit {
            Err("gc heap exhausted: requested {normalized} bytes with {self.liveBytes} live bytes")
        } else {
            Ok(self.allocateTenuredRaw(kind, normalized))
        }
    }

    pub fn tryAllocateThread(mut self, ownerId: Int, kind: ObjectKind, size: Int) -> Result<Int, String> {
        let normalized = normalizeSize(size)
        if ownerId <= 0 {
            return Err("tlab owner id must be positive")
        }
        if self.config.tlabSize <= 0 || self.isLargeSize(normalized) || normalized > self.config.tlabSize {
            return self.tryAllocate(kind, normalized)
        }
        if self.tlabCanAllocate(ownerId, normalized) && self.heapLimitAllows(normalized) {
            return Ok(self.allocateRawInTlab(ownerId, kind, normalized))
        }
        match self.refillTlab(ownerId, normalized) {
            Ok(_) -> {},
            Err(e) -> {
                return Err(e)
            },
        }
        if self.tlabCanAllocate(ownerId, normalized) && self.heapLimitAllows(normalized) {
            Ok(self.allocateRawInTlab(ownerId, kind, normalized))
        } else {
            Err("gc heap exhausted: requested {normalized} bytes with {self.liveBytes} live bytes")
        }
    }

    pub fn allocate(mut self, kind: ObjectKind, size: Int) -> Int {
        self.tryAllocate(kind, size).unwrap()
    }

    pub fn allocateTenured(mut self, kind: ObjectKind, size: Int) -> Int {
        self.tryAllocateTenured(kind, size).unwrap()
    }

    pub fn allocateThread(mut self, ownerId: Int, kind: ObjectKind, size: Int) -> Int {
        self.tryAllocateThread(ownerId, kind, size).unwrap()
    }

    pub fn allocateLlvmHandle(mut self, kind: ObjectKind, size: Int, allocationSite: String) -> Int {
        let objectId = self.allocate(kind, size)
        let handle = self.installLlvmHandle(objectId, allocationSite)
        self.recordLoweredLlvmAllocation(objectId, handle, kind, normalizeSize(size), false)
        handle
    }

    pub fn allocateLlvmHandleThread(
        mut self,
        ownerId: Int,
        kind: ObjectKind,
        size: Int,
        allocationSite: String,
    ) -> Int {
        let beforeFast = self.tlabFastAllocationCount()
        let objectId = self.allocateThread(ownerId, kind, size)
        let handle = self.installLlvmHandle(objectId, allocationSite)
        let usedThreadLocalBuffer = self.tlabFastAllocationCount() > beforeFast
        self.recordLoweredLlvmAllocation(
            objectId,
            handle,
            kind,
            normalizeSize(size),
            usedThreadLocalBuffer,
        )
        handle
    }

    pub fn exportLlvmHandle(mut self, objectId: Int, allocationSite: String) -> Int? {
        if !(self.objects.containsKey(objectId)) {
            return None
        }
        Some(self.installLlvmHandle(objectId, allocationSite))
    }

    pub fn releaseLlvmHandle(mut self, handle: Int) -> Bool {
        if !(self.llvmHandles.containsKey(handle)) {
            return false
        }
        let entry = self.llvmHandles[handle]
        if entry.released {
            return false
        }
        let objectId = entry.objectId

        let rootRefIds = self.llvmRootRefs.keys()
        for rootRefId in rootRefIds {
            if self.llvmRootRefs.containsKey(rootRefId) {
                let rootRef = self.llvmRootRefs[rootRefId]
                if rootRef.handle == handle && rootRef.alive {
                    let mut nextRef = rootRef
                    nextRef.alive = false
                    nextRef.pinned = false
                    self.llvmRootRefs.insert(rootRefId, nextRef)
                    self.recordLlvmRootRefReleased()
                }
            }
        }

        let mut next = entry
        next.rooted = false
        next.pinned = false
        next.released = true
        self.llvmHandles.insert(handle, next)
        self.refreshLlvmRuntimeRootForObject(objectId)
        self.refreshLlvmPinnedStateForObject(objectId)
        self.recordLlvmHandleReleased()
        true
    }

    pub fn retainLlvmHandleRoot(mut self, handle: Int) -> Bool {
        if !(self.llvmHandles.containsKey(handle)) {
            return false
        }
        let entry = self.llvmHandles[handle]
        if entry.released || !(self.objects.containsKey(entry.objectId)) {
            return false
        }
        let mut next = entry
        next.rooted = true
        self.llvmHandles.insert(handle, next)
        self.ensureLlvmRuntimeRoot(entry.objectId)
        if self.phase == GcMarking {
            self.shade(entry.objectId)
        }
        true
    }

    pub fn releaseLlvmHandleRoot(mut self, handle: Int) -> Bool {
        if !(self.llvmHandles.containsKey(handle)) {
            return false
        }
        let entry = self.llvmHandles[handle]
        if entry.released || !(entry.rooted) {
            return false
        }
        let objectId = entry.objectId
        let mut next = entry
        next.rooted = false
        self.llvmHandles.insert(handle, next)
        self.refreshLlvmRuntimeRootForObject(objectId)
        true
    }

    pub fn bindLlvmRootRef(mut self, handle: Int, kind: GcLlvmRootRefKind, site: String) -> Int? {
        let objectId = intOptionalOr(self.llvmLiveObjectForHandle(handle), -1)
        if objectId < 0 {
            return None
        }
        let rootRefId = self.nextLlvmRootRef
        self.nextLlvmRootRef = self.nextLlvmRootRef + 1
        let pinned = kind == GcLlvmPinnedRoot
        self.llvmRootRefs.insert(
            rootRefId,
            GcLlvmRootRefEntry {
                rootRefId,
                handle,
                objectId,
                kind,
                pinned,
                alive: true,
                site: normalizeBridgeSite(site),
            },
        )
        if pinned {
            let _ = self.pin(objectId)
            self.setLlvmHandlePinned(handle, true)
        }
        self.ensureLlvmRuntimeRoot(objectId)
        if self.phase == GcMarking {
            self.shade(objectId)
        }
        self.recordLlvmRootRefBound()
        Some(rootRefId)
    }

    pub fn releaseLlvmRootRef(mut self, rootRefId: Int) -> Bool {
        if !(self.llvmRootRefs.containsKey(rootRefId)) {
            return false
        }
        let rootRef = self.llvmRootRefs[rootRefId]
        if !(rootRef.alive) {
            return false
        }
        let objectId = rootRef.objectId
        let handle = rootRef.handle
        let mut next = rootRef
        next.alive = false
        next.pinned = false
        self.llvmRootRefs.insert(rootRefId, next)
        self.refreshLlvmRuntimeRootForObject(objectId)
        self.setLlvmHandlePinned(handle, self.llvmHandleHasAlivePinnedRootRef(handle))
        self.refreshLlvmPinnedStateForObject(objectId)
        self.recordLlvmRootRefReleased()
        true
    }

    pub fn loadLlvmHandle(mut self, handle: Int) -> Int? {
        if !(self.llvmHandles.containsKey(handle)) {
            self.recordStaleLlvmHandleLoad()
            return None
        }
        let entry = self.llvmHandles[handle]
        if entry.released || !(self.objects.containsKey(entry.objectId)) {
            self.recordStaleLlvmHandleLoad()
            return None
        }
        let mut next = entry
        next.loads = next.loads + 1
        self.llvmHandles.insert(handle, next)
        self.recordLlvmHandleLoad()
        Some(entry.objectId)
    }

    pub fn lowerLlvmStore(
        mut self,
        ownerHandle: Int,
        slot: Int,
        name: String,
        newHandle: Int,
    ) -> GcLoweredStoreTrace? {
        let ownerObjectId = intOptionalOr(self.llvmLiveObjectForHandle(ownerHandle), -1)
        let newObjectId = intOptionalOr(self.llvmLiveObjectForHandle(newHandle), -1)
        if ownerObjectId < 0 || newObjectId < 0 {
            self.recordStaleLlvmHandleLoad()
            return None
        }
        let oldObjectId = intOptionalOr(self.loweredObjectFieldValue(ownerObjectId, slot), -1)
        match self.lowerStructFieldStore(ownerObjectId, slot, name, newObjectId) {
            Some(lowered) -> {
                self.recordLlvmHandleStore(ownerHandle)
                let oldHandle = self.llvmFirstLiveHandleForObject(oldObjectId)
                let trace = GcLoweredStoreTrace {
                    backend: GcLlvmBackend,
                    ownerHandle,
                    oldHandle,
                    newHandle,
                    ownerObjectId,
                    oldObjectId,
                    newObjectId,
                    slot,
                    name,
                    postWriteCalled: lowered.postWriteCalled,
                }
                self.lastLoweredStore = Some(trace)
                self.recordLoweredLlvmStore()
                return Some(trace)
            },
            None -> {},
        }
        None
    }

    pub fn llvmHandleSame(mut self, left: Int, right: Int) -> Bool {
        self.recordLlvmIdentityCheck()
        match self.llvmLiveObjectForHandle(left) {
            Some(leftObject) -> {
                match self.llvmLiveObjectForHandle(right) {
                    Some(rightObject) -> leftObject == rightObject,
                    None -> false,
                }
            },
            None -> false,
        }
    }

    pub fn llvmHandleObject(self, handle: Int) -> Int? {
        self.llvmLiveObjectForHandle(handle)
    }

    pub fn llvmRootRefObject(self, rootRefId: Int) -> Int? {
        if self.llvmRootRefs.containsKey(rootRefId) {
            let rootRef = self.llvmRootRefs[rootRefId]
            if rootRef.alive && self.objects.containsKey(rootRef.objectId) {
                return Some(rootRef.objectId)
            }
        }
        None
    }

    pub fn llvmHandleCount(self) -> Int {
        self.llvmHandles.len()
    }

    pub fn llvmLiveHandleCount(self) -> Int {
        let mut total = 0
        for (handle, entry) in self.llvmHandles {
            let _ = handle
            if !(entry.released) && self.objects.containsKey(entry.objectId) {
                total = total + 1
            }
        }
        total
    }

    pub fn llvmRootRefCount(self) -> Int {
        self.llvmRootRefs.len()
    }

    pub fn llvmLiveRootRefCount(self) -> Int {
        let mut total = 0
        for (rootRefId, rootRef) in self.llvmRootRefs {
            let _ = rootRefId
            if rootRef.alive && self.objects.containsKey(rootRef.objectId) {
                total = total + 1
            }
        }
        total
    }

    pub fn llvmRuntimeRootCount(self) -> Int {
        self.llvmRuntimeRoots.len()
    }

    pub fn llvmPinnedHandleCount(self) -> Int {
        let mut total = 0
        for (handle, entry) in self.llvmHandles {
            let _ = handle
            if !(entry.released) && entry.pinned && self.objects.containsKey(entry.objectId) {
                total = total + 1
            }
        }
        total
    }

    pub fn llvmBridgeSnapshot(self) -> GcLlvmBridgeSnapshot {
        GcLlvmBridgeSnapshot {
            backend: GcLlvmBackend,
            handleCount: self.llvmHandleCount(),
            liveHandleCount: self.llvmLiveHandleCount(),
            rootRefCount: self.llvmRootRefCount(),
            liveRootRefCount: self.llvmLiveRootRefCount(),
            runtimeRootCount: self.llvmRuntimeRootCount(),
            pinnedHandleCount: self.llvmPinnedHandleCount(),
            handlesCreated: self.llvmBridgeTrace.handlesCreated,
            handlesReleased: self.llvmBridgeTrace.handlesReleased,
            handleLoads: self.llvmBridgeTrace.handleLoads,
            handleStores: self.llvmBridgeTrace.handleStores,
            identityChecks: self.llvmBridgeTrace.identityChecks,
            staleHandleLoads: self.llvmBridgeTrace.staleHandleLoads,
            loweredAllocations: self.llvmBridgeTrace.loweredAllocations,
            loweredStores: self.llvmBridgeTrace.loweredStores,
        }
    }

    pub fn lastLoweredAllocationTrace(self) -> GcLoweredAllocationTrace? {
        self.lastLoweredAllocation
    }

    pub fn lastLoweredStoreTrace(self) -> GcLoweredStoreTrace? {
        self.lastLoweredStore
    }

    pub fn barrierAbi(self) -> GcBarrierAbi {
        let _ = self
        gcBarrierAbiV1()
    }

    pub fn gcPreWriteBarrier(mut self, slotKind: GcBarrierSlotKind, ownerId: Int, oldValue: Int) -> Bool {
        let _ = slotKind
        if !(self.objects.containsKey(ownerId)) {
            return false
        }
        if oldValue >= 0 && !(self.objects.containsKey(oldValue)) {
            return false
        }
        self.recordPreWriteBarrier()
        true
    }

    pub fn gcPostWriteBarrier(mut self, slotKind: GcBarrierSlotKind, ownerId: Int, newValue: Int) -> Bool {
        let _ = slotKind
        if !(self.objects.containsKey(ownerId)) {
            return false
        }
        if newValue >= 0 && !(self.objects.containsKey(newValue)) {
            return false
        }
        self.recordPostWriteBarrier()
        if newValue < 0 {
            return true
        }

        let owner = self.objects[ownerId]
        let child = self.objects[newValue]
        if owner.generation > child.generation {
            let mut next = owner
            next.remembered = true
            self.objects.insert(ownerId, next)
            self.remembered.insert(ownerId)
            self.dirtyCardForObject(ownerId, true)
            self.recordRememberedSetBarrier()
        }

        let current = self.objects[ownerId]
        if self.phase == GcMarking && current.color == GcBlack && child.color == GcWhite {
            self.shade(newValue)
            self.recordIncrementalBarrierShade()
        }
        true
    }

    pub fn gcLoadBarrier(mut self, value: Int) -> Int? {
        self.recordLoadBarrier()
        if value >= 0 && self.objects.containsKey(value) {
            Some(value)
        } else {
            None
        }
    }

    pub fn lowerStructFieldStore(
        mut self,
        ownerId: Int,
        slot: Int,
