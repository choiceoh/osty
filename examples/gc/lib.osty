    pub fn lowerRuntimeFrameSlotStore(
        mut self,
        frameObjectId: Int,
        slot: Int,
        name: String,
        newValue: Int,
    ) -> GcLoweredStoreEvent? {
        if !(self.objects.containsKey(frameObjectId)) {
            return None
        }
        if self.objects[frameObjectId].kind != GcRuntimeFrame {
            return None
        }
        self.lowerPointerSlotStore(
            GcRuntimeFrameSlotStore,
            GcBarrierRuntimeFrame,
            frameObjectId,
            slot,
            name,
            newValue,
        )
    }

    pub fn lowerAsyncFrameRootStore(
        mut self,
        taskId: Int,
        slot: Int,
        name: String,
        newValue: Int,
    ) -> GcLoweredStoreEvent? {
        if !(self.asyncFrames.containsKey(taskId)) {
            return None
        }
        let frame = self.asyncFrames[taskId]
        if frame.state != GcAsyncFrameSuspended {
            return None
        }
        if frame.frameObjectId < 0 || !(self.objects.containsKey(frame.frameObjectId)) {
            return None
        }
        if slot < 0 || name == "" {
            return None
        }
        if newValue < -1 {
            return None
        }
        if newValue >= 0 && !(self.objects.containsKey(newValue)) {
            return None
        }
        let key = loweredPointerSlotKey(GcAsyncFrameRootStore, frame.frameObjectId, slot)
        let oldValue = self.loweredPointerSlotStoredValue(key)
        let lowered = self.lowerPointerSlotStore(
            GcAsyncFrameRootStore,
            GcBarrierAsyncFrameRoot,
            frame.frameObjectId,
            slot,
            name,
            newValue,
        )
        self.syncAsyncFrameRootSnapshot(taskId, oldValue, newValue)
        lowered
    }

    pub fn addRoot(mut self, id: Int) -> Bool {
        if !(self.objects.containsKey(id)) {
            return false
        }
        self.roots.insert(id)
        if self.phase == GcMarking {
            self.shade(id)
        }
        true
    }

    pub fn removeRoot(mut self, id: Int) -> Bool {
        self.roots.remove(id)
    }

    pub fn installGlobalRoot(
        mut self,
        moduleName: String,
        name: String,
        kind: GcGlobalRootKind,
        id: Int,
    ) -> Bool {
        if !(self.objects.containsKey(id)) {
            return false
        }
        if moduleName == "" || name == "" {
            return false
        }
        let key = globalRootKey(moduleName, name)
        if self.globalRoots.containsKey(key) {
            return false
        }
        self.globalRoots.insert(
            key,
            GcGlobalRoot {
                moduleName,
                name,
                kind,
                state: GcGlobalReady,
                objectId: id,
            },
        )
        if self.phase == GcMarking {
            self.shade(id)
        }
        true
    }

    pub fn declareGlobalRoot(mut self, moduleName: String, name: String, kind: GcGlobalRootKind) -> Bool {
        if moduleName == "" || name == "" {
            return false
        }
        let key = globalRootKey(moduleName, name)
        if self.globalRoots.containsKey(key) {
            return false
        }
        self.globalRoots.insert(
            key,
            GcGlobalRoot {
                moduleName,
                name,
                kind,
                state: GcGlobalDeclared,
                objectId: -1,
            },
        )
        true
    }

    pub fn beginGlobalInit(mut self, moduleName: String, name: String, kind: GcGlobalRootKind) -> Bool {
        if moduleName == "" || name == "" {
            return false
        }
        let key = globalRootKey(moduleName, name)
        if self.globalRoots.containsKey(key) {
            let mut root = self.globalRoots[key]
            if root.state != GcGlobalDeclared {
                return false
            }
            root.state = GcGlobalInitializing
            root.objectId = -1
            self.globalRoots.insert(key, root)
            return true
        }
        self.globalRoots.insert(
            key,
            GcGlobalRoot {
                moduleName,
                name,
                kind,
                state: GcGlobalInitializing,
                objectId: -1,
            },
        )
        true
    }

    pub fn setGlobalRootObject(mut self, moduleName: String, name: String, id: Int) -> Bool {
        let key = globalRootKey(moduleName, name)
        if !(self.globalRoots.containsKey(key)) {
            return false
        }
        if !(self.objects.containsKey(id)) {
            return false
        }
        let mut root = self.globalRoots[key]
        if root.state == GcGlobalPoisoned {
            return false
        }
        root.objectId = id
        if root.state == GcGlobalDeclared {
            root.state = GcGlobalInitializing
        }
        self.globalRoots.insert(key, root)
        if self.phase == GcMarking {
            self.shade(id)
        }
        true
    }

    pub fn finishGlobalInit(mut self, moduleName: String, name: String) -> Bool {
        let key = globalRootKey(moduleName, name)
        if !(self.globalRoots.containsKey(key)) {
            return false
        }
        let mut root = self.globalRoots[key]
        if root.objectId < 0 || !(self.objects.containsKey(root.objectId)) {
            return false
        }
        root.state = GcGlobalReady
        self.globalRoots.insert(key, root)
        if self.phase == GcMarking {
            self.shade(root.objectId)
        }
        true
    }

    pub fn poisonGlobalRoot(mut self, moduleName: String, name: String) -> Bool {
        let key = globalRootKey(moduleName, name)
        if !(self.globalRoots.containsKey(key)) {
            return false
        }
        let mut root = self.globalRoots[key]
        root.state = GcGlobalPoisoned
        root.objectId = -1
        self.globalRoots.insert(key, root)
        true
    }

    pub fn removeGlobalRoot(mut self, moduleName: String, name: String) -> Bool {
        let key = globalRootKey(moduleName, name)
        if self.globalRoots.containsKey(key) {
            let _ = self.globalRoots.remove(key)
            true
        } else {
            false
        }
    }

    pub fn installClosureEnvironment(
        mut self,
        closureId: Int,
        functionName: String,
        captures: List<GcClosureCapture>,
    ) -> Bool {
        if !(self.objects.containsKey(closureId)) {
            return false
        }
        if self.objects[closureId].kind != GcClosure {
            return false
        }
        if functionName == "" {
            return false
        }
        if self.closureEnvironments.containsKey(closureId) {
            return false
        }
        match self.validateClosureCaptures(captures) {
            Ok(_) -> {},
            Err(_) -> {
                return false
            },
        }

        self.rewriteClosureCaptureRefs(closureId, captures)
        self.closureEnvironments.insert(
            closureId,
            GcClosureEnvironment {
                closureId,
                functionName,
                captures,
            },
        )
        true
    }

    pub fn updateClosureCapture(mut self, closureId: Int, slot: Int, objectId: Int) -> Bool {
        if !(self.closureEnvironments.containsKey(closureId)) {
            return false
        }
        if !(self.objects.containsKey(objectId)) {
            return false
        }

        let mut env = self.closureEnvironments[closureId]
        let mut captures: List<GcClosureCapture> = []
        let mut found = false
        for capture in env.captures {
            let mut next = capture
            if next.slot == slot {
                if next.kind == GcCaptureScalar {
                    return false
                }
                next.objectId = objectId
                found = true
            }
            captures.push(next)
        }
        if !(found) {
            return false
        }
        match self.validateClosureCaptures(captures) {
            Ok(_) -> {},
            Err(_) -> {
                return false
            },
        }

        env.captures = captures
        self.rewriteClosureCaptureRefs(closureId, captures)
        self.closureEnvironments.insert(closureId, env)
        true
    }

    pub fn removeClosureEnvironment(mut self, closureId: Int) -> Bool {
        if self.closureEnvironments.containsKey(closureId) {
            let _ = self.closureEnvironments.remove(closureId)
            if self.objects.containsKey(closureId) {
                let mut obj = self.objects[closureId]
                obj.refs = []
                obj.remembered = false
                self.objects.insert(closureId, obj)
                let _ = self.remembered.remove(closureId)
            }
            true
        } else {
            false
        }
    }

    pub fn suspendAsyncFrame(
        mut self,
        taskId: Int,
        functionName: String,
        safepointId: Int,
        frameObjectId: Int,
        roots: List<Int>,
    ) -> Bool {
        if taskId <= 0 || functionName == "" || safepointId <= 0 {
            return false
        }
        if !(self.objects.containsKey(frameObjectId)) {
            return false
        }
        if self.objects[frameObjectId].kind != GcRuntimeFrame {
            return false
        }
        match self.validateAsyncFrameRoots(roots) {
            Ok(_) -> {},
            Err(_) -> {
                return false
            },
        }
        if self.asyncFrames.containsKey(taskId) {
            let old = self.asyncFrames[taskId]
            if old.state == GcAsyncFrameCompleted || old.state == GcAsyncFrameCancelled {
                return false
            }
        }

        self.asyncFrames.insert(
            taskId,
            GcAsyncFrameRoot {
                taskId,
                functionName,
                safepointId,
                state: GcAsyncFrameSuspended,
                frameObjectId,
                roots,
            },
        )
        if self.phase == GcMarking {
            self.shade(frameObjectId)
            self.shadeObjectList(roots)
        }
        true
    }

    pub fn resumeAsyncFrame(mut self, taskId: Int) -> Bool {
        if !(self.asyncFrames.containsKey(taskId)) {
            return false
        }
        let mut frame = self.asyncFrames[taskId]
        if frame.state == GcAsyncFrameCompleted || frame.state == GcAsyncFrameCancelled {
            return false
        }
        frame.state = GcAsyncFrameRunning
        frame.frameObjectId = -1
        frame.roots = []
        self.asyncFrames.insert(taskId, frame)
        true
    }

    pub fn completeAsyncFrame(mut self, taskId: Int) -> Bool {
        if !(self.asyncFrames.containsKey(taskId)) {
            return false
        }
        let mut frame = self.asyncFrames[taskId]
        frame.state = GcAsyncFrameCompleted
        frame.frameObjectId = -1
        frame.roots = []
        self.asyncFrames.insert(taskId, frame)
        true
    }

    pub fn cancelAsyncFrame(mut self, taskId: Int) -> Bool {
        if !(self.asyncFrames.containsKey(taskId)) {
            return false
        }
        let mut frame = self.asyncFrames[taskId]
        frame.state = GcAsyncFrameCancelled
        frame.frameObjectId = -1
        frame.roots = []
        self.asyncFrames.insert(taskId, frame)
        true
    }

    pub fn removeAsyncFrame(mut self, taskId: Int) -> Bool {
        if self.asyncFrames.containsKey(taskId) {
            let _ = self.asyncFrames.remove(taskId)
            true
        } else {
            false
        }
    }

    pub fn pin(mut self, id: Int) -> Bool {
        if !(self.objects.containsKey(id)) {
            return false
        }
        let mut next = self.objects[id]
        next.pinned = true
        next.region = regionForObject(next)
        self.objects.insert(id, next)
        true
    }

    pub fn unpin(mut self, id: Int) -> Bool {
        if !(self.objects.containsKey(id)) {
            return false
        }
        let mut next = self.objects[id]
        next.pinned = false
        next.region = regionForObject(next)
        self.objects.insert(id, next)
        true
    }

    pub fn link(mut self, from: Int, to: Int) -> Bool {
        if !(self.objects.containsKey(from)) {
            return false
        }
        if !(self.objects.containsKey(to)) {
            return false
        }

        let mut next = self.objects[from]
        if !(next.refs.contains(to)) {
            next.refs.push(to)
        }
        self.objects.insert(from, next)
        let _ = self.gcPostWriteBarrier(GcBarrierObjectField, from, to)
        true
    }

    pub fn unlink(mut self, from: Int, to: Int) -> Bool {
        if !(self.objects.containsKey(from)) {
            return false
        }
        let mut next = self.objects[from]
        if next.refs.contains(to) {
            let _ = self.gcPreWriteBarrier(GcBarrierObjectField, from, to)
        }
        let before = next.refs.len()
        next.refs = intListWithout(next.refs, to)
        self.objects.insert(from, next)
        if before != next.refs.len() {
            self.rebuildRemembered()
            true
        } else {
            false
        }
    }

    pub fn minorCollect(mut self) -> GcStats {
        self.minorCollectFor("manual")
    }

    pub fn majorCollect(mut self) -> GcStats {
        self.majorCollectFor("manual")
    }

    pub fn startIncrementalMajor(mut self) {
        self.cycle = self.cycle + 1
        self.phase = GcMarking
        self.retireAllTlabs()
        self.clearAllMarks()
        for id in self.roots.toList() {
            self.shade(id)
        }
        self.shadeGlobalRoots()
        self.shadeAsyncFrameRoots()
        self.shadeLlvmRuntimeRoots()
    }

    pub fn stepIncremental(mut self) -> GcStats {
        self.stepIncrementalWithBudget("incremental-budget", self.config.incrementalBudget)
    }

    fn stepIncrementalWithBudget(mut self, trigger: String, budget: Int) -> GcStats {
        if self.phase == GcIdle {
            self.startIncrementalMajor()
        }

        let beforeObjects = self.objectCount()
        let beforeBytes = self.liveBytes
        let beforeFragmentedBytes = self.fragmentedBytes()
        let allocationBytesSinceLastGC = self.allocatedSinceLastGC

        if self.phase == GcMarking {
            let markSteps = self.drainGrey(budget, false)
            if self.grey.len() > 0 {
                let stats = GcStats {
                    kind: "incremental-mark",
                    trigger,
                    cycle: self.cycle,
                    beforeObjects,
                    afterObjects: self.objectCount(),
                    reclaimedObjects: 0,
                    beforeBytes,
                    afterBytes: self.liveBytes,
                    reclaimedBytes: 0,
                    promotedObjects: 0,
                    compactedObjects: 0,
                    rememberedScanned: 0,
                    markSteps,
                    pauseUnits: telemetryPauseUnits(markSteps, 0, 0, 0, 0),
                    allocationBytesSinceLastGC,
                    beforeFragmentedBytes,
                    afterFragmentedBytes: self.fragmentedBytes(),
                    fragmentedBytes: self.fragmentedBytes(),
                    survivalPercent: percent(self.objectCount(), beforeObjects),
                    promotionPercent: 0,
                }
                self.lastStats = Some(stats)
                return stats
            }

            self.phase = GcSweeping
            let (reclaimedObjects, reclaimedBytes) = self.sweepAll()
            let compactedObjects = self.compactLive()
            self.rebuildRemembered()
            self.majorCollections = self.majorCollections + 1
            self.recordSchedulerCycleComplete()
            self.phase = GcIdle
            self.allocatedSinceLastGC = 0
            self.clearSchedulerDebtIfIdle()

            let stats = GcStats {
                kind: "incremental-sweep",
                trigger,
                cycle: self.cycle,
                beforeObjects,
                afterObjects: self.objectCount(),
                reclaimedObjects,
                beforeBytes,
                afterBytes: self.liveBytes,
                reclaimedBytes,
                promotedObjects: 0,
                compactedObjects,
                rememberedScanned: 0,
                markSteps,
                pauseUnits: telemetryPauseUnits(markSteps, reclaimedObjects, 0, compactedObjects, 0),
                allocationBytesSinceLastGC,
                beforeFragmentedBytes,
                afterFragmentedBytes: self.fragmentedBytes(),
                fragmentedBytes: self.fragmentedBytes(),
                survivalPercent: percent(self.objectCount(), beforeObjects),
                promotionPercent: 0,
            }
            self.lastStats = Some(stats)
            return stats
        }

        self.majorCollectFor("manual")
    }

    pub fn finishIncremental(mut self) -> GcStats {
        let mut last = emptyStats("incremental-idle", self)
        for self.phase != GcIdle {
            last = self.stepIncremental()
        }
        last
    }

    pub fn schedulerSafepoint(mut self, reason: String) -> GcStats {
        self.recordSchedulerSafepoint()
        if self.phase == GcIdle && self.shouldStartIncrementalAtSafepoint() {
            self.startIncrementalMajor()
            self.recordSchedulerCycleStart()
        }
        if self.phase == GcMarking {
            self.recordSchedulerStep(self.config.incrementalBudget, false)
            return self.stepIncrementalWithBudget(
                "scheduler.{reason}",
                self.config.incrementalBudget,
            )
        }
        emptyStats("scheduler-idle", self)
    }

    pub fn mutatorAssist(mut self, allocationBytes: Int) -> GcStats {
        if allocationBytes > 0 {
            self.addSchedulerAllocationDebt(allocationBytes)
        }
        if self.phase == GcIdle && self.shouldStartMutatorAssistCycle() {
            self.startIncrementalMajor()
            self.recordSchedulerCycleStart()
        }
        if self.phase == GcMarking {
            self.recordSchedulerStep(self.config.incrementalBudget, true)
            let stats = self.stepIncrementalWithBudget(
                "mutator-assist",
                self.config.incrementalBudget,
            )
            self.clearSchedulerDebtIfIdle()
            return stats
        }
        emptyStats("mutator-assist-idle", self)
    }

    pub fn startMostlyConcurrentMark(mut self) -> Bool {
        if self.phase != GcIdle {
            return false
        }
        let mut trace = emptyConcurrentMarkTrace()
        trace.active = true
        trace.snapshotRoots = self.rootCount() + self.globalObjectRootCount() + self.asyncFrameRootCount() + self.llvmRuntimeRootCount()
        trace.mutatorEpoch = self.concurrentTrace.mutatorEpoch + 1
        trace.barrierShadesAtStart = self.barriers.incrementalShades
        self.concurrentTrace = trace
        self.startIncrementalMajor()
        true
    }

    pub fn stepMostlyConcurrentMark(mut self) -> GcStats {
        if self.phase == GcIdle {
            if !(self.startMostlyConcurrentMark()) {
                return emptyStats("concurrent-idle", self)
            }
        }
        if !(self.concurrentTrace.active) {
            return emptyStats("concurrent-idle", self)
        }

        let beforeObjects = self.objectCount()
        let beforeBytes = self.liveBytes
        let beforeFragmentedBytes = self.fragmentedBytes()
        let allocationBytesSinceLastGC = self.allocatedSinceLastGC

        if self.phase == GcMarking {
            let markSteps = self.drainGrey(self.config.concurrentMarkBudget, false)
            self.recordConcurrentMarkSlice(markSteps)
            let mut kind = "concurrent-ready"
            if self.grey.len() > 0 {
                kind = "concurrent-mark"
            }
            let stats = GcStats {
                kind,
                trigger: "concurrent-budget",
                cycle: self.cycle,
                beforeObjects,
                afterObjects: self.objectCount(),
                reclaimedObjects: 0,
                beforeBytes,
                afterBytes: self.liveBytes,
                reclaimedBytes: 0,
                promotedObjects: 0,
                compactedObjects: 0,
                rememberedScanned: 0,
                markSteps,
                pauseUnits: telemetryPauseUnits(markSteps, 0, 0, 0, 0),
                allocationBytesSinceLastGC,
                beforeFragmentedBytes,
                afterFragmentedBytes: self.fragmentedBytes(),
                fragmentedBytes: self.fragmentedBytes(),
                survivalPercent: percent(self.objectCount(), beforeObjects),
                promotionPercent: 0,
            }
            self.lastStats = Some(stats)
            return stats
        }

        emptyStats("concurrent-idle", self)
    }

    pub fn finishMostlyConcurrentMark(mut self) -> GcStats {
        if self.phase == GcIdle {
            return emptyStats("concurrent-idle", self)
        }
        if !(self.concurrentTrace.active) {
            return emptyStats("concurrent-idle", self)
        }

        let beforeObjects = self.objectCount()
        let beforeBytes = self.liveBytes
        let beforeFragmentedBytes = self.fragmentedBytes()
        let allocationBytesSinceLastGC = self.allocatedSinceLastGC
        let remarkRoots = self.rootCount() + self.globalObjectRootCount() + self.asyncFrameRootCount() + self.llvmRuntimeRootCount()

        if self.phase == GcMarking {
            for id in self.roots.toList() {
                self.shade(id)
            }
            self.shadeGlobalRoots()
            self.shadeAsyncFrameRoots()
            self.shadeLlvmRuntimeRoots()
        }
        let finalRemarkSteps = self.drainGrey(0, false)

        self.phase = GcSweeping
        let (reclaimedObjects, reclaimedBytes) = self.sweepAll()
        let compactedObjects = self.compactLive()
        self.rebuildRemembered()
        self.majorCollections = self.majorCollections + 1
        self.phase = GcIdle
        self.allocatedSinceLastGC = 0
        self.finishConcurrentTrace(remarkRoots, finalRemarkSteps)

        let stats = GcStats {
            kind: "concurrent-sweep",
            trigger: "concurrent-final-remark",
            cycle: self.cycle,
            beforeObjects,
            afterObjects: self.objectCount(),
            reclaimedObjects,
            beforeBytes,
            afterBytes: self.liveBytes,
            reclaimedBytes,
            promotedObjects: 0,
            compactedObjects,
            rememberedScanned: 0,
            markSteps: finalRemarkSteps,
            pauseUnits: telemetryPauseUnits(
                finalRemarkSteps,
                reclaimedObjects,
                0,
                compactedObjects,
                0,
            ),
            allocationBytesSinceLastGC,
            beforeFragmentedBytes,
            afterFragmentedBytes: self.fragmentedBytes(),
            fragmentedBytes: self.fragmentedBytes(),
            survivalPercent: percent(self.objectCount(), beforeObjects),
            promotionPercent: 0,
        }
        self.lastStats = Some(stats)
        stats
    }

    pub fn lastCollectionStats(self) -> GcStats? {
        self.lastStats
    }

    pub fn diagnosticsSnapshot(self) -> GcDiagnosticsSnapshot {
        let mut lastKind = ""
        let mut lastTrigger = ""
        let mut lastPauseUnits = 0
        let mut lastReclaimedObjects = 0
        match self.lastStats {
            Some(stats) -> {
                lastKind = stats.kind
                lastTrigger = stats.trigger
                lastPauseUnits = stats.pauseUnits
                lastReclaimedObjects = stats.reclaimedObjects
            },
            None -> {},
        }

        let mut heapValid = true
        let mut validationMessage = "ok"
        match self.validateHeap() {
            Ok(_) -> {},
            Err(e) -> {
                heapValid = false
                validationMessage = e
            },
        }

        GcDiagnosticsSnapshot {
            cycle: self.cycle,
            phase: self.phase,
            objectCount: self.objectCount(),
            rootCount: self.rootCount(),
            globalRootCount: self.globalRootCount(),
            asyncFrameRootCount: self.asyncFrameRootCount(),
            liveBytes: self.liveBytes,
            fragmentedBytes: self.fragmentedBytes(),
            nurseryBytes: self.nurseryBytes(),
            oldBytes: self.oldBytes(),
            humongousBytes: self.humongousBytes(),
            rememberedObjects: self.rememberedCount(),
            dirtyCards: self.dirtyCardCount(),
            forwardingEntries: self.forwardingEntryCount(),
            loweredPointerSlots: self.loweredPointerSlotCount(),
            minorCollections: self.minorCollections,
            majorCollections: self.majorCollections,
            barrierPostWriteCalls: self.barriers.postWriteCalls,
            barrierRememberedSetWrites: self.barriers.rememberedSetWrites,
            barrierIncrementalShades: self.barriers.incrementalShades,
            schedulerSafepoints: self.schedulerTrace.safepoints,
            schedulerAssistSteps: self.schedulerTrace.mutatorAssistSteps,
            concurrentMarkSlices: self.concurrentTrace.slices,
            lastKind,
            lastTrigger,
            lastPauseUnits,
            lastReclaimedObjects,
            heapValid,
            validationMessage,
        }
    }

    pub fn diagnosticsLine(self) -> String {
        let snapshot = self.diagnosticsSnapshot()
        "gc cycle={snapshot.cycle} phase={tracePhaseName(snapshot.phase)} objects={snapshot.objectCount} live={snapshot.liveBytes} fragmented={snapshot.fragmentedBytes} last={snapshot.lastKind}/{snapshot.lastTrigger} valid={snapshot.heapValid}"
    }

    pub fn heapDump(self) -> GcHeapDump {
        let mut objects: List<GcHeapDumpObject> = []
        let mut edges: List<GcHeapDumpEdge> = []
        let roots = self.roots.toList()

        for id in self.objects.keys().sorted() {
            let obj = self.objects[id]
            objects.push(
                GcHeapDumpObject {
                    id,
                    kind: obj.kind,
                    size: obj.size,
                    address: obj.address,
                    generation: obj.generation,
                    age: obj.age,
                    color: obj.color,
                    region: obj.region,
                    refCount: intListLen(obj.refs),
                    rooted: self.roots.contains(id),
                    remembered: obj.remembered,
                    pinned: obj.pinned,
                    large: obj.large,
                },
            )
            for childId in obj.refs {
                edges.push(GcHeapDumpEdge { fromId: id, toId: childId })
            }
        }

        GcHeapDump {
            cycle: self.cycle,
            phase: self.phase,
            objectCount: objects.len(),
            edgeCount: edges.len(),
            rootCount: intListLen(roots),
            liveBytes: self.liveBytes,
            fragmentedBytes: self.fragmentedBytes(),
            roots,
            objects,
            edges,
        }
    }

    pub fn heapObjectDebugLine(self, id: Int) -> String? {
        if !(self.objects.containsKey(id)) {
            return None
        }
        let obj = self.objects[id]
        let kind = objectKindName(obj.kind)
        let region = gcRegionKindName(obj.region)
        let refs = intListDebug(obj.refs)
        let rooted = self.roots.contains(id)
        Some(
            "object id={id} kind={kind} region={region} gen={obj.generation} size={obj.size} addr={obj.address} refs=[{refs}] root={rooted} pinned={obj.pinned}",
        )
    }

    pub fn objectGraphDebug(self) -> String {
        let phase = tracePhaseName(self.phase)
        let objects = self.objectCount()
        let edges = self.edgeCount()
        let roots = intListDebug(self.roots.toList())
        let mut out = "gc graph cycle={self.cycle} phase={phase} objects={objects} edges={edges} roots=[{roots}]"
        for id in self.objects.keys().sorted() {
            match self.heapObjectDebugLine(id) {
                Some(line) -> {
                    out = "{out}\n\\\{line\}"
                },
                None -> {},
            }
        }
        out
    }

    pub fn runStressMode(mut self, mode: GcStressMode) -> GcStats {
        if self.phase != GcIdle && mode != GcStressIncrementalStep {
            return emptyStats("stress-busy", self)
        }
        match mode {
            GcStressOff -> emptyStats("stress-off", self),
            GcStressEveryAllocationMinor -> self.minorCollectFor("stress.every-allocation-minor"),
            GcStressFrequentFull -> self.majorCollectFor("stress.frequent-full"),
            GcStressIncrementalStep -> self.stepIncrementalWithBudget(
                "stress.incremental-step",
                self.config.incrementalBudget,
            ),
            GcStressNoCompaction -> self.majorCollectWithoutCompactionFor("stress.no-compaction"),
            GcStressAlwaysCompact -> self.majorCollectFor("stress.always-compact"),
        }
    }

    pub fn runtimeContract(self) -> GcRuntimeContract {
        let _ = self
        gcRuntimeContractV1()
    }

    pub fn barrierAudit(self) -> GcBarrierAudit {
        let mut invalidObjectReferences = 0
        let mut missingOwnerRefs = 0
        let mut rememberedMismatches = 0

        for (key, slot) in self.loweredPointerSlots {
            let _ = key
            if !(self.objects.containsKey(slot.ownerId)) {
                invalidObjectReferences = invalidObjectReferences + 1
            } else if slot.objectId >= 0 {
                if !(self.objects.containsKey(slot.objectId)) {
                    invalidObjectReferences = invalidObjectReferences + 1
                } else {
                    let owner = self.objects[slot.ownerId]
                    if !(owner.refs.contains(slot.objectId)) {
                        missingOwnerRefs = missingOwnerRefs + 1
                    }
                }
            }
        }

        for (id, obj) in self.objects {
            let expectedRemembered = obj.generation > 0 && self.hasYoungRef(obj)
            if obj.remembered != expectedRemembered {
                rememberedMismatches = rememberedMismatches + 1
            }
            if expectedRemembered != self.remembered.contains(id) {
                rememberedMismatches = rememberedMismatches + 1
            }
        }

        GcBarrierAudit {
            loweredSlots: self.loweredPointerSlotCount(),
            invalidObjectReferences,
            missingOwnerRefs,
            rememberedMismatches,
            passed: invalidObjectReferences == 0 && missingOwnerRefs == 0 && rememberedMismatches == 0,
        }
    }

    pub fn performanceReport(self, thresholds: GcPerformanceThresholds) -> GcPerformanceReport {
        let mut pauseUnits = 0
        match self.lastStats {
            Some(stats) -> {
                pauseUnits = stats.pauseUnits
            },
            None -> {},
        }
        let fragmentedBytes = self.fragmentedBytes()
        let liveBytes = self.liveBytes
        let rememberedObjects = self.rememberedCount()
        let dirtyCards = self.dirtyCardCount()
        let passed = limitAllows(pauseUnits, thresholds.maxPauseUnits) && limitAllows(
            fragmentedBytes,
            thresholds.maxFragmentedBytes,
        ) && limitAllows(liveBytes, thresholds.maxLiveBytes) && limitAllows(
            rememberedObjects,
            thresholds.maxRememberedObjects,
        ) && limitAllows(dirtyCards, thresholds.maxDirtyCards)

        GcPerformanceReport {
            pauseUnits,
            fragmentedBytes,
            liveBytes,
            rememberedObjects,
            dirtyCards,
            passed,
        }
    }

    pub fn hardeningReport(self, thresholds: GcPerformanceThresholds) -> GcHardeningReport {
        let snapshot = self.diagnosticsSnapshot()
        let audit = self.barrierAudit()
        let performance = self.performanceReport(thresholds)
        let contract = self.runtimeContract()
        let passed = snapshot.heapValid && audit.passed && performance.passed

        GcHardeningReport {
            runtimeContractVersion: contract.version,
            heapValid: snapshot.heapValid,
            barrierAuditPassed: audit.passed,
            performancePassed: performance.passed,
            ffiPinnedObjects: self.pinnedObjectCount(),
            loweredSlots: audit.loweredSlots,
            validationMessage: snapshot.validationMessage,
            passed,
        }
    }

    fn minorCollectFor(mut self, trigger: String) -> GcStats {
        self.cycle = self.cycle + 1
        self.retireAllTlabs()
        let beforeObjects = self.objectCount()
        let beforeBytes = self.liveBytes
        let beforeFragmentedBytes = self.fragmentedBytes()
        let rootObjectsScanned = self.roots.len() + self.llvmRuntimeRootCount()
        let globalRootsScanned = self.globalObjectRootCount()
        let asyncFrameRootsScanned = self.asyncFrameRootCount()
        let dirtyCardsScanned = self.cardTable.dirtyCards.len()
        let rememberedScanned = self.rememberedObjectsOnDirtyCards()
        let allocationBytesSinceLastGC = self.allocatedSinceLastGC

        self.clearYoungMarks()
        self.markYoungRoots()
        let markSteps = self.drainGrey(0, true)
        let (reclaimedObjects, reclaimedBytes, promotedObjects, survivorCopiedObjects) = self.sweepYoung()
        self.recordCardScan(dirtyCardsScanned)
        self.clearScannedDirtyCards(dirtyCardsScanned)
        self.rebuildRemembered()
        self.minorCollections = self.minorCollections + 1
        self.allocatedSinceLastGC = 0
        self.lastMinorTrace = GcMinorCollectionTrace {
            rootObjectsScanned,
            globalRootsScanned,
            asyncFrameRootsScanned,
            rememberedObjectsScanned: rememberedScanned,
            dirtyCardsScanned,
            youngMarked: markSteps,
            survivorCopiedObjects,
            promotedObjects,
            edenReset: true,
            survivorSwap: true,
        }

        let stats = GcStats {
            kind: "minor",
            trigger,
            cycle: self.cycle,
            beforeObjects,
            afterObjects: self.objectCount(),
            reclaimedObjects,
            beforeBytes,
            afterBytes: self.liveBytes,
            reclaimedBytes,
            promotedObjects,
            compactedObjects: 0,
            rememberedScanned,
            markSteps,
            pauseUnits: telemetryPauseUnits(
                markSteps,
                reclaimedObjects,
                promotedObjects,
                0,
                rememberedScanned,
            ),
            allocationBytesSinceLastGC,
            beforeFragmentedBytes,
            afterFragmentedBytes: self.fragmentedBytes(),
            fragmentedBytes: self.fragmentedBytes(),
            survivalPercent: percent(self.objectCount(), beforeObjects),
            promotionPercent: percent(promotedObjects, beforeObjects),
        }
        self.lastStats = Some(stats)
        stats
    }

    fn majorCollectFor(mut self, trigger: String) -> GcStats {
        self.cycle = self.cycle + 1
        self.retireAllTlabs()
        let beforeObjects = self.objectCount()
        let beforeBytes = self.liveBytes
        let beforeFragmentedBytes = self.fragmentedBytes()
        let allocationBytesSinceLastGC = self.allocatedSinceLastGC

        self.phase = GcMarking
        self.clearAllMarks()
        let rootObjectsSeeded = self.roots.len() + self.llvmRuntimeRootCount()
        let globalRootsSeeded = self.globalObjectRootCount()
        let asyncFrameRootsSeeded = self.asyncFrameRootCount()
        for id in self.roots.toList() {
            self.shade(id)
        }
        self.shadeGlobalRoots()
        self.shadeAsyncFrameRoots()
        self.shadeLlvmRuntimeRoots()
        let queueSeeded = self.grey.len()
        let markSteps = self.drainGrey(0, false)
        let pointerSlotsScanned = self.markedPointerSlotCount()

        self.phase = GcSweeping
        let (reclaimedObjects, reclaimedBytes) = self.sweepAll()
        let compactedObjects = self.compactLive()
        self.rebuildRemembered()
        self.majorCollections = self.majorCollections + 1
        self.phase = GcIdle
        self.allocatedSinceLastGC = 0
        self.lastFullMarkTrace = GcFullMarkTrace {
            rootObjectsSeeded,
            globalRootsSeeded,
            asyncFrameRootsSeeded,
            queueSeeded,
            objectsScanned: markSteps,
            pointerSlotsScanned,
            regionObjectsVisited: beforeObjects,
            sweptObjects: reclaimedObjects,
        }

        let stats = GcStats {
            kind: "major",
            trigger,
            cycle: self.cycle,
            beforeObjects,
            afterObjects: self.objectCount(),
            reclaimedObjects,
            beforeBytes,
            afterBytes: self.liveBytes,
            reclaimedBytes,
            promotedObjects: 0,
            compactedObjects,
            rememberedScanned: 0,
            markSteps,
            pauseUnits: telemetryPauseUnits(markSteps, reclaimedObjects, 0, compactedObjects, 0),
            allocationBytesSinceLastGC,
            beforeFragmentedBytes,
            afterFragmentedBytes: self.fragmentedBytes(),
            fragmentedBytes: self.fragmentedBytes(),
            survivalPercent: percent(self.objectCount(), beforeObjects),
            promotionPercent: 0,
        }
        self.lastStats = Some(stats)
        stats
    }

    fn majorCollectWithoutCompactionFor(mut self, trigger: String) -> GcStats {
        self.cycle = self.cycle + 1
        self.retireAllTlabs()
        let beforeObjects = self.objectCount()
        let beforeBytes = self.liveBytes
        let beforeFragmentedBytes = self.fragmentedBytes()
        let allocationBytesSinceLastGC = self.allocatedSinceLastGC

        self.phase = GcMarking
        self.clearAllMarks()
        let rootObjectsSeeded = self.roots.len() + self.llvmRuntimeRootCount()
        let globalRootsSeeded = self.globalObjectRootCount()
        let asyncFrameRootsSeeded = self.asyncFrameRootCount()
        for id in self.roots.toList() {
            self.shade(id)
        }
        self.shadeGlobalRoots()
        self.shadeAsyncFrameRoots()
        self.shadeLlvmRuntimeRoots()
        let queueSeeded = self.grey.len()
        let markSteps = self.drainGrey(0, false)
        let pointerSlotsScanned = self.markedPointerSlotCount()

        self.phase = GcSweeping
        let (reclaimedObjects, reclaimedBytes) = self.sweepAll()
        self.forwarding.clear()
        self.rebuildRemembered()
        self.majorCollections = self.majorCollections + 1
        self.phase = GcIdle
        self.allocatedSinceLastGC = 0
        self.lastFullMarkTrace = GcFullMarkTrace {
            rootObjectsSeeded,
            globalRootsSeeded,
            asyncFrameRootsSeeded,
            queueSeeded,
            objectsScanned: markSteps,
            pointerSlotsScanned,
            regionObjectsVisited: beforeObjects,
            sweptObjects: reclaimedObjects,
        }
        self.lastEvacuationTrace = emptyEvacuationTrace()
        self.lastRemapTrace = emptyRemapTrace()

        let stats = GcStats {
            kind: "major-no-compact",
            trigger,
            cycle: self.cycle,
            beforeObjects,
            afterObjects: self.objectCount(),
            reclaimedObjects,
            beforeBytes,
            afterBytes: self.liveBytes,
            reclaimedBytes,
            promotedObjects: 0,
            compactedObjects: 0,
            rememberedScanned: 0,
            markSteps,
            pauseUnits: telemetryPauseUnits(markSteps, reclaimedObjects, 0, 0, 0),
            allocationBytesSinceLastGC,
            beforeFragmentedBytes,
            afterFragmentedBytes: self.fragmentedBytes(),
            fragmentedBytes: self.fragmentedBytes(),
            survivalPercent: percent(self.objectCount(), beforeObjects),
            promotionPercent: 0,
        }
        self.lastStats = Some(stats)
        stats
    }

    pub fn contains(self, id: Int) -> Bool {
        self.objects.containsKey(id)
    }

    pub fn objectCount(self) -> Int {
        self.objects.len()
    }

    pub fn rootCount(self) -> Int {
        self.roots.len()
    }

    pub fn edgeCount(self) -> Int {
        let mut total = 0
        for (id, obj) in self.objects {
            let _ = id
            total = total + intListLen(obj.refs)
        }
        total
    }

    pub fn globalRootCount(self) -> Int {
        self.globalRoots.len()
    }

    pub fn globalObjectRootCount(self) -> Int {
        let mut total = 0
        for (key, root) in self.globalRoots {
            let _ = key
            if root.objectId >= 0 {
                total = total + 1
            }
        }
        total
    }

    pub fn closureEnvironmentCount(self) -> Int {
        self.closureEnvironments.len()
    }

    pub fn closurePointerCaptureCount(self) -> Int {
        let mut total = 0
        for (closureId, env) in self.closureEnvironments {
            let _ = closureId
            for capture in env.captures {
                if capture.objectId >= 0 {
                    total = total + 1
                }
            }
        }
        total
    }

    pub fn asyncFrameCount(self) -> Int {
        self.asyncFrames.len()
    }

    pub fn suspendedAsyncFrameCount(self) -> Int {
        let mut total = 0
        for (taskId, frame) in self.asyncFrames {
            let _ = taskId
            if frame.state == GcAsyncFrameSuspended {
                total = total + 1
            }
        }
        total
    }

    pub fn asyncFrameRootCount(self) -> Int {
        let mut total = 0
        for (taskId, frame) in self.asyncFrames {
            let _ = taskId
            if frame.state == GcAsyncFrameSuspended {
                total = total + intListLen(frame.roots)
                if frame.frameObjectId >= 0 {
                    total = total + 1
                }
            }
        }
        total
    }

    pub fn tlabCount(self) -> Int {
        self.tlabs.len()
    }

    pub fn tlabRemaining(self, ownerId: Int) -> Int? {
        if self.tlabs.containsKey(ownerId) {
            Some(tlabRemainingBytes(self.tlabs[ownerId]))
        } else {
            None
        }
    }

    pub fn tlabRefillCount(self) -> Int {
        let mut total = 0
        for (ownerId, tlab) in self.tlabs {
            let _ = ownerId
            total = total + tlab.refills
        }
        total
    }

    pub fn tlabFastAllocationCount(self) -> Int {
        let mut total = 0
        for (ownerId, tlab) in self.tlabs {
            let _ = ownerId
            total = total + tlab.fastAllocations
        }
        total
    }

    pub fn tlabSlowAllocationCount(self) -> Int {
        let mut total = 0
        for (ownerId, tlab) in self.tlabs {
            let _ = ownerId
            total = total + tlab.slowAllocations
        }
        total
    }

    pub fn tlabWasteBytes(self) -> Int {
        let mut total = 0
        for (ownerId, tlab) in self.tlabs {
            let _ = ownerId
            total = total + tlab.wasteBytes
        }
        total
    }

    pub fn tenuredFreeBlockCount(self) -> Int {
        self.tenured.freeList.len()
    }

