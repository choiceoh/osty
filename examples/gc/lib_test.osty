use std.testing

fn assertValid(heap: GcHeap) {
    match heap.validateHeap() {
        Ok(_) -> {},
        Err(e) -> testing.fail(e),
    }
}

fn emptyTestStackMap() -> GcStackMap {
    let frameLayout: List<GcFrameSlot> = []
    let entries: List<GcStackMapEntry> = []
    GcStackMap {
        functionName: "",
        frameSlots: 0,
        pointerSize: 0,
        inlineSlots: 0,
        frameLayout,
        entries,
    }
}

fn emptyTestStackMapEntry() -> GcStackMapEntry {
    let bitmapWords: List<Int> = []
    let overflowSlots: List<Int> = []
    let derivedRoots: List<GcDerivedRootMap> = []
    GcStackMapEntry {
        safepointId: 0,
        instructionOffset: 0,
        liveCount: 0,
        inlineSlots: 0,
        bitmapWords,
        overflowSlots,
        derivedRoots,
    }
}

fn testIntListLen(values: List<Int>) -> Int {
    let mut total = 0
    for value in values {
        let _ = value
        total = total + 1
    }
    total
}

fn testDerivedRootListLen(values: List<GcDerivedRootMap>) -> Int {
    let mut total = 0
    for value in values {
        let _ = value
        total = total + 1
    }
    total
}

fn testBoolMapContains(values: Map<Int, Bool>, key: Int) -> Bool {
    for (candidate, present) in values {
        if present && candidate == key {
            return true
        }
    }
    false
}

fn intOr(value: Int?, fallback: Int) -> Int {
    match value {
        Some(next) -> next,
        None -> fallback,
    }
}

fn regionOr(value: GcRegionKind?, fallback: GcRegionKind) -> GcRegionKind {
    match value {
        Some(next) -> next,
        None -> fallback,
    }
}

fn globalStateOr(value: GcGlobalInitState?, fallback: GcGlobalInitState) -> GcGlobalInitState {
    match value {
        Some(next) -> next,
        None -> fallback,
    }
}

fn survivorSpaceGcConfig(survivorLimit: Int, promotionAge: Int) -> GcConfig {
    GcConfig {
        nurseryLimit: 512,
        survivorLimit,
        heapLimit: 4096,
        promotionAge,
        incrementalBudget: 1,
        largeObjectThreshold: 512,
        tlabSize: 64,
        cardSize: 64,
        schedulerSafepointInterval: 2,
        mutatorAssistBytes: 32,
        concurrentMarkBudget: 1,
        evacuationThresholdPercent: 50,
    }
}

fn humongousSpaceGcConfig() -> GcConfig {
    GcConfig {
        nurseryLimit: 64,
        survivorLimit: 16,
        heapLimit: 4096,
        promotionAge: 2,
        incrementalBudget: 1,
        largeObjectThreshold: 32,
        tlabSize: 64,
        cardSize: 64,
        schedulerSafepointInterval: 2,
        mutatorAssistBytes: 32,
        concurrentMarkBudget: 1,
        evacuationThresholdPercent: 50,
    }
}

fn testValidateHeapRejectsLiveByteMismatch() {
    let refs: List<Int> = []
    let mut objects: Map<Int, GcObject> = {:}
    objects.insert(
        1,
        GcObject {
            id: 1,
            kind: GcRecord,
            size: 16,
            address: 0,
            generation: 0,
            age: 0,
            color: GcWhite,
            marked: false,
            pinned: false,
            large: false,
            region: GcEdenRegion,
            refs,
            remembered: false,
            allocatedCycle: 0,
        },
    )
    let empty: List<Int> = []
    let globalRoots: Map<String, GcGlobalRoot> = {:}
    let closureEnvironments: Map<Int, GcClosureEnvironment> = {:}
    let asyncFrames: Map<Int, GcAsyncFrameRoot> = {:}
    let tlabs: Map<Int, GcTlab> = {:}
    let tenured = emptyTenuredAllocator()
    let humongous = emptyHumongousAllocator()
    let barriers = emptyBarrierCounters()
    let loweredPointerSlots: Map<String, GcLoweredPointerSlot> = {:}
    let heap = GcHeap {
        config: testGcConfig(),
        nextId: 2,
        nextAddress: 16,
        liveBytes: 15,
        cycle: 0,
        minorCollections: 0,
        majorCollections: 0,
        phase: GcIdle,
        objects,
        roots: empty.toSet(),
        globalRoots,
        closureEnvironments,
        asyncFrames,
        tlabs,
        tenured,
        humongous,
        barriers,
        loweredPointerSlots,
        remembered: empty.toSet(),
        grey: [],
        allocatedSinceLastGC: 16,
        lastStats: None,
    }

    let _ = testing.expectError(heap.validateHeap())
}

