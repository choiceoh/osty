fn testTelemetryRecordsManualMajorWork() {
    let mut heap = newGcHeap(testGcConfig())
    let first = heap.allocate(GcRecord, 10)
    let dead = heap.allocate(GcBytes, 20)
    let last = heap.allocate(GcRecord, 30)
    testing.assert(heap.addRoot(first))
    testing.assert(heap.addRoot(last))
    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(dead)))
    testing.assertEq(stats.kind, "major")
    testing.assertEq(stats.trigger, "manual")
    testing.assertEq(stats.allocationBytesSinceLastGC, 60)
    testing.assertEq(stats.beforeFragmentedBytes, 0)
    testing.assertEq(stats.afterFragmentedBytes, 0)
    testing.assertEq(stats.survivalPercent, 66)
    testing.assert(stats.pauseUnits > 0)
}

fn testTelemetryRecordsNurseryPressureTrigger() {
    let mut heap = newGcHeap(
        GcConfig {
            nurseryLimit: 24,
            survivorLimit: 16,
            heapLimit: 4096,
            promotionAge: 1,
            incrementalBudget: 1,
            largeObjectThreshold: 512,
            tlabSize: 64,
            cardSize: 64,
            schedulerSafepointInterval: 2,
            mutatorAssistBytes: 32,
            concurrentMarkBudget: 1,
            evacuationThresholdPercent: 50,
        },
    )
    let first = heap.allocate(GcRecord, 16)
    assertValid(heap)

    let mut second = 0
    match heap.tryAllocate(GcArray, 16) {
        Ok(id) -> {
            second = id
        },
        Err(e) -> testing.fail(e),
    }
    assertValid(heap)

    testing.assert(!(heap.contains(first)))
    testing.assert(heap.contains(second))
    match heap.lastCollectionStats() {
        Some(stats) -> {
            testing.assertEq(stats.kind, "minor")
            testing.assertEq(stats.trigger, "nursery-pressure")
            testing.assertEq(stats.allocationBytesSinceLastGC, 16)
            testing.assertEq(stats.survivalPercent, 0)
            testing.assert(stats.pauseUnits > 0)
        },
        None -> testing.fail("missing last collection stats"),
    }
}

fn testLargeObjectBypassesNurseryAndStartsHumongous() {
    let mut heap = newGcHeap(humongousSpaceGcConfig())
    let small = heap.allocate(GcRecord, 16)
    assertValid(heap)

    let large = heap.allocate(GcBytes, 64)
    assertValid(heap)

    testing.assert(heap.contains(small))
    testing.assert(heap.contains(large))
    testing.assert(heap.isLargeObject(large))
    testing.assertEq(regionOr(heap.regionOf(large), GcEdenRegion), GcHumongousRegion)
    testing.assertEq(intOr(heap.generationOf(large), -1), 1)
    testing.assertEq(heap.nurseryBytes(), 16)
    testing.assertEq(heap.largeObjectCount(), 1)
    testing.assertEq(heap.humongousBytes(), 64)
    testing.assertEq(heap.humongousAllocatedObjectCount(), 1)
    testing.assertEq(heap.humongousBumpAllocationCount(), 1)
    testing.assertEq(heap.humongousFreeBytes(), 0)
    match heap.lastCollectionStats() {
        Some(_) -> testing.fail("large allocation unexpectedly triggered collection"),
        None -> {},
    }

    testing.assert(heap.addRoot(large))
    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(small)))
    testing.assertEq(intOr(heap.addressOf(large), -1), 16)
    testing.assertEq(stats.afterFragmentedBytes, 16)
}

fn testHumongousObjectReclaimsToDedicatedFreeList() {
    let mut heap = newGcHeap(humongousSpaceGcConfig())
    let large = heap.allocate(GcBytes, 64)
    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(large)))
    testing.assertEq(stats.reclaimedObjects, 1)
    testing.assertEq(stats.reclaimedBytes, 64)
    testing.assertEq(heap.largeObjectCount(), 0)
    testing.assertEq(heap.humongousFreeBlockCount(), 1)
    testing.assertEq(heap.humongousFreeBytes(), 64)
    testing.assertEq(heap.humongousReclaimedObjectCount(), 1)
    testing.assertEq(heap.humongousReclaimedBytes(), 64)
}

fn testHumongousAllocationReusesDedicatedFreeBlock() {
    let mut heap = newGcHeap(humongousSpaceGcConfig())
    let dead = heap.allocate(GcBytes, 64)
    assertValid(heap)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(heap.humongousFreeBytes(), 64)

    let reused = heap.allocate(GcArray, 40)
    assertValid(heap)

    testing.assert(heap.contains(reused))
    testing.assert(heap.isLargeObject(reused))
    testing.assertEq(intOr(heap.addressOf(reused), -1), 0)
    testing.assertEq(regionOr(heap.regionOf(reused), GcEdenRegion), GcHumongousRegion)
    testing.assertEq(heap.humongousReuseAllocationCount(), 1)
    testing.assertEq(heap.humongousReusedBytes(), 40)
    testing.assertEq(heap.humongousFreeBytes(), 24)
}

fn testTenuredAllocationDoesNotConsumeHumongousFreeBlock() {
    let mut heap = newGcHeap(humongousSpaceGcConfig())
    let dead = heap.allocate(GcBytes, 64)
    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(heap.humongousFreeBytes(), 64)

    let old = heap.allocateTenured(GcRecord, 16)
    assertValid(heap)

    testing.assertEq(intOr(heap.addressOf(old), -1), 64)
    testing.assertEq(regionOr(heap.regionOf(old), GcEdenRegion), GcOldRegion)
    testing.assertEq(heap.tenuredBumpAllocationCount(), 1)
    testing.assertEq(heap.humongousFreeBytes(), 64)
    testing.assertEq(heap.humongousReuseAllocationCount(), 0)
}

fn testCompactionDoesNotMoveOldObjectIntoHumongousFreeBlock() {
    let mut heap = newGcHeap(humongousSpaceGcConfig())
    let deadLarge = heap.allocate(GcBytes, 64)
    let old = heap.allocateTenured(GcRecord, 16)
    testing.assert(heap.addRoot(old))
    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(deadLarge)))
    testing.assert(heap.contains(old))
    testing.assertEq(stats.reclaimedObjects, 1)
    testing.assertEq(intOr(heap.addressOf(old), -1), 64)
    testing.assertEq(heap.humongousFreeBytes(), 64)
    testing.assertEq(heap.fragmentedBytes(), 64)
}

fn testLargeTenuredAllocationRoutesToHumongousSpace() {
    let mut heap = newGcHeap(humongousSpaceGcConfig())
    let large = heap.allocateTenured(GcBytes, 64)
    assertValid(heap)

    testing.assert(heap.isLargeObject(large))
    testing.assertEq(regionOr(heap.regionOf(large), GcEdenRegion), GcHumongousRegion)
    testing.assertEq(intOr(heap.generationOf(large), -1), 1)
    testing.assertEq(heap.tenuredDirectAllocationCount(), 0)
    testing.assertEq(heap.humongousAllocatedObjectCount(), 1)
    testing.assertEq(heap.humongousBytes(), 64)
}

fn testMajorCollectionReclaimsCycles() {
    let mut heap = newGcHeap(testGcConfig())
    assertValid(heap)

    let anchor = heap.allocate(GcRecord, 16)
    let left = heap.allocate(GcRecord, 24)
    let right = heap.allocate(GcRecord, 24)
    assertValid(heap)

    testing.assert(heap.addRoot(anchor))
    testing.assert(heap.link(anchor, left))
    testing.assert(heap.link(left, right))
    testing.assert(heap.link(right, left))
    assertValid(heap)

    testing.assert(heap.unlink(anchor, left))
    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(heap.contains(anchor))
    testing.assert(!(heap.contains(left)))
    testing.assert(!(heap.contains(right)))
    testing.assertEq(stats.reclaimedObjects, 2)
    testing.assertEq(stats.reclaimedBytes, 48)
}

fn testBarrierAbiV1SymbolsAreStable() {
    let heap = newGcHeap(testGcConfig())
    let abi = heap.barrierAbi()

    testing.assertEq(abi.version, 1)
    testing.assertEq(abi.preWriteSymbol, "osty.gc.pre_write_v1")
    testing.assertEq(abi.postWriteSymbol, "osty.gc.post_write_v1")
    testing.assertEq(abi.loadSymbol, "osty.gc.load_v1")
    testing.assert(!(abi.preWriteRequired))
    testing.assert(abi.postWriteRequired)
    testing.assert(!(abi.loadRequired))
}

fn testLoadBarrierReturnsStableIdentityWithoutForwarding() {
    let mut heap = newGcHeap(testGcConfig())
    let object = heap.allocate(GcRecord, 16)
    assertValid(heap)

    testing.assertEq(intOr(heap.gcLoadBarrier(object), -1), object)
    testing.assertEq(intOr(heap.gcLoadBarrier(999), -1), -1)
    testing.assertEq(heap.barrierLoadCallCount(), 2)
    testing.assertEq(heap.barrierLoadForwardCount(), 0)
}

fn testMinorCollectionUsesRememberedSetAndPromotes() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    testing.assert(heap.addRoot(parent))
    assertValid(heap)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assertEq(intOr(heap.generationOf(parent), -1), 1)

    let child = heap.allocate(GcArray, 32)
    testing.assert(heap.link(parent, child))
    assertValid(heap)
    testing.assertEq(heap.rememberedCount(), 1)
    let parentCard = intOr(heap.cardIndexForObject(parent), -1)
    testing.assert(parentCard >= 0)
    testing.assert(heap.cardIsDirty(parentCard))
    testing.assertEq(heap.dirtyCardCount(), 1)
    testing.assertEq(heap.dirtyCardWriteCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 1)
    testing.assertEq(heap.barrierRememberedSetWriteCount(), 1)

    let stats = heap.minorCollect()
    assertValid(heap)
    testing.assert(heap.contains(child))
    testing.assertEq(intOr(heap.generationOf(child), -1), 1)
    testing.assertEq(stats.promotedObjects, 1)
    testing.assertEq(stats.rememberedScanned, 1)
    testing.assertEq(heap.lastMinorDirtyCardsScanned(), 1)
    testing.assertEq(heap.lastMinorRememberedObjectsScanned(), 1)
    testing.assertEq(heap.lastMinorPromotedObjects(), 1)
    testing.assertEq(heap.cardScanCount(), 1)
    testing.assertEq(heap.cardClearCount(), 1)
    testing.assertEq(heap.rememberedCount(), 0)
    testing.assertEq(heap.dirtyCardCount(), 0)
}

fn testMinorCollectorBackendRecordsCopyPipeline() {
    let mut heap = newGcHeap(survivorSpaceGcConfig(128, 3))
    let parent = heap.allocate(GcRecord, 16)
    testing.assert(heap.addRoot(parent))
    let _ = heap.majorCollect()
    assertValid(heap)

    let child = heap.allocate(GcArray, 24)
    testing.assert(heap.link(parent, child))
    assertValid(heap)

    let stats = heap.minorCollect()
    assertValid(heap)

    testing.assertEq(stats.rememberedScanned, 1)
    testing.assertEq(heap.lastMinorRootObjectsScanned(), 1)
    testing.assertEq(heap.lastMinorDirtyCardsScanned(), 1)
    testing.assertEq(heap.lastMinorRememberedObjectsScanned(), 1)
    testing.assertEq(heap.lastMinorYoungMarked(), 1)
    testing.assertEq(heap.lastMinorSurvivorCopiedObjects(), 1)
    testing.assertEq(heap.lastMinorPromotedObjects(), 0)
    testing.assert(heap.lastMinorEdenReset())
    testing.assert(heap.lastMinorSurvivorSwap())
    testing.assertEq(intOr(heap.generationOf(child), -1), 0)
    testing.assertEq(heap.survivorBytes(), 24)
    testing.assertEq(heap.rememberedCount(), 1)
    testing.assertEq(heap.dirtyCardCount(), 1)
}

fn testUnlinkRunsPreWriteBarrierHook() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    let child = heap.allocate(GcArray, 16)
    testing.assert(heap.link(parent, child))
    assertValid(heap)

    testing.assert(heap.unlink(parent, child))
    assertValid(heap)

    testing.assertEq(heap.barrierPreWriteCallCount(), 1)
    testing.assertEq(intOr(heap.refCount(parent), -1), 0)
}

fn testStructFieldStoreLoweringTracksSlotAndPostBarrier() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    testing.assert(heap.addRoot(parent))
    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assertEq(intOr(heap.generationOf(parent), -1), 1)

    let child = heap.allocate(GcArray, 16)
    match heap.lowerStructFieldStore(parent, 0, "next", child) {
        Some(event) -> {
            testing.assertEq(event.kind, GcStructFieldStore)
            testing.assertEq(event.ownerId, parent)
            testing.assertEq(event.slot, 0)
            testing.assertEq(event.name, "next")
            testing.assertEq(event.oldValue, -1)
            testing.assertEq(event.newValue, child)
            testing.assertEq(event.barrierSlotKind, GcBarrierObjectField)
            testing.assert(!(event.preWriteCalled))
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("struct field store lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(heap.loweredObjectFieldCount(), 1)
    testing.assertEq(intOr(heap.loweredObjectFieldValue(parent, 0), -1), child)
    testing.assertEq(intOr(heap.refCount(parent), -1), 1)
    testing.assertEq(heap.rememberedCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 1)
    testing.assertEq(heap.barrierRememberedSetWriteCount(), 1)
}

fn testFieldStoreOverwriteRunsPreBarrierAndDropsOldRef() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    let first = heap.allocate(GcArray, 16)
    let second = heap.allocate(GcClosure, 16)
    testing.assert(heap.addRoot(parent))
    match heap.lowerTuplePayloadStore(parent, 1, "payload", first) {
        Some(_) -> {},
        None -> testing.fail("initial tuple payload store lowering failed"),
    }
    assertValid(heap)

    match heap.lowerTuplePayloadStore(parent, 1, "payload", second) {
        Some(event) -> {
            testing.assertEq(event.kind, GcTuplePayloadStore)
            testing.assertEq(event.oldValue, first)
            testing.assertEq(event.newValue, second)
            testing.assert(event.preWriteCalled)
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("tuple payload overwrite lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(heap.loweredObjectFieldCount(), 1)
    testing.assertEq(intOr(heap.loweredObjectFieldValue(parent, 1), -1), second)
    testing.assertEq(intOr(heap.refCount(parent), -1), 1)
    testing.assertEq(heap.barrierPreWriteCallCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 2)

    let stats = heap.majorCollect()
    assertValid(heap)
    testing.assert(heap.contains(parent))
    testing.assert(!(heap.contains(first)))
    testing.assert(heap.contains(second))
    testing.assertEq(stats.reclaimedObjects, 1)
}

fn testReceiverStoreLoweringShadesLateIncrementalEdge() {
    let mut heap = newGcHeap(testGcConfig())
    let root = heap.allocate(GcRecord, 16)
    let existing = heap.allocate(GcArray, 16)
    let late = heap.allocate(GcClosure, 16)

    testing.assert(heap.addRoot(root))
    match heap.lowerReceiverFieldStore(root, 0, "existing", existing) {
        Some(_) -> {},
        None -> testing.fail("receiver field store lowering failed"),
    }
    assertValid(heap)

    heap.startIncrementalMajor()
    assertValid(heap)
    let markStats = heap.stepIncremental()
    assertValid(heap)
    testing.assertEq(markStats.kind, "incremental-mark")
    testing.assertEq(heap.phaseNow(), GcMarking)

    match heap.lowerReceiverFieldStore(root, 1, "late", late) {
        Some(event) -> {
            testing.assertEq(event.kind, GcReceiverFieldStore)
            testing.assertEq(event.oldValue, -1)
            testing.assertEq(event.newValue, late)
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("late receiver store lowering failed"),
    }
    assertValid(heap)
    testing.assertEq(heap.barrierIncrementalShadeCount(), 1)

    let done = heap.finishIncremental()
    assertValid(heap)
    testing.assertEq(done.kind, "incremental-sweep")
    testing.assert(heap.contains(root))
    testing.assert(heap.contains(existing))
    testing.assert(heap.contains(late))
}

fn testStoreLoweringRejectsInvalidTargetBeforeBarrier() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    match heap.lowerEnumPayloadStore(parent, 2, "variant.payload", 999) {
        Some(_) -> testing.fail("invalid enum payload store unexpectedly lowered"),
        None -> {},
    }
    assertValid(heap)

    testing.assertEq(heap.loweredObjectFieldCount(), 0)
    testing.assertEq(heap.barrierPreWriteCallCount(), 0)
    testing.assertEq(heap.barrierPostWriteCallCount(), 0)
}

fn testArrayElementStoreLoweringUsesCollectionBarrier() {
    let mut heap = newGcHeap(testGcConfig())
    let array = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(array))
    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assertEq(intOr(heap.generationOf(array), -1), 1)

    let child = heap.allocate(GcRecord, 16)
    match heap.lowerArrayElementStore(array, 0, child) {
        Some(event) -> {
            testing.assertEq(event.kind, GcArrayElementStore)
            testing.assertEq(event.ownerId, array)
            testing.assertEq(event.slot, 0)
            testing.assertEq(event.name, "array[0]")
            testing.assertEq(event.oldValue, -1)
            testing.assertEq(event.newValue, child)
            testing.assertEq(event.barrierSlotKind, GcBarrierArrayElement)
            testing.assert(!(event.preWriteCalled))
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("array element store lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(heap.loweredPointerSlotCount(), 1)
    testing.assertEq(intOr(heap.loweredPointerSlotValue(GcArrayElementStore, array, 0), -1), child)
    testing.assertEq(intOr(heap.refCount(array), -1), 1)
    testing.assertEq(heap.rememberedCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 1)
    testing.assertEq(heap.barrierRememberedSetWriteCount(), 1)
}

fn testMapKeyAndValueStoresKeepEntryObjectsAlive() {
    let mut heap = newGcHeap(testGcConfig())
    let table = heap.allocate(GcArray, 24)
    let key = heap.allocate(GcRecord, 16)
    let value = heap.allocate(GcClosure, 16)
    testing.assert(heap.addRoot(table))

    match heap.lowerMapKeyStore(table, 10, key) {
        Some(event) -> {
            testing.assertEq(event.kind, GcMapKeyStore)
            testing.assertEq(event.name, "map.key[10]")
            testing.assertEq(event.barrierSlotKind, GcBarrierArrayElement)
        },
        None -> testing.fail("map key store lowering failed"),
    }
    match heap.lowerMapValueStore(table, 11, value) {
        Some(event) -> {
            testing.assertEq(event.kind, GcMapValueStore)
            testing.assertEq(event.name, "map.value[11]")
            testing.assertEq(event.barrierSlotKind, GcBarrierArrayElement)
        },
        None -> testing.fail("map value store lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(heap.loweredPointerSlotCount(), 2)
    testing.assertEq(intOr(heap.loweredPointerSlotValue(GcMapKeyStore, table, 10), -1), key)
    testing.assertEq(intOr(heap.loweredPointerSlotValue(GcMapValueStore, table, 11), -1), value)
    testing.assertEq(intOr(heap.refCount(table), -1), 2)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(heap.contains(table))
    testing.assert(heap.contains(key))
    testing.assert(heap.contains(value))
}

fn testCollectionStoreOverwritePreservesSharedPointerSlot() {
    let mut heap = newGcHeap(testGcConfig())
    let list = heap.allocate(GcArray, 16)
    let shared = heap.allocate(GcRecord, 16)
    let replacement = heap.allocate(GcClosure, 16)
    testing.assert(heap.addRoot(list))

    match heap.lowerListElementStore(list, 0, shared) {
        Some(event) -> testing.assertEq(event.kind, GcListElementStore),
        None -> testing.fail("list element store lowering failed"),
    }
    match heap.lowerSetKeyStore(list, 1, shared) {
        Some(event) -> testing.assertEq(event.kind, GcSetKeyStore),
        None -> testing.fail("set key store lowering failed"),
    }
    match heap.lowerListElementStore(list, 0, replacement) {
        Some(event) -> {
            testing.assertEq(event.oldValue, shared)
            testing.assertEq(event.newValue, replacement)
            testing.assert(event.preWriteCalled)
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("list element overwrite lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(heap.loweredPointerSlotCount(), 2)
    testing.assertEq(
        intOr(heap.loweredPointerSlotValue(GcListElementStore, list, 0), -1),
        replacement,
    )
    testing.assertEq(intOr(heap.loweredPointerSlotValue(GcSetKeyStore, list, 1), -1), shared)
    testing.assertEq(intOr(heap.refCount(list), -1), 2)
    testing.assertEq(heap.barrierPreWriteCallCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 3)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(heap.contains(list))
    testing.assert(heap.contains(shared))
    testing.assert(heap.contains(replacement))
}

fn testMinorCollectionMovesEdenObjectToSurvivorSpace() {
    let mut heap = newGcHeap(survivorSpaceGcConfig(64, 2))
    let rooted = heap.allocate(GcRecord, 16)
    testing.assert(heap.addRoot(rooted))
    assertValid(heap)

    testing.assertEq(heap.edenObjectCount(), 1)
    testing.assertEq(heap.survivorObjectCount(), 0)
    testing.assertEq(heap.edenBytes(), 16)

    let stats = heap.minorCollect()
    assertValid(heap)

    testing.assert(heap.contains(rooted))
    testing.assertEq(stats.promotedObjects, 0)
    testing.assertEq(intOr(heap.generationOf(rooted), -1), 0)
    testing.assertEq(intOr(heap.ageOf(rooted), -1), 1)
    testing.assertEq(regionOr(heap.regionOf(rooted), GcOldRegion), GcSurvivorRegion)
    testing.assertEq(heap.edenObjectCount(), 0)
    testing.assertEq(heap.survivorObjectCount(), 1)
    testing.assertEq(heap.survivorBytes(), 16)
    testing.assertEq(heap.nurseryBytes(), 16)
}

fn testSecondMinorPromotesAgedSurvivor() {
    let mut heap = newGcHeap(survivorSpaceGcConfig(64, 2))
    let rooted = heap.allocate(GcRecord, 16)
    testing.assert(heap.addRoot(rooted))
    assertValid(heap)

    let first = heap.minorCollect()
    assertValid(heap)
    testing.assertEq(first.promotedObjects, 0)
    testing.assertEq(regionOr(heap.regionOf(rooted), GcOldRegion), GcSurvivorRegion)

    let second = heap.minorCollect()
    assertValid(heap)

    testing.assert(heap.contains(rooted))
    testing.assertEq(second.promotedObjects, 1)
    testing.assertEq(intOr(heap.generationOf(rooted), -1), 1)
    testing.assertEq(intOr(heap.ageOf(rooted), -1), 2)
    testing.assertEq(regionOr(heap.regionOf(rooted), GcEdenRegion), GcOldRegion)
    testing.assertEq(heap.survivorObjectCount(), 0)
    testing.assertEq(heap.survivorBytes(), 0)
    testing.assertEq(heap.tenuredObjectCount(), 1)
}

fn testSurvivorOverflowPromotesFallback() {
