fn testGlobalRootKeepsObjectAcrossCollections() {
    let mut heap = newGcHeap(testGcConfig())
    let global = heap.allocate(GcRecord, 16)
    let child = heap.allocate(GcArray, 16)
    let dead = heap.allocate(GcBytes, 16)

    testing.assert(heap.installGlobalRoot("app", "cache", GcPackageGlobalRoot, global))
    testing.assert(heap.link(global, child))
    assertValid(heap)

    let minor = heap.minorCollect()
    assertValid(heap)

    testing.assert(heap.contains(global))
    testing.assert(heap.contains(child))
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(minor.reclaimedObjects, 1)
    testing.assertEq(heap.globalRootCount(), 1)
    testing.assertEq(heap.globalObjectRootCount(), 1)
    testing.assertEq(intOr(heap.globalRootObject("app", "cache"), -1), global)

    testing.assert(heap.removeGlobalRoot("app", "cache"))
    let major = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(global)))
    testing.assert(!(heap.contains(child)))
    testing.assert(major.reclaimedObjects >= 2)
    testing.assertEq(heap.globalRootCount(), 0)
}

fn testPartiallyInitializedGlobalSurvivesCollectionUntilPoisoned() {
    let mut heap = newGcHeap(testGcConfig())
    testing.assert(heap.beginGlobalInit("pkg.init", "TABLE", GcTopLevelLetRoot))
    let table = heap.allocate(GcArray, 32)
    testing.assert(heap.setGlobalRootObject("pkg.init", "TABLE", table))
    assertValid(heap)

    let first = heap.majorCollect()
    assertValid(heap)

    testing.assert(heap.contains(table))
    testing.assertEq(first.reclaimedObjects, 0)
    testing.assertEq(
        globalStateOr(heap.globalRootState("pkg.init", "TABLE"), GcGlobalPoisoned),
        GcGlobalInitializing,
    )

    testing.assert(heap.finishGlobalInit("pkg.init", "TABLE"))
    assertValid(heap)
    testing.assertEq(
        globalStateOr(heap.globalRootState("pkg.init", "TABLE"), GcGlobalPoisoned),
        GcGlobalReady,
    )

    testing.assert(heap.poisonGlobalRoot("pkg.init", "TABLE"))
    assertValid(heap)
    let second = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(table)))
    testing.assertEq(second.reclaimedObjects, 1)
    testing.assertEq(
        globalStateOr(heap.globalRootState("pkg.init", "TABLE"), GcGlobalDeclared),
        GcGlobalPoisoned,
    )
    testing.assertEq(heap.globalObjectRootCount(), 0)
}

fn testGlobalRootLifecycleRejectsInvalidTransitions() {
    let mut heap = newGcHeap(testGcConfig())
    let stable = heap.allocate(GcRecord, 16)

    testing.assert(heap.declareGlobalRoot("pkg.config", "stable", GcConstantRoot))
    testing.assert(!(heap.declareGlobalRoot("pkg.config", "stable", GcConstantRoot)))
    testing.assert(heap.beginGlobalInit("pkg.config", "stable", GcConstantRoot))
    testing.assert(!(heap.beginGlobalInit("pkg.config", "stable", GcConstantRoot)))
    testing.assert(heap.setGlobalRootObject("pkg.config", "stable", stable))
    testing.assert(heap.finishGlobalInit("pkg.config", "stable"))
    assertValid(heap)

    testing.assert(heap.poisonGlobalRoot("pkg.config", "stable"))
    let rebound = heap.allocate(GcRecord, 16)
    testing.assert(!(heap.setGlobalRootObject("pkg.config", "stable", rebound)))
    testing.assert(!(heap.installGlobalRoot("pkg.config", "stable", GcConstantRoot, rebound)))
    assertValid(heap)

    testing.assertEq(heap.globalRootCount(), 1)
    testing.assertEq(heap.globalObjectRootCount(), 0)
    testing.assertEq(
        globalStateOr(heap.globalRootState("pkg.config", "stable"), GcGlobalDeclared),
        GcGlobalPoisoned,
    )
}

fn testCrossPackageGlobalReferenceKeepsDependencyObject() {
    let mut heap = newGcHeap(testGcConfig())
    let appGlobal = heap.allocate(GcRecord, 16)
    let runtimeGlobal = heap.allocate(GcClosure, 24)
    let dead = heap.allocate(GcBytes, 16)

    testing.assert(heap.installGlobalRoot("app.main", "handler", GcTopLevelLetRoot, appGlobal))
    testing.assert(heap.link(appGlobal, runtimeGlobal))
    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(heap.contains(appGlobal))
    testing.assert(heap.contains(runtimeGlobal))
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(stats.reclaimedObjects, 1)
}

fn testGlobalRootAddedDuringIncrementalMarkingIsShaded() {
    let mut heap = newGcHeap(testGcConfig())
    let root = heap.allocate(GcRecord, 16)
    let existing = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(root))
    testing.assert(heap.link(root, existing))
    assertValid(heap)

    heap.startIncrementalMajor()
    assertValid(heap)
    let _ = heap.stepIncremental()
    assertValid(heap)
    testing.assertEq(heap.phaseNow(), GcMarking)

    let lateGlobal = heap.allocate(GcClosure, 24)
    testing.assert(heap.installGlobalRoot("late.module", "singleton", GcStaticRoot, lateGlobal))
    assertValid(heap)

    let done = heap.finishIncremental()
    assertValid(heap)

    testing.assertEq(done.kind, "incremental-sweep")
    testing.assert(heap.contains(root))
    testing.assert(heap.contains(existing))
    testing.assert(heap.contains(lateGlobal))
    testing.assertEq(intOr(heap.globalRootObject("late.module", "singleton"), -1), lateGlobal)
}

fn testClosureEnvironmentKeepsCapturedObjectsAlive() {
    let mut heap = newGcHeap(testGcConfig())
    let closure = heap.allocate(GcClosure, 24)
    let direct = heap.allocate(GcRecord, 16)
    let box = heap.allocate(GcRecord, 16)
    let boxedPayload = heap.allocate(GcArray, 16)
    let dead = heap.allocate(GcBytes, 16)
    testing.assert(heap.link(box, boxedPayload))

    let captures: List<GcClosureCapture> = [
        gcValueCapture(0, "direct", direct),
        gcMutableBoxCapture(1, "cell", box),
        gcScalarCapture(2, "counter"),
    ]
    testing.assert(heap.installClosureEnvironment(closure, "makeHandler", captures))
    testing.assert(heap.addRoot(closure))
    assertValid(heap)

    let first = heap.majorCollect()
    assertValid(heap)

    testing.assert(heap.contains(closure))
    testing.assert(heap.contains(direct))
    testing.assert(heap.contains(box))
    testing.assert(heap.contains(boxedPayload))
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(first.reclaimedObjects, 1)
    testing.assertEq(heap.closureEnvironmentCount(), 1)
    testing.assertEq(heap.closurePointerCaptureCount(), 2)

    testing.assert(heap.removeRoot(closure))
    let second = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(closure)))
    testing.assert(!(heap.contains(direct)))
    testing.assert(!(heap.contains(box)))
    testing.assert(!(heap.contains(boxedPayload)))
    testing.assert(second.reclaimedObjects >= 4)
    testing.assertEq(heap.closureEnvironmentCount(), 0)
}

fn testClosureCaptureUpdateDropsOldCapture() {
    let mut heap = newGcHeap(testGcConfig())
    let closure = heap.allocate(GcClosure, 24)
    let firstCapture = heap.allocate(GcRecord, 16)
    let secondCapture = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(closure))
    let captures: List<GcClosureCapture> = [gcValueCapture(0, "item", firstCapture)]
    testing.assert(heap.installClosureEnvironment(closure, "replaceCapture", captures))
    assertValid(heap)
    testing.assertEq(heap.barrierPostWriteCallCount(), 1)

    testing.assert(heap.updateClosureCapture(closure, 0, secondCapture))
    testing.assertEq(heap.barrierPreWriteCallCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 2)
    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(heap.contains(closure))
    testing.assert(!(heap.contains(firstCapture)))
    testing.assert(heap.contains(secondCapture))
    testing.assertEq(stats.reclaimedObjects, 1)
    testing.assertEq(heap.closurePointerCaptureCount(), 1)
}

fn testClosureDescriptorRejectsInvalidCaptures() {
    let mut heap = newGcHeap(testGcConfig())
    let closure = heap.allocate(GcClosure, 24)
    let target = heap.allocate(GcRecord, 16)

    let scalarWithObject: List<GcClosureCapture> = [
        GcClosureCapture {
            slot: 0,
            name: "badScalar",
            kind: GcCaptureScalar,
            objectId: target,
        },
    ]
    testing.assert(!(heap.installClosureEnvironment(closure, "bad", scalarWithObject)))

    let duplicateSlots: List<GcClosureCapture> = [
        gcValueCapture(0, "a", target),
        gcValueCapture(0, "b", target),
    ]
    testing.assert(!(heap.installClosureEnvironment(closure, "bad", duplicateSlots)))

    let missingObject: List<GcClosureCapture> = [gcValueCapture(1, "missing", 999)]
    testing.assert(!(heap.installClosureEnvironment(closure, "bad", missingObject)))
    assertValid(heap)
}

fn testSuspendedAsyncFrameKeepsRootsUntilResume() {
    let mut heap = newGcHeap(testGcConfig())
    let frame = heap.allocate(GcRuntimeFrame, 32)
    let payload = heap.allocate(GcRecord, 16)
    let child = heap.allocate(GcArray, 16)
    let dead = heap.allocate(GcBytes, 16)
    testing.assert(heap.link(payload, child))

    let roots: List<Int> = [payload]
    testing.assert(heap.suspendAsyncFrame(7, "worker.await", 4, frame, roots))
    assertValid(heap)

    let first = heap.minorCollect()
    assertValid(heap)

    testing.assert(heap.contains(frame))
    testing.assert(heap.contains(payload))
    testing.assert(heap.contains(child))
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(first.reclaimedObjects, 1)
    testing.assertEq(heap.asyncFrameCount(), 1)
    testing.assertEq(heap.suspendedAsyncFrameCount(), 1)
    testing.assertEq(heap.asyncFrameRootCount(), 2)

    testing.assert(heap.resumeAsyncFrame(7))
    let second = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(frame)))
    testing.assert(!(heap.contains(payload)))
    testing.assert(!(heap.contains(child)))
    testing.assert(second.reclaimedObjects >= 3)
    testing.assertEq(heap.asyncFrameCount(), 1)
    testing.assertEq(heap.suspendedAsyncFrameCount(), 0)
    testing.assertEq(heap.asyncFrameRootCount(), 0)
}

fn testAsyncFrameAddedDuringIncrementalMarkingIsShaded() {
    let mut heap = newGcHeap(testGcConfig())
    let root = heap.allocate(GcRecord, 16)
    let existing = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(root))
    testing.assert(heap.link(root, existing))
    assertValid(heap)

    heap.startIncrementalMajor()
    assertValid(heap)
    let _ = heap.stepIncremental()
    assertValid(heap)
    testing.assertEq(heap.phaseNow(), GcMarking)

    let frame = heap.allocate(GcRuntimeFrame, 32)
    let payload = heap.allocate(GcClosure, 24)
    let roots: List<Int> = [payload]
    testing.assert(heap.suspendAsyncFrame(42, "task.suspend", 9, frame, roots))
    assertValid(heap)

    let done = heap.finishIncremental()
    assertValid(heap)

    testing.assertEq(done.kind, "incremental-sweep")
    testing.assert(heap.contains(root))
    testing.assert(heap.contains(existing))
    testing.assert(heap.contains(frame))
    testing.assert(heap.contains(payload))
}

fn testRuntimeFrameSlotStoreLoweringUsesRuntimeFrameBarrier() {
    let mut heap = newGcHeap(testGcConfig())
    let frame = heap.allocate(GcRuntimeFrame, 32)
    testing.assert(heap.addRoot(frame))
    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assertEq(intOr(heap.generationOf(frame), -1), 1)

    let payload = heap.allocate(GcRecord, 16)
    match heap.lowerRuntimeFrameSlotStore(frame, 0, "spill.payload", payload) {
        Some(event) -> {
            testing.assertEq(event.kind, GcRuntimeFrameSlotStore)
            testing.assertEq(event.ownerId, frame)
            testing.assertEq(event.slot, 0)
            testing.assertEq(event.name, "spill.payload")
            testing.assertEq(event.oldValue, -1)
            testing.assertEq(event.newValue, payload)
            testing.assertEq(event.barrierSlotKind, GcBarrierRuntimeFrame)
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("runtime frame slot store lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(
        intOr(heap.loweredPointerSlotValue(GcRuntimeFrameSlotStore, frame, 0), -1),
        payload,
    )
    testing.assertEq(intOr(heap.refCount(frame), -1), 1)
    testing.assertEq(heap.rememberedCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 1)
    testing.assertEq(heap.barrierRememberedSetWriteCount(), 1)
}

fn testAsyncFrameRootStoreLoweringShadesLateRoot() {
    let mut heap = newGcHeap(testGcConfig())
    let frame = heap.allocate(GcRuntimeFrame, 32)
    let anchor = heap.allocate(GcRecord, 16)
    match heap.lowerRuntimeFrameSlotStore(frame, 0, "spill.anchor", anchor) {
        Some(_) -> {},
        None -> testing.fail("runtime frame anchor store lowering failed"),
    }
    let roots: List<Int> = []
    testing.assert(heap.suspendAsyncFrame(77, "task.await", 3, frame, roots))
    assertValid(heap)

    heap.startIncrementalMajor()
    assertValid(heap)
    let markStats = heap.stepIncremental()
    assertValid(heap)
    testing.assertEq(markStats.kind, "incremental-mark")
    testing.assertEq(heap.phaseNow(), GcMarking)

    let late = heap.allocate(GcClosure, 24)
    match heap.lowerAsyncFrameRootStore(77, 2, "await.payload", late) {
        Some(event) -> {
            testing.assertEq(event.kind, GcAsyncFrameRootStore)
            testing.assertEq(event.ownerId, frame)
            testing.assertEq(event.slot, 2)
            testing.assertEq(event.name, "await.payload")
            testing.assertEq(event.barrierSlotKind, GcBarrierAsyncFrameRoot)
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("async frame root store lowering failed"),
    }
    assertValid(heap)
    testing.assertEq(heap.asyncFrameRootCount(), 2)
    testing.assertEq(intOr(heap.loweredPointerSlotValue(GcAsyncFrameRootStore, frame, 2), -1), late)
    testing.assertEq(heap.barrierIncrementalShadeCount(), 1)

    let done = heap.finishIncremental()
    assertValid(heap)
    testing.assertEq(done.kind, "incremental-sweep")
    testing.assert(heap.contains(frame))
    testing.assert(heap.contains(late))
}

fn testAsyncFrameRootOverwriteDropsOldSnapshotRoot() {
    let mut heap = newGcHeap(testGcConfig())
    let frame = heap.allocate(GcRuntimeFrame, 32)
    let first = heap.allocate(GcRecord, 16)
    let second = heap.allocate(GcArray, 16)
    let roots: List<Int> = []
    testing.assert(heap.suspendAsyncFrame(78, "task.replace", 4, frame, roots))

    match heap.lowerAsyncFrameRootStore(78, 1, "root.value", first) {
        Some(_) -> {},
        None -> testing.fail("initial async frame root lowering failed"),
    }
    match heap.lowerAsyncFrameRootStore(78, 1, "root.value", second) {
        Some(event) -> {
            testing.assertEq(event.oldValue, first)
            testing.assertEq(event.newValue, second)
            testing.assert(event.preWriteCalled)
            testing.assert(event.postWriteCalled)
        },
        None -> testing.fail("async frame root overwrite lowering failed"),
    }
    assertValid(heap)

    testing.assertEq(heap.asyncFrameRootCount(), 2)
    testing.assertEq(
        intOr(heap.loweredPointerSlotValue(GcAsyncFrameRootStore, frame, 1), -1),
        second,
    )
    testing.assertEq(heap.barrierPreWriteCallCount(), 1)
    testing.assertEq(heap.barrierPostWriteCallCount(), 2)

    let stats = heap.majorCollect()
    assertValid(heap)
    testing.assert(heap.contains(frame))
    testing.assert(!(heap.contains(first)))
    testing.assert(heap.contains(second))
    testing.assertEq(stats.reclaimedObjects, 1)
}

fn testSafepointPlanValidatesPreciseLiveRoots() {
    let callRoots: List<GcLiveRootSlot> = [
        gcRootSlot(0, GcLocalRootSlot, "payload"),
        gcRootSlot(1, GcSpillRootSlot, "env"),
    ]
    let allocRoots: List<GcLiveRootSlot> = [
        gcRootSlot(0, GcLocalRootSlot, "payload"),
        gcRootSlot(3, GcTemporaryRootSlot, "pending"),
    ]
    let loopRoots: List<GcLiveRootSlot> = [
        gcRootSlot(0, GcLocalRootSlot, "payload"),
        gcDerivedRootSlot(2, "payload.field", 0),
    ]
    let asyncRoots: List<GcLiveRootSlot> = [
        gcRootSlot(0, GcLocalRootSlot, "payload"),
        gcRootSlot(4, GcClosureRootSlot, "task.frame"),
    ]
    let safepoints: List<GcSafepoint> = [
        gcSafepoint(1, GcCallSafepoint, 10, 32, callRoots),
        gcSafepoint(2, GcAllocationSafepoint, 14, 48, allocRoots),
        gcSafepoint(3, GcLoopBackedgeSafepoint, 21, 80, loopRoots),
        gcSafepoint(4, GcAsyncYieldSafepoint, 30, 120, asyncRoots),
    ]
    let plan = gcSafepointPlan("renderFrame", 6, safepoints)

    match validateSafepointPlan(plan) {
        Ok(_) -> {},
        Err(e) -> testing.fail(e),
    }

    testing.assert(plan.safepoints[0].mayAllocate)
    testing.assert(plan.safepoints[1].mayAllocate)
    testing.assert(!(plan.safepoints[2].mayAllocate))
    testing.assert(plan.safepoints[3].maySuspend)
}

