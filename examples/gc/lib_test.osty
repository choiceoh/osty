}

fn testMostlyConcurrentMarkKeepsLateMutationAlive() {
    let mut heap = newGcHeap(testGcConfig())
    let root = heap.allocate(GcRecord, 16)
    let existing = heap.allocate(GcArray, 16)
    let late = heap.allocate(GcClosure, 16)
    testing.assert(heap.addRoot(root))
    testing.assert(heap.link(root, existing))
    assertValid(heap)

    testing.assert(heap.startMostlyConcurrentMark())
    assertValid(heap)
    let slice = heap.stepMostlyConcurrentMark()
    assertValid(heap)
    testing.assertEq(slice.kind, "concurrent-mark")
    testing.assertEq(slice.markSteps, 1)
    testing.assertEq(heap.concurrentMarkActive(), true)
    testing.assertEq(heap.concurrentMarkSliceCount(), 1)
    testing.assertEq(heap.concurrentMarkStepCount(), 1)
    testing.assertEq(heap.concurrentSnapshotRootCount(), 1)

    testing.assert(heap.link(root, late))
    assertValid(heap)
    testing.assertEq(heap.barrierIncrementalShadeCount(), 1)

    let done = heap.finishMostlyConcurrentMark()
    assertValid(heap)
    testing.assertEq(done.kind, "concurrent-sweep")
    testing.assertEq(heap.concurrentMarkActive(), false)
    testing.assertEq(heap.concurrentRemarkRootCount(), 1)
    testing.assertEq(heap.concurrentBarrierShadeDelta(), 1)
    testing.assertEq(heap.concurrentMutatorEpoch(), 1)
    testing.assert(heap.concurrentFinalRemarkStepCount() > 0)
    testing.assert(heap.contains(root))
    testing.assert(heap.contains(existing))
    testing.assert(heap.contains(late))
}

fn testPolicyProfilesTuneMechanismKnobs() {
    let latency = gcConfigForProfile(GcLatencyFirstProfile)
    let throughput = gcConfigForProfile(GcThroughputFirstProfile)
    let memory = gcConfigForProfile(GcMemoryTightProfile)
    let heap = newGcHeap(memory)
    assertValid(heap)

    testing.assertEq(gcPolicyProfileName(GcLatencyFirstProfile), "latency-first")
    testing.assert(latency.incrementalBudget < throughput.incrementalBudget)
    testing.assert(latency.schedulerSafepointInterval < throughput.schedulerSafepointInterval)
    testing.assert(memory.nurseryLimit < throughput.nurseryLimit)
    testing.assert(memory.evacuationThresholdPercent > latency.evacuationThresholdPercent)
    testing.assertEq(heap.evacuationThresholdPercent(), 80)
    testing.assert(heap.shouldEvacuateRegion(80))
    testing.assert(!(heap.shouldEvacuateRegion(81)))
}

fn testDiagnosticsSnapshotAndHeapDumpExposeGraph() {
    let mut heap = newGcHeap(testGcConfig())
    let root = heap.allocate(GcRecord, 16)
    let child = heap.allocate(GcArray, 16)
    let dead = heap.allocate(GcBytes, 16)
    testing.assert(heap.addRoot(root))
    testing.assert(heap.link(root, child))
    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)
    testing.assertEq(stats.kind, "major")
    testing.assert(!(heap.contains(dead)))

    let snapshot = heap.diagnosticsSnapshot()
    testing.assert(snapshot.heapValid)
    testing.assertEq(snapshot.objectCount, 2)
    testing.assertEq(snapshot.rootCount, 1)
    testing.assertEq(snapshot.liveBytes, 32)
    testing.assertEq(snapshot.lastKind, "major")
    testing.assertEq(snapshot.lastTrigger, "manual")
    testing.assert(snapshot.lastPauseUnits > 0)
    testing.assertEq(snapshot.lastReclaimedObjects, 1)
    testing.assertEq(snapshot.validationMessage, "ok")

    let dump = heap.heapDump()
    testing.assertEq(dump.objectCount, 2)
    testing.assertEq(dump.edgeCount, 1)
    testing.assertEq(dump.rootCount, 1)
    testing.assertEq(dump.roots[0], root)
    testing.assertEq(dump.objects[0].id, root)
    testing.assertEq(dump.objects[0].kind, GcRecord)
    testing.assertEq(dump.objects[0].refCount, 1)
    testing.assert(dump.objects[0].rooted)
    testing.assertEq(dump.edges[0].fromId, root)
    testing.assertEq(dump.edges[0].toId, child)

    match heap.heapObjectDebugLine(root) {
        Some(line) -> {
            testing.assertEq(
                line,
                "object id={root} kind=record region=old gen=1 size=16 addr=0 refs=[{child}] root=true pinned=false",
            )
        },
        None -> testing.fail("missing heap object debug line"),
    }
    let graph = heap.objectGraphDebug()
    testing.assert(graph != "")
    testing.assertEq(tracePhaseName(snapshot.phase), "idle")
}

fn testStressModesCanDisableAndForceCompaction() {
    let mut heap = newGcHeap(testGcConfig())
    let dead = heap.allocate(GcBytes, 20)
    let live = heap.allocate(GcRecord, 20)
    testing.assert(heap.addRoot(live))
    assertValid(heap)

    let noCompact = heap.runStressMode(GcStressNoCompaction)
    assertValid(heap)
    testing.assertEq(noCompact.kind, "major-no-compact")
    testing.assertEq(noCompact.trigger, "stress.no-compaction")
    testing.assertEq(noCompact.compactedObjects, 0)
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(intOr(heap.addressOf(live), -1), 20)
    testing.assert(heap.fragmentedBytes() > 0)
    testing.assertEq(heap.forwardingEntryCount(), 0)

    let compact = heap.runStressMode(GcStressAlwaysCompact)
    assertValid(heap)
    testing.assertEq(compact.kind, "major")
    testing.assertEq(compact.trigger, "stress.always-compact")
    testing.assertEq(compact.compactedObjects, 1)
    testing.assertEq(intOr(heap.addressOf(live), -1), 0)
    testing.assertEq(heap.fragmentedBytes(), 0)
    testing.assertEq(gcStressModeName(GcStressEveryAllocationMinor), "every-allocation-minor")
}

fn testHardeningReportAuditsBarriersAndBudgets() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    let child = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(parent))
    match heap.lowerStructFieldStore(parent, 0, "child", child) {
        Some(_) -> {},
        None -> testing.fail("lowered field store failed"),
    }
    let _ = heap.majorCollect()
    assertValid(heap)

    let audit = heap.barrierAudit()
    testing.assert(audit.passed)
    testing.assertEq(audit.loweredSlots, 1)
    testing.assertEq(audit.invalidObjectReferences, 0)
    testing.assertEq(audit.missingOwnerRefs, 0)

    let thresholds = gcPerformanceThresholdsForProfile(GcThroughputFirstProfile)
    let performance = heap.performanceReport(thresholds)
    testing.assert(performance.passed)
    testing.assert(performance.pauseUnits > 0)

    let report = heap.hardeningReport(thresholds)
    testing.assert(report.passed)
    testing.assert(report.heapValid)
    testing.assert(report.barrierAuditPassed)
    testing.assert(report.performancePassed)
    testing.assertEq(report.runtimeContractVersion, 1)
    testing.assertEq(report.loweredSlots, 1)

    let contract = heap.runtimeContract()
    testing.assert(contract.oomReturnsResult)
    testing.assert(contract.abortSkipsGc)
    testing.assert(contract.deferRootsRequireStackMap)
    testing.assert(contract.ffiPinsUsePinBit)
    testing.assert(contract.refSameUsesStableIdentity)
}

fn testHardeningReportFailsOnLoweredSlotMismatch() {
    let mut heap = newGcHeap(testGcConfig())
    let parent = heap.allocate(GcRecord, 16)
    let child = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(parent))
    match heap.lowerStructFieldStore(parent, 0, "child", child) {
        Some(_) -> {},
        None -> testing.fail("lowered field store failed"),
    }
    assertValid(heap)

    if heap.objects.containsKey(parent) {
        let entry = heap.objects[parent]
        let emptyRefs: List<Int> = []
        let mut next = entry
        next.refs = emptyRefs
        heap.objects.insert(parent, next)
    } else {
        testing.fail("missing parent object")
    }

    let audit = heap.barrierAudit()
    testing.assertEq(audit.loweredSlots, 1)
    testing.assertEq(audit.invalidObjectReferences, 0)
    testing.assertEq(audit.missingOwnerRefs, 1)
    testing.assertEq(audit.rememberedMismatches, 0)
    testing.assert(!(audit.passed))

    let thresholds = gcPerformanceThresholdsForProfile(GcThroughputFirstProfile)
    let report = heap.hardeningReport(thresholds)
    testing.assert(!(report.passed))
    testing.assert(!(report.heapValid))
    testing.assert(!(report.barrierAuditPassed))
    testing.assert(report.performancePassed)
    testing.assertEq(report.loweredSlots, 1)
    testing.assert(report.validationMessage != "")
}

fn testBarrierAuditDetectsRememberedMismatch() {
    let mut heap = newGcHeap(testGcConfig())
    let old = heap.allocateTenured(GcRecord, 16)
    let young = heap.allocate(GcArray, 16)
    testing.assert(heap.addRoot(old))
    testing.assert(heap.link(old, young))
    assertValid(heap)

    if heap.objects.containsKey(old) {
        let entry = heap.objects[old]
        let mut next = entry
        next.remembered = false
        heap.objects.insert(old, next)
    } else {
        testing.fail("missing old object")
    }

    let audit = heap.barrierAudit()
    testing.assertEq(audit.invalidObjectReferences, 0)
    testing.assertEq(audit.missingOwnerRefs, 0)
    testing.assertEq(audit.rememberedMismatches, 1)
    testing.assert(!(audit.passed))

    let thresholds = gcPerformanceThresholdsForProfile(GcThroughputFirstProfile)
    let report = heap.hardeningReport(thresholds)
    testing.assert(!(report.passed))
    testing.assert(!(report.heapValid))
    testing.assert(!(report.barrierAuditPassed))
    testing.assert(report.performancePassed)
}

fn testLlvmHandleTablePreservesIdentityAcrossCompaction() {
    let mut heap = newGcHeap(testGcConfig())
    let dead = heap.allocate(GcBytes, 16)
    let handle = heap.allocateLlvmHandle(GcRecord, 24, "llvm.emitStructLit")
    let objectId = intOr(heap.llvmHandleObject(handle), -1)
    let beforeAddress = intOr(heap.addressOf(objectId), -1)
    let rootRef = intOr(heap.bindLlvmRootRef(handle, GcLlvmStackRoot, "entry.stack"), -1)
    assertValid(heap)

    testing.assert(rootRef > 0)
    testing.assertEq(heap.llvmHandleCount(), 1)
    testing.assertEq(heap.llvmRootRefCount(), 1)
    testing.assertEq(heap.llvmRuntimeRootCount(), 1)

    let stats = heap.majorCollect()
    assertValid(heap)
    let afterAddress = intOr(heap.addressOf(objectId), -1)

    testing.assert(!(heap.contains(dead)))
    testing.assert(heap.contains(objectId))
    testing.assert(afterAddress < beforeAddress)
    testing.assert(heap.llvmHandleSame(handle, handle))
    testing.assertEq(heap.lastRemapRootSlotsRemapped(), 1)
    testing.assertEq(stats.compactedObjects, 1)

    let snapshot = heap.llvmBridgeSnapshot()
    testing.assertEq(snapshot.backend, GcLlvmBackend)
    testing.assertEq(snapshot.handleCount, 1)
    testing.assertEq(snapshot.liveHandleCount, 1)
    testing.assertEq(snapshot.liveRootRefCount, 1)
    testing.assertEq(snapshot.runtimeRootCount, 1)
    testing.assertEq(snapshot.loweredAllocations, 1)
    testing.assertEq(snapshot.identityChecks, 1)

    match heap.lastLoweredAllocationTrace() {
        Some(trace) -> {
            testing.assertEq(trace.backend, GcLlvmBackend)
            testing.assertEq(trace.handle, handle)
            testing.assertEq(trace.objectId, objectId)
            testing.assertEq(trace.kind, GcRecord)
            testing.assertEq(trace.size, 24)
            testing.assertEq(trace.allocationSite, "llvm.emitStructLit")
            testing.assert(!(trace.usedThreadLocalBuffer))
        },
        None -> testing.fail("missing lowered allocation trace"),
    }
}

fn testLlvmRuntimeRootBridgeDropsReleasedRoots() {
    let mut heap = newGcHeap(testGcConfig())
    let handle = heap.allocateLlvmHandle(GcRecord, 24, "llvm.emitCall")
    let objectId = intOr(heap.llvmHandleObject(handle), -1)
    let rootRef = intOr(heap.bindLlvmRootRef(handle, GcLlvmStackRoot, "call.root"), -1)
    assertValid(heap)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(heap.contains(objectId))

    testing.assert(heap.releaseLlvmRootRef(rootRef))
    assertValid(heap)
    testing.assertEq(heap.llvmLiveRootRefCount(), 0)
    testing.assertEq(heap.llvmRuntimeRootCount(), 0)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(!(heap.contains(objectId)))
    testing.assertEq(intOr(heap.loadLlvmHandle(handle), -1), -1)

    let snapshot = heap.llvmBridgeSnapshot()
    testing.assertEq(snapshot.rootRefCount, 1)
    testing.assertEq(snapshot.liveHandleCount, 0)
    testing.assertEq(snapshot.staleHandleLoads, 1)
}

fn testLlvmPinnedRootReleaseClearsHandleAndObjectPinState() {
    let mut heap = newGcHeap(testGcConfig())
    let handle = heap.allocateLlvmHandle(GcRecord, 24, "llvm.pin")
    let objectId = intOr(heap.llvmHandleObject(handle), -1)
    let rootRef = intOr(heap.bindLlvmRootRef(handle, GcLlvmPinnedRoot, "pin.root"), -1)
