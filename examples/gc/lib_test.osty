    testing.assert(rootRef > 0)
    testing.assertEq(heap.llvmPinnedHandleCount(), 1)
    testing.assertEq(heap.pinnedObjectCount(), 1)
    testing.assertEq(heap.llvmRuntimeRootCount(), 1)

    testing.assert(heap.releaseLlvmRootRef(rootRef))
    assertValid(heap)
    testing.assertEq(heap.llvmLiveRootRefCount(), 0)
    testing.assertEq(heap.llvmPinnedHandleCount(), 0)
    testing.assertEq(heap.pinnedObjectCount(), 0)
    testing.assertEq(heap.llvmRuntimeRootCount(), 0)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(!(heap.contains(objectId)))
}

fn testValidateHeapRejectsLlvmPinnedRootWithoutPinnedHandle() {
    let mut heap = newGcHeap(testGcConfig())
    let handle = heap.allocateLlvmHandle(GcRecord, 24, "llvm.pin-corrupt")
    let rootRef = intOr(heap.bindLlvmRootRef(handle, GcLlvmPinnedRoot, "pin.corrupt"), -1)
    assertValid(heap)

    testing.assert(rootRef > 0)
    if heap.llvmHandles.containsKey(handle) {
        let entry = heap.llvmHandles[handle]
        let mut next = entry
        next.pinned = false
        heap.llvmHandles.insert(handle, next)
    } else {
        testing.fail("missing llvm handle")
    }

    let _ = testing.expectError(heap.validateHeap())
}

fn testValidateHeapRejectsLlvmBridgeRuntimeRootAccountingMismatch() {
    let mut heap = newGcHeap(testGcConfig())
    let handle = heap.allocateLlvmHandle(GcRecord, 24, "llvm.accounting")
    let rootRef = intOr(heap.bindLlvmRootRef(handle, GcLlvmStackRoot, "accounting.root"), -1)
    assertValid(heap)

    testing.assert(handle > 0)
    testing.assert(rootRef > 0)
    let mut trace = heap.llvmBridgeTrace
    trace.runtimeRootsAdded = 0
    heap.llvmBridgeTrace = trace

    let _ = testing.expectError(heap.validateHeap())
}

fn testLoweredLlvmStoreTraceCallsWriteBarrier() {
    let mut heap = newGcHeap(testGcConfig())
    let ownerHandle = heap.allocateLlvmHandle(GcRecord, 16, "llvm.owner")
    let childHandle = heap.allocateLlvmHandle(GcArray, 16, "llvm.child")
    let ownerObject = intOr(heap.llvmHandleObject(ownerHandle), -1)
    let childObject = intOr(heap.llvmHandleObject(childHandle), -1)
    testing.assert(intOr(heap.bindLlvmRootRef(ownerHandle, GcLlvmStackRoot, "owner.root"), -1) > 0)
    assertValid(heap)

    match heap.lowerLlvmStore(ownerHandle, 0, "child", childHandle) {
        Some(trace) -> {
            testing.assertEq(trace.backend, GcLlvmBackend)
            testing.assertEq(trace.ownerHandle, ownerHandle)
            testing.assertEq(trace.newHandle, childHandle)
            testing.assertEq(trace.ownerObjectId, ownerObject)
            testing.assertEq(trace.newObjectId, childObject)
            testing.assertEq(trace.oldObjectId, -1)
            testing.assertEq(trace.slot, 0)
            testing.assertEq(trace.name, "child")
            testing.assert(trace.postWriteCalled)
        },
        None -> testing.fail("lowered llvm store failed"),
    }
    assertValid(heap)

    testing.assertEq(intOr(heap.loweredObjectFieldValue(ownerObject, 0), -1), childObject)
    testing.assertEq(heap.barrierPostWriteCallCount(), 1)
    let snapshot = heap.llvmBridgeSnapshot()
    testing.assertEq(snapshot.loweredStores, 1)
    testing.assertEq(snapshot.handleStores, 1)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(heap.contains(ownerObject))
    testing.assert(heap.contains(childObject))

    match heap.lastLoweredStoreTrace() {
        Some(trace) -> {
            testing.assertEq(trace.ownerHandle, ownerHandle)
            testing.assertEq(trace.newHandle, childHandle)
        },
        None -> testing.fail("missing lowered store trace"),
    }
}

fn testMajorCompactionClosesHoles() {
    let mut heap = newGcHeap(testGcConfig())
    let first = heap.allocate(GcRecord, 10)
    let dead = heap.allocate(GcBytes, 20)
    let last = heap.allocate(GcRecord, 30)

    testing.assert(heap.addRoot(first))
    testing.assert(heap.addRoot(last))
    assertValid(heap)
    let beforeLast = intOr(heap.addressOf(last), -1)

    let stats = heap.majorCollect()
    assertValid(heap)
    let afterLast = intOr(heap.addressOf(last), -1)

    testing.assert(!(heap.contains(dead)))
    testing.assert(afterLast < beforeLast)
    testing.assertEq(afterLast, 10)
    testing.assertEq(stats.reclaimedObjects, 1)
    testing.assertEq(stats.compactedObjects, 1)
    testing.assertEq(heap.fragmentedBytes(), 0)
}

fn testFullMarkCollectorRecordsWorkQueueAndTypeScans() {
    let mut heap = newGcHeap(testGcConfig())
    let root = heap.allocate(GcRecord, 24)
    let child = heap.allocate(GcArray, 16)
    let grandchild = heap.allocate(GcClosure, 16)
    let dead = heap.allocate(GcBytes, 16)
    testing.assert(heap.addRoot(root))
    testing.assert(heap.link(root, child))
    testing.assert(heap.link(child, grandchild))
    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(heap.contains(root))
    testing.assert(heap.contains(child))
    testing.assert(heap.contains(grandchild))
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(stats.markSteps, 3)
    testing.assertEq(stats.reclaimedObjects, 1)
    testing.assertEq(heap.lastFullMarkObjectsScanned(), 3)
    testing.assertEq(heap.lastFullMarkPointerSlotsScanned(), 2)
    testing.assertEq(heap.lastFullMarkSweptObjects(), 1)
    testing.assertEq(intOr(heap.objectPointerSlotCount(root), -1), 1)
    testing.assertEq(intOr(heap.objectScalarBytes(root), -1), 16)
}

fn testEvacuationRecordsForwardingForMovedObjects() {
    let mut heap = newGcHeap(testGcConfig())
    let dead = heap.allocate(GcBytes, 16)
    let first = heap.allocate(GcRecord, 20)
    let second = heap.allocate(GcArray, 12)
