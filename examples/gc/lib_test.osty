    assertValid(heap)

    let stats = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(dead)))
    testing.assertEq(stats.compactedObjects, 2)
    testing.assertEq(heap.forwardingEntryCount(), 2)
    testing.assertEq(intOr(heap.forwardedFromAddress(first), -1), 16)
    testing.assertEq(intOr(heap.forwardedToAddress(first), -1), 0)
    testing.assertEq(intOr(heap.forwardedFromAddress(second), -1), 36)
    testing.assertEq(intOr(heap.forwardedToAddress(second), -1), 20)
    testing.assertEq(heap.lastEvacuationForwardedObjects(), 2)
    testing.assertEq(heap.lastEvacuationBytesCopied(), 32)
    testing.assert(heap.lastRemapVerified())
}

fn testRootAndObjectRemapTraceCoversForwardedHandles() {
