fn testPinnedObjectLeavesCompactionHoleUntilUnpinned() {
    let mut heap = newGcHeap(testGcConfig())
    let dead = heap.allocate(GcBytes, 20)
    let pinned = heap.allocate(GcRecord, 20)
    let tail = heap.allocate(GcArray, 10)

    testing.assert(heap.addRoot(pinned))
    testing.assert(heap.addRoot(tail))
    testing.assert(heap.pin(pinned))
    assertValid(heap)

    let first = heap.majorCollect()
    assertValid(heap)

    testing.assert(!(heap.contains(dead)))
    testing.assertEq(intOr(heap.addressOf(pinned), -1), 20)
    testing.assertEq(intOr(heap.addressOf(tail), -1), 40)
    testing.assertEq(regionOr(heap.regionOf(pinned), GcEdenRegion), GcPinnedRegion)
    testing.assertEq(heap.pinnedObjectCount(), 1)
    testing.assertEq(first.reclaimedObjects, 1)
    testing.assertEq(first.afterFragmentedBytes, 20)
    testing.assertEq(heap.fragmentedBytes(), 20)
    testing.assertEq(heap.tenuredFreeBytes(), 20)
    testing.assertEq(heap.lastEvacuationPinnedSkipped(), 1)

    testing.assert(heap.unpin(pinned))
    assertValid(heap)
    let second = heap.majorCollect()
    assertValid(heap)

    testing.assertEq(regionOr(heap.regionOf(pinned), GcEdenRegion), GcOldRegion)
    testing.assertEq(intOr(heap.addressOf(pinned), -1), 0)
    testing.assertEq(intOr(heap.addressOf(tail), -1), 20)
    testing.assertEq(heap.pinnedObjectCount(), 0)
    testing.assertEq(second.afterFragmentedBytes, 0)
    testing.assertEq(second.compactedObjects, 2)
    testing.assertEq(heap.fragmentedBytes(), 0)
    testing.assertEq(heap.tenuredFreeBytes(), 0)
}

fn testTenuredAllocationReusesPinnedCompactionHole() {
    let mut heap = newGcHeap(testGcConfig())
    let dead = heap.allocate(GcBytes, 20)
    let pinned = heap.allocate(GcRecord, 20)
    let tail = heap.allocate(GcArray, 10)

    testing.assert(heap.addRoot(pinned))
    testing.assert(heap.addRoot(tail))
    testing.assert(heap.pin(pinned))
    assertValid(heap)

    let _ = heap.majorCollect()
    assertValid(heap)
    testing.assert(!(heap.contains(dead)))
    testing.assertEq(heap.tenuredFreeBytes(), 20)

    let old = heap.allocateTenured(GcClosure, 12)
    assertValid(heap)

    testing.assertEq(intOr(heap.addressOf(old), -1), 0)
    testing.assertEq(intOr(heap.generationOf(old), -1), 1)
    testing.assertEq(regionOr(heap.regionOf(old), GcEdenRegion), GcOldRegion)
    testing.assertEq(heap.tenuredReuseAllocationCount(), 1)
    testing.assertEq(heap.tenuredFreeBytes(), 8)
    testing.assertEq(heap.fragmentedBytes(), 8)
}

fn testTryAllocateReportsOutOfMemoryAfterFullCollection() {
    let mut heap = newGcHeap(
        GcConfig {
            nurseryLimit: 64,
            survivorLimit: 32,
            heapLimit: 40,
            promotionAge: 1,
            incrementalBudget: 4,
            largeObjectThreshold: 512,
            tlabSize: 64,
            cardSize: 64,
            schedulerSafepointInterval: 2,
            mutatorAssistBytes: 32,
            concurrentMarkBudget: 1,
            evacuationThresholdPercent: 50,
        },
    )
    let rooted = heap.allocate(GcRecord, 32)
    testing.assert(heap.addRoot(rooted))
    assertValid(heap)

    let out = heap.tryAllocate(GcArray, 16)
    assertValid(heap)
    testing.expectError(out)
    match heap.lastCollectionStats() {
        Some(stats) -> {
            testing.assertEq(stats.kind, "major")
            testing.assertEq(stats.trigger, "heap-pressure")
            testing.assertEq(stats.allocationBytesSinceLastGC, 32)
        },
        None -> testing.fail("missing heap-pressure stats"),
    }
    testing.assert(heap.contains(rooted))
    testing.assertEq(heap.totalLiveBytes(), 32)
}

fn testTlabFastPathAllocatesFromThreadLocalBuffer() {
    let mut heap = newGcHeap(testGcConfig())

    let first = heap.allocateThread(1, GcRecord, 16)
    let second = heap.allocateThread(1, GcArray, 16)
    let third = heap.allocateThread(1, GcClosure, 16)
    assertValid(heap)

    testing.assert(heap.contains(first))
    testing.assert(heap.contains(second))
    testing.assert(heap.contains(third))
    testing.assertEq(intOr(heap.addressOf(first), -1), 0)
    testing.assertEq(intOr(heap.addressOf(second), -1), 16)
    testing.assertEq(intOr(heap.addressOf(third), -1), 32)
    testing.assertEq(heap.tlabCount(), 1)
    testing.assertEq(heap.tlabRefillCount(), 1)
    testing.assertEq(heap.tlabSlowAllocationCount(), 1)
    testing.assertEq(heap.tlabFastAllocationCount(), 3)
    testing.assertEq(intOr(heap.tlabRemaining(1), -1), 16)
    match heap.lastCollectionStats() {
        Some(_) -> testing.fail("tlab fast allocation unexpectedly ran collection"),
        None -> {},
    }
}

fn testTlabRefillAccountsWasteWithoutCollecting() {
    let mut heap = newGcHeap(
        GcConfig {
            nurseryLimit: 512,
            survivorLimit: 128,
            heapLimit: 4096,
            promotionAge: 1,
            incrementalBudget: 1,
            largeObjectThreshold: 512,
            tlabSize: 64,
            cardSize: 64,
            schedulerSafepointInterval: 2,
            mutatorAssistBytes: 32,
            concurrentMarkBudget: 1,
            evacuationThresholdPercent: 50,
        },
    )

    let first = heap.allocateThread(1, GcRecord, 16)
    let second = heap.allocateThread(1, GcArray, 40)
    testing.assertEq(intOr(heap.tlabRemaining(1), -1), 8)

    let third = heap.allocateThread(1, GcClosure, 16)
    assertValid(heap)

    testing.assert(heap.contains(first))
    testing.assert(heap.contains(second))
    testing.assert(heap.contains(third))
    testing.assertEq(intOr(heap.addressOf(first), -1), 0)
    testing.assertEq(intOr(heap.addressOf(second), -1), 16)
    testing.assertEq(intOr(heap.addressOf(third), -1), 64)
    testing.assertEq(heap.tlabRefillCount(), 2)
    testing.assertEq(heap.tlabSlowAllocationCount(), 2)
    testing.assertEq(heap.tlabFastAllocationCount(), 3)
    testing.assertEq(heap.tlabWasteBytes(), 8)
    testing.assertEq(intOr(heap.tlabRemaining(1), -1), 48)
    match heap.lastCollectionStats() {
        Some(_) -> testing.fail("tlab refill unexpectedly ran collection"),
        None -> {},
    }
}

fn testTlabRefillCanTriggerNurseryCollection() {
    let mut heap = newGcHeap(
        GcConfig {
            nurseryLimit: 48,
            survivorLimit: 16,
            heapLimit: 4096,
            promotionAge: 1,
            incrementalBudget: 1,
            largeObjectThreshold: 512,
            tlabSize: 64,
            cardSize: 64,
            schedulerSafepointInterval: 2,
            mutatorAssistBytes: 32,
            concurrentMarkBudget: 1,
            evacuationThresholdPercent: 50,
        },
    )

    let deadA = heap.allocateThread(1, GcRecord, 16)
    let deadB = heap.allocateThread(1, GcArray, 40)
    testing.assert(heap.contains(deadA))
    testing.assert(heap.contains(deadB))
    testing.assertEq(intOr(heap.tlabRemaining(1), -1), 8)

    let survivor = heap.allocateThread(1, GcClosure, 16)
    assertValid(heap)

    testing.assert(!(heap.contains(deadA)))
    testing.assert(!(heap.contains(deadB)))
    testing.assert(heap.contains(survivor))
    testing.assertEq(heap.tlabRefillCount(), 2)
    testing.assertEq(heap.tlabWasteBytes(), 8)
    testing.assertEq(intOr(heap.tlabRemaining(1), -1), 48)
    match heap.lastCollectionStats() {
        Some(stats) -> {
            testing.assertEq(stats.kind, "minor")
            testing.assertEq(stats.trigger, "tlab-refill")
            testing.assertEq(stats.reclaimedObjects, 2)
        },
        None -> testing.fail("missing tlab refill collection stats"),
    }
}

fn testCollectionRetiresActiveTlabAndAccountsWaste() {
