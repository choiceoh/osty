    let mark = heap.mutatorAssist(16)
    assertValid(heap)
    testing.assertEq(mark.kind, "incremental-mark")
    testing.assertEq(mark.markSteps, 1)
    testing.assertEq(heap.schedulerAllocationDebtBytes(), 32)
    testing.assertEq(heap.schedulerMutatorAssistStepCount(), 1)
    testing.assertEq(heap.schedulerCycleStartCount(), 1)

    let done = heap.finishIncremental()
    assertValid(heap)
    testing.assertEq(done.kind, "incremental-sweep")
