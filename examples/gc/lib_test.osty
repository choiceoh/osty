            allocatedCycle: 0,
        },
    )
    objects.insert(
        2,
        GcObject {
            id: 2,
            kind: GcArray,
            size: 16,
            address: 16,
            generation: 0,
            age: 0,
            color: GcWhite,
            marked: false,
            pinned: false,
            large: false,
            region: GcEdenRegion,
            refs: [],
            remembered: false,
            allocatedCycle: 0,
        },
    )
    let empty: List<Int> = []
    let globalRoots: Map<String, GcGlobalRoot> = {:}
