use std.testing

fn assertValid(heap: GcHeap) {
    match heap.validateHeap() {
        Ok(_) -> {},
        Err(e) -> testing.fail(e),
    }
}

fn emptyTestStackMap() -> GcStackMap {
    let frameLayout: List<GcFrameSlot> = []
    let entries: List<GcStackMapEntry> = []
    GcStackMap {
        functionName: "",
        frameSlots: 0,
        pointerSize: 0,
        inlineSlots: 0,
        frameLayout,
        entries,
    }
}

fn emptyTestStackMapEntry() -> GcStackMapEntry {
    let bitmapWords: List<Int> = []
    let overflowSlots: List<Int> = []
    let derivedRoots: List<GcDerivedRootMap> = []
    GcStackMapEntry {
        safepointId: 0,
        instructionOffset: 0,
        liveCount: 0,
        inlineSlots: 0,
        bitmapWords,
        overflowSlots,
        derivedRoots,
    }
}

fn testValidateHeapRejectsLiveByteMismatch() {
    let refs: List<Int> = []
    let mut objects: Map<Int, GcObject> = {:}
    objects.insert(
        1,
        GcObject {
            id: 1,
            kind: GcRecord,
            size: 16,
            address: 0,
            generation: 0,
            age: 0,
            color: GcWhite,
            marked: false,
            pinned: false,
            large: false,
            region: GcEdenRegion,
            refs,
            remembered: false,
            allocatedCycle: 0,
        },
    )
    let empty: List<Int> = []
    let globalRoots: Map<String, GcGlobalRoot> = {:}
    let heap = GcHeap {
        config: testGcConfig(),
        nextId: 2,
        nextAddress: 16,
        liveBytes: 15,
        cycle: 0,
        minorCollections: 0,
        majorCollections: 0,
        phase: GcIdle,
        objects,
        roots: empty.toSet(),
        globalRoots,
        remembered: empty.toSet(),
        grey: [],
        allocatedSinceLastGC: 16,
        lastStats: None,
    }

    let _ = testing.expectError(heap.validateHeap())
}

