// §4 Expressions — blocks, if/match/for, closures, ranges, ?/?./??, etc.

pub enum Shape {
    Circle(Float),
    Rect(Float, Float),
    Empty,
}

fn block_expr() -> Int {
    let x = {
        let tmp = 1 + 2
        tmp * 2
    }
    x
}

fn if_expr(score: Int) -> String {
    if score >= 90 {
        "A"
    } else if score >= 80 {
        "B"
    } else {
        "C"
    }
}

fn if_let(u: Int?) -> Int {
    if let Some(n) = u {
        n
    } else {
        0
    }
}

fn match_expr(s: Shape) -> Float {
    match s {
        Circle(r) -> 3.14 * r * r,
        Rect(w, h) -> w * h,
        Empty -> 0.0,
    }
}

fn match_guards(n: Int?) -> String {
    match n {
        Some(v) if v > 0 -> "positive",
        Some(v) if v < 0 -> "negative",
        Some(_) -> "zero",
        None -> "missing",
    }
}

fn patterns(n: Int) -> String {
    match n {
        0 -> "zero",
        x @ 1..=9 -> "single: {x}",
        x @ 10..=99 -> "double: {x}",
        _ -> "many",
    }
}

fn or_pattern(s: Shape) -> Float {
    match s {
        Circle(r) | Rect(r, _) -> r,
        Empty -> 0.0,
    }
}

fn loops() {
    for i in 0..10 {
        if i > 5 { break }
    }
    for i in 0..=10 { }
    for x in [1, 2, 3] {
        if x == 2 { continue }
    }
    for let Some(_) = None { }
    for cond() {
        break
    }
    for {
        break
    }
}

fn cond() -> Bool { false }

fn error_propagation(path: String) -> Result<Int, Error> {
    let text = readOrErr(path)?
    let parsed: Int = parseOrErr(text)?
    Ok(parsed)
}

fn readOrErr(_p: String) -> Result<String, Error> { Ok("") }
fn parseOrErr(_t: String) -> Result<Int, Error> { Ok(0) }

fn optional_chaining(u: User?) -> String {
    let name = u?.name ?? "anonymous"
    name
}

pub struct User {
    pub name: String,
}

fn closures() {
    let double = |x| x * 2
    let add = |a: Int, b: Int| -> Int { a + b }
    let destructure = |(k, v)| k + v
    let wildcard_closure = |(_, second)| second
    let block_body = |x| {
        let y = x * 2
        y + 1
    }
}

fn ranges() {
    let r1 = 0..10
    let r2 = 0..=10
    let r3 = ..50
    let r4 = 100..
}

fn defers(path: String) -> Result<(), Error> {
    let h = open(path)?
    defer close(h)

    let conn = connect()?
    defer close(conn)

    Ok(())
}

fn open(_path: String) -> Result<Int, Error> { Ok(0) }
fn close(_h: Int) { }
fn connect() -> Result<Int, Error> { Ok(0) }

struct CompoundCursor {
    pos: Int,

    fn advance(mut self, by: Int) {
        self.pos += by
    }
}

fn compound_assignment_idents() {
    let mut n: Int = 100
    n += 5
    n -= 3
    n *= 2
    n /= 4
    n %= 7
    let _ = n
}

fn compound_assignment_bitwise() {
    let mut bits: Int = 0b1100
    bits &= 0b1010
    bits |= 0b0001
    bits ^= 0b0011
    bits <<= 2
    bits >>= 1
    let _ = bits
}

fn compound_assignment_string() {
    let mut msg: String = "hello"
    msg += ", "
    msg += "world"
    let _ = msg
}

fn compound_assignment_field() {
    let mut cur = CompoundCursor { pos: 0 }
    cur.advance(3)
    cur.pos += 1
    let _ = cur.pos
}

// G25 §A.4: `by` step on range expressions.
fn range_step_inclusive() -> Int {
    let mut sum = 0
    for i in 0..=10 by 2 {
        sum = sum + i
    }
    sum
}

fn range_step_exclusive() -> Int {
    let mut acc = 0
    for i in 0..100 by 10 {
        acc = acc + i
    }
    acc
}

fn range_step_negative() -> Int {
    let mut sum = 0
    for i in 10..0 by -1 {
        sum = sum + i
    }
    sum
}

// G22 §A.4: `loop { ... }` expression with `break value`.
fn loop_break_value() -> Int {
    let x = loop {
        break 42
    }
    x
}

fn loop_break_computed(n: Int) -> Int {
    let mut i = 0
    loop {
        if i >= n { break i * 2 }
        i = i + 1
    }
}

// G26 §A.2: struct update shorthand `x { field: v }` ≡ `T { ..x, field: v }`.
pub struct PointG26 { pub x: Int, pub y: Int }

fn shift_right(p: PointG26, dx: Int) -> PointG26 {
    p { x: p.x + dx }
}

fn double_both(p: PointG26) -> PointG26 {
    p { x: p.x * 2, y: p.y * 2 }
}

// G23 §A.2: trailing closure — `f(a) |x| { body }` ≡ `f(a, |x| { body })`.
fn apply_g23(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn apply_trailing() -> Int {
    apply_g23(3) |n| { n * 2 }
}

fn apply_trailing_multi_arg() -> Int {
    apply_g23(3) |n| {
        let doubled = n * 2
        doubled + 1
    }
}

// G24 §4.4: labeled loops + `break 'label v` / `continue 'label`.
fn labeled_break_target() -> Int {
    let x = 'outer: loop {
        for n in 0..10 {
            if n == 5 { break 'outer 42 }
        }
        break 0
    }
    x
}

fn labeled_continue_target() -> Int {
    let mut total = 0
    'outer: for i in 0..3 {
        for j in 0..3 {
            if j == 1 { continue 'outer }
            total = total + i + j
        }
    }
    total
}
