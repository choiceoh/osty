// Negative corpus — one file per rejected construct would explode the
// corpus count, so this file bundles representative "must reject" cases.
// The integration test invokes the parser+resolver on each subsection
// and asserts the expected diagnostic code. Subsections are delimited
// by `// === CASE: <Code> === <hint>` lines and terminated by `// === END`.

// === CASE: E0001 === unterminated string literal
fn f() { let s = "hello
}
// === END

// === CASE: E0002 === uppercase base prefix
fn f() { let n = 0X1F }
// === END

// === CASE: E0003 === surrogate code point in escape
fn f() { let c = '\u{D800}' }
// === END

// === CASE: E0005 === illegal (non-ASCII) character outside strings
fn f() { let x = 1 ⚡ 2 }
// === END

// === CASE: E0006 === triple-quoted string without leading newline
fn f() { let s = """oops""" }
// === END

// === CASE: E0007 === fat-arrow removed
fn f() -> Int { match 0 { 0 => 1, _ => 2 } }
// === END

// === CASE: E0008 === numeric separator placement
fn f() { let a = 1_; let b = 0x_FF; let c = 1__000 }
// === END

// === CASE: E0009 === empty char / byte literal
fn f() { let a = ''; let b = b'' }
// === END

// === CASE: E0101 === `use go` fn with body
use go "net/http" { fn Get(u: String) -> String { "x" } }
// === END

// === CASE: E0104 === mixed dot/slash in use path
use a/b.c
// === END

// === CASE: E0105 === `} else` across newline
fn f() -> Int {
    if cond() {
        1
    }
    else {
        2
    }
}
fn cond() -> Bool { false }
// === END

// === CASE: E0106 === non-literal default value
fn connect(t: Int = compute()) {}
fn compute() -> Int { 0 }
// === END

// === CASE: E0107 === token not starting a struct member
pub struct S {
    123,
}
// === END

// === CASE: E0108 === token not starting an enum member
pub enum E {
    123,
}
// === END

// === CASE: E0109 === token not starting an interface member
pub interface I {
    123,
}
// === END

// === CASE: E0200 === non-associative comparison chain
fn f() { a() < b() < c() }
fn a() -> Int { 0 }
fn b() -> Int { 0 }
fn c() -> Int { 0 }
// === END

// === CASE: E0201 === `::` not followed by `<`
fn f() { let x = foo::bar() }
fn foo() {}
// === END

// === CASE: E0203 === closure with return type but no block body
fn f() { let g = |x: Int| -> Int x * 2 }
// === END

// === CASE: E0205 === token not starting a closure parameter
fn f() { let g = |123| 0 }
// === END

// === CASE: E0301 === token not starting a pattern
fn f(x: Int) -> Int { match x { + -> 1, _ -> 0 } }
// === END

// === CASE: E0400 === unknown annotation
// (Historically `#[inline]` was unknown; it was added to the permitted
// set in v0.6 A8, so the example is now any still-unregistered name.)
#[magicOptimize]
pub fn f() {}
// === END

// === CASE: E0500 === undefined name
fn f() { let x = undefinedThing }
// === END

// === CASE: E0501 === duplicate top-level declaration
fn dup() {}
fn dup() {}
// === END

// === CASE: E0503 === `self` outside a method
fn f() { let x = self }
// === END

// === CASE: E0504 === `Self` outside a type body
fn f() -> Self { 0 }
// === END

// === CASE: E0600 === `break` outside a loop
fn f() { break }
// === END

// === CASE: E0601 === `continue` outside a loop
fn f() { continue }
// === END

// === CASE: E0604 === `_` in expression position
fn f() { let x = _ }
// === END

// === CASE: E0605 === or-pattern with inconsistent bindings
pub enum E { A(Int), B(Int, Int) }
fn f(e: E) -> Int {
    match e { A(x) | B(x, y) -> x }
}
// === END

// === CASE: E0606 === interface default body reading a field on self
pub interface Greeter {
    fn greet(self) -> String { self.name }
}
// === END

// === CASE: E0607 === annotation on the wrong target
#[json]
pub fn wrongTarget() {}
// === END

// === CASE: E0607 === annotation on a `use` statement
#[deprecated]
use std.fs
// === END

// === CASE: E0608 === top-level `defer` in script
let x = 1
defer println("{x}")
// === END

// === CASE: E0609 === duplicate annotation name
#[deprecated]
#[deprecated]
pub fn f() {}
// === END

// === CASE: E0607 === #[vectorize] on a struct field (wrong target)
pub struct Bad {
    #[vectorize]
    pub count: Int,
}
// === END

// === CASE: E0739 === #[vectorize] rejects unknown argument keys
#[vectorize(foo = 4)]
pub fn hot(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[vectorize] rejects width out of range
#[vectorize(width = 99999)]
pub fn hot(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[unroll] rejects unknown argument keys
#[unroll(factor = 4)]
pub fn hot(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[parallel] takes no arguments
#[parallel(level = 2)]
pub fn hot(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[inline(...)] rejects unknown flag
#[inline(sometimes)]
pub fn mid(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[hot] takes no arguments
#[hot(priority = 1)]
pub fn hot(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[target_feature(...)] requires at least one feature
#[target_feature()]
pub fn wide(n: Int) -> Int { n }
// === END

// === CASE: E0739 === #[target_feature(...)] rejects duplicate features
#[target_feature(avx512f, avx512f)]
pub fn wide(n: Int) -> Int { n }
// === END

// === CASE: E0004 === unterminated block comment (MUST remain last — the
// unclosed /* is intentional and swallows every byte to EOF).
/* never closes
