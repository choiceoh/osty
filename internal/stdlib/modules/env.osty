// std.env ‚Äî command-line arguments and environment variables.
//
// Tier 2 module (spec ¬ß10.2). Bridged to Go's `os` package in the
// transpiler: `env.args()` ‚Üí `os.Args`, `env.get`/`env.set` ‚Üí
// `os.Getenv`/`os.Setenv`. Missing variables return the empty string;
// callers who need present/absent discrimination should check for
// that explicitly.

pub fn args() -> List<String> { [] }

pub fn get(key: String) -> String { "" }

pub fn set(key: String, value: String) {}
