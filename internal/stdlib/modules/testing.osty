// std.testing — assertion API for `osty test` per LANG_SPEC_v0.3 §11.
//
// Test files use the `_test.osty` suffix and live alongside code in the
// same package. Functions whose names begin with lowercase `test` and
// take no arguments are discovered and run by `osty test`; functions
// whose names begin with `bench` are benchmarks (§11.4).
//
// Core assertion/runner helpers are declaration-only: both LLVM codegen
// paths intercept these call sites and lower them to the real test
// runtime / harness behavior.

pub fn assert(cond: Bool)

pub fn assertTrue(cond: Bool)

pub fn assertFalse(cond: Bool)

pub fn assertEq<T: Equal>(actual: T, expected: T)

pub fn assertNe<T: Equal>(actual: T, expected: T)

pub fn expectOk<T, E>(result: Result<T, E>) -> T

pub fn expectError<T, E>(result: Result<T, E>) -> E

pub fn fail(msg: String) -> Never

pub fn context(msg: String, body: fn() -> ())

pub fn benchmark(iterations: Int, body: fn() -> Result<(), Error>)

/// `snapshot(name, output)` compares `output` against a golden file
/// stored at `<source_dir>/__snapshots__/<sanitize(name)>.snap`.
///
///   - First run (or file missing): the golden is written and the
///     test passes with `snapshot: created <path>` on stdout.
///   - Match: the test passes silently.
///   - Mismatch: the test prints the location + a line-level diff
///     (trim prefix/suffix with up to 3 context lines) and exits 1,
///     just like `assertEq`.
///
/// Re-run `osty test --update-snapshots` (or set
/// `OSTY_UPDATE_SNAPSHOTS=1`) to accept the new output and overwrite
/// every golden in the run. Both LLVM codegen paths intercept this
/// call and emit a direct runtime helper.
pub fn snapshot(name: String, output: String)

// ---------- property-based testing (v0.5 G33) ----------

// `Gen<T>` is declared here so `property` / `propertyN` /
// `propertySeeded` can name it without importing
// `std.testing.gen` (which would import `std.testing` in turn).
// The combinators that produce values of this type live in
// `std.testing.gen` — import that submodule to build generators.
//
// Users write:
//
//     use std.testing as testing
//     use std.testing.gen as gen
//
//     testing.property("reverse is involutive",
//         gen.list(gen.int(), 32),
//         |xs: List<Int>| xs.reversed().reversed() == xs,
//     )

/// `Gen<T>` is the opaque-ish sampler wrapper produced by the
/// `std.testing.gen` combinators. Direct construction via `Gen
/// { ... }` is reserved for stdlib internals.
pub struct Gen<T> {
    pub seed: Int,
    pub tag: Int,
}

/// `property(name, g, pred)` runs `pred` against ~100 samples drawn
/// from `g` and records one test result (pass / shrunk-
/// counterexample failure) in the surrounding test case. Seed
/// defaults to the runner-wide seed so a failing property is
/// reproducible.
pub fn property<T>(name: String, g: Gen<T>, pred: fn(T) -> Bool)

/// `propertyN` varies the sample budget. Use with large generators
/// where 100 samples is too thin, or with cheap generators where
/// more samples improve coverage.
pub fn propertyN<T>(name: String, g: Gen<T>, iterations: Int, pred: fn(T) -> Bool)

/// `propertySeeded` pins the sample seed — useful inside a test
/// that wants the property replay to match an earlier failing run.
pub fn propertySeeded<T>(name: String, g: Gen<T>, seed: Int, pred: fn(T) -> Bool)
