fn fromCharsSlice(chars: List<Char>, start: Int, end: Int) -> String {
    let mut out = ""
    let mut i = start
    for i < end {
        out = "{out}{chars[i]}"
        i = i + 1
    }
    out
}

fn matchesAt(chars: List<Char>, needle: List<Char>, at: Int) -> Bool {
    if at < 0 || at + needle.len() > chars.len() {
        return false
    }
    for i in 0..needle.len() {
        if chars[at + i] != needle[i] {
            return false
        }
    }
    true
}

// Boyer-Moore-Horspool skip: how far we can advance when the current last-char
// alignment fails. We linear-scan the needle instead of building a hash table
// because Char covers 0x110000 scalars and most needles are short; for a needle
// of length m the scan is O(m) but BMH still shifts by up to m per mismatch,
// so average complexity stays near O(n) instead of naive O(n*m).
fn bmhSkip(needle: List<Char>, c: Char) -> Int {
    let m = needle.len()
    let mut i = m - 2
    for i >= 0 {
        if needle[i] == c {
            return m - 1 - i
        }
        i = i - 1
    }
    m
}

fn indexOfCharsBMH(chars: List<Char>, needle: List<Char>) -> Int {
    let n = chars.len()
    let m = needle.len()
    if m > n {
        return -1
    }
    let mut i = 0
    for i + m <= n {
        if matchesAt(chars, needle, i) {
            return i
        }
        i = i + bmhSkip(needle, chars[i + m - 1])
    }
    -1
}

fn indexOfChars(chars: List<Char>, needle: List<Char>) -> Int {
    if needle.len() == 0 {
        return 0
    }
    if needle.len() >= 4 {
        return indexOfCharsBMH(chars, needle)
    }
    let mut i = 0
    for i + needle.len() <= chars.len() {
        if matchesAt(chars, needle, i) {
            return i
        }
        i = i + 1
    }
    -1
}

fn lastIndexOfChars(chars: List<Char>, needle: List<Char>) -> Int {
    if needle.len() == 0 {
        return chars.len()
    }
    if needle.len() > chars.len() {
        return -1
    }
    let mut i = chars.len() - needle.len()
    for i >= 0 {
        if matchesAt(chars, needle, i) {
            return i
        }
        if i == 0 {
            break
        }
        i = i - 1
    }
    -1
}

fn inRanges(ranges: List<Int>, r: Int) -> Bool {
    let mut lo = 0
    let mut hi = ranges.len() / 2
    for lo < hi {
        let mid = (lo + hi) / 2
        let end = ranges[mid * 2 + 1]
        if end < r {
            lo = mid + 1
        } else {
            hi = mid
        }
    }
    lo < ranges.len() / 2 && ranges[lo * 2] <= r
}

fn graphemeBreakProperty(r: Int) -> Int {
    if inRanges(graphemeBreakCRRanges, r) {
        return graphemeBreakCR
    }
    if inRanges(graphemeBreakLFRanges, r) {
        return graphemeBreakLF
    }
    if inRanges(graphemeBreakControlRanges, r) {
        return graphemeBreakControl
    }
    if inRanges(graphemeBreakExtendRanges, r) {
        return graphemeBreakExtend
    }
    if inRanges(graphemeBreakZWJRanges, r) {
        return graphemeBreakZWJ
    }
    if inRanges(graphemeBreakRegionalIndicatorRanges, r) {
        return graphemeBreakRegionalIndicator
    }
    if inRanges(graphemeBreakPrependRanges, r) {
        return graphemeBreakPrepend
    }
    if inRanges(graphemeBreakSpacingMarkRanges, r) {
        return graphemeBreakSpacingMark
    }
    if inRanges(graphemeBreakLRanges, r) {
        return graphemeBreakL
    }
    if inRanges(graphemeBreakVRanges, r) {
        return graphemeBreakV
    }
    if inRanges(graphemeBreakTRanges, r) {
        return graphemeBreakT
    }
    if inRanges(graphemeBreakLVRanges, r) {
        return graphemeBreakLV
    }
    if inRanges(graphemeBreakLVTRanges, r) {
        return graphemeBreakLVT
    }
    graphemeBreakOther
}

fn indicConjunctBreakProperty(r: Int) -> Int {
    if inRanges(graphemeInCBConsonantRanges, r) {
        return indicConjunctConsonant
    }
    if inRanges(graphemeInCBExtendRanges, r) {
        return indicConjunctExtend
    }
    if inRanges(graphemeInCBLinkerRanges, r) {
        return indicConjunctLinker
    }
    indicConjunctNone
}

fn isExtendedPictographic(r: Int) -> Bool {
    inRanges(graphemeExtendedPictographicRanges, r)
}

fn hasExtendedPictographicZWJPrefix(chars: List<Char>, i: Int) -> Bool {
    let zwj = 0x200D
    let mut j = i - 1
    if j < 0 || chars[j].toInt() != zwj {
        return false
    }
    j = j - 1
    for j >= 0 && graphemeBreakProperty(chars[j].toInt()) == graphemeBreakExtend {
        j = j - 1
    }
    j >= 0 && isExtendedPictographic(chars[j].toInt())
}

fn hasIndicConjunctLinkerPrefix(chars: List<Char>, i: Int) -> Bool {
    if indicConjunctBreakProperty(chars[i].toInt()) != indicConjunctConsonant {
        return false
    }
    let mut seenLinker = false
    let mut j = i - 1
    for j >= 0 {
        let prop = indicConjunctBreakProperty(chars[j].toInt())
        if prop == indicConjunctExtend {
            j = j - 1
            continue
        }
        if prop == indicConjunctLinker {
            seenLinker = true
            j = j - 1
            continue
        }
        if prop == indicConjunctConsonant {
            return seenLinker
        }
        return false
    }
    false
}

fn graphemeNoBreak(chars: List<Char>, i: Int, prev: Int, curr: Int, riRun: Int) -> Bool {
    if prev == graphemeBreakCR && curr == graphemeBreakLF {
        return true
    }
    if prev == graphemeBreakCR || prev == graphemeBreakLF || prev == graphemeBreakControl {
        return false
    }
    if curr == graphemeBreakCR || curr == graphemeBreakLF || curr == graphemeBreakControl {
        return false
    }
    if prev == graphemeBreakL && (curr == graphemeBreakL || curr == graphemeBreakV || curr == graphemeBreakLV || curr == graphemeBreakLVT) {
        return true
    }
    if (prev == graphemeBreakLV || prev == graphemeBreakV) && (curr == graphemeBreakV || curr == graphemeBreakT) {
        return true
    }
    if (prev == graphemeBreakLVT || prev == graphemeBreakT) && curr == graphemeBreakT {
        return true
    }
    if curr == graphemeBreakExtend || curr == graphemeBreakZWJ {
        return true
    }
    if curr == graphemeBreakSpacingMark {
        return true
    }
    if prev == graphemeBreakPrepend {
        return true
    }
    if hasIndicConjunctLinkerPrefix(chars, i) {
        return true
    }
    if isExtendedPictographic(chars[i].toInt()) && hasExtendedPictographicZWJPrefix(chars, i) {
        return true
    }
    if prev == graphemeBreakRegionalIndicator && curr == graphemeBreakRegionalIndicator {
        return riRun % 2 == 1
    }
    false
}

fn graphemesFromChars(chars: List<Char>) -> List<String> {
    if chars.len() == 0 {
        return []
    }
    let mut out: List<String> = []
    let mut start = 0
    let mut riRun = 0
    if graphemeBreakProperty(chars[0].toInt()) == graphemeBreakRegionalIndicator {
        riRun = 1
    }
    for i in 1..chars.len() {
        let prev = graphemeBreakProperty(chars[i - 1].toInt())
        let curr = graphemeBreakProperty(chars[i].toInt())
        let noBreak = graphemeNoBreak(chars, i, prev, curr, riRun)
        if !noBreak {
            out.push(fromCharsSlice(chars, start, i))
            start = i
        }
        if curr == graphemeBreakRegionalIndicator {
            if noBreak {
                riRun = riRun + 1
            } else {
                riRun = 1
            }
        } else {
            riRun = 0
        }
    }
    out.push(fromCharsSlice(chars, start, chars.len()))
    out
}

pub fn len(s: String) -> Int {
    s.bytes().len()
}

pub fn isEmpty(s: String) -> Bool {
    s.bytes().len() == 0
}

pub fn charCount(s: String) -> Int {
    s.chars().len()
}

pub fn get(s: String, i: Int) -> Byte? {
    let bytes = s.bytes()
    if i < 0 || i >= bytes.len() {
        None
    } else {
        Some(bytes[i])
    }
}

pub fn slice(s: String, start: Int, end: Int) -> String {
    s[start..end]
}

pub fn concat(a: String, b: String) -> String {
    "{a}{b}"
}

pub fn chars(s: String) -> List<Char> {
    s.chars()
}

pub fn bytes(s: String) -> List<Byte> {
    s.bytes()
}

pub fn graphemes(s: String) -> List<String> {
    graphemesFromChars(s.chars())
}

pub fn toBytes(s: String) -> Bytes {
    s.toBytes()
}

pub fn toInt(s: String) -> Result<Int, Error> {
    s.toInt()
}

pub fn toFloat(s: String) -> Result<Float, Error> {
    s.toFloat()
}

pub fn split(s: String, sep: String) -> List<String> {
    let chars = s.chars()
    let needle = sep.chars()
    let mut out: List<String> = []
    if needle.len() == 0 {
        for c in chars {
            out.push("{c}")
        }
        return out
    }
    let mut start = 0
    let mut i = 0
    for i + needle.len() <= chars.len() {
        if matchesAt(chars, needle, i) {
            out.push(fromCharsSlice(chars, start, i))
            i = i + needle.len()
            start = i
        } else {
            i = i + 1
        }
    }
    out.push(fromCharsSlice(chars, start, chars.len()))
    out
}

pub fn splitN(s: String, sep: String, n: Int) -> List<String> {
    if n == 0 {
        return []
    }
    if n < 0 {
        return split(s, sep)
    }
    if n == 1 {
        return [s]
    }

    let chars = s.chars()
    let needle = sep.chars()
    let mut out: List<String> = []
    if needle.len() == 0 {
        let mut i = 0
        for i < chars.len() && out.len() < n - 1 {
            out.push("{chars[i]}")
            i = i + 1
        }
        if i < chars.len() {
            out.push(fromCharsSlice(chars, i, chars.len()))
        }
        return out
    }

    let mut start = 0
    let mut i = 0
    for i + needle.len() <= chars.len() && out.len() < n - 1 {
        if matchesAt(chars, needle, i) {
            out.push(fromCharsSlice(chars, start, i))
            i = i + needle.len()
            start = i
        } else {
            i = i + 1
        }
    }
    out.push(fromCharsSlice(chars, start, chars.len()))
    out
}

pub fn lines(s: String) -> List<String> {
    split(s, "\n")
}

pub fn join(parts: List<String>, sep: String) -> String {
    if parts.isEmpty() {
        return ""
    }
    let mut out = parts[0]
    for i in 1..parts.len() {
        out = "{out}{sep}{parts[i]}"
    }
    out
}

pub fn contains(s: String, substr: String) -> Bool {
    indexOfChars(s.chars(), substr.chars()) >= 0
}

pub fn indexOf(s: String, substr: String) -> Int? {
    let at = indexOfChars(s.chars(), substr.chars())
    if at < 0 {
        None
    } else {
        Some(at)
    }
}

pub fn lastIndexOf(s: String, substr: String) -> Int? {
    let at = lastIndexOfChars(s.chars(), substr.chars())
    if at < 0 {
        None
    } else {
        Some(at)
    }
}

pub fn count(s: String, substr: String) -> Int {
    let chars = s.chars()
    let needle = substr.chars()
    if needle.len() == 0 {
        return chars.len() + 1
    }
    let mut total = 0
    let mut i = 0
    for i + needle.len() <= chars.len() {
        if matchesAt(chars, needle, i) {
            total = total + 1
            i = i + needle.len()
        } else {
            i = i + 1
        }
    }
    total
}

pub fn startsWith(s: String, prefix: String) -> Bool {
    matchesAt(s.chars(), prefix.chars(), 0)
}

pub fn hasPrefix(s: String, prefix: String) -> Bool {
    startsWith(s, prefix)
}

pub fn endsWith(s: String, suffix: String) -> Bool {
    let chars = s.chars()
    let needle = suffix.chars()
    matchesAt(chars, needle, chars.len() - needle.len())
}

pub fn hasSuffix(s: String, suffix: String) -> Bool {
    endsWith(s, suffix)
}

pub fn trim(s: String) -> String {
    trimEnd(trimStart(s))
}

pub fn trimSpace(s: String) -> String {
    trim(s)
}

pub fn trimStart(s: String) -> String {
    let chars = s.chars()
    let mut start = 0
    for start < chars.len() && chars[start].isWhitespace() {
        start = start + 1
    }
    fromCharsSlice(chars, start, chars.len())
}

pub fn trimEnd(s: String) -> String {
    let chars = s.chars()
    let mut end = chars.len()
    for end > 0 && chars[end - 1].isWhitespace() {
        end = end - 1
    }
    fromCharsSlice(chars, 0, end)
}

pub fn trimPrefix(s: String, prefix: String) -> String {
    let chars = s.chars()
    let needle = prefix.chars()
    if matchesAt(chars, needle, 0) {
        return fromCharsSlice(chars, needle.len(), chars.len())
    }
    s
}

pub fn trimSuffix(s: String, suffix: String) -> String {
    let chars = s.chars()
    let needle = suffix.chars()
    let start = chars.len() - needle.len()
    if matchesAt(chars, needle, start) {
        return fromCharsSlice(chars, 0, start)
    }
    s
}

pub fn toUpper(s: String) -> String {
    let mut out = ""
    for c in s.chars() {
        out = "{out}{c.toUpper()}"
    }
    out
}

pub fn toLower(s: String) -> String {
    let mut out = ""
    for c in s.chars() {
        out = "{out}{c.toLower()}"
    }
    out
}

pub fn repeat(s: String, n: Int) -> String {
    if n <= 0 {
        return ""
    }
    let mut out = ""
    let mut i = 0
    for i < n {
        out = "{out}{s}"
        i = i + 1
    }
    out
}

pub fn replace(s: String, old: String, new: String) -> String {
    replaceN(s, old, new, 1)
}

pub fn replaceAll(s: String, old: String, new: String) -> String {
    replaceN(s, old, new, -1)
}

pub fn replaceN(s: String, old: String, new: String, n: Int) -> String {
    if n == 0 {
        return s
    }
    let chars = s.chars()
    let needle = old.chars()
    if needle.len() == 0 {
        let mut out = ""
        let mut inserted = 0
        if n < 0 || inserted < n {
            out = "{out}{new}"
            inserted = inserted + 1
        }
        for c in chars {
            out = "{out}{c}"
            if n < 0 || inserted < n {
                out = "{out}{new}"
                inserted = inserted + 1
            }
        }
        return out
    }
    let mut out = ""
    let mut i = 0
    let mut replaced = 0
    for i < chars.len() {
        if (n < 0 || replaced < n) && matchesAt(chars, needle, i) {
            out = "{out}{new}"
            i = i + needle.len()
            replaced = replaced + 1
        } else {
            out = "{out}{chars[i]}"
            i = i + 1
        }
    }
    out
}

pub fn fromChar(c: Char) -> String {
    c.toString()
}

pub fn fromChars(chars: List<Char>) -> String {
    fromCharsSlice(chars, 0, chars.len())
}

pub fn repeatChar(c: Char, n: Int) -> String {
    if n <= 0 {
        return ""
    }
    let mut out = ""
    let mut i = 0
    for i < n {
        out = "{out}{c}"
        i = i + 1
    }
    out
}

fn inCutset(cutset: List<Char>, c: Char) -> Bool {
    for x in cutset {
        if x == c {
            return true
        }
    }
    false
}

pub fn trimStartChars(s: String, cutset: String) -> String {
    let chars = s.chars()
    let cs = cutset.chars()
    if cs.len() == 0 {
        return s
    }
    let mut start = 0
    for start < chars.len() && inCutset(cs, chars[start]) {
        start = start + 1
    }
    fromCharsSlice(chars, start, chars.len())
}

pub fn trimEndChars(s: String, cutset: String) -> String {
    let chars = s.chars()
    let cs = cutset.chars()
    if cs.len() == 0 {
        return s
    }
    let mut end = chars.len()
    for end > 0 && inCutset(cs, chars[end - 1]) {
        end = end - 1
    }
    fromCharsSlice(chars, 0, end)
}

pub fn trimChars(s: String, cutset: String) -> String {
    let chars = s.chars()
    let cs = cutset.chars()
    if cs.len() == 0 {
        return s
    }
    let mut start = 0
    for start < chars.len() && inCutset(cs, chars[start]) {
        start = start + 1
    }
    let mut end = chars.len()
    for end > start && inCutset(cs, chars[end - 1]) {
        end = end - 1
    }
    fromCharsSlice(chars, start, end)
}

pub fn fields(s: String) -> List<String> {
    let chars = s.chars()
    let mut out: List<String> = []
    let mut start = -1
    for i in 0..chars.len() {
        if chars[i].isWhitespace() {
            if start >= 0 {
                out.push(fromCharsSlice(chars, start, i))
                start = -1
            }
        } else {
            if start < 0 {
                start = i
            }
        }
    }
    if start >= 0 {
        out.push(fromCharsSlice(chars, start, chars.len()))
    }
    out
}

// splitLines splits on \n, \r\n, and bare \r; lines() splits only on \n.
pub fn splitLines(s: String) -> List<String> {
    let chars = s.chars()
    let mut out: List<String> = []
    let mut start = 0
    let mut i = 0
    for i < chars.len() {
        let c = chars[i]
        if c == '\n' {
            out.push(fromCharsSlice(chars, start, i))
            i = i + 1
            start = i
        } else if c == '\r' {
            out.push(fromCharsSlice(chars, start, i))
            i = i + 1
            if i < chars.len() && chars[i] == '\n' {
                i = i + 1
            }
            start = i
        } else {
            i = i + 1
        }
    }
    if start < chars.len() {
        out.push(fromCharsSlice(chars, start, chars.len()))
    }
    out
}

pub fn containsChar(s: String, c: Char) -> Bool {
    for ch in s.chars() {
        if ch == c {
            return true
        }
    }
    false
}

pub fn indexOfChar(s: String, c: Char) -> Int? {
    let chars = s.chars()
    for i in 0..chars.len() {
        if chars[i] == c {
            return Some(i)
        }
    }
    None
}

pub fn lastIndexOfChar(s: String, c: Char) -> Int? {
    let chars = s.chars()
    let mut i = chars.len()
    for i > 0 {
        i = i - 1
        if chars[i] == c {
            return Some(i)
        }
    }
    None
}

pub fn containsAny(s: String, cutset: String) -> Bool {
    let set = cutset.chars()
    if set.len() == 0 {
        return false
    }
    for c in s.chars() {
        if inCutset(set, c) {
            return true
        }
    }
    false
}

pub fn indexOfAny(s: String, cutset: String) -> Int? {
    let set = cutset.chars()
    if set.len() == 0 {
        return None
    }
    let source = s.chars()
    for i in 0..source.len() {
        if inCutset(set, source[i]) {
            return Some(i)
        }
    }
    None
}

pub fn lastIndexOfAny(s: String, cutset: String) -> Int? {
    let set = cutset.chars()
    if set.len() == 0 {
        return None
    }
    let source = s.chars()
    let mut i = source.len()
    for i > 0 {
        i = i - 1
        if inCutset(set, source[i]) {
            return Some(i)
        }
    }
    None
}

// Miss behavior is asymmetric so callers can distinguish hit from miss without
// a second search: partition returns (s,"",""), rpartition returns ("","",s).
pub fn partition(s: String, sep: String) -> (String, String, String) {
    let chars = s.chars()
    let needle = sep.chars()
    if needle.len() == 0 {
        return (s, "", "")
    }
    let at = indexOfChars(chars, needle)
    if at < 0 {
        return (s, "", "")
    }
    let before = fromCharsSlice(chars, 0, at)
    let after = fromCharsSlice(chars, at + needle.len(), chars.len())
    (before, sep, after)
}

pub fn rpartition(s: String, sep: String) -> (String, String, String) {
    let chars = s.chars()
    let needle = sep.chars()
    if needle.len() == 0 {
        return ("", "", s)
    }
    let at = lastIndexOfChars(chars, needle)
    if at < 0 {
        return ("", "", s)
    }
    let before = fromCharsSlice(chars, 0, at)
    let after = fromCharsSlice(chars, at + needle.len(), chars.len())
    (before, sep, after)
}

pub fn capitalize(s: String) -> String {
    let chars = s.chars()
    if chars.len() == 0 {
        return ""
    }
    let mut out = "{chars[0].toUpper()}"
    for i in 1..chars.len() {
        out = "{out}{chars[i].toLower()}"
    }
    out
}

pub fn title(s: String) -> String {
    let mut out = ""
    let mut atWordStart = true
    for c in s.chars() {
        if c.isWhitespace() {
            out = "{out}{c}"
            atWordStart = true
        } else {
            if atWordStart {
                out = "{out}{c.toUpper()}"
                atWordStart = false
            } else {
                out = "{out}{c.toLower()}"
            }
        }
    }
    out
}

pub fn swapCase(s: String) -> String {
    let mut out = ""
    for c in s.chars() {
        if c.isUpper() {
            out = "{out}{c.toLower()}"
        } else if c.isLower() {
            out = "{out}{c.toUpper()}"
        } else {
            out = "{out}{c}"
        }
    }
    out
}

// Caseless comparison per Unicode TR#21. Uses the generated CaseFolding tables
// with full fold applied: multi-char expansions like German ß → ss and Greek
// ligatures compare equal. Turkic folds (dotless I) are intentionally omitted;
// those need a locale-aware variant.
pub fn equalFold(a: String, b: String) -> Bool {
    foldString(a) == foldString(b)
}

pub fn compare(a: String, b: String) -> Int {
    let ac = a.chars()
    let bc = b.chars()
    let mut n = ac.len()
    if bc.len() < n {
        n = bc.len()
    }
    for i in 0..n {
        let ai = ac[i].toInt()
        let bi = bc[i].toInt()
        if ai < bi {
            return -1
        }
        if ai > bi {
            return 1
        }
    }
    if ac.len() < bc.len() {
        return -1
    }
    if ac.len() > bc.len() {
        return 1
    }
    0
}

// reverseChars reverses by Unicode scalar -- fast, but breaks combining
// sequences (é as e + combining-acute reverses to combining-acute + e, which
// applies the accent to whatever followed it). reverse walks graphemes and is
// what users mean by "reverse a string"; use reverseChars only when inputs are
// known to have no combining marks, joiners, or regional-indicator pairs.
pub fn reverseChars(s: String) -> String {
    let chars = s.chars()
    let mut out = ""
    let mut i = chars.len()
    for i > 0 {
        i = i - 1
        out = "{out}{chars[i]}"
    }
    out
}

pub fn reverse(s: String) -> String {
    let gs = graphemesFromChars(s.chars())
    let mut out = ""
    let mut i = gs.len()
    for i > 0 {
        i = i - 1
        out = "{out}{gs[i]}"
    }
    out
}

pub fn isBlank(s: String) -> Bool {
    for c in s.chars() {
        if !c.isWhitespace() {
            return false
        }
    }
    true
}

pub fn isAscii(s: String) -> Bool {
    for b in s.bytes() {
        if b.toInt() > 127 {
            return false
        }
    }
    true
}

pub fn isDigits(s: String) -> Bool {
    let chars = s.chars()
    if chars.len() == 0 {
        return false
    }
    for c in chars {
        if !c.isDigit() {
            return false
        }
    }
    true
}

pub fn isAlpha(s: String) -> Bool {
    let chars = s.chars()
    if chars.len() == 0 {
        return false
    }
    for c in chars {
        if !c.isAlpha() {
            return false
        }
    }
    true
}

pub fn isAlphanumeric(s: String) -> Bool {
    let chars = s.chars()
    if chars.len() == 0 {
        return false
    }
    for c in chars {
        if !c.isAlphanumeric() {
            return false
        }
    }
    true
}

// Bytes → String constructor that surfaces UTF-8 validation errors instead of
// falling back to replacement characters. Use tryFromBytesLossy if you want
// invalid bytes replaced with U+FFFD instead.
pub fn fromBytes(b: Bytes) -> Result<String, Error> {
    b.toString()
}

// Grapheme-indexed accessors. Unlike chars/bytes indexing these count by
// extended grapheme cluster, which matches what users see. All of them walk
// the UAX29 algorithm per call; if you need a hot loop, call graphemes(s) once
// and index the resulting list instead.
pub fn graphemeCount(s: String) -> Int {
    graphemesFromChars(s.chars()).len()
}

pub fn graphemeAt(s: String, i: Int) -> String? {
    let gs = graphemesFromChars(s.chars())
    if i < 0 || i >= gs.len() {
        None
    } else {
        Some(gs[i])
    }
}

pub fn graphemeSlice(s: String, start: Int, end: Int) -> String {
    let gs = graphemesFromChars(s.chars())
    let n = gs.len()
    let mut lo = start
    let mut hi = end
    if lo < 0 {
        lo = 0
    }
    if hi > n {
        hi = n
    }
    if lo >= hi {
        return ""
    }
    let mut out = ""
    for i in lo..hi {
        out = "{out}{gs[i]}"
    }
    out
}

// StringBuilder accumulates chars/strings without exposing the O(n^2) concat
// pattern throughout user code. Today the underlying build is still O(n) calls
// to string interpolation because Osty lacks a mutable Bytes primitive; the
// wrapper exists so callers use the *shape* of a builder and we can swap the
// implementation for a true Bytes-backed one without changing callers.
pub struct StringBuilder {
    pub parts: List<String>,

    pub fn pushStr(mut self, s: String) {
        self.parts.push(s)
    }

    pub fn pushChar(mut self, c: Char) {
        self.parts.push(c.toString())
    }

    pub fn pushRepeat(mut self, s: String, n: Int) {
        let mut i = 0
        for i < n {
            self.parts.push(s)
            i = i + 1
        }
    }

    pub fn len(self) -> Int {
        let mut total = 0
        for p in self.parts {
            total = total + p.bytes().len()
        }
        total
    }

    pub fn isEmpty(self) -> Bool {
        self.parts.isEmpty()
    }

    pub fn clear(mut self) {
        self.parts = []
    }

    pub fn build(self) -> String {
        join(self.parts, "")
    }
}

pub fn builder() -> StringBuilder {
    StringBuilder { parts: [] }
}

