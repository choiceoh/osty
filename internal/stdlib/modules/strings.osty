fn binSearchInt(arr: List<Int>, key: Int) -> Int {
    let mut lo = 0
    let mut hi = arr.len()
    for lo < hi {
        let mid = (lo + hi) / 2
        let v = arr[mid]
        if v == key {
            return mid
        }
        if v < key {
            lo = mid + 1
        } else {
            hi = mid
        }
    }
    -1
}

// Simple case fold: at most one target char. Good for canonicalising single
// chars, e.g. for building a case-insensitive HashSet<Char>. Does NOT handle
// multi-char folds; use foldString for Unicode-correct caseless comparison.
pub fn foldChar(c: Char) -> Char {
    let idx = binSearchInt(caseFoldSimpleFrom, c.toInt())
    if idx < 0 {
        return c
    }
    caseFoldSimpleTo[idx].toChar()
}

// Full case fold: may expand one input char into multiple output chars.
pub fn foldCharFull(c: Char) -> List<Char> {
    let idx = binSearchInt(caseFoldFullFrom, c.toInt())
    if idx < 0 {
        return [c]
    }
    let start = caseFoldFullOffsets[idx]
    let end = caseFoldFullOffsets[idx + 1]
    let mut out: List<Char> = []
    for i in start..end {
        out.push(caseFoldFullData[i].toChar())
    }
    out
}

pub fn foldString(s: String) -> String {
    let b = builder()
    for c in s.chars() {
        let idx = binSearchInt(caseFoldFullFrom, c.toInt())
        if idx < 0 {
            b.pushChar(c)
        } else {
            let start = caseFoldFullOffsets[idx]
            let end = caseFoldFullOffsets[idx + 1]
            for i in start..end {
                b.pushChar(caseFoldFullData[i].toChar())
            }
        }
    }
    b.build()
}


