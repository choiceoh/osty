// END GENERATED NORMALIZATION TABLES.

// Hangul algorithmic (de)composition. Storing all 11172 syllables in the
// table would dominate the binary; the algorithmic form is exact.
let hangulSBase = 0xAC00
let hangulLBase = 0x1100
let hangulVBase = 0x1161
let hangulTBase = 0x11A7
let hangulLCount = 19
let hangulVCount = 21
let hangulTCount = 28
let hangulNCount = 588
let hangulSCount = 11172

fn canonicalCombiningClass(c: Char) -> Int {
    let idx = binSearchInt(cccCode, c.toInt())
    if idx < 0 {
        return 0
    }
    cccValue[idx]
}

fn expandCanonDecomp(c: Char, out: List<Char>) {
    let ci = c.toInt()
    if ci >= hangulSBase && ci < hangulSBase + hangulSCount {
        let sIdx = ci - hangulSBase
        let l = hangulLBase + sIdx / hangulNCount
        let v = hangulVBase + (sIdx % hangulNCount) / hangulTCount
        let t = hangulTBase + sIdx % hangulTCount
        out.push(l.toChar())
        out.push(v.toChar())
        if t != hangulTBase {
            out.push(t.toChar())
        }
        return
    }
    let idx = binSearchInt(canonDecompFrom, ci)
    if idx < 0 {
        out.push(c)
        return
    }
    let start = canonDecompOffsets[idx]
    let end = canonDecompOffsets[idx + 1]
    for i in start..end {
        out.push(canonDecompData[i].toChar())
    }
}

fn expandCompatDecomp(c: Char, out: List<Char>) {
    let ci = c.toInt()
    if ci >= hangulSBase && ci < hangulSBase + hangulSCount {
        let sIdx = ci - hangulSBase
        let l = hangulLBase + sIdx / hangulNCount
        let v = hangulVBase + (sIdx % hangulNCount) / hangulTCount
        let t = hangulTBase + sIdx % hangulTCount
        out.push(l.toChar())
        out.push(v.toChar())
        if t != hangulTBase {
            out.push(t.toChar())
        }
        return
    }
    let idx = binSearchInt(compatDecompFrom, ci)
    if idx < 0 {
        out.push(c)
        return
    }
    let start = compatDecompOffsets[idx]
    let end = compatDecompOffsets[idx + 1]
    for i in start..end {
        out.push(compatDecompData[i].toChar())
    }
}

// Stable-sort each maximal run of combining marks by CCC (UAX #15 D108).
// Insertion sort: combining runs are almost always short (<8), and insertion
// sort is stable with zero overhead on already-ordered input.
fn canonicalOrder(chars: List<Char>) -> List<Char> {
    let mut out: List<Char> = []
    for c in chars {
        out.push(c)
    }
    let n = out.len()
    let mut i = 0
    for i < n {
        if canonicalCombiningClass(out[i]) == 0 {
            i = i + 1
            continue
        }
        let mut j = i
        for j < n && canonicalCombiningClass(out[j]) != 0 {
            j = j + 1
        }
        let mut k = i + 1
        for k < j {
            let cur = out[k]
            let curCCC = canonicalCombiningClass(cur)
            let mut m = k
            for m > i && canonicalCombiningClass(out[m - 1]) > curCCC {
                out[m] = out[m - 1]
                m = m - 1
            }
            out[m] = cur
            k = k + 1
        }
        i = j
    }
    out
}

fn composePair(a: Char, b: Char) -> Char? {
    let ai = a.toInt()
    let bi = b.toInt()
    if hangulLBase <= ai && ai < hangulLBase + hangulLCount && hangulVBase <= bi && bi < hangulVBase + hangulVCount {
        let lIdx = ai - hangulLBase
        let vIdx = bi - hangulVBase
        return Some((hangulSBase + (lIdx * hangulVCount + vIdx) * hangulTCount).toChar())
    }
    if hangulSBase <= ai && ai < hangulSBase + hangulSCount && (ai - hangulSBase) % hangulTCount == 0 && hangulTBase < bi && bi < hangulTBase + hangulTCount {
        return Some((ai + (bi - hangulTBase)).toChar())
    }
    let mut lo = 0
    let mut hi = composeFirst.len()
    for lo < hi {
        let mid = (lo + hi) / 2
        if composeFirst[mid] < ai {
            lo = mid + 1
        } else {
            hi = mid
        }
    }
    let mut i = lo
    for i < composeFirst.len() && composeFirst[i] == ai {
        if composeSecond[i] == bi {
            return Some(composeResult[i].toChar())
        }
        i = i + 1
    }
    None
}

fn decomposeAll(s: String, compat: Bool) -> List<Char> {
    let mut out: List<Char> = []
    for c in s.chars() {
        if compat {
            expandCompatDecomp(c, out)
        } else {
            expandCanonDecomp(c, out)
        }
    }
    canonicalOrder(out)
}

pub fn normalizeNFD(s: String) -> String {
    fromChars(decomposeAll(s, false))
}

pub fn normalizeNFKD(s: String) -> String {
    fromChars(decomposeAll(s, true))
}

fn composeAfterDecomp(chars: List<Char>) -> List<Char> {
    if chars.len() == 0 {
        return []
    }
    let mut out: List<Char> = []
    out.push(chars[0])
    let firstCCC = canonicalCombiningClass(chars[0])
    let mut starterIdx = 0
    let mut lastCCC = firstCCC
    if firstCCC != 0 {
        starterIdx = -1
    }
    for i in 1..chars.len() {
        let c = chars[i]
        let cccC = canonicalCombiningClass(c)
        let canCompose = starterIdx >= 0 && (lastCCC == 0 || lastCCC < cccC)
        if canCompose {
            let composed = composePair(out[starterIdx], c)
            match composed {
                Some(r) -> {
                    out[starterIdx] = r
                    continue
                },
                None -> {},
            }
        }
        out.push(c)
        if cccC == 0 {
            starterIdx = out.len() - 1
            lastCCC = 0
        } else {
            if cccC > lastCCC {
                lastCCC = cccC
            }
        }
    }
    out
}

pub fn normalizeNFC(s: String) -> String {
    fromChars(composeAfterDecomp(decomposeAll(s, false)))
}

pub fn normalizeNFKC(s: String) -> String {
    fromChars(composeAfterDecomp(decomposeAll(s, true)))
}

// Collation: lightweight orderings. Proper locale-aware collation needs the
// CLDR root collation table (tens of thousands of weighted entries) and the
// UCA DUCET algorithm; that's a separate project. These give you the common
// needs without that weight.

// compareCI: case-insensitive scalar ordering using simple fold. Correct for
// ASCII and most BMP cases; misses multi-char folds like ß ≡ ss.
pub fn compareCI(a: String, b: String) -> Int {
    let ac = a.chars()
    let bc = b.chars()
    let mut n = ac.len()
    if bc.len() < n {
        n = bc.len()
    }
    for i in 0..n {
        let ai = foldChar(ac[i]).toInt()
        let bi = foldChar(bc[i]).toInt()
        if ai < bi {
            return -1
        }
        if ai > bi {
            return 1
        }
    }
    if ac.len() < bc.len() {
        return -1
    }
    if ac.len() > bc.len() {
        return 1
    }
    0
}

// compareFold: full-fold comparison matching equalFold semantics. Slower
// (folds expand some chars to multiple) but handles ß ≡ ss correctly.
pub fn compareFold(a: String, b: String) -> Int {
    compare(foldString(a), foldString(b))
}

// Normalized comparison: if two strings differ only in how their codepoints
// are composed (precomposed é vs e + combining-acute), they compare equal.
pub fn equalNFC(a: String, b: String) -> Bool {
    normalizeNFC(a) == normalizeNFC(b)
}

pub fn compareNFC(a: String, b: String) -> Int {
    compare(normalizeNFC(a), normalizeNFC(b))
}
