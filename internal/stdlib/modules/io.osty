// std.io — console I/O.
//
// `print`, `println`, `eprint`, `eprintln`, `readLine` are the full
// Tier 1 surface. All five except `readLine` are prelude-aliased so
// user code can call them unqualified. Bodies are placeholders; the
// transpiler emits the actual stdio calls.

pub fn print(s: String) {}

pub fn println(s: String) {}

pub fn eprint(s: String) {}

pub fn eprintln(s: String) {}

pub fn readLine() -> String {
    ""
}
