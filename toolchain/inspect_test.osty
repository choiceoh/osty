use std.testing

fn testInspectEmitsLiteralAndIdentRecords() {
    let recs = inspectSource(
        r"""
            fn main() {
                let x: Int = 42
                let y = x + 1
            }
            """,
    )

    testing.assert(recs.len() >= 3)

    let mut sawIntLit = false
    let mut sawVar = false
    let mut sawBinop = false
    for rec in recs {
        if rec.rule == "LIT-INT" {
            sawIntLit = true
        }
        if rec.rule == "VAR" {
            sawVar = true
        }
        if rec.rule == "BINOP" {
            sawBinop = true
        }
    }
    testing.assert(sawIntLit)
    testing.assert(sawVar)
    testing.assert(sawBinop)
}

fn testInspectRecordsSortedByStart() {
    let recs = inspectSource(
        r"""
            fn main() {
                let a = 1
                let b = 2
                let c = a + b
            }
            """,
    )

    if recs.len() < 2 {
        return
    }

    let mut prev = recs[0].start
    for i in 1..recs.len() {
        let cur = recs[i].start
        testing.assert(prev <= cur)
        prev = cur
    }
}

fn testInspectCarriesTypeNamesForLiterals() {
    let recs = inspectSource(
        r"""
            fn main() {
                let x: Int = 7
                let s: String = "hi"
            }
            """,
    )

    let mut sawIntType = false
    let mut sawStringType = false
    for rec in recs {
        if rec.rule == "LIT-INT" && rec.typeName == "Int" {
            sawIntType = true
        }
        if rec.rule == "LIT-STRING" && rec.typeName == "String" {
            sawStringType = true
        }
    }
    testing.assert(sawIntType)
    testing.assert(sawStringType)
}

fn testInspectRuleCoverageIsNonEmpty() {
    let recs = inspectSource(
        r"""
            fn main() {
                let xs: List<Int> = [1, 2, 3]
                let pair: (Int, Int) = (1, 2)
                let result = if xs.len() > 0 { 1 } else { 0 }
                let _ = xs[0]
            }
            """,
    )

    let mut sawList = false
    let mut sawTuple = false
    let mut sawIf = false
    let mut sawIndex = false
    for rec in recs {
        if rec.rule == "LIST" { sawList = true }
        if rec.rule == "TUPLE" { sawTuple = true }
        if rec.rule == "IF" { sawIf = true }
        if rec.rule == "INDEX" { sawIndex = true }
    }
    testing.assert(sawList)
    testing.assert(sawTuple)
    testing.assert(sawIf)
    testing.assert(sawIndex)
}

fn testInspectEmptyOnEmptyFile() {
    let recs = inspectSource("")
    testing.assertEq(recs.len(), 0)
}

fn testInspectEmitsFnDeclRecords() {
    let recs = inspectSource(
        r"""
            pub fn greet(name: String) -> String {
                "hi, {name}"
            }

            fn main() {
                let _ = greet("alice")
            }
            """,
    )

    let mut sawGreet = false
    let mut sawMain = false
    for rec in recs {
        if rec.rule != "FN-DECL" {
            continue
        }
        for note in rec.notes {
            if note == "name: greet" {
                sawGreet = true
            }
            if note == "name: main" {
                sawMain = true
            }
        }
    }
    testing.assert(sawGreet)
    testing.assert(sawMain)
}

fn testInspectEmitsTopLevelLetRecord() {
    let recs = inspectSource(
        r"""
            let answer: Int = 42

            fn main() {
                let _ = answer
            }
            """,
    )

    let mut sawLet = false
    for rec in recs {
        if rec.rule == "LET" && rec.typeName == "Int" {
            for note in rec.notes {
                if note == "name: answer" {
                    sawLet = true
                }
            }
        }
    }
    testing.assert(sawLet)
}

fn testInspectEmitsBindRecords() {
    let recs = inspectSource(
        r"""
            fn main() {
                let opt: Option<Int> = Some(42)
                match opt {
                    Some(x) -> x,
                    None -> 0,
                }
            }
            """,
    )

    let mut sawBind = false
    for rec in recs {
        if rec.rule == "BIND" {
            for note in rec.notes {
                if note == "name: x" {
                    sawBind = true
                }
            }
        }
    }
    testing.assert(sawBind)
}

fn testInspectEmitsLocalLetAsLetRule() {
    let recs = inspectSource(
        r"""
            fn main() {
                let inner: Int = 7
                let mut counter: Int = 0
                counter = counter + inner
            }
            """,
    )

    let mut sawInner = false
    let mut sawCounter = false
    for rec in recs {
        if rec.rule != "LET" {
            continue
        }
        if rec.nodeKind != "LetStmt" {
            continue
        }
        for note in rec.notes {
            if note == "name: inner" {
                sawInner = true
            }
            if note == "name: counter" {
                sawCounter = true
            }
        }
    }
    testing.assert(sawInner)
    testing.assert(sawCounter)
}

fn testInspectEmitsTupleDestructureLet() {
    let recs = inspectSource(
        r"""
            fn main() {
                let (lo, hi): (Int, Int) = (1, 10)
                let _ = lo + hi
            }
            """,
    )

    let mut sawLo = false
    let mut sawHi = false
    for rec in recs {
        if rec.rule != "LET" || rec.nodeKind != "LetStmt" {
            continue
        }
        for note in rec.notes {
            if note == "name: lo" {
                sawLo = true
            }
            if note == "name: hi" {
                sawHi = true
            }
        }
    }
    testing.assert(sawLo)
    testing.assert(sawHi)
}

fn testInspectEmitsStructDestructureLet() {
    let recs = inspectSource(
        r"""
            pub struct Point { pub x: Int, pub y: Int }

            fn main() {
                let p: Point = Point { x: 3, y: 4 }
                let Point { x, y } = p
                let _ = x + y
            }
            """,
    )

    let mut sawX = false
    let mut sawY = false
    for rec in recs {
        if rec.rule != "LET" || rec.nodeKind != "LetStmt" {
            continue
        }
        for note in rec.notes {
            if note == "name: x" {
                sawX = true
            }
            if note == "name: y" {
                sawY = true
            }
        }
    }
    testing.assert(sawX)
    testing.assert(sawY)
}

fn testInspectMatchPatternStaysBindRule() {
    let recs = inspectSource(
        r"""
            fn main() {
                let opt: Option<Int> = Some(3)
                match opt {
                    Some(v) -> v,
                    None -> 0,
                }
            }
            """,
    )

    let mut sawBindV = false
    for rec in recs {
        if rec.rule == "BIND" && rec.nodeKind == "Binding" {
            for note in rec.notes {
                if note == "name: v" {
                    sawBindV = true
                }
            }
        }
    }
    testing.assert(sawBindV)
}

fn testInspectEmitsStructAndEnumDeclRecords() {
    let recs = inspectSource(
        r"""
            pub struct Point { pub x: Int, pub y: Int }

            pub enum Color { Red, Green, Blue }

            fn main() {
                let _ = Point { x: 1, y: 2 }
            }
            """,
    )

    let mut sawStruct = false
    let mut sawEnum = false
    for rec in recs {
        if rec.rule == "STRUCT-DECL" {
            for note in rec.notes {
                if note == "name: Point" {
                    sawStruct = true
                }
            }
        }
        if rec.rule == "ENUM-DECL" {
            for note in rec.notes {
                if note == "name: Color" {
                    sawEnum = true
                }
            }
        }
    }
    testing.assert(sawStruct)
    testing.assert(sawEnum)
}

fn testInspectHintsListElement() {
    let recs = inspectSource(
        r"""
            fn main() {
                let xs: List<Int> = [42]
            }
            """,
    )

    let mut sawHint = false
    for rec in recs {
        if rec.rule == "LIT-INT" && rec.hintName == "Int" {
            sawHint = true
        }
    }
    testing.assert(sawHint)
}

fn testInspectHintsTupleElements() {
    let recs = inspectSource(
        r"""
            fn main() {
