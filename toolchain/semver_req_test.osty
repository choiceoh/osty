use std.testing

fn assertReqMatch(req: SemReq, version: SemVersion) {
    testing.assert(semReqMatches(req, version))
}

fn assertReqMiss(req: SemReq, version: SemVersion) {
    testing.assert(!(semReqMatches(req, version)))
}

fn testSemverReqExactAndRelationalGoldenCases() {
    let exact = exactReq(stableVersion(1, 2, 3))
    assertReqMatch(exact, stableVersion(1, 2, 3))
    assertReqMiss(exact, stableVersion(1, 2, 4))
    assertReqMiss(exact, stableVersion(1, 3, 0))

    let ge = atLeastReq(stableVersion(1, 2, 3))
    assertReqMatch(ge, stableVersion(1, 2, 3))
    assertReqMatch(ge, stableVersion(2, 0, 0))
    assertReqMiss(ge, stableVersion(1, 2, 2))

    let gt = greaterThanReq(stableVersion(1, 2, 3))
    assertReqMatch(gt, stableVersion(1, 2, 4))
    assertReqMiss(gt, stableVersion(1, 2, 3))

    let le = atMostReq(stableVersion(1, 2, 3))
    assertReqMatch(le, stableVersion(1, 0, 0))
    assertReqMatch(le, stableVersion(1, 2, 3))
    assertReqMiss(le, stableVersion(1, 2, 4))

    let lt = lessThanReq(stableVersion(1, 2, 3))
    assertReqMatch(lt, stableVersion(1, 2, 2))
    assertReqMiss(lt, stableVersion(1, 2, 3))
}

fn testSemverReqRangeGoldenCases() {
    let caret = caretReq(stableVersion(1, 2, 3))
    assertReqMatch(caret, stableVersion(1, 9, 9))
    assertReqMiss(caret, stableVersion(2, 0, 0))
    assertReqMiss(caret, stableVersion(1, 2, 2))

    let caretZeroMinor = caretReq(stableVersion(0, 1, 2))
    assertReqMatch(caretZeroMinor, stableVersion(0, 1, 9))
    assertReqMiss(caretZeroMinor, stableVersion(0, 2, 0))

    let caretZeroPatch = caretReq(stableVersion(0, 0, 1))
    assertReqMatch(caretZeroPatch, stableVersion(0, 0, 1))
    assertReqMiss(caretZeroPatch, stableVersion(0, 0, 2))

    let tilde = tildeReq(stableVersion(1, 2, 3))
    assertReqMatch(tilde, stableVersion(1, 2, 9))
    assertReqMiss(tilde, stableVersion(1, 3, 0))

    let majorWildcard = wildcardMajorReq(1)
    assertReqMatch(majorWildcard, stableVersion(1, 0, 0))
    assertReqMatch(majorWildcard, stableVersion(1, 9, 9))
    assertReqMiss(majorWildcard, stableVersion(2, 0, 0))

    let minorWildcard = wildcardMinorReq(1, 2)
    assertReqMatch(minorWildcard, stableVersion(1, 2, 0))
    assertReqMatch(minorWildcard, stableVersion(1, 2, 9))
    assertReqMiss(minorWildcard, stableVersion(1, 3, 0))
}

fn testSemverReqPrereleaseGoldenCases() {
    let stableRange = caretReq(stableVersion(1, 2, 3))
    assertReqMiss(stableRange, prerelease1(1, 3, 0, preText("alpha")))

    let preRange = caretReq(prerelease1(1, 2, 3, preText("alpha")))
    assertReqMatch(preRange, prerelease2(1, 2, 3, preText("alpha"), preNumber(1)))
}

fn testSemverReqAnyMatchesStableOnly() {
    let any = anySemReq()
    assertReqMatch(any, stableVersion(0, 0, 0))
    assertReqMatch(any, stableVersion(99, 1, 2))
    assertReqMiss(any, prerelease1(1, 0, 0, preText("alpha")))
}

fn testSemverReqBoundedConjunctionExamples() {
    let req = boundedReq(stableVersion(1, 4, 0), stableVersion(1, 6, 0))

    assertReqMiss(req, stableVersion(1, 3, 9))
    assertReqMatch(req, stableVersion(1, 4, 0))
    assertReqMatch(req, stableVersion(1, 5, 9))
    assertReqMiss(req, stableVersion(1, 6, 0))
}

fn testSemverReqMaxMatchingSkipsPrereleasesByDefault() {
    let versions = [
        prerelease1(2, 0, 0, preText("alpha")),
        stableVersion(1, 9, 9),
        stableVersion(1, 8, 0),
    ]
    let best = maxMatchingVersion(atLeastReq(stableVersion(1, 0, 0)), versions)

    testing.assert(best.found)
    testing.assertEq(compareSemVersion(best.version, stableVersion(1, 9, 9)), 0)
}

fn testSemverReqMaxMatchingCanSelectPrereleaseWhenRequested() {
    let req = exactReq(prerelease1(2, 0, 0, preText("alpha")))
    let versions = [
        stableVersion(1, 9, 9),
        prerelease1(2, 0, 0, preText("alpha")),
        prerelease1(2, 0, 0, preText("beta")),
    ]
    let best = maxMatchingVersion(req, versions)

    testing.assert(best.found)
    testing.assertEq(compareSemVersion(best.version, prerelease1(2, 0, 0, preText("alpha"))), 0)
}

fn testSemverReqMaxMatchingReportsNoMatch() {
    let versions = [
        stableVersion(0, 9, 0),
        stableVersion(2, 0, 0),
    ]
    let best = maxMatchingVersion(wildcardMinorReq(1, 4), versions)

    testing.assert(!(best.found))
    testing.assertEq(compareSemVersion(best.version, stableVersion(0, 0, 0)), 0)
}
