/// — the trim family (strings.Trim / TrimLeft / TrimRight / TrimSpace).
pub fn mirCallValueStringTrimLine(reg: String, sym: String, sReg: String) -> String {
    mirCallValuePtrFromPtrLine(reg, sym, sReg)
