pub fn mirCallLifetimeStartLine(sizeBytes: String, slot: String) -> String {
    mirCallVoidLLVMLifetimeStartLine(sizeBytes, slot)
}

pub fn mirCallLifetimeEndLine(sizeBytes: String, slot: String) -> String {
