use std.testing

fn testManifestValidationExamplesAcceptPackageNameShape() {
    testing.assert(manifestPackageNameValid("core"))
    testing.assert(manifestPackageNameValid("_core-1"))
    testing.assert(manifestPackageNameValid("std_json"))

    testing.assert(!(manifestPackageNameValid("")))
    testing.assert(!(manifestPackageNameValid("1core")))
    testing.assert(!(manifestPackageNameValid("bad.name")))
}

fn testManifestValidationExamplesAcceptStrictPackageVersion() {
    testing.assert(manifestPackageVersionValid("0.1.0"))
    testing.assert(manifestPackageVersionValid("1.2.3-alpha+build.7"))
    testing.assert(manifestPackageVersionValid("1.2.3-alpha.1.sha.9"))

    testing.assert(!(manifestPackageVersionValid("")))
    testing.assert(!(manifestPackageVersionValid("v1.2.3")))
    testing.assert(!(manifestPackageVersionValid("1.2")))
    testing.assert(!(manifestPackageVersionValid("1.2.3-alpha_bad")))
}

fn testManifestValidationExamplesRequirePackageOrWorkspaceRoot() {
    let spec = manifestSpec(
        manifestPackageSpec(false, "", "", ""),
        manifestWorkspaceSpec(false, []),
        [],
        [],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assertEq(result.missingRoots, 1)
    testing.assertEq(manifestValidationErrorCount(result), 1)
}

fn testManifestValidationExamplesCheckPackageIdentity() {
    let spec = manifestSpec(
        manifestPackageSpec(true, "1bad", "v1.2.3", "9.9"),
        manifestWorkspaceSpec(false, []),
        [],
        [],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assertEq(result.badPackageNames, 1)
    testing.assertEq(result.badPackageVersions, 1)
    testing.assertEq(result.unknownEditions, 1)
    testing.assertEq(manifestValidationErrorCount(result), 3)
}

fn testManifestValidationExamplesWarnOnMissingEdition() {
    let spec = manifestSpec(
        manifestPackageSpec(true, "demo", "1.2.3", ""),
        manifestWorkspaceSpec(false, []),
        [],
        [],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assertEq(result.missingEditions, 1)
    testing.assertEq(manifestValidationWarningCount(result), 1)
    testing.assertEq(manifestValidationErrorCount(result), 0)
}

fn testManifestValidationExamplesEmitDiagnosticSpecs() {
    let spec = manifestSpecWithDeps(
        manifestPackageSpecAt(true, "1bad", "v1.2.3", "", 10, 11, 12, 13),
        manifestWorkspaceSpec(false, []),
        [
            manifestDependencySpecAt("bad", "1.*.3", "", "", "dependencies", 20),
        ],
        [],
        [
            manifestProfileSpecAt("custom", "missing", false, 0, 30),
        ],
        [
            manifestTargetSpecAt("amd64", 40),
        ],
        ["missing"],
        [
            featureSpec("loop", []),
        ],
    )
    let diagnostics = validateManifestDiagnostics(spec)

    testing.assertEq(diagnostics.len(), 7)
    testing.assertEq(diagnostics[0].code, "E2014")
    testing.assertEq(diagnostics[0].line, 11)
    testing.assertEq(diagnostics[1].code, "E2015")
    testing.assertEq(diagnostics[1].line, 12)
    testing.assertEq(diagnostics[2].severity, "warning")
    testing.assertEq(diagnostics[2].hint, "add edition = \"0.5\" to pin the spec version")
    testing.assertEq(diagnostics[3].line, 30)
    testing.assertEq(diagnostics[4].line, 40)
    testing.assertEq(diagnostics[5].message, "dependencies.bad has invalid version requirement \"1.*.3\"")
    testing.assertEq(diagnostics[6].message, "features.default references undefined feature \"missing\"")
}

fn testManifestValidationExamplesCheckWorkspaceMembers() {
    let spec = manifestSpec(
        manifestPackageSpec(false, "", "", ""),
        manifestWorkspaceSpec(true, []),
        [],
        [],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assertEq(result.missingRoots, 0)
    testing.assertEq(result.emptyWorkspaces, 1)
    testing.assertEq(manifestValidationErrorCount(result), 1)
}

fn testManifestValidationExamplesCheckProfiles() {
    let profiles = [
        manifestProfileSpec("dev", "release", true, 2),
        manifestProfileSpec("too_fast", "debug", true, 4),
        manifestProfileSpec("custom", "missing", false, 0),
        manifestProfileSpec("a", "b", false, 0),
        manifestProfileSpec("b", "a", false, 0),
    ]
    let spec = manifestSpec(
        manifestPackageSpec(true, "demo", "1.2.3", "0.5"),
        manifestWorkspaceSpec(false, []),
        profiles,
        [],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assert(manifestProfileExists("dev", profiles))
    testing.assert(!(manifestProfileExists("release", profiles)))
    testing.assertEq(result.badProfileOptLevels, 1)
    testing.assertEq(result.unknownProfileBases, 1)
    testing.assertEq(result.profileCycles, 2)
}

fn testManifestValidationExamplesCheckTargetTriples() {
    let spec = manifestSpec(
        manifestPackageSpec(true, "demo", "1.2.3", "0.5"),
        manifestWorkspaceSpec(false, []),
        [],
        [
            manifestTargetSpec("amd64-linux"),
            manifestTargetSpec("arm64-darwin"),
            manifestTargetSpec("wasm-js"),
            manifestTargetSpec("amd64"),
            manifestTargetSpec("-linux"),
            manifestTargetSpec("arm64-"),
        ],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assert(manifestTargetTripleValid("x-y-z"))
    testing.assert(!(manifestTargetTripleValid("amd64")))
    testing.assertEq(result.badTargets, 3)
}

fn testManifestValidationExamplesCheckDependencyRequirements() {
    testing.assert(manifestVersionReqValid("1.2.3"))
    testing.assert(manifestVersionReqValid("^1.2"))
    testing.assert(manifestVersionReqValid(">=1.0 <2.0"))
    testing.assert(manifestVersionReqValid("1.2.*"))
    testing.assert(manifestVersionReqValid("*"))

    testing.assert(!(manifestVersionReqValid("")))
    testing.assert(!(manifestVersionReqValid("1.2.3.4")))
    testing.assert(!(manifestVersionReqValid("1.*.3")))
    testing.assert(!(manifestVersionReqValid("*.1")))
    testing.assert(!(manifestVersionReqValid("^")))

    let spec = manifestSpecWithDeps(
        manifestPackageSpec(true, "demo", "1.2.3", "0.5"),
        manifestWorkspaceSpec(false, []),
        [
            manifestDependencySpec("ok", "^1.0", "", ""),
            manifestDependencySpec("bad", "1.2.3.4", "", ""),
            manifestDependencySpec("local", "not semver", "../local", ""),
        ],
        [
            manifestDependencySpec("dev_bad", "1.*.3", "", ""),
        ],
        [],
        [],
        [],
        [],
    )
    let result = validateManifestSpec(spec)

    testing.assertEq(result.badDependencyVersions, 2)
    testing.assertEq(manifestValidationErrorCount(result), 2)
}

fn testManifestValidationExamplesComposeFeatureGraph() {
    let spec = manifestSpec(
        manifestPackageSpec(true, "demo", "1.2.3", "0.5"),
        manifestWorkspaceSpec(false, []),
        [],
        [],
        ["missing"],
        [
            featureSpec("cli", ["cli"]),
            featureSpec("serde", []),
        ],
    )
    let result = validateManifestSpec(spec)

    testing.assertEq(result.features.undefinedDefault, 1)
    testing.assertEq(result.features.selfReferences, 1)
    testing.assertEq(manifestValidationErrorCount(result), 2)
}
