// ---- Aggregates ----

pub fn coreList(arena: CoreArena, elems: List<Int>, ty: Int, start: Int, end: Int) -> Int {
    let mut n = emptyCoreNode(CkList)
    n.children = elems
    n.ty = ty
    n.start = start
    n.end = end
    coreArenaAdd(arena, n)
