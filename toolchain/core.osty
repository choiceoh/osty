pub fn coreField(arena: CoreArena, recv: Int, name: String, ty: Int, start: Int, end: Int) -> Int {
    let mut n = emptyCoreNode(CkField)
    n.left = recv
    n.text = name
    n.name = name
    n.ty = ty
    n.start = start
    n.end = end
    coreArenaAdd(arena, n)
}

