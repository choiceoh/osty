use std.strings as strings

/// SelfSymbol is the self-hosting resolver's compact symbol record.
pub struct SelfSymbol {
    pub name: String,
    pub kind: String,
    pub typeName: String,
    pub arity: Int,
    pub depth: Int,
    pub start: Int,
    pub end: Int,
    pub public: Bool,
    pub node: Int,
}

/// SelfResolveDiagnostic mirrors the compiler's name-resolution diagnostics in
/// a small, self-host-friendly shape.
pub struct SelfResolveDiagnostic {
    pub code: String,
    pub message: String,
    pub name: String,
    pub start: Int,
    pub end: Int,
    pub node: Int,
    pub hint: String,
}

/// SelfPartialDecl tracks one struct/enum name that may be declared across
/// multiple files in a package per LANG_SPEC v0.5 §3.4 / grammar R19.
/// The resolver accumulates state as it walks each partial declaration so
/// later partials can be validated against earlier ones — pub visibility,
/// generic-parameter list, fields-in-one-place, and cross-declaration
/// method-name uniqueness.
pub struct SelfPartialDecl {
    pub name: String,
    pub kind: String,
    pub firstNode: Int,
    pub firstStart: Int,
    pub firstEnd: Int,
    pub firstPub: Bool,
    pub firstGenerics: List<String>,
    pub methodNames: List<String>,
    pub methodStarts: List<Int>,
    pub methodEnds: List<Int>,
    pub methodNodes: List<Int>,
    pub hasFields: Bool,
    pub firstFieldsStart: Int,
    pub firstFieldsEnd: Int,
}

/// SelfResolvedRef is one resolved value-ref site: the identifier's AST node
/// plus the target symbol it binds to. `target` is the target symbol's node,
/// or `-1` for builtins / unresolved. `targetStart` / `targetEnd` carry the
/// target symbol's declaration span for the (rare) cases where the consumer
/// needs it directly (e.g. cross-file `def` row rendering that can't walk
/// the arena). The ref site's own source span is derivable from `node`, so
/// it is not duplicated here.
pub struct SelfResolvedRef {
    pub name: String,
    pub node: Int,
    pub target: Int,
    pub targetStart: Int,
    pub targetEnd: Int,
}

/// SelfResolvedTypeRef is one resolved type-ref head site. Carrying just
/// the ident's AST node is enough — type-ref consumers only need the name
/// and the node for disambiguation.
pub struct SelfResolvedTypeRef {
    pub name: String,
    pub node: Int,
}

/// SelfResolveResult contains package symbols plus resolver diagnostics and
/// references collected while walking lexical scopes in function bodies.
pub struct SelfResolveResult {
    pub symbols: List<SelfSymbol>,
    pub diagnostics: List<SelfResolveDiagnostic>,
    pub refs: Int,
    pub refList: List<SelfResolvedRef>,
    pub typeRefs: Int,
    pub typeRefList: List<SelfResolvedTypeRef>,
    pub unresolved: Int,
    pub duplicates: Int,
    /// partials is scratch state used by the top-level collect pass to
    /// detect R19 violations across partial struct/enum declarations.
    /// Consumers of SelfResolveResult can ignore this field — it stays
    /// in the struct so the pass can thread state through the existing
    /// walker signatures without extra tuple returns.
    pub partials: List<SelfPartialDecl>,
}

/// SelfResolveCfgEnv carries the `#[cfg(key = "value")]` evaluation
/// context per LANG_SPEC v0.5 §5 / G29. When `enabled` is false every
/// `#[cfg(...)]` guard is treated as passing — callers that want
/// conditional filtering must construct an env with `enabled = true`.
/// Malformed cfg arguments (E0405 unknown-key, E0739 non-string value)
/// are diagnosed regardless of `enabled` so tooling sees the same
/// validation errors whether or not filtering is active.
///
/// v0.5 scope: simple `key = "value"` form with keys `os`, `target`,
/// `arch`, `feature`. Composite `all(...) / any(...) / not(...)` forms
/// are deferred until the annotation-argument grammar grows nested
/// function-like calls. Multiple `#[cfg(...)]` on one decl are
/// conjoined.
pub struct SelfResolveCfgEnv {
    pub enabled: Bool,
    pub os: String,
    pub arch: String,
    pub target: String,
    pub features: List<String>,
}

pub fn selfSymbol(
    name: String,
    kind: String,
    typeName: String,
    arity: Int,
    depth: Int,
    start: Int,
    end: Int,
    public: Bool,
) -> SelfSymbol {
    SelfSymbol { name, kind, typeName, arity, depth, start, end, public, node: -1 }
}

fn selfSymbolAtNode(
    name: String,
    kind: String,
    typeName: String,
    arity: Int,
    depth: Int,
    start: Int,
    end: Int,
    public: Bool,
    node: Int,
) -> SelfSymbol {
    SelfSymbol { name, kind, typeName, arity, depth, start, end, public, node }
}

pub fn selfResolveDiagnostic(
    code: String,
    message: String,
    name: String,
    start: Int,
    end: Int,
) -> SelfResolveDiagnostic {
    selfResolveDiagnosticAtNode(code, message, name, start, end, -1)
}

fn selfResolveDiagnosticAtNode(
    code: String,
    message: String,
    name: String,
    start: Int,
    end: Int,
    node: Int,
) -> SelfResolveDiagnostic {
    selfResolveDiagnosticHintAtNode(code, message, name, start, end, node, "")
}

fn selfResolveDiagnosticHintAtNode(
    code: String,
    message: String,
    name: String,
    start: Int,
    end: Int,
    node: Int,
    hint: String,
) -> SelfResolveDiagnostic {
    SelfResolveDiagnostic { code, message, name, start, end, node, hint }
}

pub fn emptySelfResolveResult() -> SelfResolveResult {
    SelfResolveResult {
        symbols: [],
        diagnostics: [],
        refs: 0,
        refList: [],
        typeRefs: 0,
        typeRefList: [],
        unresolved: 0,
        duplicates: 0,
        partials: [],
    }
}

/// selfResolveSource builds a package-level symbol table and resolves simple
/// function-body references using the self-hosted AST surface.
pub fn selfResolveSource(source: String) -> SelfResolveResult {
    selfResolveAstFile(astParse(source))
}

pub fn selfResolveAstFile(file: AstFile) -> SelfResolveResult {
    selfResolveAstFileWithCfg(file, selfResolveCfgDisabled())
}

/// selfResolveCfgDisabled constructs a sentinel env whose `enabled` flag is
/// false — the resolver treats every `#[cfg(...)]` guard as passing while
/// still emitting shape-validation diagnostics for malformed args.
pub fn selfResolveCfgDisabled() -> SelfResolveCfgEnv {
    SelfResolveCfgEnv { enabled: false, os: "", arch: "", target: "", features: [] }
}

/// selfResolveCfgEnv builds an enabled env from the host-derived values that
/// `#[cfg(os = ...)]`, `#[cfg(arch = ...)]`, `#[cfg(target = ...)]`, and
/// `#[cfg(feature = ...)]` predicates compare against.
pub fn selfResolveCfgEnv(
    os: String,
    arch: String,
    target: String,
    features: List<String>,
) -> SelfResolveCfgEnv {
    SelfResolveCfgEnv { enabled: true, os, arch, target, features }
}

pub fn selfResolveAstFileWithCfg(file: AstFile, cfg: SelfResolveCfgEnv) -> SelfResolveResult {
    let mut result = emptySelfResolveResult()
    result = selfResolveAstCollectTopLevel(file, cfg, result)
    let scope = srRootScope(result)
    result = selfResolveAstScanFunctions(file, cfg, scope, result)
    result
}

/// SelfUseEdge is one `use target.path` edge in the workspace import
/// graph. `pos` / `endPos` are source offsets pointing at the use site
/// that introduced the edge — cycle diagnostics anchor on them.
pub struct SelfUseEdge {
    pub target: String,
    pub pos: Int,
    pub endPos: Int,
    pub file: String,
}

/// SelfPackageUses groups every non-FFI `use` edge emitted by one
/// package. `path` is the dotted package key (same format as `UseKey`
/// in internal/resolve).
pub struct SelfPackageUses {
    pub path: String,
    pub uses: List<SelfUseEdge>,
}

/// SelfWorkspaceUses is the cross-package input accepted by
/// `selfDetectImportCycles`. Callers should pre-sort `packages` by
/// `path` so the diagnostic emission order is deterministic — the
/// algorithm respects the given order.
pub struct SelfWorkspaceUses {
    pub packages: List<SelfPackageUses>,
}

/// SelfCycleDiag is one `E0506` cyclic-import diagnostic carrying the
/// edge that closed the cycle. The rendered message matches the Go
/// resolver's existing wording (v0.2 §5.4) so golden snapshots stay
/// stable whether the diag is produced by Go or Osty.
pub struct SelfCycleDiag {
    pub importer: String,
    pub target: String,
    pub pos: Int,
    pub endPos: Int,
    pub file: String,
    pub message: String,
}

struct SelfCycleState {
    colors: List<Int>,
    out: List<SelfCycleDiag>,
}

/// selfDetectImportCycles walks the workspace import graph and emits one
/// SelfCycleDiag per edge that completes a cycle. Mirrors
/// internal/resolve/workspace.go::detectCycles — DFS with a tri-state
/// colour array (0=unvisited, 1=on-stack, 2=done). Targets absent from
/// `input.packages` are ignored (matches the Go behaviour: stub and
/// external-dep packages contribute no edges).
pub fn selfDetectImportCycles(input: SelfWorkspaceUses) -> List<SelfCycleDiag> {
    let mut paths: List<String> = []
    let mut usesLists: List<List<SelfUseEdge>> = []
    for pkg in input.packages {
        paths.push(pkg.path)
        usesLists.push(pkg.uses)
    }
    let mut colors: List<Int> = []
    for p in paths {
        let _keep = p
        colors.push(0)
    }
    let mut state = SelfCycleState { colors, out: [] }
    let mut idx = 0
    for p in paths {
        let _keep = p
        state = selfCycleDfs(idx, paths, usesLists, state)
        idx = idx + 1
    }
    state.out
}

fn selfCycleDfs(
    idx: Int,
    paths: List<String>,
    usesLists: List<List<SelfUseEdge>>,
    state: SelfCycleState,
) -> SelfCycleState {
    if state.colors[idx] == 2 {
        return state
    }
    let mut out = state
    out.colors[idx] = 1
    for edge in usesLists[idx] {
        let targetIdx = srStringListIndex(paths, edge.target)
        if targetIdx < 0 {
            continue
        }
        if out.colors[targetIdx] == 1 {
            let message = "cyclic import: `" + paths[idx] + "` imports `" + edge.target + "` which (transitively) imports `" + paths[idx] + "`"
            out.out.push(SelfCycleDiag {
                importer: paths[idx],
                target: edge.target,
                pos: edge.pos,
                endPos: edge.endPos,
                file: edge.file,
                message,
            })
            continue
        }
        if out.colors[targetIdx] == 0 {
            out = selfCycleDfs(targetIdx, paths, usesLists, out)
        }
    }
    out.colors[idx] = 2
    out
}

/// SelfMemberLookupResult encodes the outcome of a cross-package
/// `pkg.member` lookup plus the diagnostic wording that should be
/// emitted (if any). The Go resolver owns the Scope traversal — this
/// function only decides which diag code + message / note / hint
/// string to render for the (pkgName, member, found, public) tuple.
///
/// `status`:
///   0 — member is public; caller should return the looked-up symbol
///       and emit nothing.
///   1 — member exists but is private (E0507). All string fields are
///       populated.
///   2 — member does not exist in the package (E0508). `note`/`hint`
///       stay empty.
pub struct SelfMemberLookupResult {
    pub status: Int,
    pub code: String,
    pub message: String,
    pub primary: String,
    pub note: String,
    pub hint: String,
}

/// selfLookupPackageMember computes the cross-package member-access
/// diagnostic for `pkg.member` access sites. Mirrors the wording of
/// internal/resolve/resolve.go::lookupPackageMember so golden
/// snapshots stay identical whether the diagnostic is produced by Go
/// or Osty.
///
/// `pkgName` — local name of the package symbol (e.g. `fs`).
/// `member` — the identifier being accessed.
/// `typePos` — true when the call site is in a type position; this
///             tightens "name" to "type" in the E0508 wording.
/// `found` — true when pkgScope lookup returned a symbol.
/// `public` — true when the found symbol is marked `pub`. Ignored
///             when `found` is false.
pub fn selfLookupPackageMember(
    pkgName: String,
    member: String,
    typePos: Bool,
    found: Bool,
    public: Bool,
) -> SelfMemberLookupResult {
    if !found {
        let noun = if typePos { "type" } else { "name" }
        let message = "package `" + pkgName + "` has no exported " + noun + " `" + member + "`"
        return SelfMemberLookupResult {
            status: 2,
            code: "E0508",
            message,
            primary: "unknown member",
            note: "",
            hint: "",
        }
    }
    if !public {
        let message = "`" + pkgName + "." + member + "` is not exported from package `" + pkgName + "`"
        let note = "declared without `pub` in package `" + pkgName + "`"
        let hint = "add `pub` to the declaration of `" + member + "` or access it only from within its package"
        return SelfMemberLookupResult {
            status: 1,
            code: "E0507",
            message,
            primary: "private across packages",
            note,
            hint,
        }
    }
    SelfMemberLookupResult {
        status: 0,
        code: "",
        message: "",
        primary: "",
        note: "",
        hint: "",
    }
}

pub fn selfResolveDiagnosticCount(result: SelfResolveResult) -> Int {
    result.diagnostics.len()
}

pub fn selfResolveCodeCount(result: SelfResolveResult, code: String) -> Int {
    let mut count = 0
    for diag in result.diagnostics {
        if diag.code == code {
            count = count + 1
        }
    }
    count
}

pub fn selfResolveSymbolCount(result: SelfResolveResult, kind: String) -> Int {
    let mut count = 0
    for sym in result.symbols {
        if sym.kind == kind {
            count = count + 1
        }
    }
    count
}

pub fn selfResolveHasSymbol(result: SelfResolveResult, name: String, kind: String) -> Bool {
    for sym in result.symbols {
        if sym.name == name && sym.kind == kind {
            return true
        }
    }
    false
}

pub fn selfResolveHasRef(result: SelfResolveResult, name: String) -> Bool {
    for ref in result.refList {
        if ref.name == name {
            return true
        }
    }
    false
}

pub fn selfResolveHasRefNode(result: SelfResolveResult, node: Int) -> Bool {
    for ref in result.refList {
        if ref.node == node {
            return true
        }
    }
    false
}

pub fn selfResolveHasTypeRef(result: SelfResolveResult, name: String) -> Bool {
    for ref in result.typeRefList {
        if ref.name == name {
            return true
        }
    }
    false
}

pub fn selfResolveHasRefTarget(
    result: SelfResolveResult,
    name: String,
    start: Int,
    end: Int,
    node: Int,
) -> Bool {
    for ref in result.refList {
        if ref.name == name {
            if node >= 0 && ref.target >= 0 && ref.target == node {
                return true
            }
            if ref.targetStart == start && ref.targetEnd == end {
                return true
            }
        }
    }
    false
}

pub fn selfResolveRefNodeTargets(
    result: SelfResolveResult,
    refNode: Int,
    name: String,
    start: Int,
    end: Int,
    targetNode: Int,
) -> Bool {
    for ref in result.refList {
        if ref.node == refNode && ref.name == name {
            if targetNode >= 0 && ref.target >= 0 && ref.target == targetNode {
                return true
            }
            if ref.targetStart == start && ref.targetEnd == end {
                return true
            }
        }
    }
    false
}

pub fn selfResolveRefNodesSameTarget(
    result: SelfResolveResult,
    leftNode: Int,
    rightNode: Int,
) -> Bool {
    // Fused single-pass scan: the previous version walked `refNodes`
    // twice, once to find each side. Merging both checks into one
    // traversal halves the work and the early `break` lets us leave
    // as soon as both sides are resolved.
    let mut leftFound = false
    let mut leftTarget = -1
    let mut leftStart = -1
    let mut leftEnd = -1
    let mut rightFound = false
    let mut rightTarget = -1
    let mut rightStart = -1
    let mut rightEnd = -1
    for ref in result.refList {
        if ref.node == leftNode && !(leftFound) {
            leftFound = true
            leftTarget = ref.target
            leftStart = ref.targetStart
            leftEnd = ref.targetEnd
        } else if ref.node == rightNode && !(rightFound) {
            rightFound = true
            rightTarget = ref.target
            rightStart = ref.targetStart
            rightEnd = ref.targetEnd
        }
        if leftFound && rightFound {
            break
        }
    }

    if !(leftFound) || !(rightFound) {
        return false
    }
    if leftTarget >= 0 || rightTarget >= 0 {
        return leftTarget == rightTarget
    }
    leftStart >= 0 && leftStart == rightStart && leftEnd == rightEnd
}

struct SelfResolveName {
    name: String,
    start: Int,
    end: Int,
    node: Int,
}

fn selfResolveName(name: String, start: Int, end: Int, node: Int) -> SelfResolveName {
    SelfResolveName { name, start, end, node }
}

/// SelfResolveScope is the self-hosted resolver's compact lexical scope. It
/// stores the currently visible symbols as a flat list and uses `depth` to
/// distinguish same-scope duplicates from legal child-scope shadowing.
///
/// `inFn`/`inLoop` track the flow context that gates `return`/`defer` and
/// `break`/`continue`. A closure starts a fresh fn context with `inLoop=false`
/// so that `for { || { break } }` is correctly rejected: the loop doesn't
/// leak through the closure barrier. These mirror the Go resolver's flowCtx.
struct SelfResolveScope {
    symbols: List<SelfSymbol>,
    depth: Int,
    ifaceDefault: Bool,
    inFn: Bool,
    inLoop: Bool,
    loopLabels: List<String>,
    loopLabelStarts: List<Int>,
    loopLabelEnds: List<Int>,
}

fn srRootScope(result: SelfResolveResult) -> SelfResolveScope {
    SelfResolveScope {
        symbols: srSymbolListCopy(result.symbols),
        depth: 0,
        ifaceDefault: false,
        inFn: false,
        inLoop: false,
        loopLabels: [],
        loopLabelStarts: [],
        loopLabelEnds: [],
    }
}

fn srChildScope(parent: SelfResolveScope) -> SelfResolveScope {
    SelfResolveScope {
        symbols: srSymbolListCopy(parent.symbols),
        depth: parent.depth + 1,
        ifaceDefault: parent.ifaceDefault,
        inFn: parent.inFn,
        inLoop: parent.inLoop,
        loopLabels: srStringListCopy(parent.loopLabels),
        loopLabelStarts: srIntListCopy(parent.loopLabelStarts),
        loopLabelEnds: srIntListCopy(parent.loopLabelEnds),
    }
}

fn srFnChildScope(parent: SelfResolveScope, ifaceDefault: Bool) -> SelfResolveScope {
    SelfResolveScope {
        symbols: srSymbolListCopy(parent.symbols),
        depth: parent.depth + 1,
        ifaceDefault,
        inFn: true,
        inLoop: false,
        loopLabels: [],
        loopLabelStarts: [],
        loopLabelEnds: [],
    }
}

fn srLoopChildScope(parent: SelfResolveScope) -> SelfResolveScope {
    SelfResolveScope {
        symbols: srSymbolListCopy(parent.symbols),
        depth: parent.depth + 1,
        ifaceDefault: parent.ifaceDefault,
        inFn: parent.inFn,
        inLoop: true,
        loopLabels: srStringListCopy(parent.loopLabels),
        loopLabelStarts: srIntListCopy(parent.loopLabelStarts),
        loopLabelEnds: srIntListCopy(parent.loopLabelEnds),
    }
}

fn srScopeDefine(
    scope: SelfResolveScope,
    result: SelfResolveResult,
    sym: SelfSymbol,
) -> SelfResolveResult {
    let mut out = result
    if srIsDiscardName(sym.name) {
        return out
    }
    if srSymbolExistsAtDepth(scope.symbols, sym.name, scope.depth) {
        return srDuplicateAtNode(out, sym.name, sym.start, sym.end, sym.node)
    }
    let mut scoped = sym
    scoped.depth = scope.depth
    scope.symbols.push(scoped)
    out
}

fn srScopeLookup(scope: SelfResolveScope, name: String) -> SelfSymbol {
    let mut found = selfSymbol("", "", "", 0, -1, 0, 0, false)
    for sym in scope.symbols {
        if sym.name == name {
            found = sym
        }
    }
    found
}

fn srScopeHas(scope: SelfResolveScope, name: String) -> Bool {
    srScopeLookup(scope, name).name != ""
}

fn selfResolveAstCollectTopLevel(
    file: AstFile,
    cfg: SelfResolveCfgEnv,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    for declIdx in file.arena.decls {
        out = srAstCollectDecl(file, declIdx, cfg, out)
    }
    out
}

fn srAstCollectDecl(
    file: AstFile,
    idx: Int,
    cfg: SelfResolveCfgEnv,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    // cfg arg shape validation runs whether or not the decl will drop —
    // tooling surfaces E0405/E0739 on malformed cfg even when the filter
    // would have removed the decl. The main annotation walk below does
    // NOT re-validate cfg (see srCheckAnnotationArgs) so diags don't
    // double-fire for decls that survive.
    let mut out = srValidateCfgAnnotationsOnDecl(file, node.extra, result)
    if !srCfgDeclPasses(file, node, cfg) {
        return out
    }
    if node.kind == AstNUseDecl {
        let alias = srAstUseAlias(file, node)
        if alias != "" {
            out = srAddSymbol(
                out,
                selfSymbolAtNode(alias, "package", "", 0, 0, node.start, node.end, true, idx),
            )
        }
    } else if node.kind == AstNFnDecl {
        out = srAstAddFunctionSymbol(file, idx, out)
        out = srCheckDeclAnnotations(file, node.extra, srAnnotTargetTopLevel(), out)
    } else if node.kind == AstNStructDecl {
        out = srHandlePartialType(file, node, idx, "struct", out)
        out = srCheckDeclAnnotations(file, node.extra, srAnnotTargetTopLevel(), out)
        out = srCheckTypeMemberAnnotations(file, node, out)
    } else if node.kind == AstNInterfaceDecl || node.kind == AstNTypeAlias {
        out = srAddSymbol(
            out,
            selfSymbolAtNode(node.text, "type", "", 0, 0, node.start, node.end, node.flags == 1, idx),
        )
        out = srCheckDeclAnnotations(file, node.extra, srAnnotTargetTopLevel(), out)
        out = srCheckTypeMemberAnnotations(file, node, out)
    } else if node.kind == AstNEnumDecl {
        out = srHandlePartialType(file, node, idx, "enum", out)
        out = srCheckDeclAnnotations(file, node.extra, srAnnotTargetTopLevel(), out)
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            if member.kind == AstNVariant {
                out = srAddSymbol(
                    out,
                    selfSymbolAtNode(
                        member.text,
                        "variant",
                        "",
                        0,
                        0,
                        member.start,
                        member.end,
                        true,
                        memberIdx,
                    ),
                )
                out = srCheckDeclAnnotations(file, member.extra, srAnnotTargetVariant(), out)
            } else if member.kind == AstNFnDecl {
                out = srCheckDeclAnnotations(file, member.extra, srAnnotTargetMethod(), out)
            }
        }
        out = srCheckDuplicateVariantJSONTags(file, idx, out)
    } else if node.kind == AstNLet {
        let names = srAstPatternNames(file, node.left, [])
        for item in names {
            out = srAddSymbol(
                out,
                selfSymbolAtNode(item.name, "value", srAstLetTypeName(file, node), 0, 0, item.start, item.end, false, item.node),
            )
        }
        out = srCheckDeclAnnotations(file, node.extra, srAnnotTargetTopLevel(), out)
    }
    out
}

fn srCheckTypeMemberAnnotations(
    file: AstFile,
    node: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if node.kind == AstNStructDecl {
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            if member.kind == AstNField_ {
                out = srCheckDeclAnnotations(file, member.extra, srAnnotTargetField(), out)
                out = srCheckJSONFieldArgs(file, member, out)
            } else if member.kind == AstNFnDecl {
                out = srCheckDeclAnnotations(file, member.extra, srAnnotTargetMethod(), out)
            }
        }
    } else if node.kind == AstNInterfaceDecl {
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            if member.kind == AstNFnDecl {
                out = srCheckDeclAnnotations(file, member.extra, srAnnotTargetMethod(), out)
            }
        }
    }
    out
}

fn srAstAddFunctionSymbol(
    file: AstFile,
    idx: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let node = srAstNode(file, idx)
    srAddSymbol(
        result,
        selfSymbolAtNode(
            node.text,
            "fn",
            "",
            srAstListCount(node.children),
            0,
            node.start,
            node.end,
            node.flags == 1,
            idx,
        ),
    )
}

fn selfResolveAstScanFunctions(
    file: AstFile,
    cfg: SelfResolveCfgEnv,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    for declIdx in file.arena.decls {
        out = srAstScanFunctionsInDecl(file, declIdx, cfg, scope, out)
    }
    out
}

fn srAstScanFunctionsInDecl(
    file: AstFile,
    idx: Int,
    cfg: SelfResolveCfgEnv,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    if !srCfgDeclPasses(file, node, cfg) {
        return result
    }
    let mut out = result
    if node.kind == AstNFnDecl {
        return srAstResolveFunction(file, idx, scope, "", false, out)
    }
    if node.kind == AstNStructDecl || node.kind == AstNEnumDecl || node.kind == AstNInterfaceDecl {
        return srAstResolveTypeDecl(file, idx, scope, out)
    }
    if node.kind == AstNTypeAlias {
        return srAstResolveTypeAlias(file, node, scope, out)
    }
    if node.kind == AstNLet {
        out = srAstResolveType(file, srAstChildAt(node.children, 0), scope, "", out)
        return srAstResolveExpr(file, node.right, scope, out)
    }
    out
}

fn srAstResolveTypeDecl(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let node = srAstNode(file, idx)
    let typeScope = srChildScope(scope)
    let mut out = srScopeDefine(
        typeScope,
        result,
        selfSymbolAtNode("Self", "type", node.text, 0, typeScope.depth, node.start, node.end, true, idx),
    )
    if node.kind == AstNStructDecl || node.kind == AstNEnumDecl {
        out = srAstDeclareGenerics(file, node.children2, typeScope, out)
    }
    if node.kind == AstNStructDecl {
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            if member.kind == AstNField_ {
                out = srAstResolveType(file, member.right, typeScope, node.text, out)
                out = srAstResolveExpr(file, member.left, typeScope, out)
            } else if member.kind == AstNFnDecl {
                out = srAstResolveFunction(file, memberIdx, typeScope, node.text, false, out)
            }
        }
    } else if node.kind == AstNEnumDecl {
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            if member.kind == AstNVariant {
                for ty in member.children {
                    out = srAstResolveType(file, ty, typeScope, node.text, out)
                }
            } else if member.kind == AstNFnDecl {
                out = srAstResolveFunction(file, memberIdx, typeScope, node.text, false, out)
            }
        }
    } else if node.kind == AstNInterfaceDecl {
        for superIdx in node.children2 {
            out = srAstResolveType(file, superIdx, typeScope, node.text, out)
        }
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            if member.kind == AstNFnDecl {
                out = srAstResolveFunction(file, memberIdx, typeScope, node.text, member.right >= 0, out)
            } else if member.kind == AstNType {
                out = srAstResolveType(file, memberIdx, typeScope, node.text, out)
            }
        }
    }
    out
}

fn srAstResolveTypeAlias(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let aliasScope = srChildScope(scope)
    let mut out = srAstDeclareGenerics(file, node.children, aliasScope, result)
    srAstResolveType(file, node.left, aliasScope, "", out)
}

fn srAstDeclareGenerics(
    file: AstFile,
    generics: List<Int>,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    for genericIdx in generics {
        let generic = srAstNode(file, genericIdx)
        out = srScopeDefine(
            scope,
            out,
            selfSymbolAtNode(generic.text, "generic", "", 0, scope.depth, generic.start, generic.end, false, genericIdx),
        )
    }
    for genericIdx in generics {
        let generic = srAstNode(file, genericIdx)
        for boundIdx in generic.children {
            out = srAstResolveType(file, boundIdx, scope, "", out)
        }
    }
    out
}

fn srAstResolveFunction(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    owner: String,
    ifaceDefault: Bool,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let node = srAstNode(file, idx)
    let mut out = result
    let fnScope = srFnChildScope(scope, ifaceDefault)
    out = srAstDeclareGenerics(file, node.children2, fnScope, out)
    for paramIdx in node.children {
        let param = srAstNode(file, paramIdx)
        if param.left >= 0 && param.text != "" {
            out = srAstResolveExpr(file, param.left, fnScope, out)
        }
        out = srAstResolveType(file, param.right, fnScope, owner, out)
        out = srAstResolveParamBindings(file, paramIdx, fnScope, owner, out)
    }
    out = srAstResolveType(file, node.left, fnScope, owner, out)
    let bodyScope = srChildScope(fnScope)
    srAstResolveBlock(file, node.right, bodyScope, out)
}

fn srAstResolveBlock(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    if node.kind != AstNBlock {
        return srAstResolveExpr(file, idx, scope, result)
    }
    let mut out = result
    for stmtIdx in node.children {
        let stmt = srAstNode(file, stmtIdx)
        if stmt.kind == AstNLet {
            out = srAstResolveType(file, srAstChildAt(stmt.children, 0), scope, "", out)
            if stmt.right >= 0 {
                out = srAstResolveExpr(file, stmt.right, scope, out)
            }
            out = srAstResolvePattern(file, stmt.left, scope, out)
        } else {
            out = srAstResolveStmt(file, stmtIdx, scope, out)
        }
    }
    out
}

fn srAstResolveStmt(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    let mut out = result
    if node.kind == AstNFor {
        return srAstResolveFor(file, node, scope, out)
    }
    if node.kind == AstNReturn {
        if !scope.inFn {
            out = srPushFlowDiag(
                out,
                "E0602",
                "`return` is only valid inside a function body",
                node.start,
                node.end,
                idx,
            )
        }
        return srAstResolveExpr(file, node.left, scope, out)
    }
    if node.kind == AstNDefer {
        if !scope.inFn {
            out = srPushFlowDiag(
                out,
                "E0603",
                "`defer` is only valid inside a function body",
                node.start,
                node.end,
                idx,
            )
        }
        return srAstResolveExpr(file, node.left, scope, out)
    }
    if node.kind == AstNBreak {
        if !scope.inLoop {
            out = srPushFlowDiag(
                out,
                "E0600",
                "`break` is only valid inside a `for` loop",
                node.start,
                node.end,
                idx,
            )
        }
        if scope.inLoop && node.extra >= 0 {
            let labelNode = srAstNode(file, node.extra)
            if srFindLoopLabel(scope, labelNode.text) < 0 {
                out.diagnostics.push(
                    selfResolveDiagnosticHintAtNode(
                        "E0763",
                        "undefined loop label",
                        labelNode.text,
                        labelNode.start,
                        labelNode.end,
                        node.extra,
                        "add the label to an enclosing `for`/`loop`, or remove it from the break",
                    ),
                )
            }
        }
        return srAstResolveExpr(file, node.left, scope, out)
    }
    if node.kind == AstNContinue {
        if !scope.inLoop {
            out = srPushFlowDiag(
                out,
                "E0601",
                "`continue` is only valid inside a `for` loop",
                node.start,
                node.end,
                idx,
            )
        }
        if scope.inLoop && node.extra >= 0 {
            let labelNode = srAstNode(file, node.extra)
            if srFindLoopLabel(scope, labelNode.text) < 0 {
                out.diagnostics.push(
                    selfResolveDiagnosticHintAtNode(
                        "E0763",
                        "undefined loop label",
                        labelNode.text,
                        labelNode.start,
                        labelNode.end,
                        node.extra,
                        "add the label to an enclosing `for`/`loop`, or remove it from the continue",
                    ),
                )
            }
        }
        return out
    }
    if node.kind == AstNExprStmt {
        return srAstResolveExpr(file, node.left, scope, out)
    }
    if node.kind == AstNAssign || node.kind == AstNChanSend {
        out = srAstResolveExpr(file, node.left, scope, out)
        return srAstResolveExpr(file, node.right, scope, out)
    }
    srAstResolveExpr(file, idx, scope, out)
}

fn srPushFlowDiag(
    result: SelfResolveResult,
    code: String,
    message: String,
    start: Int,
    end: Int,
    node: Int,
) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(selfResolveDiagnosticAtNode(code, message, "", start, end, node))
    out
}

fn srFindLoopLabel(scope: SelfResolveScope, name: String) -> Int {
    let mut idx = scope.loopLabels.len() - 1
    for idx >= 0 {
        if srStringListAt(scope.loopLabels, idx) == name {
            return idx
        }
        idx = idx - 1
    }
    -1
}

fn srPushLoopLabelShadowDiag(
    scope: SelfResolveScope,
    file: AstFile,
    labelIdx: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if labelIdx < 0 {
        return out
    }
    let labelNode = srAstNode(file, labelIdx)
    let shadow = srFindLoopLabel(scope, labelNode.text)
    if shadow >= 0 {
        out.diagnostics.push(
            selfResolveDiagnosticHintAtNode(
                "E0764",
                "loop label shadows an outer loop label",
                labelNode.text,
                labelNode.start,
                labelNode.end,
                labelIdx,
                "rename one of the two loop labels so each nested loop name stays unique",
            ),
        )
    }
    out
}

fn srScopeWithLoopLabel(
    scope: SelfResolveScope,
    file: AstFile,
    labelIdx: Int,
) -> SelfResolveScope {
    let mut next = scope
    if labelIdx < 0 {
        return next
    }
    let labelNode = srAstNode(file, labelIdx)
    next.loopLabels.push(labelNode.text)
    next.loopLabelStarts.push(labelNode.start)
    next.loopLabelEnds.push(labelNode.end)
    next
}

fn srAstResolveFor(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    out = srAstResolveExpr(file, node.left, scope, out)
    let iterIdx = srAstChildAt(node.children, 1)
    out = srAstResolveExpr(file, iterIdx, scope, out)
    let loopScope = srChildScope(scope)
    out = srPushLoopLabelShadowDiag(loopScope, file, node.extra, out)
    let loopScope2 = srScopeWithLoopLabel(loopScope, file, node.extra)
    let patIdx = srAstChildAt(node.children, 0)
    out = srAstResolvePattern(file, patIdx, loopScope2, out)
    let bodyScope = srLoopChildScope(loopScope2)
    srAstResolveBlock(file, node.right, bodyScope, out)
}

fn srAstResolveType(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    owner: String,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    if node.kind != AstNType {
        return result
    }
    let mut out = result
    if node.text == "error" {
        return out
    }
    if node.text == "optional" {
        out = srAstResolveType(file, node.left, scope, owner, out)
    } else if node.text == "tuple" {
        for child in node.children {
            out = srAstResolveType(file, child, scope, owner, out)
        }
    } else if node.text == "fn" {
        for child in node.children {
            out = srAstResolveType(file, child, scope, owner, out)
        }
        out = srAstResolveType(file, node.right, scope, owner, out)
    } else {
        out = srResolveOneAstType(node.text, node.start, node.end, idx, scope, owner, out)
        let head = srPathHead(node.text)
        let tail = srPathLastSegment(node.text)
        let sym = srScopeLookup(scope, head)
        if head != "" && tail != head && sym.kind == "package" {
            out = srResolvePackageMember(file, sym, tail, node.start, node.end, idx, true, out)
        }
        for child in node.children {
            out = srAstResolveType(file, child, scope, owner, out)
        }
    }
    out
}

fn srAstResolveExpr(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    let mut out = result
    if node.kind == AstNIdent {
        return srResolveOneAstIdent(node.text, node.start, node.end, idx, scope, out)
    }
    if node.kind == AstNField {
        return srAstResolveField(file, idx, node, scope, out)
    }
    if node.kind == AstNCall {
        return srAstResolveCall(file, node, scope, out)
    }
    if node.kind == AstNStructLit {
        out = srAstResolveExpr(file, node.left, scope, out)
        for fieldIdx in node.children {
            out = srAstResolveStructField(file, fieldIdx, scope, out)
        }
        return srAstResolveExpr(file, node.right, scope, out)
    }
    if node.kind == AstNIf {
        return srAstResolveIf(file, node, scope, out)
    }
    if node.kind == AstNMatch {
        return srAstResolveMatch(file, node, scope, out)
    }
    if node.kind == AstNClosure {
        return srAstResolveClosure(file, node, scope, out)
    }
    if node.kind == AstNFor && node.text == "loopexpr" {
        let loopScope = srLoopChildScope(scope)
        out = srPushLoopLabelShadowDiag(loopScope, file, node.extra, out)
        let labeledScope = srScopeWithLoopLabel(loopScope, file, node.extra)
        return srAstResolveBlock(file, node.right, labeledScope, out)
    }
    if node.kind == AstNBlock {
        let blockScope = srChildScope(scope)
        return srAstResolveBlock(file, idx, blockScope, out)
    }
    if node.kind == AstNType || node.kind == AstNPattern || node.kind == AstNParam || node.kind == AstNGenericParam {
        return out
    }
    out = srAstResolveExpr(file, node.left, scope, out)
    out = srAstResolveExpr(file, node.right, scope, out)
    for child in node.children {
        out = srAstResolveExpr(file, child, scope, out)
    }
    for child in node.children2 {
        out = srAstResolveExpr(file, child, scope, out)
    }
    out
}

fn srAstResolveStructField(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    if node.kind != AstNField_ {
        return srAstResolveExpr(file, idx, scope, result)
    }
    if node.left >= 0 {
        return srAstResolveExpr(file, node.left, scope, result)
    }
    srResolveOneAstIdent(node.text, node.start, node.end, idx, scope, result)
}

fn srAstResolveField(
    file: AstFile,
    idx: Int,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = srAstResolveExpr(file, node.left, scope, result)
    let base = srAstNode(file, node.left)
    if base.kind == AstNIdent {
        let sym = srScopeLookup(scope, base.text)
        if sym.kind == "package" {
            return srResolvePackageMember(file, sym, node.text, node.start, node.end, idx, false, out)
        }
        if scope.ifaceDefault && node.flags != 1 && base.text == "self" {
            return srInterfaceDefaultFieldAtNode(out, node.start, node.end, idx)
        }
    }
    out
}

fn srAstResolveCall(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let callee = srAstNode(file, node.left)
    if callee.kind == AstNField {
        out = srAstResolveCallField(file, callee, scope, out)
    } else {
        out = srAstResolveExpr(file, node.left, scope, out)
    }
    for child in node.children {
        out = srAstResolveExpr(file, child, scope, out)
    }
    out
}

fn srAstResolveCallField(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = srAstResolveExpr(file, node.left, scope, result)
    let base = srAstNode(file, node.left)
    if base.kind == AstNIdent {
        let sym = srScopeLookup(scope, base.text)
        if sym.kind == "package" {
            out = srResolvePackageMember(file, sym, node.text, node.start, node.end, node.left, false, out)
        }
    }
    out
}

fn srAstResolveIf(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = srAstResolveExpr(file, node.left, scope, result)
    let thenScope = srChildScope(scope)
    if node.flags == 1 {
        let patIdx = srAstChildAt(node.children, 1)
        out = srAstResolvePattern(file, patIdx, thenScope, out)
    }
    let thenBlockScope = srChildScope(thenScope)
    out = srAstResolveBlock(file, node.right, thenBlockScope, out)
    let elseIdx = srAstChildAt(node.children, 0)
    srAstResolveExpr(file, elseIdx, scope, out)
}

fn srAstResolveMatch(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = srAstResolveExpr(file, node.left, scope, result)
    for armIdx in node.children {
        let arm = srAstNode(file, armIdx)
        let armScope = srChildScope(scope)
        out = srAstResolvePattern(file, arm.left, armScope, out)
        let guardIdx = srAstChildAt(arm.children, 0)
        out = srAstResolveExpr(file, guardIdx, armScope, out)
        out = srAstResolveExpr(file, arm.right, armScope, out)
    }
    out
}

fn srAstResolveClosure(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let closureScope = srFnChildScope(scope, false)
    for paramIdx in node.children {
        let param = srAstNode(file, paramIdx)
        out = srAstResolveType(file, param.right, closureScope, "", out)
        out = srAstResolveParamBindings(file, paramIdx, closureScope, "", out)
    }
    out = srAstResolveType(file, node.right, closureScope, "", out)
    srAstResolveExpr(file, node.left, closureScope, out)
}

fn srResolveOneAstIdent(
    name: String,
    start: Int,
    end: Int,
    node: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if name == "_" {
        // `_` is a pattern wildcard; in an expression it is never a value.
        // The parser rejects it at the token level too (E0604), but we
        // emit here to match Go's resolver contract and to suppress the
        // misleading "undefined name `_`" that the normal lookup path
        // would otherwise produce.
        return srWildcardInExprAtNode(out, start, end, node)
    }
    if srIsBuiltinName(name) {
        return out
    }
    if name == "self" {
        let sym = srScopeLookup(scope, name)
        if sym.name != "" {
            return srRecordRef(out, name, node, sym)
        }
        return srSelfOutsideAtNode(out, start, end, node)
    }
    if name == "Self" {
        let sym = srScopeLookup(scope, name)
        if sym.name != "" {
            return srRecordRef(out, name, node, sym)
        }
        return srSelfTypeOutsideAtNode(out, start, end, node)
    }
    let sym = srScopeLookup(scope, name)
    if sym.name != "" {
        return srRecordRef(out, name, node, sym)
    }
    out.unresolved = out.unresolved + 1
    let hint = srUndefinedHint(scope, name)
    if hint == "" {
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0500", "undefined name", name, start, end, node))
    } else {
        out.diagnostics.push(
            selfResolveDiagnosticHintAtNode("E0500", "undefined name", name, start, end, node, hint),
        )
    }
    out
}

fn srResolveOneAstType(
    name: String,
    start: Int,
    end: Int,
    node: Int,
    scope: SelfResolveScope,
    owner: String,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let head = srPathHead(name)
    if head == "" {
        return out
    }
    if head == "Self" {
        if owner == "" {
            return srSelfTypeOutsideAtNode(out, start, end, node)
        }
        return srRecordTypeRef(out, name, node)
    }
    if srIsBuiltinTypeName(head) {
        return srRecordTypeRef(out, name, node)
    }
    let sym = srScopeLookup(scope, head)
    if sym.name == "" {
        out.unresolved = out.unresolved + 1
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0500", "undefined type", head, start, end, node))
        return out
    }
    if !(srSymbolCanBeType(sym)) {
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0502", "name is not a type", head, start, end, node))
        return out
    }
    srRecordTypeRef(out, name, node)
}

fn srResolvePackageMember(
    file: AstFile,
    pkgSym: SelfSymbol,
    member: String,
    start: Int,
    end: Int,
    node: Int,
    typePos: Bool,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let useNode = srAstUseNode(file, pkgSym)
    if useNode.kind != AstNUseDecl {
        return out
    }
    if srAstListCount(useNode.children) == 0 {
        return out
    }
    let sym = srAstLookupPackageMember(file, useNode, member)
    if sym.name == "" {
        let noun = if typePos {
            "type"
        } else {
            "name"
        }
        out.diagnostics.push(
            selfResolveDiagnosticAtNode(
                "E0508",
                "package `{pkgSym.name}` has no exported {noun}",
                member,
                start,
                end,
                node,
            ),
        )
        return out
    }
    if typePos && !(srSymbolCanBeType(sym)) {
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0502", "name is not a type", member, start, end, node))
    }
    out
}

fn srRecordRef(
    result: SelfResolveResult,
    name: String,
    node: Int,
    target: SelfSymbol,
) -> SelfResolveResult {
    let mut out = result
    out.refs = out.refs + 1
    out.refList.push(SelfResolvedRef {
        name: name,
        node: node,
        target: target.node,
        targetStart: target.start,
        targetEnd: target.end,
    })
    out
}

fn srRecordBareRef(result: SelfResolveResult, name: String, node: Int) -> SelfResolveResult {
    srRecordRef(result, name, node, srEmptySymbol())
}

fn srRecordTypeRef(result: SelfResolveResult, name: String, node: Int) -> SelfResolveResult {
    let mut out = result
    out.typeRefs = out.typeRefs + 1
    out.typeRefList.push(SelfResolvedTypeRef { name: name, node: node })
    out
}

fn srSelfOutsideAtNode(result: SelfResolveResult, start: Int, end: Int, node: Int) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(selfResolveDiagnosticAtNode("E0503", "`self` outside method", "self", start, end, node))
    out
}

fn srSelfTypeOutsideAtNode(result: SelfResolveResult, start: Int, end: Int, node: Int) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(selfResolveDiagnosticAtNode("E0504", "`Self` outside type body", "Self", start, end, node))
    out
}

fn srWildcardInExprAtNode(result: SelfResolveResult, start: Int, end: Int, node: Int) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(selfResolveDiagnosticHintAtNode(
        "E0604",
        "`_` is only valid as a pattern wildcard, not as an expression",
        "_",
        start,
        end,
        node,
        "use `let _ = expr` to ignore a value",
    ))
    out
}

fn srInterfaceDefaultFieldAtNode(
    result: SelfResolveResult,
    start: Int,
    end: Int,
    node: Int,
) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(
        selfResolveDiagnosticHintAtNode(
            "E0606",
            "interface default method bodies may not access fields on `self`",
            "",
            start,
            end,
            node,
            "expose the value through an interface method and call that instead",
        ),
    )
    out
}

fn srAstResolveParamBindings(
    file: AstFile,
    paramIdx: Int,
    scope: SelfResolveScope,
    owner: String,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if paramIdx < 0 {
        return result
    }
    let param = srAstNode(file, paramIdx)
    let mut out = result
    if param.text != "" {
        if param.text == "self" && owner == "" {
            out = srSelfOutsideAtNode(out, param.start, param.end, paramIdx)
        }
        return srScopeDefine(
            scope,
            out,
            selfSymbolAtNode(
                param.text,
                "value",
                srAstTypeName(file, param.right),
                0,
                scope.depth,
                param.start,
                param.end,
                false,
                paramIdx,
            ),
        )
    }
    srAstResolvePattern(file, param.left, scope, out)
}

fn srAstResolvePattern(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    let mut out = result
    if node.kind == AstNIdent {
        return srAstBindPatternName(scope, out, selfResolveName(node.text, node.start, node.end, idx))
    }
    if node.kind != AstNPattern {
        return out
    }
    if node.extra == astPatternWildcardKind() {
        return out
    }
    if node.extra == astPatternLiteralKind() {
        return srAstResolvePatternValue(file, node.left, scope, out)
    }
    if node.extra == astPatternIdentKind() {
        return srAstResolveIdentPattern(node, idx, scope, out)
    }
    if node.extra == astPatternFieldKind() {
        if node.left >= 0 {
            return srAstResolvePattern(file, node.left, scope, out)
        }
        return srAstBindPatternName(scope, out, selfResolveName(node.text, node.start, node.end, idx))
    }
    if node.extra == astPatternStructKind() {
        out = srResolvePatternTypePath(node.text, node.start, node.end, idx, scope, out)
        for child in node.children {
            out = srAstResolvePattern(file, child, scope, out)
        }
        return out
    }
    if node.extra == astPatternVariantKind() {
        out = srResolvePatternVariantPath(node.text, node.start, node.end, idx, scope, out)
        for child in node.children {
            out = srAstResolvePattern(file, child, scope, out)
        }
        return out
    }
    if node.extra == astPatternRangeKind() {
        out = srAstResolvePatternValue(file, node.left, scope, out)
        return srAstResolvePatternValue(file, node.right, scope, out)
    }
    if node.extra == astPatternOrKind() {
        return srAstResolveOrPattern(file, node, scope, out)
    }
    if node.extra == astPatternBindingKind() {
        out = srAstBindPatternName(scope, out, selfResolveName(node.text, node.start, node.start + 1, idx))
        return srAstResolvePattern(file, node.left, scope, out)
    }
    out = srAstResolvePattern(file, node.left, scope, out)
    out = srAstResolvePattern(file, node.right, scope, out)
    for child in node.children {
        out = srAstResolvePattern(file, child, scope, out)
    }
    out
}

fn srAstResolveIdentPattern(
    node: AstNode,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if srIsUpperName(node.text) {
        if srIsBuiltinVariantName(node.text) {
            return srRecordBareRef(result, node.text, idx)
        }
        let sym = srScopeLookup(scope, node.text)
        if sym.kind == "variant" {
            return srRecordRef(result, node.text, idx, sym)
        }
    }
    srAstBindPatternName(scope, result, selfResolveName(node.text, node.start, node.end, idx))
}

fn srAstBindPatternName(
    scope: SelfResolveScope,
    result: SelfResolveResult,
    item: SelfResolveName,
) -> SelfResolveResult {
    if srIsDiscardName(item.name) {
        return result
    }
    srScopeDefine(
        scope,
        result,
        selfSymbolAtNode(item.name, "value", "", 0, scope.depth, item.start, item.end, false, item.node),
    )
}

fn srAstResolvePatternValue(
    file: AstFile,
    idx: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if idx < 0 {
        return result
    }
    let node = srAstNode(file, idx)
    let mut out = result
    if node.kind == AstNIdent {
        return srResolveOneAstIdent(node.text, node.start, node.end, idx, scope, out)
    }
    if node.kind != AstNPattern {
        return out
    }
    if node.extra == astPatternIdentKind() {
        if srIsUpperName(node.text) {
            return srResolvePatternVariantPath(node.text, node.start, node.end, idx, scope, out)
        }
        return srResolveOneAstIdent(node.text, node.start, node.end, idx, scope, out)
    }
    if node.extra == astPatternLiteralKind() {
        return srAstResolvePatternValue(file, node.left, scope, out)
    }
    if node.extra == astPatternStructKind() {
        out = srResolvePatternTypePath(node.text, node.start, node.end, idx, scope, out)
    } else if node.extra == astPatternVariantKind() {
        out = srResolvePatternVariantPath(node.text, node.start, node.end, idx, scope, out)
    }
    out = srAstResolvePatternValue(file, node.left, scope, out)
    out = srAstResolvePatternValue(file, node.right, scope, out)
    for child in node.children {
        out = srAstResolvePatternValue(file, child, scope, out)
    }
    out
}

fn srAstResolveOrPattern(
    file: AstFile,
    node: AstNode,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut alts: List<Int> = []
    alts = srAstOrPatternAlts(file, node.left, alts)
    alts = srAstOrPatternAlts(file, node.right, alts)
    let mut out = result
    let mut names: List<String> = []
    let mut symbols: List<SelfSymbol> = []
    let mut counts: List<Int> = []
    let mut altCount = 0
    for altIdx in alts {
        altCount = altCount + 1
        let altScope = srChildScope(scope)
        out = srAstResolvePattern(file, altIdx, altScope, out)
        let bound = srSymbolsAtDepth(altScope.symbols, altScope.depth)
        for sym in bound {
            let existing = srStringListIndex(names, sym.name)
            if existing >= 0 {
                counts[existing] = counts[existing] + 1
            } else {
                names.push(sym.name)
                symbols.push(sym)
                counts.push(1)
            }
        }
    }
    let mut idx = 0
    for name in names {
        let sym = symbols[idx]
        if counts[idx] == altCount {
            out = srScopeDefine(scope, out, sym)
        } else {
            out = srOrPatternMismatch(out, sym)
        }
        let _ = name
        idx = idx + 1
    }
    out
}

fn srAstOrPatternAlts(file: AstFile, idx: Int, alts: List<Int>) -> List<Int> {
    if idx < 0 {
        return alts
    }
    let node = srAstNode(file, idx)
    let mut out = alts
    if node.kind == AstNPattern && node.extra == astPatternOrKind() {
        out = srAstOrPatternAlts(file, node.left, out)
        out = srAstOrPatternAlts(file, node.right, out)
    } else {
        out.push(idx)
    }
    out
}

fn srResolvePatternTypePath(
    path: String,
    start: Int,
    end: Int,
    node: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let head = srPathHead(path)
    let mut out = result
    if head == "" {
        return out
    }
    if head == "Self" {
        if srScopeHas(scope, head) {
            return srRecordTypeRef(out, head, node)
        }
        return srSelfTypeOutsideAtNode(out, start, end, node)
    }
    if srIsBuiltinTypeName(head) {
        return srRecordTypeRef(out, head, node)
    }
    let sym = srScopeLookup(scope, head)
    if sym.name == "" {
        out.unresolved = out.unresolved + 1
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0500", "undefined type", head, start, end, node))
        return out
    }
    if !(srSymbolCanBeType(sym)) {
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0502", "name is not a type", head, start, end, node))
        return out
    }
    srRecordTypeRef(out, head, node)
}

fn srResolvePatternVariantPath(
    path: String,
    start: Int,
    end: Int,
    node: Int,
    scope: SelfResolveScope,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let head = srPathHead(path)
    let name = srPathLastSegment(path)
    let mut out = result
    if head == "" {
        return out
    }
    if head == name {
        if srIsBuiltinVariantName(name) {
            return srRecordBareRef(out, name, node)
        }
        let sym = srScopeLookup(scope, name)
        if sym.name == "" {
            out.unresolved = out.unresolved + 1
            out.diagnostics.push(selfResolveDiagnosticAtNode("E0500", "undefined name", name, start, end, node))
            return out
        }
        if sym.kind == "variant" {
            return srRecordRef(out, name, node, sym)
        }
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0502", "name is not a variant", name, start, end, node))
        return out
    }
    if srIsBuiltinTypeName(head) {
        return srRecordTypeRef(out, head, node)
    }
    let sym = srScopeLookup(scope, head)
    if sym.name == "" {
        out.unresolved = out.unresolved + 1
        out.diagnostics.push(selfResolveDiagnosticAtNode("E0500", "undefined name", head, start, end, node))
        return out
    }
    if srSymbolCanBeType(sym) {
        return srRecordTypeRef(out, head, node)
    }
    if sym.kind == "variant" {
        return srRecordRef(out, head, node, sym)
    }
    out.diagnostics.push(selfResolveDiagnosticAtNode("E0502", "name is not a pattern path", head, start, end, node))
    out
}

fn srSymbolsAtDepth(symbols: List<SelfSymbol>, depth: Int) -> List<SelfSymbol> {
    let mut out: List<SelfSymbol> = []
    for sym in symbols {
        if sym.depth == depth {
            out.push(sym)
        }
    }
    out
}

fn srOrPatternMismatch(result: SelfResolveResult, sym: SelfSymbol) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(
        selfResolveDiagnosticAtNode(
            "E0605",
            "name is not bound by every alternative of the or-pattern",
            sym.name,
            sym.start,
            sym.end,
            sym.node,
        ),
    )
    out
}

fn srAstPatternNames(
    file: AstFile,
    idx: Int,
    names: List<SelfResolveName>,
) -> List<SelfResolveName> {
    if idx < 0 {
        return names
    }
    let node = srAstNode(file, idx)
    let mut out = names
    if node.kind == AstNIdent {
        out.push(selfResolveName(node.text, node.start, node.end, idx))
        return out
    }
    if node.kind != AstNPattern {
        return out
    }
    if node.extra == srPatternIdentKind() {
        out.push(selfResolveName(node.text, node.start, node.end, idx))
    } else if node.extra == srPatternBindingKind() {
        out.push(selfResolveName(node.text, node.start, node.start + 1, idx))
        out = srAstPatternNames(file, node.left, out)
    } else if node.extra == srPatternFieldKind() {
        if node.left >= 0 {
            out = srAstPatternNames(file, node.left, out)
        } else {
            out.push(selfResolveName(node.text, node.start, node.end, idx))
        }
    } else {
        out = srAstPatternNames(file, node.left, out)
        out = srAstPatternNames(file, node.right, out)
        for child in node.children {
            out = srAstPatternNames(file, child, out)
        }
    }
    out
}

fn srPatternIdentKind() -> Int { 3 }

fn srPatternBindingKind() -> Int { 9 }

fn srPatternFieldKind() -> Int { 10 }

fn srAstLetTypeName(file: AstFile, node: AstNode) -> String {
    srAstTypeName(file, srAstChildAt(node.children, 0))
}

fn srAstTypeName(file: AstFile, idx: Int) -> String {
    if idx < 0 {
        return ""
    }
    let node = srAstNode(file, idx)
    if node.kind == AstNType {
        return node.text
    }
    ""
}

fn srAstUseAlias(file: AstFile, node: AstNode) -> String {
    let aliasIdx = srAstChildAt(node.children2, 0)
    if aliasIdx >= 0 {
        let alias = srAstNode(file, aliasIdx)
        if alias.text != "" {
            return alias.text
        }
    }
    srPathLastSegment(node.text)
}

fn srPathLastSegment(path: String) -> String {
    let parts = strings.split(path, ".")
    let mut last = ""
    for part in parts {
        if part != "" {
            last = part
        }
    }
    last
}

fn srPathHead(path: String) -> String {
    let parts = strings.split(path, ".")
    for part in parts {
        if part != "" {
            return part
        }
    }
    ""
}

fn srAstNode(file: AstFile, idx: Int) -> AstNode {
    astArenaNodeAt(file.arena, idx)
}

fn srAstChildAt(children: List<Int>, target: Int) -> Int {
    if target < 0 || target >= children.len() { return -1 }
    children[target]
}

fn srAstListCount(items: List<Int>) -> Int {
    items.len()
}

fn srIntListAt(items: List<Int>, target: Int) -> Int {
    if target < 0 || target >= items.len() { return -1 }
    items[target]
}

fn srStringListAt(items: List<String>, target: Int) -> String {
    if target < 0 || target >= items.len() { return "" }
    items[target]
}

fn srIntListCopy(items: List<Int>) -> List<Int> {
    let mut out: List<Int> = []
    for item in items {
        out.push(item)
    }
    out
}

fn srStringListCopy(items: List<String>) -> List<String> {
    let mut out: List<String> = []
    for item in items {
        out.push(item)
    }
    out
}

fn srSymbolListCopy(items: List<SelfSymbol>) -> List<SelfSymbol> {
    let mut out: List<SelfSymbol> = []
    for item in items {
        out.push(item)
    }
    out
}

/// srHandlePartialType routes a struct or enum declaration through the
/// partial-merge flow (LANG_SPEC v0.5 §3.4 / R19). The first declaration
/// of a name installs its symbol and registers a SelfPartialDecl tracker;
/// later same-kind declarations validate R19 against the first without
/// re-emitting E0501, while kind-mismatched duplicates fall through to
/// the normal duplicate-declaration path. Methods spread across partials
/// are merged into the tracker so cross-declaration method-name
/// collisions can fire E0501 with a targeted message.
fn srHandlePartialType(
    file: AstFile,
    node: AstNode,
    idx: Int,
    kind: String,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let partialIdx = srFindPartialIdx(result.partials, node.text)
    let isPub = node.flags == 1
    if partialIdx < 0 {
        // First time — install symbol and seed the partial tracker.
        let mut out = srAddSymbol(
            result,
            selfSymbolAtNode(node.text, "type", "", 0, 0, node.start, node.end, isPub, idx),
        )
        out = srRegisterPartial(file, node, idx, kind, isPub, out)
        return out
    }
    let prev = result.partials[partialIdx]
    if prev.kind != kind {
        // Struct-vs-enum mismatch is a normal duplicate — route through
        // srAddSymbol so the E0501 / duplicates counter fire as usual.
        return srAddSymbol(
            result,
            selfSymbolAtNode(node.text, "type", "", 0, 0, node.start, node.end, isPub, idx),
        )
    }
    // Legal partial — no new symbol is added; instead, validate R19
    // invariants against the canonical (first) declaration and merge the
    // new partial's methods into the shared tracker.
    let mut out = srValidatePartialConsistency(file, node, idx, isPub, kind, prev, result)
    out = srMergePartialMembers(file, node, idx, kind, partialIdx, out)
    out
}

fn srFindPartialIdx(partials: List<SelfPartialDecl>, name: String) -> Int {
    let mut idx = 0
    for p in partials {
        if p.name == name {
            return idx
        }
        idx = idx + 1
    }
    -1
}

fn srRegisterPartial(
    file: AstFile,
    node: AstNode,
    idx: Int,
    kind: String,
    isPub: Bool,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let generics = srCollectGenericNames(file, node.children2)
    let mut hasFields = false
    let mut firstFieldsStart = -1
    let mut firstFieldsEnd = -1
    for memberIdx in node.children {
        let member = srAstNode(file, memberIdx)
        let isMember = (kind == "struct" && member.kind == AstNField_) ||
                       (kind == "enum" && member.kind == AstNVariant)
        if isMember && !hasFields {
            hasFields = true
            firstFieldsStart = member.start
            firstFieldsEnd = member.end
        }
    }
    let mut methodNames: List<String> = []
    let mut methodStarts: List<Int> = []
    let mut methodEnds: List<Int> = []
    let mut methodNodes: List<Int> = []
    for memberIdx in node.children {
        let member = srAstNode(file, memberIdx)
        if member.kind == AstNFnDecl {
            methodNames.push(member.text)
            methodStarts.push(member.start)
            methodEnds.push(member.end)
            methodNodes.push(memberIdx)
        }
    }
    let entry = SelfPartialDecl {
        name: node.text,
        kind,
        firstNode: idx,
        firstStart: node.start,
        firstEnd: node.end,
        firstPub: isPub,
        firstGenerics: generics,
        methodNames,
        methodStarts,
        methodEnds,
        methodNodes,
        hasFields,
        firstFieldsStart,
        firstFieldsEnd,
    }
    let mut out = result
    out.partials.push(entry)
    out
}

fn srCollectGenericNames(file: AstFile, generics: List<Int>) -> List<String> {
    let mut names: List<String> = []
    for gIdx in generics {
        let g = srAstNode(file, gIdx)
        names.push(g.text)
    }
    names
}

fn srValidatePartialConsistency(
    file: AstFile,
    node: AstNode,
    idx: Int,
    isPub: Bool,
    kind: String,
    prev: SelfPartialDecl,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if isPub != prev.firstPub {
        let message = "partial declarations of " + kind + " `" + node.text + "` disagree on visibility"
        out.diagnostics.push(selfResolveDiagnosticHintAtNode(
            "E0501",
            message,
            node.text,
            node.start,
            node.end,
            idx,
            "v0.5 R19: all partial declarations of the same type must have matching `pub` modifiers",
        ))
    }
    let newGenerics = srCollectGenericNames(file, node.children2)
    if !srGenericsEqual(prev.firstGenerics, newGenerics) {
        out.diagnostics.push(selfResolveDiagnosticHintAtNode(
            "E0501",
            "partial declarations of `" + node.text + "` disagree on type parameters",
            node.text,
            node.start,
            node.end,
            idx,
            "v0.5 R19: all partial declarations must have the same type-parameter list",
        ))
    }
    let mut newHasFields = false
    let mut newFieldsStart = -1
    let mut newFieldsEnd = -1
    for memberIdx in node.children {
        let member = srAstNode(file, memberIdx)
        let isMember = (kind == "struct" && member.kind == AstNField_) ||
                       (kind == "enum" && member.kind == AstNVariant)
        if isMember && !newHasFields {
            newHasFields = true
            newFieldsStart = member.start
            newFieldsEnd = member.end
        }
    }
    if prev.hasFields && newHasFields {
        let label = if kind == "struct" { "fields" } else { "variants" }
        out.diagnostics.push(selfResolveDiagnosticHintAtNode(
            "E0501",
            kind + " `" + node.text + "` may declare " + label + " in exactly one partial declaration",
            node.text,
            newFieldsStart,
            newFieldsEnd,
            idx,
            "v0.5 R19: a partial struct/enum may spread methods across files, but its fields or variants must live in exactly one declaration",
        ))
    }
    out
}

fn srGenericsEqual(a: List<String>, b: List<String>) -> Bool {
    if a.len() != b.len() {
        return false
    }
    let mut i = 0
    for name in a {
        if name != b[i] { return false }
        i = i + 1
    }
    true
}

fn srMergePartialMembers(
    file: AstFile,
    node: AstNode,
    idx: Int,
    kind: String,
    partialIdx: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    // Update hasFields if the new partial is the first to declare members.
    let prev = out.partials[partialIdx]
    if !prev.hasFields {
        for memberIdx in node.children {
            let member = srAstNode(file, memberIdx)
            let isMember = (kind == "struct" && member.kind == AstNField_) ||
                           (kind == "enum" && member.kind == AstNVariant)
            if isMember {
                let mut entry = out.partials[partialIdx]
                entry.hasFields = true
                entry.firstFieldsStart = member.start
                entry.firstFieldsEnd = member.end
                out.partials[partialIdx] = entry
                break
            }
        }
    }
    // Walk new partial's methods: cross-declaration duplicates emit
    // E0501 with the method-specific message; fresh names are recorded.
    for memberIdx in node.children {
        let member = srAstNode(file, memberIdx)
        if member.kind != AstNFnDecl {
            continue
        }
        let dupIdx = srStringListIndex(out.partials[partialIdx].methodNames, member.text)
        if dupIdx >= 0 {
            let message = "method `" + member.text + "` is declared more than once on type `" + node.text + "`"
            out.diagnostics.push(selfResolveDiagnosticHintAtNode(
                "E0501",
                message,
                member.text,
                member.start,
                member.end,
                memberIdx,
                "v0.5 R19: methods spread across partial declarations must have unique names",
            ))
            continue
        }
        let mut entry = out.partials[partialIdx]
        entry.methodNames.push(member.text)
        entry.methodStarts.push(member.start)
        entry.methodEnds.push(member.end)
        entry.methodNodes.push(memberIdx)
        out.partials[partialIdx] = entry
    }
    out
}

fn srAddSymbol(result: SelfResolveResult, sym: SelfSymbol) -> SelfResolveResult {
    let mut out = result
    if srSymbolExistsAtDepth(out.symbols, sym.name, sym.depth) {
        out = srDuplicateAtNode(out, sym.name, sym.start, sym.end, sym.node)
    } else if !(srIsDiscardName(sym.name)) {
        out.symbols.push(sym)
    }
    out
}

fn srDuplicate(result: SelfResolveResult, name: String, start: Int, end: Int) -> SelfResolveResult {
    srDuplicateAtNode(result, name, start, end, -1)
}

fn srDuplicateAtNode(
    result: SelfResolveResult,
    name: String,
    start: Int,
    end: Int,
    node: Int,
) -> SelfResolveResult {
    let mut out = result
    out.duplicates = out.duplicates + 1
    out.diagnostics.push(
        selfResolveDiagnosticAtNode("E0501", "duplicate declaration", name, start, end, node),
    )
    out
}

fn srSymbolExistsAtDepth(symbols: List<SelfSymbol>, name: String, depth: Int) -> Bool {
    for sym in symbols {
        if sym.name == name && sym.depth == depth {
            return true
        }
    }
    false
}

fn srStringListIndex(items: List<String>, target: String) -> Int {
    let mut idx = 0
    for item in items {
        if item == target {
            return idx
        }
        idx = idx + 1
    }
    -1
}

fn srUndefinedHint(scope: SelfResolveScope, name: String) -> String {
    let suggestion = srSuggestSimilar(scope, name)
    if suggestion == "" {
        return ""
    }
    "did you mean `{suggestion}`?"
}

fn srSuggestSimilar(scope: SelfResolveScope, name: String) -> String {
    let mut names: List<String> = []
    for sym in scope.symbols {
        names.push(sym.name)
    }
    srSuggestFromList(name, names)
}

fn srLevenshteinBounded(left: String, right: String, limit: Int) -> Int {
    if left == right {
        return 0
    }
    let leftUnits = strings.split(left, "")
    let rightUnits = strings.split(right, "")
    let leftLen = srStringUnitCount(left)
    let rightLen = srStringUnitCount(right)
    let diff = leftLen - rightLen
    if diff >= limit || 0 - diff >= limit {
        return limit
    }
    let mut prev: List<Int> = []
    let mut cur: List<Int> = []
    let mut j = 0
    for j <= rightLen {
        prev.push(j)
        cur.push(0)
        j = j + 1
    }
    let mut i = 1
    for i <= leftLen {
        cur[0] = i
        let mut rowMin = cur[0]
        j = 1
        for j <= rightLen {
            let leftUnit = srStringListAt(leftUnits, i - 1)
            let rightUnit = srStringListAt(rightUnits, j - 1)
            let cost = if leftUnit == rightUnit {
                0
            } else {
                1
            }
            let mut dist = prev[j] + 1
            if cur[j - 1] + 1 < dist {
                dist = cur[j - 1] + 1
            }
            if prev[j - 1] + cost < dist {
                dist = prev[j - 1] + cost
            }
            cur[j] = dist
            if dist < rowMin {
                rowMin = dist
            }
            j = j + 1
        }
        if rowMin >= limit {
            return limit
        }
        j = 0
        for j <= rightLen {
            prev[j] = cur[j]
            cur[j] = 0
            j = j + 1
        }
        i = i + 1
    }
    prev[rightLen]
}

fn srStringUnitCount(text: String) -> Int {
    let mut count = 0
    for unit in strings.split(text, "") {
        if unit != "" {
            count = count + 1
        }
    }
    count
}

fn srSymbolCanBeType(sym: SelfSymbol) -> Bool {
    sym.kind == "type" || sym.kind == "generic" || sym.kind == "package"
}

fn srAstUseNode(file: AstFile, pkgSym: SelfSymbol) -> AstNode {
    if pkgSym.node < 0 {
        return emptyAstNode(AstNFile)
    }
    srAstNode(file, pkgSym.node)
}

fn srAstLookupPackageMember(file: AstFile, useNode: AstNode, member: String) -> SelfSymbol {
    for childIdx in useNode.children {
        let child = srAstNode(file, childIdx)
        if child.text == member {
            return selfSymbolAtNode(
                member,
                srAstPackageMemberKind(child),
                "",
                0,
                0,
                child.start,
                child.end,
                true,
                childIdx,
            )
        }
    }
    srEmptySymbol()
}

fn srAstPackageMemberKind(node: AstNode) -> String {
    if node.kind == AstNFnDecl {
        return "fn"
    }
    if node.kind == AstNStructDecl || node.kind == AstNEnumDecl || node.kind == AstNInterfaceDecl || node.kind == AstNTypeAlias {
        return "type"
    }
    if node.kind == AstNLet {
        return "value"
    }
    ""
}

fn srEmptySymbol() -> SelfSymbol {
    selfSymbolAtNode("", "", "", 0, -1, -1, -1, false, -1)
}

fn srSymbolFound(sym: SelfSymbol) -> Bool {
    sym.name != ""
}

fn srIsBuiltinName(name: String) -> Bool {
    name == "true" || name == "false" || name == "None" || name == "Some" || name == "Ok" || name == "Err" || name == "println" || name == "panic" || name == "spawn" || name == "parallel" || name == "taskGroup" || name == "thread" || name == "Int" || name == "Float" || name == "Bool" || name == "String" || name == "Bytes" || name == "Char" || name == "Never" || name == "List" || name == "Map" || name == "Set" || name == "Option" || name == "Result" || name == "Error" || name == "Unit"
}

fn srIsBuiltinTypeName(name: String) -> Bool {
    name == "Int" || name == "Float" || name == "Bool" || name == "String" || name == "Bytes" || name == "Char" || name == "Never" || name == "List" || name == "Map" || name == "Set" || name == "Option" || name == "Result" || name == "Error" || name == "Unit"
}

fn srIsBuiltinVariantName(name: String) -> Bool {
    name == "None" || name == "Some" || name == "Ok" || name == "Err"
}

fn srIsUpperName(name: String) -> Bool {
    astIsUpperName(name)
}

fn srIsDiscardName(name: String) -> Bool {
    name == "_" || strings.hasPrefix(name, "_")
}

// Annotation target bitmask. Matches the Go resolver's
// `ast.AnnotationTarget` values (internal/ast/ast.go:79) so the
// self-hosted checker can reuse the same allow-list logic.
fn srAnnotTargetField() -> Int { 1 }
fn srAnnotTargetTopLevel() -> Int { 2 }
fn srAnnotTargetMethod() -> Int { 4 }
fn srAnnotTargetVariant() -> Int { 8 }

/// srAnnotAllowedTargets returns the bitmask of valid targets for a
/// permitted annotation, or 0 for unknown names. Keep in sync with
/// `annotationRules` in internal/ast/ast.go:93.
fn srAnnotAllowedTargets(name: String) -> Int {
    if name == "json" { return srAnnotTargetField() | srAnnotTargetVariant() }
    if name == "deprecated" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "allow" {
        return srAnnotTargetTopLevel() | srAnnotTargetMethod() | srAnnotTargetField() | srAnnotTargetVariant()
    }
    if name == "intrinsic_methods" { return srAnnotTargetTopLevel() }
    if name == "requires" { return srAnnotTargetMethod() }
    if name == "no_alloc" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "intrinsic" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "c_abi" { return srAnnotTargetTopLevel() }
    if name == "export" { return srAnnotTargetTopLevel() }
    if name == "pod" { return srAnnotTargetTopLevel() }
    if name == "repr" { return srAnnotTargetTopLevel() }
    if name == "cfg" {
        return srAnnotTargetTopLevel() | srAnnotTargetMethod() | srAnnotTargetField() | srAnnotTargetVariant()
    }
    if name == "op" { return srAnnotTargetMethod() }
    if name == "test" { return srAnnotTargetTopLevel() }
    // v0.6 performance annotations (A5–A11, A13). All target fn / method.
    if name == "vectorize" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "no_vectorize" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "parallel" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "unroll" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "inline" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "hot" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "cold" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "pure" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "target_feature" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    if name == "noalias" { return srAnnotTargetTopLevel() | srAnnotTargetMethod() }
    0
}

fn srIsAllowedAnnotation(name: String) -> Bool {
    srAnnotAllowedTargets(name) != 0
}

fn srAnnotationAllowedAt(name: String, target: Int) -> Bool {
    let allowed = srAnnotAllowedTargets(name)
    allowed != 0 && (allowed & target) != 0
}

fn srAnnotationTargetString(name: String) -> String {
    let allowed = srAnnotAllowedTargets(name)
    if allowed == 0 {
        return "(unknown)"
    }
    let mut parts: List<String> = []
    if (allowed & srAnnotTargetField()) != 0 { parts.push("struct fields") }
    if (allowed & srAnnotTargetTopLevel()) != 0 { parts.push("top-level declarations") }
    if (allowed & srAnnotTargetMethod()) != 0 { parts.push("methods") }
    if (allowed & srAnnotTargetVariant()) != 0 { parts.push("enum variants") }
    srJoinWithAnd(parts)
}

fn srJoinWithAnd(parts: List<String>) -> String {
    let n = parts.len()
    if n == 0 { return "" }
    if n == 1 { return parts[0] }
    if n == 2 { return parts[0] + " and " + parts[1] }
    let mut out = ""
    let mut idx = 0
    for p in parts {
        if idx == 0 {
            out = p
        } else if idx == n - 1 {
            out = out + ", and " + p
        } else {
            out = out + ", " + p
        }
        idx = idx + 1
    }
    out
}

/// srCollectAnnotationNodes unpacks a decl's `extra` field into the flat
/// list of AstNAnnotation nodes that hang off it. The parser packs 0, 1,
/// or N annotations differently (-1 / direct idx / "__group" wrapper);
/// this helper hides the shape difference.
fn srCollectAnnotationNodes(file: AstFile, extraIdx: Int) -> List<AstNode> {
    let mut anns: List<AstNode> = []
    if extraIdx < 0 {
        return anns
    }
    let ann = srAstNode(file, extraIdx)
    if ann.kind != AstNAnnotation {
        return anns
    }
    if ann.text == "__group" {
        for childIdx in ann.children {
            let child = srAstNode(file, childIdx)
            if child.kind == AstNAnnotation {
                anns.push(child)
            }
        }
    } else {
        anns.push(ann)
    }
    anns
}

/// srCheckDeclAnnotations validates the annotations attached to a single
/// declaration (or member) against v0.4 §18.1:
///   - unknown names → E0400 (with did-you-mean hint)
///   - wrong target kind → E0607
///   - same name twice on one target → E0609
fn srCheckDeclAnnotations(
    file: AstFile,
    extraIdx: Int,
    target: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    // Most decls carry no annotations; skip the unpack call (and its
    // list allocation) in the common case.
    if extraIdx < 0 {
        return result
    }
    let anns = srCollectAnnotationNodes(file, extraIdx)
    let mut out = result
    let mut seen: List<String> = []
    for ann in anns {
        let name = ann.text
        if !srIsAllowedAnnotation(name) {
            out.diagnostics.push(selfResolveDiagnosticHintAtNode(
                "E0400",
                "unknown annotation `#[" + name + "]`",
                name,
                ann.start,
                ann.end,
                -1,
                srDidYouMeanHint(name, srAnnotationNameList()),
            ))
            continue
        }
        if !srAnnotationAllowedAt(name, target) {
            out.diagnostics.push(selfResolveDiagnosticHintAtNode(
                "E0607",
                "annotation `#[" + name + "]` is not allowed here",
                name,
                ann.start,
                ann.end,
                -1,
                "`#[" + name + "]` is permitted on " + srAnnotationTargetString(name),
            ))
        }
        let mut isDup = false
        for prev in seen {
            if prev == name {
                isDup = true
            }
        }
        if isDup {
            out.diagnostics.push(selfResolveDiagnostic(
                "E0609",
                "annotation `#[" + name + "]` is repeated on the same target",
                name,
                ann.start,
                ann.end,
            ))
            continue
        }
        seen.push(name)
        out = srCheckAnnotationArgs(file, ann, target, out)
    }
    out
}

/// SrAnnotArgView normalizes the three shapes the parser emits for
/// annotation args into one record. `#[json(key = "x")]` produces
/// AstNField_ (keyed value); `#[json(skip)]` produces AstNIdent (bare
/// flag); `#[export("name")]` produces the raw expression. See
/// toolchain/parser.osty:1647 `opParseAnnotationArg`.
struct SrAnnotArgView {
    key: String,
    valueIdx: Int,
    isFlag: Bool,
    start: Int,
    end: Int,
}

fn srAnnotArgView(file: AstFile, argIdx: Int) -> SrAnnotArgView {
    let arg = srAstNode(file, argIdx)
    if arg.kind == AstNField_ {
        return SrAnnotArgView { key: arg.text, valueIdx: arg.left, isFlag: false, start: arg.start, end: arg.end }
    }
    if arg.kind == AstNIdent {
        return SrAnnotArgView { key: arg.text, valueIdx: -1, isFlag: true, start: arg.start, end: arg.end }
    }
    SrAnnotArgView { key: "", valueIdx: argIdx, isFlag: false, start: arg.start, end: arg.end }
}

fn srIsStringLitAtIdx(file: AstFile, idx: Int) -> Bool {
    if idx < 0 {
        return false
    }
    srAstNode(file, idx).kind == AstNStringLit
}

fn srIsFlagOrTrue(file: AstFile, view: SrAnnotArgView) -> Bool {
    if view.isFlag {
        return true
    }
    if view.valueIdx < 0 {
        return true
    }
    let v = srAstNode(file, view.valueIdx)
    v.kind == AstNBoolLit && v.flags == 1
}

fn srPushBadArg(
    result: SelfResolveResult,
    message: String,
    start: Int,
    end: Int,
) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(selfResolveDiagnostic("E0739", message, "", start, end))
    out
}

fn srPushUnknownArg(
    result: SelfResolveResult,
    message: String,
    name: String,
    start: Int,
    end: Int,
    hint: String,
) -> SelfResolveResult {
    // Matches the Go resolver's quirk: unknown annotation-arg keys are
    // emitted as E0400 (CodeUnknownAnnotation), not E0739. See
    // internal/resolve/resolve.go:711. The `hint` field carries the
    // did-you-mean suggestion (empty if none) — this is a strict
    // improvement over Go, which emits no suggestion.
    let mut out = result
    out.diagnostics.push(selfResolveDiagnosticHintAtNode(
        "E0400",
        message,
        name,
        start,
        end,
        -1,
        hint,
    ))
    out
}

/// srCheckAnnotationArgs dispatches to the per-annotation argument
/// validator. Only runs on allowed + non-duplicate annotations. Mirrors
/// the Go resolver's `checkAnnotationArgs` (internal/resolve/resolve.go:546).
fn srCheckAnnotationArgs(
    file: AstFile,
    ann: AstNode,
    target: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if ann.text == "json" { return srCheckJSONArgs(file, ann, target, result) }
    if ann.text == "deprecated" { return srCheckDeprecatedArgs(file, ann, result) }
    if ann.text == "repr" { return srCheckReprArgs(file, ann, result) }
    if ann.text == "export" { return srCheckExportArgs(file, ann, result) }
    // cfg args are validated up front in srAstCollectDecl (before the
    // filter drop) so dropped decls still surface E0405/E0739. Skipping
    // cfg here avoids double-emission for decls that survive.
    if ann.text == "intrinsic" || ann.text == "pod" || ann.text == "c_abi" || ann.text == "no_alloc" {
        return srCheckNoArgsRuntime(file, ann, result)
    }
    // v0.6 bare-flag annotations (A5.2 / A6 / A9 / A13): reject any args.
    if ann.text == "hot" || ann.text == "cold" || ann.text == "pure" ||
       ann.text == "no_vectorize" || ann.text == "parallel" {
        return srCheckBareFlagAnnotation(file, ann, result)
    }
    if ann.text == "inline" { return srCheckInlineArgs(file, ann, result) }
    if ann.text == "unroll" { return srCheckUnrollArgs(file, ann, result) }
    if ann.text == "vectorize" { return srCheckVectorizeArgs(file, ann, result) }
    if ann.text == "target_feature" { return srCheckTargetFeatureArgs(file, ann, result) }
    if ann.text == "noalias" { return srCheckNoaliasArgs(file, ann, result) }
    result
}

/// srValidateCfgAnnotationsOnDecl runs cfg shape validation over every
/// `#[cfg(...)]` annotation attached to a decl. Called from the top-level
/// decl walker before the filter drop so dropped decls still surface
/// E0405 / E0739. Non-cfg annotations are skipped here — the main
/// srCheckDeclAnnotations walk handles them when the decl survives.
fn srValidateCfgAnnotationsOnDecl(
    file: AstFile,
    extraIdx: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if extraIdx < 0 {
        return result
    }
    let anns = srCollectAnnotationNodes(file, extraIdx)
    let mut out = result
    for ann in anns {
        if ann.text == "cfg" {
            out = srCheckCfgArgs(file, ann, out)
        }
    }
    out
}

/// srCheckCfgArgs validates `#[cfg(key = "value")]` arguments. Emits
/// E0739 when the annotation is empty or an arg is not `key = string`,
/// and E0405 when the key is not one of `os / arch / target / feature`.
/// Mirrors the Go resolver's cfg.go::evaluateCfgAnnotation +
/// evaluateCfgArg (internal/resolve/cfg.go:111, 139). Diag emission is
/// independent of filter evaluation — tooling sees the same shape
/// errors whether or not filtering is enabled.
fn srCheckCfgArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if srAstListCount(ann.children) == 0 {
        out.diagnostics.push(selfResolveDiagnosticHintAtNode(
            "E0739",
            "`#[cfg(...)]` requires at least one predicate",
            "cfg",
            ann.start,
            ann.end,
            -1,
            "v0.5 §5 / G29: use `#[cfg(key = \"value\")]` where key is `os`, `target`, `arch`, or `feature`",
        ))
        return out
    }
    for argIdx in ann.children {
        out = srCheckCfgArg(file, argIdx, out)
    }
    out
}

fn srCheckCfgArg(
    file: AstFile,
    argIdx: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let view = srAnnotArgView(file, argIdx)
    let mut out = result
    if view.isFlag || view.key == "" || view.valueIdx < 0 || !srIsStringLitAtIdx(file, view.valueIdx) {
        out.diagnostics.push(selfResolveDiagnosticHintAtNode(
            "E0739",
            "`#[cfg(...)]` requires a `key = \"value\"` argument",
            "cfg",
            view.start,
            view.end,
            -1,
            "v0.5 §5: cfg argument values must be string literals — no identifiers or computed expressions",
        ))
        return out
    }
    if view.key == "os" || view.key == "arch" || view.key == "target" || view.key == "feature" {
        return out
    }
    out.diagnostics.push(selfResolveDiagnosticHintAtNode(
        "E0405",
        "unknown cfg key `" + view.key + "`",
        "cfg",
        view.start,
        view.end,
        -1,
        "v0.5 §5 / G29 recognises only `os`, `target`, `arch`, `feature`",
    ))
    out
}

/// srCfgDeclPasses decides whether a decl survives the `#[cfg(...)]`
/// pre-resolve filter. When the env is disabled every decl passes.
/// Otherwise multiple cfg annotations are conjoined — all must hold —
/// mirroring internal/resolve/cfg.go::evaluateCfgOnDecl. Malformed
/// cfg arguments evaluate to false, matching the Go filter.
fn srCfgDeclPasses(file: AstFile, node: AstNode, cfg: SelfResolveCfgEnv) -> Bool {
    if !cfg.enabled {
        return true
    }
    if node.extra < 0 {
        return true
    }
    let anns = srCollectAnnotationNodes(file, node.extra)
    for ann in anns {
        if ann.text != "cfg" {
            continue
        }
        if !srCfgAnnotationPasses(file, ann, cfg) {
            return false
        }
    }
    true
}

fn srCfgAnnotationPasses(file: AstFile, ann: AstNode, cfg: SelfResolveCfgEnv) -> Bool {
    if srAstListCount(ann.children) == 0 {
        return false
    }
    for argIdx in ann.children {
        let view = srAnnotArgView(file, argIdx)
        if !srCfgArgPasses(file, view, cfg) {
            return false
        }
    }
    true
}

fn srCfgArgPasses(file: AstFile, view: SrAnnotArgView, cfg: SelfResolveCfgEnv) -> Bool {
    if view.isFlag { return false }
    if view.valueIdx < 0 { return false }
    let v = srAstNode(file, view.valueIdx)
    if v.kind != AstNStringLit { return false }
    let value = srStringLitContent(v.text)
    if view.key == "os" { return cfg.os == value }
    if view.key == "arch" { return cfg.arch == value }
    if view.key == "target" { return cfg.target == value }
    if view.key == "feature" { return srCfgEnvHasFeature(cfg, value) }
    false
}

/// srStringLitContent unwraps the raw string-literal lexeme stored on an
/// AstNStringLit node. The parser records the full source text (including
/// the surrounding `"` / `"""` / `r"…"` syntax) so the formatter can
/// round-trip exactly. cfg argument matching needs just the inner value;
/// escape sequences inside the literal are not interpreted because
/// v0.5 §5 restricts cfg values to simple identifiers.
fn srStringLitContent(text: String) -> String {
    if strings.hasPrefix(text, "r\"\"\"") && strings.hasSuffix(text, "\"\"\"") {
        return strings.trimSuffix(strings.trimPrefix(text, "r\"\"\""), "\"\"\"")
    }
    if strings.hasPrefix(text, "\"\"\"") && strings.hasSuffix(text, "\"\"\"") {
        return strings.trimSuffix(strings.trimPrefix(text, "\"\"\""), "\"\"\"")
    }
    if strings.hasPrefix(text, "r\"") && strings.hasSuffix(text, "\"") {
        return strings.trimSuffix(strings.trimPrefix(text, "r\""), "\"")
    }
    if strings.hasPrefix(text, "\"") && strings.hasSuffix(text, "\"") {
        return strings.trimSuffix(strings.trimPrefix(text, "\""), "\"")
    }
    text
}

fn srCfgEnvHasFeature(cfg: SelfResolveCfgEnv, name: String) -> Bool {
    for f in cfg.features {
        if f == name {
            return true
        }
    }
    false
}

fn srCheckJSONArgs(
    file: AstFile,
    ann: AstNode,
    target: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let mut hasKey = false
    let mut hasSkip = false
    let mut hasOptional = false
    for argIdx in ann.children {
        let view = srAnnotArgView(file, argIdx)
        if view.key == "key" {
            hasKey = true
            if !srIsStringLitAtIdx(file, view.valueIdx) {
                out = srPushBadArg(out, "`#[json(key = ...)]` requires a string literal", view.start, view.end)
            }
        } else if view.key == "skip" {
            hasSkip = true
            if !srIsFlagOrTrue(file, view) {
                out = srPushBadArg(out, "`#[json(skip)]` takes no value or `skip = true`", view.start, view.end)
            }
        } else if view.key == "optional" {
            hasOptional = true
            if target != srAnnotTargetField() {
                out = srPushBadArg(out, "`#[json(optional)]` is only valid on struct fields", view.start, view.end)
            }
            if !srIsFlagOrTrue(file, view) {
                out = srPushBadArg(out, "`#[json(optional)]` takes no value or `optional = true`", view.start, view.end)
            }
        } else {
            out = srPushUnknownArg(
                out,
                "`#[json]` does not accept argument `" + view.key + "`",
                view.key,
                view.start,
                view.end,
                srDidYouMeanHint(view.key, srJSONArgKeys()),
            )
        }
    }
    if hasSkip && (hasKey || hasOptional) {
        out = srPushBadArg(out, "`skip` is mutually exclusive with `key` and `optional`", ann.start, ann.end)
    }
    out
}

/// srCheckJSONFieldArgs validates that `#[json(optional)]` is only
/// attached to struct fields whose declared type is already optional —
/// either the `T?` sugar or an unqualified `Option<T>`. Runs after the
/// generic annotation walk so malformed args (unknown key, wrong value
/// shape) are already reported; this pass only adds the type-shape
/// check that needs the field node as context. Mirrors
/// internal/resolve/resolve.go::checkJSONFieldArgs.
fn srCheckJSONFieldArgs(
    file: AstFile,
    field: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if field.extra < 0 {
        return result
    }
    let anns = srCollectAnnotationNodes(file, field.extra)
    let mut out = result
    for ann in anns {
        if ann.text != "json" {
            continue
        }
        for argIdx in ann.children {
            let view = srAnnotArgView(file, argIdx)
            if view.key != "optional" {
                continue
            }
            if !srJsonFieldTypeAllowsOptional(file, field.right) {
                out = srPushBadArg(
                    out,
                    "`#[json(optional)]` requires an optional field type",
                    view.start,
                    view.end,
                )
            }
        }
    }
    out
}

/// srJsonFieldTypeAllowsOptional reports whether an AST type node
/// represents `T?` or an unqualified `Option<T>` — the two shapes the
/// JSON decoder treats as optional for `#[json(optional)]`. Mirrors
/// internal/resolve/resolve.go::jsonFieldTypeAllowsOptional. Qualified
/// `pkg.Option<T>` does not qualify because the Go resolver restricts
/// the match to a single-component path.
fn srJsonFieldTypeAllowsOptional(file: AstFile, typeIdx: Int) -> Bool {
    if typeIdx < 0 {
        return false
    }
    let t = srAstNode(file, typeIdx)
    if t.kind != AstNType {
        return false
    }
    if t.text == "optional" {
        return true
    }
    let parts = strings.split(t.text, ".")
    parts.len() == 1 && t.text == "Option"
}

/// srJsonVariantTag returns the JSON tag for a variant node, or None if
/// the variant has `#[json(skip)]`. Mirrors
/// internal/resolve/resolve.go::jsonVariantTag.
fn srJsonVariantTag(file: AstFile, variantIdx: Int) -> Option<String> {
    let node = srAstNode(file, variantIdx)
    let mut tag = node.text
    let mut skipped = false
    if node.extra >= 0 {
        let anns = srCollectAnnotationNodes(file, node.extra)
        for ann in anns {
            if ann.text != "json" {
                continue
            }
            for argIdx in ann.children {
                let view = srAnnotArgView(file, argIdx)
                if view.key == "key" {
                    if srIsStringLitAtIdx(file, view.valueIdx) {
                        tag = srAstNode(file, view.valueIdx).text
                    }
                } else if view.key == "skip" {
                    skipped = true
                }
            }
        }
    }
    if skipped { None } else { Some(tag) }
}

/// srCheckDuplicateVariantJSONTags checks for duplicate JSON tags
/// across variants of a single enum. Mirrors
/// internal/resolve/resolve.go::checkDuplicateVariantJSONTags.
fn srCheckDuplicateVariantJSONTags(
    file: AstFile,
    enumIdx: Int,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let node = srAstNode(file, enumIdx)
    let mut out = result
    let mut seenTags: List<String> = []
    let mut seenStarts: List<Int> = []
    let mut seenEnds: List<Int> = []
    for memberIdx in node.children {
        let member = srAstNode(file, memberIdx)
        if member.kind != AstNVariant {
            continue
        }
        let tagOpt = srJsonVariantTag(file, memberIdx)
        if tagOpt == None {
            continue
        }
        let tag = match tagOpt { Some(t) -> t, None -> "" }
        let mut dup = false
        for i in 0..seenTags.len() {
            if seenTags[i] == tag {
                dup = true
                out.diagnostics.push(selfResolveDiagnostic(
                    "E0501",
                    "enum `{node.text}` has duplicate JSON tag `{tag}`",
                    "",
                    member.start,
                    member.end,
                ))
                out.diagnostics.push(selfResolveDiagnosticHintAtNode(
                    "E0501",
                    "previous JSON tag here",
                    "",
                    seenStarts[i],
                    seenEnds[i],
                    -1,
                    "",
                ))
                break
            }
        }
        if !dup {
            seenTags.push(tag)
            seenStarts.push(member.start)
            seenEnds.push(member.end)
        }
    }
    out
}

fn srCheckDeprecatedArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    for argIdx in ann.children {
        let view = srAnnotArgView(file, argIdx)
        if view.key == "since" || view.key == "use" || view.key == "message" {
            if view.valueIdx < 0 || !srIsStringLitAtIdx(file, view.valueIdx) {
                out = srPushUnknownArg(
                    out,
                    "`#[deprecated(" + view.key + " = ...)]` requires a string literal",
                    view.key,
                    view.start,
                    view.end,
                    "",
                )
            }
        } else {
            out = srPushUnknownArg(
                out,
                "`#[deprecated]` does not accept argument `" + view.key + "`",
                view.key,
                view.start,
                view.end,
                srDidYouMeanHint(view.key, srDeprecatedArgKeys()),
            )
        }
    }
    out
}

fn srCheckReprArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let args = ann.children
    let n = args.len()
    if n == 0 {
        return srPushBadArg(out, "`#[repr]` requires a layout argument", ann.start, ann.end)
    }
    if n > 1 {
        let extra = srAnnotArgView(file, args[1])
        out = srPushBadArg(out, "`#[repr]` accepts exactly one argument", extra.start, extra.end)
    }
    let view = srAnnotArgView(file, args[0])
    if !view.isFlag {
        return srPushBadArg(out, "`#[repr]` takes a bare-flag argument, not a value", view.start, view.end)
    }
    if view.key != "c" {
        out = srPushBadArg(out, "`#[repr(" + view.key + ")]` is not a recognized layout", view.start, view.end)
    }
    out
}

fn srCheckExportArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let args = ann.children
    let n = args.len()
    if n == 0 {
        return srPushBadArg(out, "`#[export]` requires a symbol-name argument", ann.start, ann.end)
    }
    if n > 1 {
        let extra = srAnnotArgView(file, args[1])
        out = srPushBadArg(out, "`#[export]` accepts exactly one argument", extra.start, extra.end)
    }
    let view = srAnnotArgView(file, args[0])
    if view.key != "" {
        return srPushBadArg(
            out,
            "`#[export]` takes a positional string literal, not a key-value argument",
            view.start,
            view.end,
        )
    }
    if !srIsStringLitAtIdx(file, view.valueIdx) {
        return srPushBadArg(out, "`#[export]` requires a string literal argument", view.start, view.end)
    }
    out
}

fn srCheckNoArgsRuntime(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if ann.children.len() == 0 {
        return result
    }
    let first = srAnnotArgView(file, ann.children[0])
    srPushBadArg(
        result,
        "`#[" + ann.text + "]` does not take arguments",
        first.start,
        first.end,
    )
}

/// srCheckBareFlagAnnotation validates the v0.6 bare-flag annotations
/// (`#[hot]`, `#[cold]`, `#[pure]`, `#[no_vectorize]`, `#[parallel]`):
/// any argument is an E0739 error. Mirrors internal/resolve/resolve.go
/// ::checkBareFlag / ::checkNoVectorizeArgs / ::checkParallelArgs.
fn srCheckBareFlagAnnotation(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if ann.children.len() == 0 {
        return result
    }
    let first = srAnnotArgView(file, ann.children[0])
    srPushBadArg(
        result,
        "`#[" + ann.text + "]` does not take arguments",
        first.start,
        first.end,
    )
}

/// srCheckInlineArgs validates `#[inline]` / `#[inline(always)]` /
/// `#[inline(never)]` (v0.6 A8). Bare form is a soft hint; the
/// `always` / `never` sub-flags pick the hard `alwaysinline` /
/// `noinline` LLVM attributes. Mirrors
/// internal/resolve/resolve.go::checkInlineArgs.
fn srCheckInlineArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if ann.children.len() == 0 {
        return result
    }
    if ann.children.len() > 1 {
        let second = srAnnotArgView(file, ann.children[1])
        return srPushBadArgHint(
            result,
            "`#[inline(...)]` takes at most one argument",
            second.start,
            second.end,
            "use either `#[inline]`, `#[inline(always)]`, or `#[inline(never)]`",
        )
    }
    let view = srAnnotArgView(file, ann.children[0])
    if view.key == "always" || view.key == "never" {
        if !srIsFlagOrTrue(file, view) {
            return srPushBadArg(
                result,
                "`" + view.key + "` in `#[inline(...)]` is a bare flag",
                view.start,
                view.end,
            )
        }
        return result
    }
    srPushBadArgHint(
        result,
        "unknown `#[inline]` argument `" + view.key + "`",
        view.start,
        view.end,
        "accepted: `always` (force inlining), `never` (forbid inlining), or no argument (soft hint)",
    )
}

/// srCheckUnrollArgs validates `#[unroll]` / `#[unroll(count = N)]`
/// (v0.6 A7). Bare form lets LLVM choose the factor; the `count = N`
/// form pins it to 1..1024. Mirrors
/// internal/resolve/resolve.go::checkUnrollArgs.
fn srCheckUnrollArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    if ann.children.len() == 0 {
        return result
    }
    if ann.children.len() > 1 {
        let second = srAnnotArgView(file, ann.children[1])
        return srPushBadArg(
            result,
            "`#[unroll(...)]` takes at most one argument",
            second.start,
            second.end,
        )
    }
    let view = srAnnotArgView(file, ann.children[0])
    if view.key != "count" {
        return srPushBadArgHint(
            result,
            "unknown `#[unroll]` argument `" + view.key + "`",
            view.start,
            view.end,
            "accepted: `count = N` for a fixed unroll factor",
        )
    }
    srCheckUnrollCountValue(file, view, result)
}

fn srCheckUnrollCountValue(
    file: AstFile,
    view: SrAnnotArgView,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let n = srAnnotIntValue(file, view)
    if n < 0 {
        return srPushBadArg(
            result,
            "`#[unroll(count = N)]` requires a positive integer literal",
            view.start,
            view.end,
        )
    }
    if n < 1 || n > 1024 {
        return srPushBadArg(
            result,
            "`#[unroll(count = N)]` value must be in 1..1024",
            view.start,
            view.end,
        )
    }
    result
}

/// srCheckVectorizeArgs validates `#[vectorize]` (v0.6 A5 / A5.1).
/// Accepts the bare form (default treatment; redundant hint) plus
/// named tuning args: `scalable` flag, `predicate` flag, and
/// `width = N` with N in 1..1024. Duplicates and unknown keys fire
/// E0739 apiece. Mirrors
/// internal/resolve/resolve.go::checkVectorizeArgs.
fn srCheckVectorizeArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    let mut hasScalable = false
    let mut hasPredicate = false
    let mut hasWidth = false
    for argIdx in ann.children {
        let view = srAnnotArgView(file, argIdx)
        if view.key == "scalable" {
            if hasScalable {
                out = srPushBadArg(
                    out,
                    "duplicate `scalable` in `#[vectorize(...)]`",
                    view.start,
                    view.end,
                )
                continue
            }
            hasScalable = true
            if !srIsFlagOrTrue(file, view) {
                out = srPushBadArg(
                    out,
                    "`scalable` in `#[vectorize(...)]` is a bare flag",
                    view.start,
                    view.end,
                )
            }
            continue
        }
        if view.key == "predicate" {
            if hasPredicate {
                out = srPushBadArg(
                    out,
                    "duplicate `predicate` in `#[vectorize(...)]`",
                    view.start,
                    view.end,
                )
                continue
            }
            hasPredicate = true
            if !srIsFlagOrTrue(file, view) {
                out = srPushBadArg(
                    out,
                    "`predicate` in `#[vectorize(...)]` is a bare flag",
                    view.start,
                    view.end,
                )
            }
            continue
        }
        if view.key == "width" {
            if hasWidth {
                out = srPushBadArg(
                    out,
                    "duplicate `width` in `#[vectorize(...)]`",
                    view.start,
                    view.end,
                )
                continue
            }
            hasWidth = true
            let n = srAnnotIntValue(file, view)
            if n < 0 {
                out = srPushBadArg(
                    out,
                    "`width` in `#[vectorize(...)]` requires a positive integer literal",
                    view.start,
                    view.end,
                )
                continue
            }
            if n < 1 || n > 1024 {
                out = srPushBadArg(
                    out,
                    "`width` in `#[vectorize(...)]` must be in 1..1024",
                    view.start,
                    view.end,
                )
            }
            continue
        }
        if view.key == "" {
            out = srPushBadArg(
                out,
                "`#[vectorize(...)]` arguments must be named",
                view.start,
                view.end,
            )
            continue
        }
        out = srPushBadArgHint(
            out,
            "unknown `#[vectorize]` argument `" + view.key + "`",
            view.start,
            view.end,
            "accepted: `scalable`, `predicate`, `width = N`",
        )
    }
    out
}

/// srCheckTargetFeatureArgs validates `#[target_feature(...)]` (v0.6
/// A10): at least one bare-identifier feature name, no duplicates,
/// no `key = value` shapes. Mirrors
/// internal/resolve/resolve.go::checkTargetFeatureArgs.
fn srCheckTargetFeatureArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if ann.children.len() == 0 {
        return srPushBadArgHint(
            out,
            "`#[target_feature(...)]` requires at least one feature name",
            ann.start,
            ann.end,
            "example: `#[target_feature(avx512f, avx512bw)]`",
        )
    }
    let mut seen: List<String> = []
    for argIdx in ann.children {
        let view = srAnnotArgView(file, argIdx)
        if view.key == "" {
            out = srPushBadArg(
                out,
                "`#[target_feature(...)]` feature names must be bare identifiers",
                view.start,
                view.end,
            )
            continue
        }
        if !srIsFlagOrTrue(file, view) {
            out = srPushBadArg(
                out,
                "feature `" + view.key + "` in `#[target_feature(...)]` takes no value",
                view.start,
                view.end,
            )
            continue
        }
        if srStringListIndex(seen, view.key) >= 0 {
            out = srPushBadArg(
                out,
                "duplicate feature `" + view.key + "` in `#[target_feature(...)]`",
                view.start,
                view.end,
            )
            continue
        }
        seen.push(view.key)
    }
    out
}

/// srCheckNoaliasArgs validates `#[noalias]` / `#[noalias(p1, p2)]`
/// (v0.6 A11). Bare form marks every pointer param; the arg-list form
/// names specific parameter identifiers. Each arg must be a bare
/// identifier; duplicates are rejected. Mirrors
/// internal/resolve/resolve.go::checkNoaliasArgs.
fn srCheckNoaliasArgs(
    file: AstFile,
    ann: AstNode,
    result: SelfResolveResult,
) -> SelfResolveResult {
    let mut out = result
    if ann.children.len() == 0 {
        return out
    }
    let mut seen: List<String> = []
    for argIdx in ann.children {
        let view = srAnnotArgView(file, argIdx)
        if view.key == "" {
            out = srPushBadArg(
                out,
                "`#[noalias(...)]` parameter names must be bare identifiers",
                view.start,
                view.end,
            )
            continue
        }
        if !srIsFlagOrTrue(file, view) {
            out = srPushBadArg(
                out,
                "parameter `" + view.key + "` in `#[noalias(...)]` takes no value",
                view.start,
                view.end,
            )
            continue
        }
        if srStringListIndex(seen, view.key) >= 0 {
            out = srPushBadArg(
                out,
                "duplicate parameter `" + view.key + "` in `#[noalias(...)]`",
                view.start,
                view.end,
            )
            continue
        }
        seen.push(view.key)
    }
    out
}

fn srPushBadArgHint(
    result: SelfResolveResult,
    message: String,
    start: Int,
    end: Int,
    hint: String,
) -> SelfResolveResult {
    let mut out = result
    out.diagnostics.push(selfResolveDiagnosticHintAtNode("E0739", message, "", start, end, -1, hint))
    out
}

/// srAnnotIntValue extracts a non-negative integer literal from an
/// annotation arg's value slot. Returns -1 when the value slot is
/// empty, not an IntLit, or parses to a non-representable value.
/// Supports decimal / hex / octal / binary + underscores, matching
/// the Osty numeric grammar (§1.6.1).
fn srAnnotIntValue(file: AstFile, view: SrAnnotArgView) -> Int {
    if view.valueIdx < 0 { return -1 }
    let v = srAstNode(file, view.valueIdx)
    if v.kind != AstNIntLit { return -1 }
    srParseAnnotationInt(v.text)
}

fn srParseAnnotationInt(raw: String) -> Int {
    let stripped = strings.replaceAll(raw, "_", "")
    if stripped.len() == 0 { return -1 }
    let mut text = stripped
    let mut base = 10
    if strings.hasPrefix(text, "0x") || strings.hasPrefix(text, "0X") {
        base = 16
        text = strings.slice(text, 2, text.len())
    } else if strings.hasPrefix(text, "0o") || strings.hasPrefix(text, "0O") {
        base = 8
        text = strings.slice(text, 2, text.len())
    } else if strings.hasPrefix(text, "0b") || strings.hasPrefix(text, "0B") {
        base = 2
        text = strings.slice(text, 2, text.len())
    }
    if text.len() == 0 { return -1 }
    let mut acc = 0
    for ch in text.chars() {
        let d = srCharToDigit(ch)
        if d < 0 || d >= base { return -1 }
        acc = acc * base + d
    }
    acc
}

fn srCharToDigit(ch: Char) -> Int {
    let cp = ch.toInt()
    if cp >= 48 && cp <= 57 {
        cp - 48
    } else if cp >= 65 && cp <= 70 {
        cp - 55
    } else if cp >= 97 && cp <= 102 {
        cp - 87
    } else {
        -1
    }
}

/// srAnnotationNameList returns every permitted annotation name as a
/// flat list for did-you-mean suggestions. Keep in sync with the
/// `srAnnotAllowedTargets` switch.
fn srAnnotationNameList() -> List<String> {
    [
        "json",
        "deprecated",
        "allow",
        "intrinsic_methods",
        "requires",
        "no_alloc",
        "intrinsic",
        "c_abi",
        "export",
        "pod",
        "repr",
        "cfg",
        "op",
        "test",
        // v0.6 performance hints.
        "vectorize",
        "no_vectorize",
        "parallel",
        "unroll",
        "inline",
        "hot",
        "cold",
        "pure",
        "target_feature",
        "noalias",
    ]
}

fn srJSONArgKeys() -> List<String> {
    ["key", "skip", "optional"]
}

fn srDeprecatedArgKeys() -> List<String> {
    ["since", "use", "message"]
}

/// srSuggestFromList finds the closest candidate (Levenshtein distance
/// < 3) from a fixed list. Returns "" if nothing is within reach. This
/// is the typo-suggestion primitive for annotation names and arg keys —
/// unlike Go's resolver, which emits unknown-annotation errors with no
/// spelling hints, the self-hosted version nudges the user toward the
/// right spelling.
fn srSuggestFromList(name: String, candidates: List<String>) -> String {
    let mut best = ""
    let mut bestDist = 3
    let nameLen = srStringUnitCount(name)
    for candidate in candidates {
        let diff = srStringUnitCount(candidate) - nameLen
        if diff > bestDist - 1 || 0 - diff > bestDist - 1 {
            continue
        }
        let dist = srLevenshteinBounded(name, candidate, bestDist)
        if dist < bestDist {
            best = candidate
            bestDist = dist
            if bestDist == 1 {
                return best
            }
        }
    }
    best
}

fn srDidYouMeanHint(name: String, candidates: List<String>) -> String {
    let suggestion = srSuggestFromList(name, candidates)
    if suggestion == "" {
        return ""
    }
    "did you mean `{suggestion}`?"
}
