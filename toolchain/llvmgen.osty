pub fn llvmBoolRuntimeToString(emitter: LlvmEmitter, value: LlvmValue) -> LlvmValue {
    llvmCall(emitter, "ptr", "osty_rt_bool_to_string", [value])
}

pub fn llvmStringCompare(
    emitter: LlvmEmitter,
    op: String,
    left: LlvmValue,
    right: LlvmValue,
) -> LlvmValue {
    if op == "==" {
        return llvmStringEqual(emitter, left, right)
    }
    if op == "!=" {
        return llvmNotI1(emitter, llvmStringEqual(emitter, left, right))
    }
    let cmp = llvmStringRuntimeCompare(emitter, left, right)
    llvmCompare(emitter, llvmIntComparePredicate(op), cmp, llvmIntLiteral(0))
}

pub fn llvmStringByteLen(emitter: LlvmEmitter, value: LlvmValue) -> LlvmValue {
    llvmCall(emitter, "i64", "osty_rt_strings_ByteLen", [value])
}

pub fn llvmStringRuntimeCompare(
    emitter: LlvmEmitter,
    left: LlvmValue,
    right: LlvmValue,
) -> LlvmValue {
    llvmCall(emitter, "i64", "osty_rt_strings_Compare", [left, right])
