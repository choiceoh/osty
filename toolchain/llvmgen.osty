pub fn llvmSmokeStructStringFieldIR(sourcePath: String) -> String {
    let main = llvmEmitter()
    let msg = llvmStructLiteral(main, "%Message", [llvmStringLiteral(main, "struct string")])
    llvmImmutableLet(main, "msg", msg)
    llvmPrintlnString(main, llvmExtractValue(main, llvmIdent(main, "msg"), "ptr", 0))
    llvmReturnI32Zero(main)

    llvmRenderModuleWithGlobalsAndTypes(
        sourcePath,
        "",
        [
            llvmStructTypeDef("Message", ["ptr"]),
        ],
        main.stringGlobals,
        [
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

pub fn llvmSmokeStructBoolFieldIR(sourcePath: String) -> String {
    let main = llvmEmitter()
    let gate = llvmStructLiteral(main, "%Gate", [llvmI1("true")])
    llvmImmutableLet(main, "gate", gate)
    let cond = llvmExtractValue(main, llvmIdent(main, "gate"), "i1", 0)
    let labels = llvmIfStart(main, cond)
    llvmPrintlnI64(main, llvmIntLiteral(42))
    llvmIfElse(main, labels)
    llvmPrintlnI64(main, llvmIntLiteral(0))
    llvmIfEnd(main, labels)
    llvmReturnI32Zero(main)

    llvmRenderModuleWithGlobalsAndTypes(
        sourcePath,
        "",
        [
            llvmStructTypeDef("Gate", ["i1"]),
        ],
        [],
        [
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

pub fn llvmSmokeBoolMutableIR(sourcePath: String) -> String {
    let main = llvmEmitter()
    llvmMutableLet(main, "flag", llvmI1("false"))
    let _ = llvmAssign(main, "flag", llvmI1("true"))
    let cond = llvmIdent(main, "flag")
    let labels = llvmIfStart(main, cond)
    llvmPrintlnI64(main, llvmIntLiteral(42))
    llvmIfElse(main, labels)
    llvmPrintlnI64(main, llvmIntLiteral(0))
    llvmIfEnd(main, labels)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

fn llvmCallArgs(args: List<LlvmValue>) -> String {
    let mut parts: List<String> = []
    for arg in args {
        parts.push("{arg.typ} {arg.name}")
    }
    llvmStrings.join(parts, ", ")
}

fn llvmParams(params: List<LlvmParam>) -> String {
    let mut parts: List<String> = []
    for param in params {
        parts.push("{param.typ} %{param.name}")
    }
    llvmStrings.join(parts, ", ")
}

fn llvmNextTemp(emitter: LlvmEmitter) -> String {
    let name = "%t{emitter.temp}"
    emitter.temp = emitter.temp + 1
    name
}

fn llvmNextLabel(emitter: LlvmEmitter, prefix: String) -> String {
    let name = "{prefix}{emitter.label}"
    emitter.label = emitter.label + 1
    name
}
