pub fn llvmSmokeFloatCompareIR(sourcePath: String) -> String {
    let main = llvmEmitter()
    let value = llvmFloatLiteral("42.0")
    let eq = llvmCompareF64(main, "oeq", value, llvmFloatLiteral("42.0"))
    let ne = llvmCompareF64(main, "one", value, llvmFloatLiteral("41.0"))
    let lt = llvmCompareF64(main, "olt", value, llvmFloatLiteral("100.0"))
    let gt = llvmCompareF64(main, "ogt", value, llvmFloatLiteral("0.0"))
    let le = llvmCompareF64(main, "ole", value, llvmFloatLiteral("42.0"))
    let ge = llvmCompareF64(main, "oge", value, llvmFloatLiteral("42.0"))
    let cond = llvmLogicalI1(
        main,
        "and",
        llvmLogicalI1(
            main,
            "and",
            llvmLogicalI1(main, "and", eq, ne),
            llvmLogicalI1(main, "and", lt, gt),
        ),
        llvmLogicalI1(main, "and", le, ge),
    )
    let labels = llvmIfStart(main, cond)
    llvmPrintlnF64(main, value)
    llvmIfElse(main, labels)
    llvmPrintlnF64(main, llvmFloatLiteral("0.0"))
    llvmIfEnd(main, labels)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

