pub fn llvmSmokeBoolParamReturnIR(sourcePath: String) -> String {
    let pick = llvmEmitter()
    llvmBind(pick, "flag", llvmI1("%flag"))
    let labels = llvmIfExprStart(pick, llvmIdent(pick, "flag"))
    let thenValue = llvmIntLiteral(42)
    llvmIfExprElse(pick, labels)
    let elseValue = llvmIntLiteral(0)
    let out = llvmIfExprEnd(pick, "i64", thenValue, elseValue, labels)
    llvmReturn(pick, out)

    let main = llvmEmitter()
    let value = llvmCall(main, "i64", "pick", [llvmI1("true")])
    llvmPrintlnI64(main, value)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i64", "pick", [llvmParam("flag", "i1")], pick.body),
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

pub fn llvmSmokeIntRangeExclusiveIR(sourcePath: String) -> String {
    let sumTo = llvmEmitter()
    llvmBind(sumTo, "n", llvmI64("%n"))
    llvmMutableLet(sumTo, "total", llvmIntLiteral(0))
    let loop = llvmRangeStart(sumTo, "i", llvmIntLiteral(0), llvmIdent(sumTo, "n"), false)
    let nextTotal = llvmBinaryI64(sumTo, "add", llvmIdent(sumTo, "total"), llvmIdent(sumTo, "i"))
    let _ = llvmAssign(sumTo, "total", nextTotal)
    llvmRangeEnd(sumTo, loop)
    llvmReturn(sumTo, llvmIdent(sumTo, "total"))

    let main = llvmEmitter()
    let value = llvmCall(main, "i64", "sumTo", [llvmIntLiteral(7)])
    llvmPrintlnI64(main, value)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i64", "sumTo", [llvmParam("n", "i64")], sumTo.body),
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

pub fn llvmSmokeIntUnaryIR(sourcePath: String) -> String {
    let main = llvmEmitter()
    let diff = llvmBinaryI64(main, "sub", llvmIntLiteral(40), llvmIntLiteral(82))
    let value = llvmBinaryI64(main, "sub", llvmIntLiteral(0), diff)
    llvmPrintlnI64(main, value)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

