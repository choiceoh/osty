pub fn llvmSmokeIntIfExprIR(sourcePath: String) -> String {
    let main = llvmEmitter()
    let labels = llvmIfExprStart(main, llvmI1("true"))
    let thenValue = llvmIntLiteral(42)
    llvmIfExprElse(main, labels)
    let elseValue = llvmIntLiteral(0)
    let out = llvmIfExprEnd(main, "i64", thenValue, elseValue, labels)
    llvmPrintlnI64(main, out)
    llvmReturnI32Zero(main)

    llvmRenderModule(
        sourcePath,
        "",
        [
            llvmRenderFunction("i32", "main", [], main.body),
        ],
    )
}

