use std.testing

use std.strings as llvmTestStrings

fn assertLlvmContains(ir: String, text: String) {
    testing.assert(llvmTestStrings.contains(ir, text))
}

fn testLlvmSmokeMinimalPrintIsOstyOwned() {
    let ir = llvmSmokeMinimalPrintIR("/tmp/minimal_print.osty")

    assertLlvmContains(ir, "; Code generated by osty LLVM backend. DO NOT EDIT.")
    assertLlvmContains(ir, "source_filename = \"/tmp/minimal_print.osty\"")
    assertLlvmContains(ir, "define i32 @main() \{")
    assertLlvmContains(ir, "%t0 = add i64 40, 2")
    assertLlvmContains(ir, "call i32 (ptr, ...) @printf(ptr @.fmt_i64, i64 %t0)")
    assertLlvmContains(ir, "ret i32 0")
}

fn testLlvmGcRuntimeDeclarationsAreOstyOwned() {
    let declarations = llvmTestStrings.join(llvmGcRuntimeDeclarations(), "\n")

    assertLlvmContains(declarations, "declare ptr @osty.gc.alloc_v1(i64, i64, ptr)")
    assertLlvmContains(declarations, "declare void @osty.gc.post_write_v1(ptr, ptr, i64)")
    assertLlvmContains(declarations, "declare void @osty.gc.root_bind_v1(ptr)")
    assertLlvmContains(declarations, "declare void @osty.gc.root_release_v1(ptr)")
}

fn testLlvmSmokeGcRuntimeAbiIsOstyOwned() {
    let ir = llvmSmokeGcRuntimeAbiIR("/tmp/gc_runtime_abi.osty")

    assertLlvmContains(ir, "source_filename = \"/tmp/gc_runtime_abi.osty\"")
    assertLlvmContains(ir, "declare ptr @osty.gc.alloc_v1(i64, i64, ptr)")
    assertLlvmContains(ir, "declare void @osty.gc.post_write_v1(ptr, ptr, i64)")
    assertLlvmContains(ir, "declare void @osty.gc.root_bind_v1(ptr)")
    assertLlvmContains(ir, "declare void @osty.gc.root_release_v1(ptr)")
    assertLlvmContains(
        ir,
        "@.str0 = private unnamed_addr constant [15 x i8] c\"llvm.gc.object\\00\"",
    )
    assertLlvmContains(
        ir,
        "@.str1 = private unnamed_addr constant [14 x i8] c\"llvm.gc.child\\00\"",
    )
    assertLlvmContains(ir, "%t0 = call ptr @osty.gc.alloc_v1(i64 1, i64 32, ptr @.str0)")
    assertLlvmContains(ir, "call void @osty.gc.root_bind_v1(ptr %t0)")
    assertLlvmContains(ir, "%t1 = call ptr @osty.gc.alloc_v1(i64 2, i64 16, ptr @.str1)")
    assertLlvmContains(ir, "call void @osty.gc.post_write_v1(ptr %t0, ptr %t1, i64 0)")
    assertLlvmContains(ir, "call void @osty.gc.root_release_v1(ptr %t0)")
    assertLlvmContains(ir, "ret i32 0")
}

fn testLlvmSkeletonIsOstyOwned() {
    let ir = llvmRenderSkeleton(
        "main",
        "/tmp/unsupported.osty",
        "llvm-ir",
        "x86_64-unknown-linux-gnu",
        "llvmgen: unsupported source shape",
    )

    assertLlvmContains(ir, "; Osty LLVM backend skeleton")
    assertLlvmContains(ir, "; package: main")
    assertLlvmContains(ir, "; source: /tmp/unsupported.osty")
    assertLlvmContains(ir, "; emit: llvm-ir")
    assertLlvmContains(ir, "; target: x86_64-unknown-linux-gnu")
    assertLlvmContains(ir, "; unsupported: llvmgen: unsupported source shape")
    assertLlvmContains(ir, "; code generation is not implemented yet")
    assertLlvmContains(ir, "source_filename = \"/tmp/unsupported.osty\"")
    assertLlvmContains(ir, "target triple = \"x86_64-unknown-linux-gnu\"")
}

fn testLlvmSkeletonDefaultsPackageAndSource() {
    let ir = llvmRenderSkeleton("", "", "binary", "", "")

    assertLlvmContains(ir, "; package: main")
    assertLlvmContains(ir, "; source: <unknown>")
    assertLlvmContains(ir, "; emit: binary")
    assertLlvmContains(ir, "source_filename = \"<unknown>\"")
}

fn testLlvmToolchainPlanIsOstyOwned() {
    testing.assert(llvmNeedsObjectArtifact("object"))
    testing.assert(llvmNeedsObjectArtifact("binary"))
    testing.assert(!(llvmNeedsObjectArtifact("llvm-ir")))
    testing.assert(llvmNeedsBinaryArtifact("binary"))
    testing.assert(!(llvmNeedsBinaryArtifact("object")))

    let compile = llvmTestStrings.join(
        llvmClangCompileObjectArgs("x86_64-unknown-linux-gnu", "/tmp/main.ll", "/tmp/main.o"),
        " ",
    )
    assertLlvmContains(compile, "-target x86_64-unknown-linux-gnu")
    assertLlvmContains(compile, "-c /tmp/main.ll")
    assertLlvmContains(compile, "-o /tmp/main.o")

    let link = llvmTestStrings.join(
        llvmClangLinkBinaryArgs("", "/tmp/main.o", "/tmp/app"),
        " ",
    )
    assertLlvmContains(link, "/tmp/main.o")
    assertLlvmContains(link, "-o /tmp/app")
    testing.assert(!(llvmTestStrings.contains(link, "-target")))
    assertLlvmContains(llvmMissingClangMessage(), "clang not found")
    assertLlvmContains(
        llvmClangFailureMessage("link binary", "clang main.o -o app", "boom"),
        "link binary",
    )
}

