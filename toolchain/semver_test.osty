use std.testing
use std.testing.gen as gen

fn testSemverComparesCoreNumbers() {
    testing.assertEq(compareSemVersion(stableVersion(1, 0, 0), stableVersion(1, 0, 0)), 0)
    testing.assertEq(compareSemVersion(stableVersion(1, 0, 0), stableVersion(2, 0, 0)), -1)
    testing.assertEq(compareSemVersion(stableVersion(2, 0, 0), stableVersion(1, 0, 0)), 1)
    testing.assertEq(compareSemVersion(stableVersion(1, 1, 0), stableVersion(1, 0, 0)), 1)
    testing.assertEq(compareSemVersion(stableVersion(1, 0, 1), stableVersion(1, 0, 0)), 1)
}

fn testSemverOrdersPrereleasesBeforeStable() {
    let stable = stableVersion(1, 0, 0)
    let alpha = prerelease1(1, 0, 0, preText("alpha"))
    let rc1 = prerelease2(1, 0, 0, preText("rc"), preNumber(1))

    testing.assert(isSemPrerelease(alpha))
    testing.assert(!(isSemPrerelease(stable)))
    testing.assertEq(compareSemVersion(stable, alpha), 1)
    testing.assertEq(compareSemVersion(rc1, stable), -1)
}

fn testSemverOrdersPrereleaseIdentifiers() {
    let alpha = prerelease1(1, 0, 0, preText("alpha"))
    let alpha1 = prerelease2(1, 0, 0, preText("alpha"), preNumber(1))
    let alphaBeta = prerelease2(1, 0, 0, preText("alpha"), preText("beta"))
    let beta = prerelease1(1, 0, 0, preText("beta"))
    let beta2 = prerelease2(1, 0, 0, preText("beta"), preNumber(2))
    let beta11 = prerelease2(1, 0, 0, preText("beta"), preNumber(11))

    testing.assertEq(compareSemVersion(alpha, alpha1), -1)
    testing.assertEq(compareSemVersion(alpha1, alphaBeta), -1)
    testing.assertEq(compareSemVersion(alphaBeta, beta), -1)
    testing.assertEq(compareSemVersion(beta, beta2), -1)
    testing.assertEq(compareSemVersion(beta2, beta11), -1)
}

fn testSemverIgnoresBuildMetadata() {
    let a = versionWithBuild(1, 0, 0, "build.1")
    let b = versionWithBuild(1, 0, 0, "build.2")
    testing.assertEq(compareSemVersion(a, b), 0)
}

fn testSemverConstructorsExposePrereleaseSlots() {
    let v = semVersion(
        2,
        3,
        4,
        preText("rc"),
        preNumber(2),
        preText("hotfix"),
        "build.9",
    )

    testing.assertEq(v.major, 2)
    testing.assertEq(v.minor, 3)
    testing.assertEq(v.patch, 4)
    testing.assertEq(v.build, "build.9")
    testing.assert(isSemPrerelease(v))
    testing.assertEq(comparePreIdent(v.pre1, preText("rc")), 0)
    testing.assertEq(comparePreIdent(v.pre2, preNumber(2)), 0)
    testing.assertEq(comparePreIdent(v.pre3, preText("hotfix")), 0)
}

fn testSemverOrdersShorterPrereleaseBeforeLongerPrefix() {
    let alpha = prerelease1(1, 0, 0, preText("alpha"))
    let alpha0 = prerelease2(1, 0, 0, preText("alpha"), preNumber(0))
    let alpha0Build = semVersion(1, 0, 0, preText("alpha"), preNumber(0), preText("build"), "")

    testing.assertEq(compareSemVersion(alpha, alpha0), -1)
    testing.assertEq(compareSemVersion(alpha0, alpha0Build), -1)
    testing.assertEq(comparePreIdent(preNone(), preNumber(1)), -1)
}

fn testSemverOrdersNumericPrereleaseBeforeText() {
    testing.assertEq(comparePreIdent(preNumber(10), preText("alpha")), -1)
    testing.assertEq(comparePreIdent(preText("alpha"), preNumber(10)), 1)
    testing.assertEq(comparePreIdent(preText("alpha"), preText("beta")), -1)
    testing.assertEq(comparePreIdent(preText("rc"), preText("rc")), 0)
}

fn testSemverComparisonHelpersAreThreeWay() {
    testing.assertEq(signInt(1, 2), -1)
    testing.assertEq(signInt(2, 1), 1)
    testing.assertEq(signInt(2, 2), 0)

    testing.assertEq(signString("alpha", "beta"), -1)
    testing.assertEq(signString("beta", "alpha"), 1)
    testing.assertEq(signString("rc", "rc"), 0)
}

// Property-based tests (v0.5 G33). The current LLVM lowering exercises
// the `intRange` / `pair` / `triple` subset directly from the property
// call site, so these now run as real invariants instead of placeholders.

fn testSemverPropSignIntReflexive() {
    testing.property(
        "signInt(a, a) == 0",
        gen.intRange(-1000, 1000),
        |a: Int| signInt(a, a) == 0,
    )
}

fn testSemverPropSignIntAntisymmetric() {
    testing.property(
        "signInt(a, b) + signInt(b, a) == 0",
        gen.pair(gen.intRange(-1000, 1000), gen.intRange(-1000, 1000)),
        |(a, b): (Int, Int)| signInt(a, b) + signInt(b, a) == 0,
    )
}

fn testSemverPropCompareStableReflexive() {
    testing.property(
        "compareSemVersion(stable(a, b, c), same) == 0",
        gen.triple(gen.intRange(0, 99), gen.intRange(0, 99), gen.intRange(0, 99)),
        |(a, b, c): (Int, Int, Int)| {
            let v = stableVersion(a, b, c)
            compareSemVersion(v, v) == 0
        },
    )
}

fn testSemverPropBuildMetadataDoesNotAffectOrdering() {
    testing.property(
        "compareSemVersion ignores build metadata",
        gen.triple(gen.intRange(0, 99), gen.intRange(0, 99), gen.intRange(0, 99)),
        |(a, b, c): (Int, Int, Int)| {
            let plain = stableVersion(a, b, c)
            let tagged = versionWithBuild(a, b, c, "build.1")
            compareSemVersion(plain, tagged) == 0
        },
    )
}
