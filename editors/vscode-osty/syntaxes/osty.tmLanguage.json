{
  "scopeName": "source.osty",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.osty",
          "match": "//.*$"
        },
        {
          "name": "comment.block.osty",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.osty",
          "begin": "r?\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.osty",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.osty",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.osty",
              "begin": "\\{",
              "end": "\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.osty",
          "match": "\\b(?:0x[0-9A-Fa-f_]+|0b[01_]+|0o[0-7_]+|\\d[\\d_]*(?:\\.\\d[\\d_]*)?)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.osty",
          "match": "\\b(?:if|else|for|in|match|return|break|continue|defer|spawn|parallel)\\b"
        },
        {
          "name": "storage.type.osty",
          "match": "\\b(?:fn|let|mut|struct|enum|interface|type|use|pub|as)\\b"
        },
        {
          "name": "constant.language.osty",
          "match": "\\b(?:true|false|None|Some|Ok|Err)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.osty",
          "match": "\\b(?:Int|Int8|Int16|Int32|Int64|UInt8|UInt16|UInt32|UInt64|Byte|Float|Float32|Float64|Bool|Char|String|Bytes|Never|List|Map|Set|Option|Result|Error|Chan|Channel)\\b"
        }
      ]
    }
  }
}
